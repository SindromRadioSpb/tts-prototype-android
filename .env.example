# =============================================================================
# TTS Prototype Android - Environment Configuration
# Copy this file to .env and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database (SQLite)
# -----------------------------------------------------------------------------
DB_PATH=data/app.db
MIGRATIONS_DIR=migrations
BACKUPS_DIR=data/backups
# Set to 1 to skip automatic backup before migrations
NO_BACKUP=0

# -----------------------------------------------------------------------------
# Google Cloud TTS
# -----------------------------------------------------------------------------
# Option 1: Path to service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Option 2: Inline JSON (for Docker/CI environments)
# GOOGLE_CLOUD_TTS_KEY={"type":"service_account","project_id":"..."}

# Safety limit for TTS input (bytes)
# TTS_SAFE_TARGET_BYTES=4800

# Allow audio prefetch from remote hosts (0 = localhost only)
ALLOW_REMOTE_AUDIO_PREFETCH=0

# -----------------------------------------------------------------------------
# Google Gemini AI (Translation)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
# Alternative key name (fallback)
# GOOGLE_API_KEY=

# Daily request limit
GEMINI_DAILY_LIMIT=50
# Hour (UTC) when daily counter resets
GEMINI_RESET_HOUR_UTC=21

# -----------------------------------------------------------------------------
# AnkiConnect Integration
# -----------------------------------------------------------------------------
ANKI_CONNECT_HOST=127.0.0.1
ANKI_CONNECT_PORT=8765
ANKI_CONNECT_VERSION=6
# API key if AnkiConnect requires authentication
# ANKI_CONNECT_API_KEY=
# Origin header for CORS (if required by AnkiConnect)
# ANKI_CONNECT_ORIGIN=

# Timeouts and retries
ANKI_CONNECT_TIMEOUT_MS=60000
ANKI_CONNECT_RETRIES=3
ANKI_CONNECT_RETRY_DELAY_MS=250

# Batch sizes
ANKI_ADDNOTES_CHUNK=25
ANKI_MULTI_CHUNK=50

# ===== Мастер-ключ для создания когорт через интерфейс =====
#  Логика такая:
#  - Нет этой переменной → эндпоинт создания когорты отвечает 503 ADMIN_DISABLED. Это не баг, а защита: чтобы случайный
#  человек в интернете не мог создавать когорты на вашем сервере.
#  - Переменная задана → форма «Создать когорту» работает. Учитель один раз за сессию вставляет этот же секрет в поле «Admin-секрет».
RESEARCH_ADMIN_TOKEN=

# -----------------------------------------------------------------------------
# OSF Integration (Open Science Framework)
# -----------------------------------------------------------------------------
# OSF Personal Access Token — for programmatic interaction with OSF API
# (e.g. fetching preregistration metadata, updating registration components,
# uploading replication-package artifacts to the diploma's OSF project).
#
# How to obtain:
#  1. Log in to https://osf.io/settings/tokens
#  2. Click "Create Token", name it (e.g. "linguistpro-thesis")
#  3. Select scopes (typically: osf.full_read + osf.full_write for replication uploads)
#  4. Copy the generated token IMMEDIATELY — OSF shows it once
#  5. Paste below in .env (NOT in this .env.example file)
#
# Security:
#  - Tokens authenticate as the account that created them — protect them like passwords.
#  - Tokens can be revoked at https://osf.io/settings/tokens without changing the account password.
#  - DO NOT commit .env to git; only .env.example with placeholders is tracked.
#  - If a token leaks (chat transcript, screenshot, log file): revoke + reissue.
#
# Project context: registered preregistration at https://osf.io/zdv9j/
# (DOI 10.17605/OSF.IO/ZDV9J). The token is OPTIONAL — diploma functionality
# does not depend on OSF API access; the token enables future automation
# (replication package upload, scheduled metadata refresh, etc.).
OSF_PERSONAL_TOKEN=

# ============================================================
# tts-translator-dashboard — .env.example
# This file MUST NOT contain real secrets.
# Copy to .env for local dev:
#   Windows CMD:  copy .env.example .env
#   PowerShell :  Copy-Item .env.example .env
# ============================================================

# ------------------------------------------------------------
# Base
# ------------------------------------------------------------
PORT=3000
NODE_ENV=development

# ------------------------------------------------------------
# Week 6/7 — Existing app (Translate + TTS + DOCX + Usage)
# ------------------------------------------------------------

# Gemini API key (REQUIRED for /api/translate-table)
GEMINI_API_KEY=

# Google Cloud TTS credentials
# Option A (common in local dev): path to service account JSON on your machine
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\google-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=

# (Optional) any existing limits/knobs your current server.js supports
# If you are not using these, leave empty.
GEMINI_DAILY_LIMIT=
GEMINI_RESET_HOUR_UTC=
TTS_SAFE_TARGET_BYTES=

# ------------------------------------------------------------
# Week 7.5 — Platform / Multiuser foundation
# ------------------------------------------------------------

# Postgres connection string
# Local docker example:
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/tts_dashboard
DATABASE_URL=

# If your Postgres requires TLS/SSL (Railway commonly does): set 1
# 0 = no SSL (local), 1 = SSL enabled
DATABASE_SSL=0

# Session secret (REQUIRED when REQUIRE_AUTH=1)
# Generate:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Feature flag:
# 0 = platform optional (Week 6/7 UX stays open)
# 1 = platform required (auth enforced on platform endpoints)
REQUIRE_AUTH=0

# Bootstrap first teacher (used by: npm run bootstrap:teacher)
# Fill these in your local .env or Railway Variables (NOT here)
BOOTSTRAP_TEACHER_EMAIL=
BOOTSTRAP_TEACHER_PASSWORD=

# ------------------------------------------------------------
# Week 6/7 (существующее приложение)
# ------------------------------------------------------------
PORT=3000
NODE_ENV=development

# Gemini
GEMINI_API_KEY=

# Google Cloud TTS (пример — зависит от вашей текущей схемы подключения)
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/google-sa.json

# ------------------------------------------------------------
# Week 7.5 (Platform / Multiuser foundation)
# ------------------------------------------------------------

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tts_dashboard

# Session secret (32+ bytes hex). Generate:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# 0 = платформа отключена (старый UX как Week 6/7)
# 1 = платформа включена (auth + RBAC на platform endpoints)
REQUIRE_AUTH=0

# Teacher bootstrap (used by npm run bootstrap:teacher)
BOOTSTRAP_TEACHER_EMAIL=teacher@example.com
BOOTSTRAP_TEACHER_PASSWORD=ChangeMe123!

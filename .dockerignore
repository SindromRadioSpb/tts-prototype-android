# -------------------------------------------------------
# .dockerignore — files excluded from Docker build context
# -------------------------------------------------------

# Secrets (never bake into image)
.env
.env.local
.env.*.local
*.pem
*.key
credentials*.json

# Dependencies installed fresh in image
node_modules/

# Persistent runtime data (mounted as volume at /app/data)
data/
# EXCEPTION: the shipped offline Pealim inflection dataset lives under
# public/data/ — must be IN the image (served at /data/inflection/). The
# unanchored data/ rule above would exclude it, so re-include it.
!public/data/
!public/data/inflection/
!public/data/inflection/**

# Test/personal library fixtures (version-controlled in git, but NOT baked
# into the server image — user libraries live in browser OPFS, not on server)
Library/

# Audio / cache artefacts
audio/
audio-cache/
gemini-cache/
*.mp3
*.wav
*.ogg

# Build artefacts
dist/
build/

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/

# Git
.git/
.gitignore

# Claude / tooling workspaces
.claude/
.kilo/
.remember/
.mcp.json
.playwright-mcp/

# Tests / smoke
Smoke-check/
*.test.js
*.spec.js

# Docs / misc
*.md
*.xlsx
*.docx
*.tmp
*.log
repo_tree.txt
Архив/

# Phase 9.3.5+ scratch debugging probes
/test-prod-mt*.js

# Phase 11.5+ visual regression captures (Smoke-check/teacher-dashboard/<timestamp>/)
# These are ephemeral artifacts produced by scripts/research/teacher-screenshots.js.
# Use `git add -f` to commit a baseline snapshot manually if needed.
# Ignore everything under Smoke-check/ EXCEPT the graph-view baseline.
# (git cannot re-include a path whose parent dir is excluded, so we
# ignore the *contents* with /Smoke-check/* and re-include the chain
# down to the v3.3.6 C9 visual-regression baseline, which must be
# version-controlled so `npm run smoke:graph:visual` pixel-diffs
# against it on any machine / CI. Ad-hoc verify temp dirs live in
# os.tmpdir() and remain ignored.)
/Smoke-check/*
!/Smoke-check/graph-view/
/Smoke-check/graph-view/*
!/Smoke-check/graph-view/baseline/
.playwright-mcp/
/Smoke-check/test-cohort-credentials.txt

# External source bundles (HebMorph, hspell, etc.) — large 3rd-party trees
# fetched locally for the morphology pipeline. Not part of repo history.
.external/

# Remember plugin runtime data (logs, state, session cache)
.remember/

# Full-tier morphology dictionary raw form (~75 MB). The gzipped sibling
# `heb_morphology_full.bin.gz` (~5 MB) IS tracked — runtime decompresses
# it via DecompressionStream. Rebuild raw via `npm run build:morphology:full`
# if you need it for debugging.
public/morph/heb_morphology_full.bin

# Ben-Yehuda corpus work BODIES — live on the prod volume, served volume-first by
# server.js; NOT in git (the thin catalog index ships, bodies do not). Re-bakeable
# + backed up. (Legacy: ~100 were committed in 9ccf6b1 before this norm; now untracked.)
public/data/benyehuda/works/
# BRR-P2-001 full-text index SHARDS — tens of MB, grow with coverage; volume-served
# (push-corpus-fts.js), NOT git. The thin manifest corpus-fts-v<N>.json DOES ship.
public/data/benyehuda/fts/

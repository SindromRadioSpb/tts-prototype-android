{
  "name": "tts-translator-dashboard",
  "version": "3.3.5",
  "description": "TTS & Translator Dashboard (Google Cloud Text-to-Speech + Gemini, Hebrew-Russian tables)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:all": "powershell -ExecutionPolicy Bypass -File scripts/start_all.ps1",
    "db:migrate": "node db/migrate-cli.js",
    "db:backup": "node db/backup-cli.js",
    "db:backup:list": "node db/backup-cli.js list",
    "db:backup:cleanup": "node db/backup-cli.js cleanup",
    "db:restore": "node db/restore-cli.js",
    "db:integrity": "node db/integrity-cli.js",
    "tts:models:check": "node scripts/check_tts_models.js",
    "tts:models:checksums": "node scripts/update_tts_model_checksums.js",
    "tts:stage:assets": "powershell -ExecutionPolicy Bypass -File scripts/stage_tts_assets.ps1",
    "test:tts-browser-smoke": "node scripts/tts_browser_smoke.js",
    "test:api-smoke": "node scripts/api-smoke.js",
    "test": "node --test",
    "bench:premium": "node tests/premium/bench.js",
    "pwa:icons": "node scripts/generate-pwa-icons.js",
    "build:morphology": "node scripts/morph/build-morphology.mjs",
    "build:morphology:basic": "node scripts/morph/build-morphology.mjs --tier basic",
    "build:morphology:full": "node scripts/morph/build-morphology.mjs --tier full",
    "smoke:morph": "node scripts/morph/tier-switch-smoke.js && node scripts/morph/settings-ui-smoke.js && node scripts/morph/full-dict-live-smoke.js",
    "smoke:morph:tier": "node scripts/morph/tier-switch-smoke.js",
    "smoke:morph:settings": "node scripts/morph/settings-ui-smoke.js",
    "smoke:morph:live": "node scripts/morph/full-dict-live-smoke.js",
    "smoke:crosstext": "node scripts/morph/crosstext-smoke.js",
    "smoke:quiz": "node scripts/quiz/bank-validate-smoke.js && node scripts/quiz/scoring-smoke.js && node scripts/quiz/ui-smoke.js && node scripts/quiz/privacy-smoke.js && node scripts/quiz/client-submit-smoke.js",
    "smoke:quiz:bank": "node scripts/quiz/bank-validate-smoke.js",
    "smoke:quiz:scoring": "node scripts/quiz/scoring-smoke.js",
    "smoke:quiz:ui": "node scripts/quiz/ui-smoke.js",
    "smoke:quiz:a11y": "node scripts/quiz/ui-a11y-smoke.js",
    "smoke:quiz:privacy": "node scripts/quiz/privacy-smoke.js",
    "smoke:quiz:client-submit": "node scripts/quiz/client-submit-smoke.js",
    "smoke:quiz:server-validator": "node scripts/research/quiz-validator-smoke.js",
    "smoke:quiz:teacher": "node scripts/research/teacher-quiz-smoke.js",
    "smoke:quiz:reset-cli": "node scripts/research/quiz-reset-cli-smoke.js",
    "smoke:graph": "node scripts/notes-graph/lazyload-smoke.js",
    "smoke:graph:lazyload": "node scripts/notes-graph/lazyload-smoke.js",
    "vendor:build:graph": "node scripts/vendor/build-d3-graph.mjs",
    "research:quiz-reset": "node scripts/research/reset_quiz_for_student.js",
    "quiz:validate": "node scripts/quiz/validate-bank.js",
    "quiz:regen-fixture": "node scripts/quiz/generate-mirt-fixture.js",
    "research:cohort": "node scripts/research/create_cohort.js",
    "research:seed": "node scripts/research/seed_research_fake_cohort.js",
    "research:rotate": "node scripts/research/rotate_token.js",
    "research:link": "node scripts/research/link_student_ids.js",
    "research:validate": "node scripts/research/validate-cli.js",
    "smoke:research:cli": "node scripts/research/rotate-token-smoke.js && node scripts/research/link-student-ids-smoke.js && node scripts/research/validate-cli-smoke.js && node scripts/research/admin-cli-flags-smoke.js",
    "smoke:research:cli:rotate": "node scripts/research/rotate-token-smoke.js",
    "smoke:research:cli:link": "node scripts/research/link-student-ids-smoke.js",
    "smoke:research:cli:validate": "node scripts/research/validate-cli-smoke.js",
    "smoke:research:cli:flags": "node scripts/research/admin-cli-flags-smoke.js",
    "smoke:research": "node scripts/research/all-smoke.js",
    "smoke:research:fast": "node scripts/research/all-smoke.js --skip-screenshots",
    "smoke:research:server": "node scripts/research/smoke.js",
    "smoke:research:browser": "node scripts/research/browser-smoke.js",
    "smoke:research:teacher": "node scripts/research/teacher-smoke.js",
    "smoke:research:teacher:multi": "node scripts/research/teacher-multicohort-smoke.js",
    "smoke:research:screenshots": "node scripts/research/teacher-screenshots.js",
    "smoke:prep": "node scripts/research/prepare_smoke_artifacts.js",
    "smoke:prep:clean": "node scripts/research/prepare_smoke_artifacts.js --cleanup"
  },
  "dependencies": {
    "@google-cloud/text-to-speech": "^5.7.0",
    "@google-cloud/translate": "^9.3.0",
    "@google/generative-ai": "^0.19.0",
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "body-parser": "^1.20.3",
    "docx": "^8.5.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "hebrew-transliteration": "^2.9.1",
    "jszip": "^3.10.1",
    "qrcode-generator": "^2.0.4",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.0",
    "wa-sqlite": "^1.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "d3-force": "3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "3.0.0",
    "esbuild": "^0.21.0",
    "playwright": "^1.52.0"
  }
}

ru":"хазэев вэхакэлэв харазэ","russian":"Волк и Тощая Собака","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"דג קטן התחנן פעם לשוב המים,","hebrew_niqqud":"דָּג קָטֹן הִתְחַנֵּן פַּעַם לָשׁוּב הַמָּיִם,","translit":"dāḡ qāṭōn hiṯḥannēn paʿam lāšûḇ hammāyim,","translit_ru":"даг катон хитханен паам лашув хамайим,","russian":"Однажды маленькая рыбка умоляла вернуться в воду,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"אך הדיג לא הטה לדבריו אזנים,","hebrew_niqqud":"אַךְ הַדַּיָּג לֹא הִטָּה לִדְבָרָיו אָזְנָיִם,","translit":"ʾaḵ haddayyāḡ lōʾ hiṭṭâ liḏḇārāyw ʾoznāyim,","translit_ru":"ах хадайаг ло хита лидварав ознайим,","russian":"Но рыбак не внял ее словам,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"ויורידהו אל תוך סיר נפוח1","hebrew_niqqud":"וַיּוֹרִידֵהוּ אֶל תּוֹךְ סִיר נָפוּחַ1","translit":"wayyôrîḏēhû ʾel tôḵ sîr nāp̄ûḥa1","translit_ru":"вайоридеху эл тох сир нафуха1","russian":"И опустил ее в большой, пузатый котел.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"במשל ההוא לדעת הראינו","hebrew_niqqud":"בַּמָּשָׁל הַהוּא לָדַעַת הָרְאֵינוּ","translit":"bammāšāl hahûʾ lāḏaʿaṯ hārəʾênû","translit_ru":"бамашал хаху ладаат харэену","russian":"В этой басне нам показано,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"לבלי כפתים נטש מידינו","hebrew_niqqud":"לִבְלִי כִּפְתָיִם נִטּשׁ מִיָּדֵינוּ","translit":"liḇlî kip̄ṯāyim niṭš miyyāḏênû","translit_ru":"ливли кифтайим нитш мийадену","russian":"Не следует упускать из рук","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"בעבור תקות שוא כל דבר בטוח.","hebrew_niqqud":"בַּעֲבוּר תִּקְוַת שָׁוְא כָּל דָּבָר בָּטוּחַ.","translit":"baʿăḇûr tiqwaṯ šāwʾ kol dāḇār bāṭûaḥ.","translit_ru":"баавур тикват шав кол давар батуах.","russian":"Ничего верного ради пустой надежды.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"הדיג טוב עשה גם הדג לא הרשיע,","hebrew_niqqud":"הַדַּיָּג טוֹב עָשָׂה גַּם הַדָּג לֹא הִרְשִׁיעַ,","translit":"haddayyāḡ ṭôḇ ʿāśâ gam haddāḡ lōʾ hiršîaʿ,","translit_ru":"хадайаг тов аса гам хадаг ло хиршиа,","russian":"Рыбак поступил верно, и рыба не согрешила,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"כי בקש על נפשו ולאויבו הפגיע,","hebrew_niqqud":"כִּי בִקֵּשׁ עַל נַפְשׁוֹ וּלְאוֹיְבוֹ הִפְגִּיעַ,","translit":"kî ḇiqqēš ʿal nap̄šô ûləʾôyəḇô hip̄gîaʿ,","translit_ru":"ки викеш ал нафшо улэойэво хифгиа,","russian":"Ибо просила за себя и не причиняла вреда врагу,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"כי כל אשר יוכל יעשה גבר","hebrew_niqqud":"כִּי כָל אֲשֶׁר יוּכַל יַעֲשֶׂה גֶּבֶר","translit":"kî ḵol ʾăšer yûḵal yaʿăśê geḇer","translit_ru":"ки хол ашэр йухал йаасэ гэвэр","russian":"Ибо все, что в силах, сделает человек","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"בעבור הצל נפשו מרדת קבר;","hebrew_niqqud":"בַּעֲבוּר הַצֵּל נַפְשׁוֹ מֵרֶדֶת קֶבֶר;","translit":"baʿăḇûr haṣṣēl nap̄šô mēreḏeṯ qeḇer;","translit_ru":"баавур хацел нафшо мерэдэт кэвэр;","russian":"Чтобы спасти себя от могилы;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"אולם הזאב הזה היה קל דעת","hebrew_niqqud":"אוּלָם הַזְּאֵב הַזֶּה הָיָה קַל דַּעַת","translit":"ʾûlām hazzəʾēḇ hazzê hāyâ qal daʿaṯ","translit_ru":"улам хазэев хазэ хайа кал даат","russian":"Однако этот волк был легкомысленным","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"ובאולתו הטה אזן שומעת,","hebrew_niqqud":"וּבְאִוַּלְתּוֹ הִטָּה אֹזֶן שׁוֹמַעַת,","translit":"ûḇəʾiwwaltô hiṭṭâ ʾōzen šômaʿaṯ,","translit_ru":"увэивалто хита озэн шомаат,","russian":"И в своей глупости внял,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"נפתה ויענש.","hebrew_niqqud":"נִפְתָּה וַיֵּעָנַשׁ.","translit":"nip̄tâ wayyēʿānaš.","translit_ru":"нифта вайеанаш.","russian":"Поддался обману и был наказан.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"– כי פגש כלב","hebrew_niqqud":"– כִּי פָגַשׁ כֶּלֶב","translit":"– kî p̄āḡaš keleḇ","translit_ru":"– ки фагаш кэлэв","russian":"– Ибо встретил собаку","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"הרחק מן הכפר ויחפץ אכלהו.","hebrew_niqqud":"הַרְחֵק מִן הַכְּפָר וַיַּחְפֹּץ אָכְלֵהוּ.","translit":"harḥēq min hakkəp̄ār wayyaḥpōṣ ʾoḵlēhû.","translit_ru":"хархек мин хакэфар вайахпоц охлеху.","russian":"Далеко от деревни и захотел ее съесть.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"\"אדוני!","hebrew_niqqud":"\"אֲדוֹנִי!","translit":"\"ʾăḏônî!","translit_ru":"\"адони!","russian":"«Господин!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"– אמר הכלב אליהו –","hebrew_niqqud":"– אָמַר הַכֶּלֶב אֵלֵיהוּ –","translit":"– ʾāmar hakkeleḇ ʾēlêhû –","translit_ru":"– амар хакэлэв елеху –","russian":"– Сказал пес ему –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"דל בשר אני, בכסלי אין חלב,","hebrew_niqqud":"דַּל בָּשָׂר אָנִי, בִּכְסָלַי אֵין חֵלֶב,","translit":"dal bāśār ʾānî, biḵsālay ʾên ḥēleḇ,","translit_ru":"дал басар ани, бихсалай ен хелэв,","russian":"Я тощ, на боках моих нет жира,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"מעי חמרמרו, בעצמי אין מח,","hebrew_niqqud":"מֵעַי חֳמַרְמְרוּ, בַּעֲצָמַי אֵין מֹחַ,","translit":"mēʿay ḥŏmarmərû, baʿăṣāmay ʾên mōaḥ,","translit_ru":"меай хомармэру, баацамай ен моах,","russian":"Внутренности мои пусты, в костях моих нет мозга,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"ומה-ימריצך אם כעת תאכלני?","hebrew_niqqud":"וּמַה-יַּמְרִיצְךָ אִם כָּעֵת תֹּאכלֵנִי?","translit":"ûmah-yamrîṣəḵā ʾim kāʿēṯ tōʾḵlēnî?","translit_ru":"умах-йамрицэха им кает тохлени?","russian":"И какая тебе польза, если сейчас съешь меня?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"הבה לי היום חפש ופקח-קוח,","hebrew_niqqud":"הָבָה לִי הַיּוֹם חֹפֶשׁ וּפְקַח-קוֹחַ,","translit":"hāḇâ lî hayyôm ḥōp̄eš ûp̄əqaḥ-qôaḥ,","translit_ru":"хава ли хайом хофэш уфэках-коах,","russian":"Дай мне сегодня свободу и отсрочку,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"הנה חג לאדני מחר בכפר,","hebrew_niqqud":"הִנֵּה חַג לַאדֹנִי מָחָר בַּכֹּפֶר,","translit":"hinnê ḥaḡ laʾḏōnî māḥār bakkōp̄er,","translit_ru":"хине хаг ладони махар бакофэр,","russian":"Вот, завтра праздник у моего господина в деревне,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"שם אשבע, אעש פימה עלי כסל,","hebrew_niqqud":"שָׁם אֶשְׂבַּע, אַעַשׂ פִּימָה עֲלֵי כֶסֶל,","translit":"šām ʾeśbaʿ, ʾaʿaś pîmâ ʿălê ḵesel,","translit_ru":"шам эсба, аас пима але хэсэл,","russian":"Там я наемся, нагуляю жир на боках,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"אחר אשובה ובידך הנני\"","hebrew_niqqud":"אַחַר אָשׁוּבָה וּבְיָדְךָ הִנֵּנִי\"","translit":"ʾaḥar ʾāšûḇâ ûḇəyāḏəḵā hinnēnî\"","translit_ru":"ахар ашува увэйадэха хинени\"","russian":"Потом вернусь и буду в твоих руках!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"ויטשהו הזאב וירבה כסל","hebrew_niqqud":"וַיִּטְּשֵׁהוּ הַזְּאֵב וַיַּרְבֶּה כֶּסֶל","translit":"wayyiṭṭəšēhû hazzəʾēḇ wayyarbê kesel","translit_ru":"вайитэшеху хазэев вайарбэ кэсэл","russian":"И волк оставил его, умножив свою глупость,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"ויברח הכלב כצבי כעפר.","hebrew_niqqud":"וַיִּבְרַח הַכֶּלֶב כַּצְּבִי כָּעֹפֶר.","translit":"wayyiḇraḥ hakkeleḇ kaṣṣəḇî kāʿōp̄er.","translit_ru":"вайиврах хакэлэв кацэви каофэр.","russian":"И убежал пес, как олень, как прах.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"ככלות יומים שב הזאב אליהו","hebrew_niqqud":"כִּכְלוֹת יוֹמַיִם שָׁב הַזְּאֵב אֵלֵיהוּ","translit":"kiḵlôṯ yômayim šāḇ hazzəʾēḇ ʾēlêhû","translit_ru":"кихлот йомайим шав хазэев елеху","russian":"По истечении двух дней вернулся волк к нему","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"לראות את כלבו ומה-מעשהו,","hebrew_niqqud":"לִרְאוֹת אֶת כַּלבּוֹ וּמַה-מַּעֲשֵׂהוּ,","translit":"lirʾôṯ ʾeṯ kalbbô ûmah-maʿăśēhû,","translit_ru":"лирот эт калбо умах-маасеху,","russian":"Увидеть своего пса и каково его состояние,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"אם שמן אם הרבה חלב ופדר","hebrew_niqqud":"אִם שָׁמֵן אִם הִרְבָּה חֵלֶב וָפֶדֶר","translit":"ʾim šāmēn ʾim hirbâ ḥēleḇ wāp̄eḏer","translit_ru":"им шамен им хирба хелэв вафэдэр","russian":"Нагулял ли он жира или много сала.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"וימצאהו – חדר בחדר.","hebrew_niqqud":"וַיִּמְצָאֵהוּ – חֶדֶר בַּחֶדֶר.","translit":"wayyimṣāʾēhû – ḥeḏer baḥeḏer.","translit_ru":"вайимцаеху – хэдэр бахэдэр.","russian":"И нашел его – запертым в доме.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"\"עמד-נא שם, אחי, רגע תחתיך","hebrew_niqqud":"\"עֲמָד-נָא שָׁם, אָחִי, רֶגַע תַּחְתֶּיךָ","translit":"\"ʿămāḏ-nāʾ šām, ʾāḥî, reḡaʿ taḥtêḵā","translit_ru":"\"амад-на шам, ахи, рэга тахтеха","russian":"– Постой-ка там, брат мой, минутку,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"– מבעד חר המפתח זה יענהו –","hebrew_niqqud":"– מִבְּעַד חֹר הַמַּפְתֵּחַ זֶה יַעֲנֵהוּ –","translit":"– mibbəʿaḏ ḥōr hammap̄tēaḥ zê yaʿănēhû –","translit_ru":"– мибэад хор хамафтеах зэ йаанеху –","russian":"– Ответил тот ему через замочную скважину –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r33","order_index":33,"hebrew_plain":"כתר לי זעיר, הנני אליך,","hebrew_niqqud":"כַּתַּר לִי זְעֵיר, הִנְנִי אֵלֶיךָ,","translit":"kattar lî zəʿêr, hinnî ʾēlêḵā,","translit_ru":"катар ли зэер, хинни елеха,","russian":"Погоди немного, я сейчас подойду к тебе,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r34","order_index":34,"hebrew_plain":"אני עם עמיתי שומר הפתח\".","hebrew_niqqud":"אֲנִי עִם עֲמִיתִי שׁוֹמֵר הַפֶּתַח\".","translit":"ʾănî ʿim ʿămîṯî šômēr happeṯaḥ\".","translit_ru":"ани им амити шомер хапэтах\".","russian":"Я со своим товарищем, привратником.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r35","order_index":35,"hebrew_plain":"(שומר הפתח היה כלב אמיץ כח","hebrew_niqqud":"(שׁוֹמֵר הַפֶּתַח הָיָה כֶּלֶב אַמִּיץ כֹּחַ","translit":"(šômēr happeṯaḥ hāyâ keleḇ ʾammîṣ kōaḥ","translit_ru":"(шомер хапэтах хайа кэлэв амиц коах","russian":"(Привратник был псом могучей силы,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r36","order_index":36,"hebrew_plain":"ידיו רב לו להדך זאב תחתיהו","hebrew_niqqud":"יָדָיו רָב לוֹ לַהֲדֹךְ זְאֵב תַּחְתֵּיהוּ","translit":"yāḏāyw rāḇ lô lahăḏōḵ zəʾēḇ taḥtêhû","translit_ru":"йадав рав ло лахадох зэев тахтеху","russian":"Хватало у него сил повалить волка","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r37","order_index":37,"hebrew_plain":"ולשסף אותו נתח נתח) –","hebrew_niqqud":"וּלְשַׁסֵּף אוֹתוֹ נֶתַח נֶתַח) –","translit":"ûləšassēp̄ ʾôṯô neṯaḥ neṯaḥ) –","translit_ru":"улэшасеф ото нэтах нэтах) –","russian":"И разорвать его на куски) –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r38","order_index":38,"hebrew_plain":"וישמע הזאב וימהר לברוח.","hebrew_niqqud":"וַיִּשְׁמַע הַזְּאֵב וַיְמַהֵר לִבְרוֹחַ.","translit":"wayyišmaʿ hazzəʾēḇ wayəmahēr liḇrôaḥ.","translit_ru":"вайишма хазэев вайэмахер ливроах.","russian":"И волк услышал и поспешил убежать.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r39","order_index":39,"hebrew_plain":"ספר ראשון, משל \"הדג הקטן והדיג\".","hebrew_niqqud":"סֵפֶר רִאשׁוֹן, מִשֶּׁל \"הַדָּג הַקָּטָן וְהַדַּיִג\".","translit":"sēp̄er riʾšôn, miššel \"haddāḡ haqqāṭān wəhaddayiḡ\".","translit_ru":"сефэр ришон, мишэл \"хадаг хакатан вэхадайиг\".","russian":"Книга первая, басня «Маленькая Рыбка и Рыбак».","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r40","order_index":40,"hebrew_plain":"&nbsp;↩︎","hebrew_niqqud":"","translit":"","translit_ru":"","russian":" ↩︎","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
eseṯ hayyāšān bəṯēʾôḏôsəyâ","translit_ru":"бет-хакэнэсэт хайашан бэтеодосэйа","russian":"Старая синагога в Феодосии,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"כאגדה צנועה זו נובעת מפי סבה,","hebrew_niqqud":"כְּאַגָּדָה צְנוּעָה זוֹ נוֹבַעַת מִפִּי סָבָה,","translit":"kəʾaggāḏâ ṣənûʿâ zô nôḇaʿaṯ mippî sāḇâ,","translit_ru":"кэагада цэнуа зо новаат мипи сава,","russian":"Словно скромная легенда, что льётся с уст деда,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"שכלה-כלה רך ובאה מן הלב,","hebrew_niqqud":"שֶׁכֻּלָּהּ-כֻּלָּהּ רֹךְ וּבָאָה מִן הַלֵּב,","translit":"šekkūllāh-kūllāh rōḵ ûḇāʾâ min hallēḇ,","translit_ru":"шэкулах-кулах рох уваа мин халев,","russian":"Вся нежная и идущая от сердца,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"שאין שלטונה אך בנימה שבכאב,","hebrew_niqqud":"שֶּׁאֵין שִׁלְטוֹנָהּ אַךְ בַּנִּימָה שֶׁבַּכְּאֵב,","translit":"šeʾên šilṭônāh ʾaḵ bannîmâ šebbakkəʾēḇ,","translit_ru":"шэен шилтонах ах банима шэбакэев,","russian":"Чья власть не только в ноте скорби,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"נצבת, מקדש מעט, בגזרתך המחטבה.","hebrew_niqqud":"נִצַּבְתָּ, מִקְדָּשׁ מְעַט, בְּגִזְרָתְךָ הַמְחֻטָּבָה.","translit":"niṣṣaḇtā, miqdāš məʿaṭ, bəḡizrāṯəḵā haməḥūṭṭāḇâ.","translit_ru":"ницавта, микдаш мэат, бэгизратэха хамэхутава.","russian":"Стоишь ты, малый храм, в своём отточенном очертаньи.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"ובעיני אשק דמות כל-פליטת-זמן ככתבה","hebrew_niqqud":"וּבְעֵינֵי אֶשַׁק דְּמוּת כָּל-פְּלֵיטַת-זְמַן כִּכְתָבָהּ","translit":"ûḇəʿênê ʾešaq dəmûṯ kālpəlêṭaṯ--zəman kiḵṯāḇāh","translit_ru":"увэене эшак дэмут калпэлетат--зэман кихтавах","russian":"И взором я целую облик каждого пережитка времён, как есть он,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"על-פני כתליך ועל-תקרתך בחלב","hebrew_niqqud":"עַל-פְּנֵי כְתָלֶיךָ וְעַל-תִּקְרָתְךָ בַּחֲלֵב","translit":"ʿal-pənê ḵəṯālêḵā wəʿal-tiqrāṯəḵā baḥălēḇ","translit_ru":"ал-пэне хэталеха вэал-тикратэха бахалев","russian":"На лике стен твоих и на потолке, что молоком","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"הסיד המכסה לה, ברצותי לשלב","hebrew_niqqud":"הַסִּיד הַמְכַסֶּה לָהּ, בִּרְצוֹתִי לְשַׁלֵּב","translit":"hassîḏ haməḵassê lāh, birṣôṯî ləšallēḇ","translit_ru":"хасид хамэхасэ лах, бирцоти лэшалев","russian":"Извести́ покрыт, когда хочу я слить воедино","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"בחרותך משכבר וגבורת ימי-סתוה.","hebrew_niqqud":"בַּחֲרוּתְךָ מִשֶּׁכְּבָר וּגְבוּרַת יְמֵי-סְתָוָהּ.","translit":"baḥărûṯəḵā miššekkəḇār ûḡəḇûraṯ yəmê-səṯāwāh.","translit_ru":"бахарутэха мишэкэвар угэвурат йэме-сэтавах.","russian":"Твою былую юность и доблесть осенних дней.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"אל עמודיך הם מסתכלים בענות-חן","hebrew_niqqud":"אֶל עַמוּדֶיךָ הֵם מִסְתַּכְּלִים בְּעַנְוַת-חֵן","translit":"ʾel ʿamûḏêḵā hēm mistakkəlîm bəʿanwaṯ-ḥēn","translit_ru":"эл амудеха хем мистакэлим бэанват-хен","russian":"К твоим колоннам взирают они со смиренной грацией,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"בבאים: \"שלום, בני!","hebrew_niqqud":"בַּבָּאִים: \"שָׁלוֹם, בְּנִי!","translit":"babbāʾîm: \"šālôm, bənî!","translit_ru":"бабаим: \"шалом, бэни!","russian":"Те, кто приходят: «Мир тебе, сын мой!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"גם-אתה באת?","hebrew_niqqud":"גַּם-אַתָּה בָאתָ?","translit":"gam-ʾattâ ḇāʾṯā?","translit_ru":"гам-ата вата?","russian":"И ты пришёл?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"כן?","hebrew_niqqud":"כֵּן?","translit":"kēn?","translit_ru":"кен?","russian":"Да?»","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"ובמשך מאות דור אני ראיתי רבים:","hebrew_niqqud":"וּבְמֶשֶׁךְ מֵאוֹת דּוֹר אֲנִי רָאִיתִי רַבִּים:","translit":"ûḇəmešeḵ mēʾôṯ dôr ʾănî rāʾîṯî rabbîm:","translit_ru":"увэмэшэх меот дор ани раити рабим:","russian":"И сквозь сотни поколений я видел многих:","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"\"בשבי… נכבדי-עם… נמלטים מן השמד…","hebrew_niqqud":"\"בַּשְּׁבִי… נִכְבַּדֵּי-עָם… נִמְלָטִים מִן הַשְּׁמָד…","translit":"\"baššəḇî... niḵbaddê-ʿām... nimlāṭîm min haššəmāḏ...","translit_ru":"\"башэви... нихбаде-ам... нимлатим мин хашэмад...","russian":"«В плену… почтенных людей… бегущих от гибели…","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"הללו ספו, שוב אל צצו – כעשבים,","hebrew_niqqud":"הַלָּלוּ סָפוּ, שׁוּב אֵל צָצוּ – כַּעֲשַׂבִּים,","translit":"hallālû sāp̄û, šûḇ ʾēl ṣāṣû – kaʿăśabbîm,","translit_ru":"халалу сафу, шув ел цацу – каасабим,","russian":"Эти исчезли, вновь не проросли – как травы,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"מצפון ומים, מצטרפים ב'אחד'!\"","hebrew_niqqud":"מִצָּפוֹן וּמִיָּם, מִצְטָרְפִים בְּ'אֶחָד'!\"","translit":"miṣṣāp̄ôn ûmiyyām, miṣṭārəp̄îm bəʾeḥāḏ''!\"","translit_ru":"мицафон умийам, мицтарэфим бээхад''!\"","russian":"С севера и вод, соединяясь в Едином!»","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"1920","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"1920","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
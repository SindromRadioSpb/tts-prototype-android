{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-20","text_key":"92161157778c9952dfe307fed80fa0796e44fb98619952531d2e3fa5a3e58590","title":"אל הציפור","level":null,"tags":["poetry","tehiya"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"20","content_hash":"sha256:27e198cecf19d0d721c5237a6de63f56167075f245bccf8bcbb8197a39a6a070","author":"חיים נחמן ביאליק","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q359705","translator":null,"translator_uri":null,"orig_language":"he","era":"tehiya","genre":"poetry","themes":[],"register":"poetic","track":"literary","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/20","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: תל אביב: דביר, תשל\"ג","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"20","content_hash":"sha256:27e198cecf19d0d721c5237a6de63f56167075f245bccf8bcbb8197a39a6a070","author":"חיים נחמן ביאליק","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q359705","translator":null,"translator_uri":null,"orig_language":"he","era":"tehiya","genre":"poetry","themes":[],"register":"poetic","track":"literary","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/20","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: תל אביב: דביר, תשל\"ג","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"אל הציפור","hebrew_niqqud":"אֶל הַצִּפּוֹר","translit":"ʾel haṣṣippôr","translit_ru":"эл хаципор","russian":"К птице","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"שלום רב שובך, צפרה נחמדת,","hebrew_niqqud":"שָׁלוֹם רָב שׁוּבֵךְ, צִפֹּרָה נֶחְמֶדֶת,","translit":"šālôm rāḇ šûḇēḵ, ṣippōrâ neḥmeḏeṯ,","translit_ru":"шалом рав шувех, ципора нэхмэдэт,","russian":"Привет твоему возвращенью, милая пташка,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"מארצות החם אלחלוני -","hebrew_niqqud":"מֵאַרְצוֹת הַחֹם אֶל־חַלּוֹנִי -","translit":"mēʾarṣôṯ haḥōm ʾel-ḥallônî -","translit_ru":"меарцот хахом эл-халони -","russian":"Из тёплых краёв, к моему окну –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"אל קולך כי ערב מהנפשי כלתה","hebrew_niqqud":"אֶל קוֹלֵךְ כִּי עָרֵב מַה־נַּפְשִׁי כָלָתָה","translit":"ʾel qôlēḵ kî ʿārēḇ mah-nnap̄šî ḵālāṯâ","translit_ru":"эл колех ки арев мах-нафши халата","russian":"К голосу твоему, столь сладостному, душа моя стремилась,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"בחרף בעזבך מעוני.","hebrew_niqqud":"בַּחֹרֶף בְּעָזְבֵךְ מְעוֹנִי.","translit":"baḥōrep̄ bəʿāzəḇēḵ məʿônî.","translit_ru":"бахорэф бэазэвех мэони.","russian":"Зимой, когда покинула ты мой кров.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"זמרי, ספרי, צפורי היקרה,","hebrew_niqqud":"זַמְּרִי, סַפֵּרִי, צִפּוֹרִי הַיְקָרָה,","translit":"zammərî, sappērî, ṣippôrî hayəqārâ,","translit_ru":"замэри, сапери, ципори хайэкара,","russian":"Пой, расскажи мне, пташка дорогая,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"מארץ מרחקים נפלאות,","hebrew_niqqud":"מֵאֶרֶץ מֶרְחַקִּים נִפְלָאוֹת,","translit":"mēʾereṣ merḥaqqîm nip̄lāʾôṯ,","translit_ru":"меэрэц мэрхаким нифлаот,","russian":"Из дальних стран, о дивных чудесах,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"הגם שם בארץ החמה, היפה,","hebrew_niqqud":"הֲגַם שָׁם בָּאָרֶץ הַחַמָּה, הַיָּפָה,","translit":"hăḡam šām bāʾāreṣ haḥammâ, hayyāp̄â,","translit_ru":"хагам шам баарэц хахама, хайафа,","russian":"И там, в краю том тёплом, прекрасном,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"תרבינה הרעות, התלאות?","hebrew_niqqud":"תִּרְבֶּינָה הָרָעוֹת, הַתְּלָאוֹת?","translit":"tirbênâ hārāʿôṯ, hattəlāʾôṯ?","translit_ru":"тирбена хараот, хатэлаот?","russian":"Умножатся ль невзгоды, страданья?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"התשאי לי שלום מאחי בציון,","hebrew_niqqud":"הֲתִשְׂאִי לִי שָׁלוֹם מֵאַחַי בְּצִיּוֹן,","translit":"hăṯiśʾî lî šālôm mēʾaḥay bəṣiyyôn,","translit_ru":"хатиси ли шалом меахай бэцийон,","russian":"Принесёшь ли мне весть от братьев моих в Сионе,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"מאחי הרחוקים הקרובים?","hebrew_niqqud":"מֵאַחַי הָרְחוֹקִים הַקְּרוֹבִים?","translit":"mēʾaḥay hārəḥôqîm haqqərôḇîm?","translit_ru":"меахай харэхоким хакэровим?","russian":"От братьев далёких, но сердцу столь близких?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"הוי מאשרים!","hebrew_niqqud":"הוֹי מְאֻשָּׁרִים!","translit":"hôy məʾūššārîm!","translit_ru":"хой мэушарим!","russian":"О, счастливцы!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"הידעו ידע","hebrew_niqqud":"הֲיֵדְעוּ יָדֹעַ","translit":"hăyēḏəʿû yāḏōaʿ","translit_ru":"хайедэу йадоа","russian":"Ужель известно им,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"כי אסבל, הוי אסבל מכאובים?","hebrew_niqqud":"כִּי אֶסְבֹּל, הוֹי אֶסְבֹּל מַכְאוֹבִים?","translit":"kî ʾesbōl, hôy ʾesbōl maḵʾôḇîm?","translit_ru":"ки эсбол, хой эсбол маховим?","russian":"Что я страдаю, о, я страдаю от боли?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"הידעו ידע מה רבו פה שטני,","hebrew_niqqud":"הֲיֵדְעוּ יָדֹעַ מָה רַבּוּ פֹה שֹטְנַי,","translit":"hăyēḏəʿû yāḏōaʿ mâ rabbû p̄ōh šōṭənay,","translit_ru":"хайедэу йадоа ма рабу фох шотэнай,","russian":"Ужель известно им, как множится здесь враг мой,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"מה רבים, הוי רבים לי קמים?","hebrew_niqqud":"מָה רַבִּים, הוֹי רַבִּים לִי קָמִים?","translit":"mâ rabbîm, hôy rabbîm lî qāmîm?","translit_ru":"ма рабим, хой рабим ли камим?","russian":"Как много, о, как много восстаёт их на меня?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"זמרי, צפורי, נפלאות מארץ,","hebrew_niqqud":"זַמְּרִי, צִפּוֹרִי, נִפְלָאוֹת מֵאֶרֶץ,","translit":"zammərî, ṣippôrî, nip̄lāʾôṯ mēʾereṣ,","translit_ru":"замэри, ципори, нифлаот меэрэц,","russian":"Пой, пташка моя, о чудесах страны,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"האביב בה ינוה עולמים.","hebrew_niqqud":"הָאָבִיב בָּהּ יִנְוֶה עוֹלָמִים.","translit":"hāʾāḇîḇ bāh yinwê ʿôlāmîm.","translit_ru":"хаавив бах йинвэ оламим.","russian":"Где весна обитает вовеки.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"התשאי לי שלום מזמרת הארץ,","hebrew_niqqud":"הֲתִשְׂאִי לִי שָלוֹם מִזִּמְרַת הָאָרֶץ,","translit":"hăṯiśʾî lî šālôm mizzimraṯ hāʾāreṣ,","translit_ru":"хатиси ли шалом мизимрат хаарэц,","russian":"Принесёшь ли мне весть от песни родной земли,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"מעמק, מגיא, מראש הרים?","hebrew_niqqud":"מֵעֵמֶק, מִגַּיְא, מֵרֹאשׁ הָרִים?","translit":"mēʿēmeq, miggayʾ, mērōʾš hārîm?","translit_ru":"меемэк, мигай, мерош харим?","russian":"Из долин, ущелий, с вершин гор?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"הרחם, הנחם אלוה אתציון,","hebrew_niqqud":"הֲרִחַם, הֲנִחַם אֱלוֹהַּ אֶת־צִיּוֹן,","translit":"hăriḥam, hăniḥam ʾĕlôah ʾeṯ-ṣiyyôn,","translit_ru":"харихам, ханихам элоах эт-цийон,","russian":"Смилуется ли, утешит ли Господь Сион,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"אם עודה עזובה לקברים?","hebrew_niqqud":"אִם עוֹדָהּ עֲזוּבָה לִקְבָרִים?","translit":"ʾim ʿôḏāh ʿăzûḇâ liqḇārîm?","translit_ru":"им одах азува ликварим?","russian":"Коль брошен он всё так же могилам?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"ועמק השרון וגבעת הלבונה -","hebrew_niqqud":"וְעֵמֶק הַשָּׁרוֹן וְגִבְעַת הַלְּבוֹנָה -","translit":"wəʿēmeq haššārôn wəḡiḇʿaṯ halləḇônâ -","translit_ru":"вэемэк хашарон вэгиват халэвона -","russian":"А долина Шарона и холм Левоны –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"היתנו אתמרם, אתנרדם?","hebrew_niqqud":"הֲיִתְּנוּ אֶת־מֹרָם, אֶת־נִרְדָּם?","translit":"hăyittənû ʾeṯ-mōrām, ʾeṯ-nirdām?","translit_ru":"хайитэну эт-морам, эт-нирдам?","russian":"Дадут ли свой бальзам, свой нард?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"ההקיץ משנתו השב ביערים,","hebrew_niqqud":"הַהֵקִיץ מִשְּׁנָתוֹ הַשָּׂב בַּיְּעָרִים,","translit":"hahēqîṣ miššənāṯô haśśāḇ bayyəʿārîm,","translit_ru":"хахекиц мишэнато хасав байэарим,","russian":"Проснётся ли от сна старец, живущий в лесах,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"הלבנון הישן, הנרדם?","hebrew_niqqud":"הַלְבָנוֹן הַיָּשֵׁן, הַנִּרְדָּם?","translit":"haləḇānôn hayyāšēn, hannirdām?","translit_ru":"халэванон хайашен, ханирдам?","russian":"Ливан, что стар, погружённый во сон?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"הירד כפנינים הטל על הר חרמון,","hebrew_niqqud":"הֲיֵרֵד כִּפְנִינִים הַטַּל עַל הַר חֶרְמוֹן,","translit":"hăyērēḏ kip̄nînîm haṭṭal ʿal har ḥermôn,","translit_ru":"хайеред кифниним хатал ал хар хэрмон,","russian":"Падёт ли роса, как жемчуг, на Хермон,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"אם ירד ויפל כדמעות?","hebrew_niqqud":"אִם יֵרֵד וְיִפֹּל כִּדְמָעוֹת?","translit":"ʾim yērēḏ wəyippōl kiḏmāʿôṯ?","translit_ru":"им йеред вэйипол кидмаот?","russian":"Иль упадёт и скатится слезами?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"ומהשלום הירדן ומימיו הבהירים?","hebrew_niqqud":"וּמַה־שְּׁלוֹם הַיַּרְדֵּן וּמֵימָיו הַבְּהִירִים?","translit":"ûmah-ššəlôm hayyardēn ûmêmāyw habbəhîrîm?","translit_ru":"умах-шэлом хайарден умемав хабэхирим?","russian":"А как Иордан и его воды чистые?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"ושלום כלההרים, הגבעות?","hebrew_niqqud":"וּשְׁלוֹם כָּל־הֶהָרִים, הַגְּבָעוֹת?","translit":"ûšəlôm kol-hehārîm, haggəḇāʿôṯ?","translit_ru":"ушэлом кол-хэхарим, хагэваот?","russian":"И мир ли в горах, на холмах?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"הסר מעליהם הענן הכבד,","hebrew_niqqud":"הֲסָר מֵעֲלֵיהֶם הֶעָנָן הַכָּבֵד,","translit":"hăsār mēʿălêhem heʿānān hakkāḇēḏ,","translit_ru":"хасар меалехэм хэанан хакавед,","russian":"Ушло ли с них облако тяжёлое,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"הפרש עלטה, צלמות?","hebrew_niqqud":"הַפֹּרֵשׂ עֲלָטָה, צַלְמָוֶת?","translit":"happōrēś ʿălāṭâ, ṣalmāweṯ?","translit_ru":"хапорес алата, цалмавэт?","russian":"Что тьму и смертный мрак на них стелило?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"-","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"-","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r33","order_index":33,"hebrew_plain":"זמרי, צפורי, עלארץ בה מצאו","hebrew_niqqud":"זַמְּרִי, צִפּוֹרִי, עַל־אֶרֶץ בָּהּ מָצְאוּ","translit":"zammərî, ṣippôrî, ʿal-ʾereṣ bāh māṣəʾû","translit_ru":"замэри, ципори, ал-эрэц бах мацэу","russian":"Пой, пташка моя, о той земле, где предки обрели","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r34","order_index":34,"hebrew_plain":"אבותי החיים, המות!","hebrew_niqqud":"אֲבוֹתַי הַחַיִּים, הַמָּוֶת!","translit":"ʾăḇôṯay haḥayyîm, hammāweṯ!","translit_ru":"авотай хахайим, хамавэт!","russian":"Мои отцы и жизнь, и смерть!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r35","order_index":35,"hebrew_plain":"האםעוד לאנבלו הפרחים שתלתי","hebrew_niqqud":"הַאִם־עוֹד לֹא־נָבְלוּ הַפְּרָחִים שָׁתַלְתִּי","translit":"haʾim-ʿôḏ lōʾ-nāḇəlû happərāḥîm šāṯaltî","translit_ru":"хаим-од ло-навэлу хапэрахим шаталти","russian":"Не увяли ль ещё те цветы, что сажал я,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r36","order_index":36,"hebrew_plain":"כאשר נבלתי אנכי?","hebrew_niqqud":"כַּאֲשֶׁר נָבַלְתִּי אָנֹכִי?","translit":"kaʾăšer nāḇaltî ʾānōḵî?","translit_ru":"каашэр навалти анохи?","russian":"Как сам я теперь увял?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r37","order_index":37,"hebrew_plain":"אזכרה ימים כמוהם פרחתי,","hebrew_niqqud":"אֶזְכְּרָה יָמִים כְּמוֹהֶם פָּרַחְתִּי,","translit":"ʾezkərâ yāmîm kəmôhem pāraḥtî,","translit_ru":"эзкэра йамим кэмохэм парахти,","russian":"Я помню дни, когда сам я цвел,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r38","order_index":38,"hebrew_plain":"אך עתה זקנתי, סר כחי.","hebrew_niqqud":"אַךְ עַתָּה זָקַנְתִּי, סָר כֹּחִי.","translit":"ʾaḵ ʿattâ zāqantî, sār kōḥî.","translit_ru":"ах ата заканти, сар кохи.","russian":"Но ныне я стар, и силы иссякли.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r39","order_index":39,"hebrew_plain":"ספרי, צפורי, סוד שיח כלשיח,","hebrew_niqqud":"סַפְּרִי, צִפּוֹרִי, סוֹד שִׂיחַ כָּל־שִׂיחַ,","translit":"sappərî, ṣippôrî, sôḏ śîaḥ kol-śîaḥ,","translit_ru":"сапэри, ципори, сод сиах кол-сиах,","russian":"Поведай, пташка, тайный шёпот всех кустов,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r40","order_index":40,"hebrew_plain":"ומהלך טרפיהם לחשו?","hebrew_niqqud":"וּמַה־לָּךְ טַרְפֵּיהֶם לָחָשׁוּ?","translit":"ûmah-llāḵ ṭarpêhem lāḥāšû?","translit_ru":"умах-лах тарпехэм лахашу?","russian":"И что движеньем листьев они шептали?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r41","order_index":41,"hebrew_plain":"הבשרו נחומים אםקוו לימים,","hebrew_niqqud":"הֲבִשְּׂרוּ נִחוּמִים אִם־קִוּוּ לְיָמִים,","translit":"hăḇiśśərû niḥûmîm ʾim-qiwwû ləyāmîm,","translit_ru":"хависэру нихумим им-киву лэйамим,","russian":"Вещали ль им утешенья, надежду на дни,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r42","order_index":42,"hebrew_plain":"פרימו כלבנון ירעשו?","hebrew_niqqud":"פִּרְיָמוֹ כַּלְּבָנוֹן יִרְעָשׁוּ?","translit":"piryāmô kalləḇānôn yirʿāšû?","translit_ru":"пирйамо калэванон йирашу?","russian":"Когда плоды их, как Ливан, зашелестят?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r43","order_index":43,"hebrew_plain":"ואחי העבדים, הזרעים בדמעה -","hebrew_niqqud":"וְאַחַי הָעֹבְדִים, הַזֹּרְעִים בְּדִמְעָה -","translit":"wəʾaḥay hāʿōḇəḏîm, hazzōrəʿîm bəḏimʿâ -","translit_ru":"вэахай хаовэдим, хазорэим бэдима -","russian":"А братья мои, рабы, сеющие в слезах –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r44","order_index":44,"hebrew_plain":"הקצרו ברנה העמר?","hebrew_niqqud":"הֲקָצְרוּ בְרִנָּה הָעֹמֶר?","translit":"hăqāṣərû ḇərinnâ hāʿōmer?","translit_ru":"хакацэру вэрина хаомэр?","russian":"Пожнут ли они снопы с ликованьем?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r45","order_index":45,"hebrew_plain":"-","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"-","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r46","order_index":46,"hebrew_plain":"מי יתןלי אבר ועפתי אלארץ","hebrew_niqqud":"מִי יִתֶּן־לִי אֵבֶר וְעַפְתִּי אֶל־אֶרֶץ","translit":"mî yitten-lî ʾēḇer wəʿap̄tî ʾel-ʾereṣ","translit_ru":"ми йитэн-ли евэр вэафти эл-эрэц","russian":"Кто даст мне крыло, и я полечу в ту землю,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r47","order_index":47,"hebrew_plain":"בה ינץ השקד, התמר!","hebrew_niqqud":"בָּהּ יָנֵץ הַשָּׁקֵד, הַתֹּמֶר!","translit":"bāh yānēṣ haššāqēḏ, hattōmer!","translit_ru":"бах йанец хашакед, хатомэр!","russian":"Где миндаль цветёт и финик!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r48","order_index":48,"hebrew_plain":"ואני מה אספר לך, צפור נחמדה,","hebrew_niqqud":"וַאֲנִי מָה אֲסַפֵּר לָךְ, צִפּוֹר נֶחְמָדָה,","translit":"waʾănî mâ ʾăsappēr lāḵ, ṣippôr neḥmāḏâ,","translit_ru":"ваани ма асапер лах, ципор нэхмада,","russian":"А я что поведаю тебе, милая пташка,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r49","order_index":49,"hebrew_plain":"מפי מהתקוי לשמע?","hebrew_niqqud":"מִפִּי מַה־תְּקַוִּי לִשְׁמֹעַ?","translit":"mippî mah-ttəqawwî lišmōaʿ?","translit_ru":"мипи мах-тэкави лишмоа?","russian":"Из уст моих что чаять тебе услышать?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r50","order_index":50,"hebrew_plain":"מכנף ארץ קרה לאזמירות תשמעי,","hebrew_niqqud":"מִכְּנַף אֶרֶץ קָרָה לֹא־זְמִירוֹת תִּשְׁמָעִי,","translit":"mikkənap̄ ʾereṣ qārâ lōʾ-zəmîrôṯ tišmāʿî,","translit_ru":"микэнаф эрэц кара ло-зэмирот тишмаи,","russian":"С холодного края земли ты песнопений не услышишь,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r51","order_index":51,"hebrew_plain":"רק קינים, רק הגה ונה.","hebrew_niqqud":"רַק קִינִים, רַק הֶגֶה וָנֹהַּ.","translit":"raq qînîm, raq heḡê wānōah.","translit_ru":"рак киним, рак хэгэ ваноах.","russian":"Лишь стоны, лишь плач и рыданья.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r52","order_index":52,"hebrew_plain":"האספר התלאות, שכבר הן בארצות","hebrew_niqqud":"הַאֲסַפֵּר הַתְּלָאוֹת, שֶׁכְּבָר הֵן בְּאַרְצוֹת","translit":"haʾăsappēr hattəlāʾôṯ, šekkəḇār hēn bəʾarṣôṯ","translit_ru":"хаасапер хатэлаот, шэкэвар хен бэарцот","russian":"Разве поведать мне беды, что уже по землям","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r53","order_index":53,"hebrew_plain":"החיים נשמעות, מודעות?","hebrew_niqqud":"הַחַיִּים נִשְׁמָעוֹת, מוּדָעוֹת?","translit":"haḥayyîm nišmāʿôṯ, mûḏāʿôṯ?","translit_ru":"хахайим нишмаот, мудаот?","russian":"Живых разносятся, ведомы?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r54","order_index":54,"hebrew_plain":"-","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"-","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r55","order_index":55,"hebrew_plain":"הוי, מספר מי ימנה לצרות העברות,","hebrew_niqqud":"הוֹי, מִסְפָּר מִי יִמְנֶה לַצָּרוֹת הָעֹבְרוֹת,","translit":"hôy, mispār mî yimnê laṣṣārôṯ hāʿōḇərôṯ,","translit_ru":"хой, миспар ми йимнэ лацарот хаовэрот,","russian":"О, кто исчислит беды минувшие,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r56","order_index":56,"hebrew_plain":"לצרות מתרגשות ובאות?","hebrew_niqqud":"לְצָרוֹת מִתְרַגְּשׁוֹת וּבָאוֹת?","translit":"ləṣārôṯ miṯraggəšôṯ ûḇāʾôṯ?","translit_ru":"лэцарот митрагэшот уваот?","russian":"Бедам грядущим и наступающим?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r57","order_index":57,"hebrew_plain":"נודי, צפורי, אלהרך, מדברך!","hebrew_niqqud":"נוּדִי, צִפּוֹרִי, אֶל־הָרֵךְ, מִדְבָּרֵךְ!","translit":"nûḏî, ṣippôrî, ʾel-hārēḵ, miḏbārēḵ!","translit_ru":"нуди, ципори, эл-харех, мидбарех!","russian":"Лети, пташка моя, к горам твоим, в пустыню твою!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r58","order_index":58,"hebrew_plain":"אשרת, כי עזבת אתאהלי;","hebrew_niqqud":"אֻשַּׁרְתְּ, כִּי עָזַבְתְּ אֶת־אָהֳלִי;","translit":"ʾūššart, kî ʿāzaḇt ʾeṯ-ʾohŏlî;","translit_ru":"ушарт, ки азавт эт-охоли;","russian":"Блаженна ты, что оставила мой стан;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r59","order_index":59,"hebrew_plain":"לו עמי שכנת, אז גםאת, כנף רננים,","hebrew_niqqud":"לוּ עִמִּי שָׁכַנְתְּ, אָז גַּם־אַתְּ, כְּנַף רְנָנִים,","translit":"lû ʿimmî šāḵant, ʾāz gam-ʾat, kənap̄ rənānîm,","translit_ru":"лу ими шахант, аз гам-ат, кэнаф рэнаним,","russian":"О, если б ты жила с моим народом, то и ты, крыло певучее,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r60","order_index":60,"hebrew_plain":"בכית, מר בכית לגורלי.","hebrew_niqqud":"בָּכִית, מַר בָּכִית לְגוֹרָלִי.","translit":"bāḵîṯ, mar bāḵîṯ ləḡôrālî.","translit_ru":"бахит, мар бахит лэгорали.","russian":"Плакала б, горько плакала о моей доле.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r61","order_index":61,"hebrew_plain":"אך לא בכי ודמעות לי גהה ייטיבו,","hebrew_niqqud":"אַךְ לֹא בְכִי וּדְמָעוֹת לִי גֵהָה יֵיטִיבוּ,","translit":"ʾaḵ lōʾ ḇəḵî ûḏəmāʿôṯ lî ḡēhâ yêṭîḇû,","translit_ru":"ах ло вэхи удэмаот ли геха йетиву,","russian":"Но ни плач, ни слезы не принесут мне исцеления,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r62","order_index":62,"hebrew_plain":"לא אלה ירפאו מכתי;","hebrew_niqqud":"לֹא אֵלֶּה יְרַפְּאוּ מַכָּתִי;","translit":"lōʾ ʾēllê yərappəʾû makkāṯî;","translit_ru":"ло елэ йэрапэу макати;","russian":"Не они залечат мою рану;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r63","order_index":63,"hebrew_plain":"כבר עיני עששו, מלאתי נאד דמעות,","hebrew_niqqud":"כְּבָר עֵינַי עָשֵׁשׁוּ, מִלֵּאתִי נֹאד דְּמָעוֹת,","translit":"kəḇār ʿênay ʿāšēšû, millēʾṯî nōʾḏ dəmāʿôṯ,","translit_ru":"кэвар енай ашешу, милети нод дэмаот,","russian":"Уж очи мои померкли, я слезами наполнил бурдюк,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r64","order_index":64,"hebrew_plain":"כבר הכתה כעשב לבתי;","hebrew_niqqud":"כְּבָר הֻכְּתָה כָּעֵשֶׂב לִבָּתִי;","translit":"kəḇār hūkkəṯâ kāʿēśeḇ libbāṯî;","translit_ru":"кэвар хукэта каесэв либати;","russian":"Уж сердце моё иссохло, как трава;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r65","order_index":65,"hebrew_plain":"כבר כלו הדמעות, כבר כלו הקצים -","hebrew_niqqud":"כְּבָר כָּלוּ הַדְּמָעוֹת, כְּבָר כָּלוּ הַקִּצִּים -","translit":"kəḇār kālû haddəmāʿôṯ, kəḇār kālû haqqiṣṣîm -","translit_ru":"кэвар калу хадэмаот, кэвар калу хакицим -","russian":"Уж кончились слезы, уж истекли все сроки –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r66","order_index":66,"hebrew_plain":"ולא הקיץ הקץ עליגוני,","hebrew_niqqud":"וְלֹא הֵקִיץ הַקֵּץ עַל־יְגוֹנִי,","translit":"wəlōʾ hēqîṣ haqqēṣ ʿal-yəḡônî,","translit_ru":"вэло хекиц хакец ал-йэгони,","russian":"А конец моей печали всё не наступает,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r67","order_index":67,"hebrew_plain":"שלום רב שובך, צפורי היקרה,","hebrew_niqqud":"שָׁלוֹם רָב שׁוּבֵךְ, צִפּוֹרִי הַיְקָרָה,","translit":"šālôm rāḇ šûḇēḵ, ṣippôrî hayəqārâ,","translit_ru":"шалом рав шувех, ципори хайэкара,","russian":"С возвращением, дорогая моя птица,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r68","order_index":68,"hebrew_plain":"צהלינא קולך ורני!","hebrew_niqqud":"צַהֲלִי־נָא קוֹלֵךְ וָרֹנִּי!","translit":"ṣahălî-nāʾ qôlēḵ wārōnnî!","translit_ru":"цахали-на колех варони!","russian":"Возвысь свой голос и пой!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r69","order_index":69,"hebrew_plain":"ניסן, תרנ\"א.","hebrew_niqqud":"נִיסָן, תרנ\"א.","translit":"nîsān, ṯrnʾ\".","translit_ru":"нисан, трн\".","russian":"Нисан, 1891 год.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
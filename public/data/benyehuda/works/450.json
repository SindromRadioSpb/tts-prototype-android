pdated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"למ – ה ג.","hebrew_niqqud":"לְמ – ה ג.","translit":"lm – h ḡ.","translit_ru":"лм – х г.","russian":"Л. М. – Х. Г.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"– ג.","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"– Г.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"I","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"I","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"עליתי בראש ההר: לשרשרות גלמי סלעים","hebrew_niqqud":"עָלִיתִי בְּרֹאשׁ הָהָר: לְשַׁרְשְׁרוֹת גָּלְמֵי סְלָעִים","translit":"ʿālîṯî bərōʾš hāhār: ləšaršərôṯ gāləmê səlāʿîm","translit_ru":"алити бэрош хахар: лэшаршэрот галэме сэлаим","russian":"Я взошел на вершину горы: к цепям скальных глыб –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"ברקת ואיזמרגד, ושלגים מני עולם","hebrew_niqqud":"בָּרֶקֶת וְאִיזְמָרַגְדְּ, וּשְׁלָגִים מִנִּי עוֹלָם","translit":"bāreqeṯ wəʾîzəmāraḡd, ûšəlāḡîm minnî ʿôlām","translit_ru":"барэкэт вэизэмарагд, ушэлагим мини олам","russian":"Изумруд и берилл, и снега извечные","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"משתרעים שם, כזר לפני כס בורא עולם,","hebrew_niqqud":"מִשְׂתָּרְעִים שָׁם, כְּזֵר לִפְנֵי כֵּס בּוֹרֵא עוֹלָם,","translit":"miśtārəʿîm šām, kəzēr lip̄nê kēs bôrēʾ ʿôlām,","translit_ru":"мистарэим шам, кэзер лифне кес боре олам,","russian":"Там простираются, как венок пред троном Творца миров,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"הניחו שרפי-רום מתפעלים, משתאים.","hebrew_niqqud":"הִנִּיחוּ שַׂרְפֵי-רוֹם מִתְפָּעֲלִים, מִשְׁתָּאִים.","translit":"hinnîḥû śarp̄ê-rôm miṯpāʿălîm, mištāʾîm.","translit_ru":"хиниху сарфе-ром митпаалим, миштаим.","russian":"Их возложили вышние серафимы, восхищённые, изумлённые.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"ונדמה לי: כל כך לי קרוב זר הפלאים – – –","hebrew_niqqud":"וְנִדְמֶה לִי: כָּל כָּךְ לִי קָרוֹב זֵר הַפְּלָאִים – – –","translit":"wəniḏmê lî: kol kāḵ lî qārôḇ zēr happəlāʾîm – – –","translit_ru":"вэнидмэ ли: кол ках ли каров зер хапэлаим – – –","russian":"И мнилось мне: так близок мне чудес венок – – –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"\"אדוני!","hebrew_niqqud":"\"אֲדוֹנִי!","translit":"\"ʾăḏônî!","translit_ru":"\"адони!","russian":"«Господин!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"– אז אלי הרועים נשאו קולם –","hebrew_niqqud":"– אָז אֵלַי הָרוֹעִים נָשְׂאוּ קוֹלָם –","translit":"– ʾāz ʾēlay hārôʿîm nāśəʾû qôlām –","translit_ru":"– аз елай хароим насэу колам –","russian":"– Тогда ко мне пастухи воззвали –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"כשהמה קרובים כך למקטנם ועד גדולם,","hebrew_niqqud":"כְּשֶׁהֵמָּה קְרוֹבִים כָּךְ לְמִקְּטַנָּם וְעַד גְּדוֹלָם,","translit":"kəšehēmmâ qərôḇîm kāḵ ləmiqqəṭannām wəʿaḏ gəḏôlām,","translit_ru":"кэшэхема кэровим ках лэмикэтанам вэад гэдолам,","russian":"Когда столь близки они, от мала до велика,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"לימי הסערות אות הממשמשים ובאים\".","hebrew_niqqud":"לִימֵי הַסְּעָרוֹת אוֹת הַמְמַשְׁמְשִׁים וּבָאִים\".","translit":"lîmê hassəʿārôṯ ʾôṯ haməmašməšîm ûḇāʾîm\".","translit_ru":"лиме хасэарот от хамэмашмэшим уваим\".","russian":"Что дни бурь уж близятся, грядут».","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"אני הגיתי אש: וחלום נפשנו כמה","hebrew_niqqud":"אֲנִי הָגִיתִי אֵשׁ: וַחֲלוֹם נַפְשֵׁנוּ כַּמָּה","translit":"ʾănî hāḡîṯî ʾēš: waḥălôm nap̄šēnû kammâ","translit_ru":"ани хагити еш: вахалом нафшену кама","russian":"Я мыслил пламень: о, как мечта души нашей","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"וכמה קרב כבר, ולראשו קשרה חמה","hebrew_niqqud":"וְכַמָּה קָרַב כְּבָר, וּלְרֹאשׁוֹ קָשְׁרָה חַמָּה","translit":"wəḵammâ qāraḇ kəḇār, ûlərōʾšô qāšərâ ḥammâ","translit_ru":"вэхама карав кэвар, улэрошо кашэра хама","russian":"И как уж близок он, и солнце к голове его сплело","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"עטרה לו – וגז, והסער טרם בא.","hebrew_niqqud":"עֲטָרָה לוֹ – וָגָז, וְהַסַּעַר טֶרֶם בָּא.","translit":"ʿăṭārâ lô – wāḡāz, wəhassaʿar ṭerem bāʾ.","translit_ru":"атара ло – вагаз, вэхасаар тэрэм ба.","russian":"Венец ему – и он исчез, а буря всё не шла.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"צור ישעי, הרעם נא על תל-הפגרים כלו!","hebrew_niqqud":"צוּר יִשְׁעִי, הַרְעֵם נָא עַל תֵּל-הַפְּגָרִים כֻּלּוֹ!","translit":"ṣûr yišʿî, harʿēm nāʾ ʿal tēl-happəḡārîm kūllô!","translit_ru":"цур йиши, харем на ал тел-хапэгарим куло!","russian":"Скала спасенья, гром грянь над холмом всех трупов!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"ואם יש עוד סער זה, שיעיר עם מת בעלו,","hebrew_niqqud":"וְאִם יֵשׁ עוֹד סַעַר זֶה, שֶׁיָּעִיר עַם מֵת בְּעֻלּוֹ,","translit":"wəʾim yēš ʿôḏ saʿar zê, šeyyāʿîr ʿam mēṯ bəʿūllô,","translit_ru":"вэим йеш од саар зэ, шэйаир ам мет бэуло,","russian":"И если есть ещё та буря, что мёртвый люд с хозяином пробудит,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"ובחדריך הוא – לסער, שדי, קרא!","hebrew_niqqud":"וּבַחֲדָרֶיךָ הוּא – לַסַּעַר, שַׁדַּי, קְרָא!","translit":"ûḇaḥăḏārêḵā hûʾ – lassaʿar, šadday, qərāʾ!","translit_ru":"увахадареха ху – ласаар, шадай, кэра!","russian":"И в чертогах Твоих она – на бурю, Всевышний, зови!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"II","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"II","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"בין הגלים קורא שחף","hebrew_niqqud":"בֵּין הַגַּלִּים קוֹרֵא שָׁחַף","translit":"bên haggallîm qôrēʾ šāḥap̄","translit_ru":"бен хагалим коре шахаф","russian":"Меж волн кричит чайка,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"ובכנפיו יך הגלים,","hebrew_niqqud":"וּבִכְנָפָיו יַךְ הַגַּלִּים,","translit":"ûḇiḵnāp̄āyw yaḵ haggallîm,","translit_ru":"увихнафав йах хагалим,","russian":"И крыльями волны бьёт,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"מקום יהומו וקצפם מעלים;","hebrew_niqqud":"מְקוֹם יֵהוֹמוּ וְקִצְפָּם מַעֲלִים;","translit":"məqôm yēhômû wəqiṣpām maʿălîm;","translit_ru":"мэком йехому вэкицпам маалим;","russian":"Где шумят они и пену вздымают;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"גב משברים בחזו דחף.","hebrew_niqqud":"גַב מִשְׁבָּרִים בְּחָזוֹ דָחָף.","translit":"ḡaḇ mišbārîm bəḥāzô ḏāḥāp̄.","translit_ru":"гав мишбарим бэхазо дахаф.","russian":"Гребень валов грудью своей толкает.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"ולקול רעם סופה רחף","hebrew_niqqud":"וּלְקוֹל רַעַם סוּפָה רָחַף","translit":"ûləqôl raʿam sûp̄â rāḥap̄","translit_ru":"улэкол раам суфа рахаф","russian":"И под грохот бури парил","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"ברבור צח על פני הגלים,","hebrew_niqqud":"בַּרְבּוּר צַח עַל פְּנֵי הַגַּלִּים,","translit":"barbûr ṣaḥ ʿal pənê haggallîm,","translit_ru":"барбур цах ал пэне хагалим,","russian":"Лебедь белый над волнами,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"הדור, שוקט ונידיו קלים,","hebrew_niqqud":"הָדוּר, שׁוֹקֵט וְנִידָיו קַלִּים,","translit":"hāḏûr, šôqēṭ wənîḏāyw qallîm,","translit_ru":"хадур, шокет вэнидав калим,","russian":"Величавый, спокойный, и легки его движения,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"בגאות-הוד משברים רכב.","hebrew_niqqud":"בְּגַאֲוַת-הוֹד מִשְׁבָּרִים רָכָב.","translit":"bəḡaʾăwaṯ-hôḏ mišbārîm rāḵāḇ.","translit_ru":"бэгаават-ход мишбарим рахав.","russian":"В величавой гордости валы он оседлал.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"לבי אל שדות-ים וקרבות,","hebrew_niqqud":"לִבִּי אֶל שְׂדוֹת-יָם וּקְרָבוֹת,","translit":"libbî ʾel śəḏôṯ-yām ûqərāḇôṯ,","translit_ru":"либи эл сэдот-йам укэравот,","russian":"Моё сердце к просторам моря и битвам,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"מקום שם תחזק הלמות-לבבות,","hebrew_niqqud":"מְקוֹם שָׁם תֶּחֱזַק הַלְמוּת-לְבָבוֹת,","translit":"məqôm šām teḥĕzaq haləmûṯ-ləḇāḇôṯ,","translit_ru":"мэком шам тэхэзак халэмут-лэвавот,","russian":"Там, где стук сердец крепчает,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"והד נצחונות בא ורן;","hebrew_niqqud":"וְהֵד נִצְחוֹנוֹת בָּא וָרָן;","translit":"wəhēḏ niṣḥônôṯ bāʾ wārān;","translit_ru":"вэхед ницхонот ба варан;","russian":"И эхо побед там приходит и поёт;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"ועולם-אל נח כל-כך יפה,","hebrew_niqqud":"וְעוֹלַם-אֵל נָח כָּל-כָּך יָפֶה,","translit":"wəʿôlam-ʾēl nāḥ kāl-kāḵ yāp̄ê,","translit_ru":"вэолам-ел нах кал-ках йафэ,","russian":"И Божий мир так прекрасен в покое,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"עד שאין הלב הרפה","hebrew_niqqud":"עַד שֶׁאֵין הַלֵּב הָרָפֶה","translit":"ʿaḏ šeʾên hallēḇ hārāp̄ê","translit_ru":"ад шэен халев харафэ","russian":"Что сердце ослабевшее не","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r33","order_index":33,"hebrew_plain":"ידע יבר לו: לאן…","hebrew_niqqud":"יֵדַע יָבֹר לוֹ: לְאָן…","translit":"yēḏaʿ yāḇōr lô: ləʾān...","translit_ru":"йеда йавор ло: лэан...","russian":"Знает, куда ему путь избрать…","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r34","order_index":34,"hebrew_plain":"III","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"III","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r35","order_index":35,"hebrew_plain":"\"לאן, לאן?\" – אל אשר יש","hebrew_niqqud":"\"לְאָן, לְאָן?\" – אֶל אֲשֶׁר יֵשׁ","translit":"\"ləʾān, ləʾān?\" – ʾel ʾăšer yēš","translit_ru":"\"лэан, лэан?\" – эл ашэр йеш","russian":"«Куда, куда?» – Туда, где есть","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r36","order_index":36,"hebrew_plain":"קול קורא לך: עלה ורש!","hebrew_niqqud":"קוֹל קוֹרֵא לָךְ: עֲלֵה וָרֵשׁ!","translit":"qôl qôrēʾ lāḵ: ʿălê wārēš!","translit_ru":"кол коре лах: але вареш!","russian":"Там глас зовёт: «Взойди и владей!»","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r37","order_index":37,"hebrew_plain":"מקום צוקי-צור שם נושקים תהום,","hebrew_niqqud":"מְקוֹם צוּקֵי-צוּר שָׁם נוֹשְׁקִים תְּהוֹם,","translit":"məqôm ṣûqê-ṣûr šām nôšəqîm təhôm,","translit_ru":"мэком цуке-цур шам ношэким тэхом,","russian":"Где скальные утесы бездну целуют,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r38","order_index":38,"hebrew_plain":"וגבולות אין לתהומות-רום,","hebrew_niqqud":"וּגְבוּלוֹת אֵין לִתְהוֹמוֹת-רוֹם,","translit":"ûḡəḇûlôṯ ʾên liṯhômôṯ-rôm,","translit_ru":"угэвулот ен литхомот-ром,","russian":"И нет предела безднам горним,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r39","order_index":39,"hebrew_plain":"מקום יתר אור לאור היום,","hebrew_niqqud":"מְקוֹם יֶתֶר אוֹר לְאוֹר הַיּוֹם,","translit":"məqôm yeṯer ʾôr ləʾôr hayyôm,","translit_ru":"мэком йэтэр ор лэор хайом,","russian":"Где света больше, чем свет дня,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r40","order_index":40,"hebrew_plain":"ולילה ילין ביערות-דום.","hebrew_niqqud":"וְלַיְלָה יָלִין בְּיַעֲרוֹת-דּוֹם.","translit":"wəlaylâ yālîn bəyaʿărôṯ-dôm.","translit_ru":"вэлайла йалин бэйаарот-дом.","russian":"И ночь ночует в безмолвных лесах.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r41","order_index":41,"hebrew_plain":"ואל תעמד שם!","hebrew_niqqud":"וְאַל תַּעֲמֹד שָׁם!","translit":"wəʾal taʿămōḏ šām!","translit_ru":"вэал таамод шам!","russian":"И не стой там!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r42","order_index":42,"hebrew_plain":"כי לך בקש,","hebrew_niqqud":"כִּי לֵךְ בַּקֵּשׁ,","translit":"kî lēḵ baqqēš,","translit_ru":"ки лех бакеш,","russian":"Ведь ты ищи,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r43","order_index":43,"hebrew_plain":"אי קדשי-אל והיכלו אש.","hebrew_niqqud":"אֵי קָדְשֵׁי-אֵל וְהֵיכָלוֹ אֵשׁ.","translit":"ʾê qoḏšê-ʾēl wəhêḵālô ʾēš.","translit_ru":"е кодше-ел вэхехало еш.","russian":"Где Божьи святыни, и храм Его – огонь.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r44","order_index":44,"hebrew_plain":"אל תחת אם השמש רד,","hebrew_niqqud":"אַל תֵּחַת אִם הַשֶּׁמֶש רַד,","translit":"ʾal tēḥaṯ ʾim haššemeš raḏ,","translit_ru":"ал техат им хашэмэш рад,","russian":"Не бойся, если солнце зайдёт,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r45","order_index":45,"hebrew_plain":"ולא יעצרך קרח-עד!","hebrew_niqqud":"וְלֹא יַעְצָרְךָ קֶרַח-עַד!","translit":"wəlōʾ yaʿṣārəḵā qeraḥ-ʿaḏ!","translit_ru":"вэло йацарэха кэрах-ад!","russian":"И не остановит тебя вечный лёд!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r46","order_index":46,"hebrew_plain":"ולך ולך, בשם אדני,","hebrew_niqqud":"וְלֵךְ וָלֵךְ, בְּשֵׁם אֲדֹנָי,","translit":"wəlēḵ wālēḵ, bəšēm ʾăḏōnāy,","translit_ru":"вэлех валех, бэшем адонай,","russian":"Иди же, иди, во имя Господа,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r47","order_index":47,"hebrew_plain":"עד תמצא מקום, שם במלא","hebrew_niqqud":"עַד תִּמְצָא מָקוֹם, שָׁם בִּמְלֹא","translit":"ʿaḏ timṣāʾ māqôm, šām bimlōʾ","translit_ru":"ад тимца маком, шам бимло","russian":"Доколь не найдешь места, где всей","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r48","order_index":48,"hebrew_plain":"כל כחות נעוריו לבך יך,","hebrew_niqqud":"כָּל כֹּחוֹת נְעוּרָיו לִבְּךָ יַךְ,","translit":"kol kōḥôṯ nəʿûrāyw libbəḵā yaḵ,","translit_ru":"кол кохот нэурав либэха йах,","russian":"Всею силой юности сердце твоё забьётся,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r49","order_index":49,"hebrew_plain":"והמות מלא הוד כל-כך…","hebrew_niqqud":"וְהַמָּוֶת מָלֵא הוֹד כָּל-כָּךְ…","translit":"wəhammāweṯ mālēʾ hôḏ kāl-kāḵ...","translit_ru":"вэхамавэт мале ход кал-ках...","russian":"И смерть там полна стольким величием…","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r50","order_index":50,"hebrew_plain":"Lausanne","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"Лозанна","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
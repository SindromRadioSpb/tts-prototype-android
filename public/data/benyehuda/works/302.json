ull},{"row_id":"r1","order_index":1,"hebrew_plain":"רועה צאן היה בארץ, רועה נאמן","hebrew_niqqud":"רוֹעֶה צֹאן הָיָה בָּאָרֶץ, רוֹעֶה נֶאֱמָן","translit":"rôʿê ṣōʾn hāyâ bāʾāreṣ, rôʿê neʾĕmān","translit_ru":"роэ цон хайа баарэц, роэ нээман","russian":"Жил в том краю пастух, пастух верный.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"וישמר על צאן מרעיתו ויאהבנה.","hebrew_niqqud":"וַיִּשְׁמֹר עַל צֹאן מַרְעִיתוֹ וַיֶּאֱהָבֶנָּה.","translit":"wayyišmōr ʿal ṣōʾn marʿîṯô wayyeʾĕhāḇennâ.","translit_ru":"вайишмор ал цон марито вайээхавэна.","russian":"Он берег стадо свое и любил его.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"ויהי היום ותאחזהו תנומה ויישן.","hebrew_niqqud":"וַיְהִי הַיּוֹם וַתֹּאחֲזֵהוּ תְּנוּמָה וַיִּישָׁן.","translit":"wayəhî hayyôm wattōʾḥăzēhû tənûmâ wayyîšān.","translit_ru":"вайэхи хайом ватохазеху тэнума вайишан.","russian":"И было в один день, объяла его дремота, и уснул он.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"וייקץ – והנה צאן מרעיתו איננה.","hebrew_niqqud":"וַיִּיקַץ – וְהִנֵּה צֹאן מַרְעִיתוֹ אֵינֶנָּה.","translit":"wayyîqaṣ – wəhinnê ṣōʾn marʿîṯô ʾênennâ.","translit_ru":"вайикац – вэхине цон марито енэна.","russian":"Проснулся он – и вот, нет стада его.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"איננה, אהה,","hebrew_niqqud":"אֵינֶנָּה, אֲהָהּ,","translit":"ʾênennâ, ʾăhāh,","translit_ru":"енэна, ахах,","russian":"Нет его, увы!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"אנה אני בא?","hebrew_niqqud":"אָנָה אֲנִי בָּא?","translit":"ʾānâ ʾănî bāʾ?","translit_ru":"ана ани ба?","russian":"Куда мне идти?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"מחר איככה","hebrew_niqqud":"מָחָר אֵיכָכָה","translit":"māḥār ʾêḵāḵâ","translit_ru":"махар ехаха","russian":"Как же мне завтра","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"אשובה למעון","hebrew_niqqud":"אָשׁוּבָה לִמְעוֹן","translit":"ʾāšûḇâ limʿôn","translit_ru":"ашува лимон","russian":"вернуться в свой дом,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"ביתי השמם","hebrew_niqqud":"בֵּיתִי הַשָּׁמֵם","translit":"bêṯî haššāmēm","translit_ru":"бети хашамем","russian":"в дом мой опустевший,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"בלעדי הצאן?!","hebrew_niqqud":"בִּלְעֲדֵי הַצֹּאן?!","translit":"bilʿăḏê haṣṣōʾn?!","translit_ru":"биладе хацон?!","russian":"без стада?!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"ואצא לדרך וארא והנה קוצים בעגלה,","hebrew_niqqud":"וָאֵצֵא לַדֶּרֶךְ וָאֵרֶא וְהִנֵּה קוֹצִים בַּעֲגָלָה,","translit":"wāʾēṣēʾ laddereḵ wāʾēreʾ wəhinnê qôṣîm baʿăḡālâ,","translit_ru":"ваеце ладэрэх ваерэ вэхине коцим баагала,","russian":"И вышел я в путь и вижу: вот, тернии в повозке,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"ואמר: האין אלה קרני צאני האמללה?","hebrew_niqqud":"וָאֹמַר: הַאֵין אֵלֶּה קַרְנֵי צֹאנִי הָאֻמְלָלָה?","translit":"wāʾōmar: haʾên ʾēllê qarnê ṣōʾnî hāʾūmlālâ?","translit_ru":"ваомар: хаен елэ карне цони хаумлала?","russian":"И сказал я: Разве не рога ли это моего несчастного стада?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"איננה, אהה,","hebrew_niqqud":"אֵינֶנָּה, אֲהָהּ,","translit":"ʾênennâ, ʾăhāh,","translit_ru":"енэна, ахах,","russian":"Нет его, увы!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"אנה אני בא?","hebrew_niqqud":"אָנָה אֲנִי בָּא?","translit":"ʾānâ ʾănî bāʾ?","translit_ru":"ана ани ба?","russian":"Куда мне идти?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"מחר איככה","hebrew_niqqud":"מָחָר אֵיכָכָה","translit":"māḥār ʾêḵāḵâ","translit_ru":"махар ехаха","russian":"Как же мне завтра","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"אשובה למעון","hebrew_niqqud":"אָשׁוּבָה לִמְעוֹן","translit":"ʾāšûḇâ limʿôn","translit_ru":"ашува лимон","russian":"вернуться в свой дом,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"ביתי השמם","hebrew_niqqud":"בֵּיתִי הַשָּׁמֵם","translit":"bêṯî haššāmēm","translit_ru":"бети хашамем","russian":"в дом мой опустевший,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"בלעדי הצאן?!","hebrew_niqqud":"בִּלְעֲדֵי הַצֹּאן?!","translit":"bilʿăḏê haṣṣōʾn?!","translit_ru":"биладе хацон?!","russian":"без стада?!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"ואצא לדרך וארא והנה תפוחים בעגלה,","hebrew_niqqud":"וָאֵצֵא לַדֶּרֶךְ וָאֵרֶא וְהִנֵּה תַּפּוּחִים בַּעֲגָלָה,","translit":"wāʾēṣēʾ laddereḵ wāʾēreʾ wəhinnê tappûḥîm baʿăḡālâ,","translit_ru":"ваеце ладэрэх ваерэ вэхине тапухим баагала,","russian":"И вышел я в путь и вижу: вот, яблоки в повозке,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"ואמר: האין אלה גלגלות צאני האמללה?","hebrew_niqqud":"וָאֹמַר: הַאֵין אֵלֶּה גֻלְגְּלוֹת צֹאנִי הָאֻמְלָלָה?","translit":"
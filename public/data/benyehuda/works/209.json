{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-209","text_key":"971784171deeacf92a1d6d1d79b7d7fb19f0840e41f8b4a34f7d553c7ec6ac50","title":"צִפֹּרֶת","level":null,"tags":["poetry","tehiya"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"209","content_hash":"sha256:7efd0d64857e5c20f4aa421902b0e6bc42e365975cb767b2b26dd7de086cd68f","author":"חיים נחמן ביאליק","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q359705","translator":null,"translator_uri":null,"orig_language":"he","era":"tehiya","genre":"poetry","themes":[],"register":"poetic","track":"literary","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/209","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: תל אביב: דביר, תשל\"ג","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"209","content_hash":"sha256:7efd0d64857e5c20f4aa421902b0e6bc42e365975cb767b2b26dd7de086cd68f","author":"חיים נחמן ביאליק","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q359705","translator":null,"translator_uri":null,"orig_language":"he","era":"tehiya","genre":"poetry","themes":[],"register":"poetic","track":"literary","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/209","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: תל אביב: דביר, תשל\"ג","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"צפרת","hebrew_niqqud":"צִפֹּרֶת","translit":"ṣippōreṯ","translit_ru":"ципорэт","russian":"Птичка","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"כל-העולם טובע באור ובשיר,","hebrew_niqqud":"כָּל-הָעוֹלָם טוֹבֵעַ בָּאוֹר וּבַשִּׁיר,","translit":"kāl-hāʿôlām ṭôḇēaʿ bāʾôr ûḇaššîr,","translit_ru":"кал-хаолам товеа баор увашир,","russian":"Весь мир купается в свете и песне,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"אוצרות חיים לא-שערתים מסביב מתרחשים,","hebrew_niqqud":"אוֹצְרוֹת חַיִּים לֹא-שְׁעַרְתִּים מִסָּבִיב מִתְרַחֲשִׁים,","translit":"ʾôṣərôṯ ḥayyîm lōʾ-šəʿartîm missāḇîḇ miṯraḥăšîm,","translit_ru":"оцэрот хайим ло-шэартим мисавив митрахашим,","russian":"Несметные сокровища жизни вокруг развёртываются,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"ובמשעל הנמתח בין יער וניר","hebrew_niqqud":"וּבַמִּשְׁעֹל הַנִּמְתָּח בֵּין יַעַר וָנִיר","translit":"ûḇammišʿōl hannimtāḥ bên yaʿar wānîr","translit_ru":"увамишол ханимтах бен йаар ванир","russian":"И на тропе, что тянется меж лесом и нивой,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"שנינו הולכים ומחשים.","hebrew_niqqud":"שְׁנֵינוּ הוֹלְכִים וּמַחֲשִׁים.","translit":"šənênû hôləḵîm ûmaḥăšîm.","translit_ru":"шэнену холэхим умахашим.","russian":"Мы оба идём и молчим.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"אנו הולכים והולכים, לשבילנו אין קץ,","hebrew_niqqud":"אָנוּ הוֹלְכִים וְהוֹלְכִים, לִשְׁבִילֵנוּ אֵין קֵץ,","translit":"ʾānû hôləḵîm wəhôləḵîm, lišḇîlēnû ʾên qēṣ,","translit_ru":"ану холэхим вэхолэхим, лишвилену ен кец,","russian":"Мы идём и идём, нашему пути нет конца,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"אפפונו שבלים, כתרונו צפרות,","hebrew_niqqud":"אֲפָפוּנוּ שִׁבֳּלִים, כִּתְּרוּנוּ צִפֳּרוֹת,","translit":"ʾăp̄āp̄ûnû šibbŏlîm, kittərûnû ṣippŏrôṯ,","translit_ru":"афафуну шиболим, китэруну ципорот,","russian":"Нас окружили колосья, увенчали птицы,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"ובחניתות של-זהב יפגענו כל-עץ","hebrew_niqqud":"וּבַחֲנִיתוֹת שֶׁל-זָהָב יִפְגָּעֵנוּ כָל-עֵץ","translit":"ûḇaḥănîṯôṯ šel-zāhāḇ yip̄gāʿēnû ḵāl-ʿēṣ","translit_ru":"уваханитот шэл-захав йифгаену хал-ец","russian":"И золотыми копьями поразит нас каждое дерево","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"ובצאלי צמרות.","hebrew_niqqud":"וּבְצֶאֱלֵי צַמָּרוֹת.","translit":"ûḇəṣeʾĕlê ṣammārôṯ.","translit_ru":"увэцээле цамарот.","russian":"В тени своих крон.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"הדמות כרוב אם עב קלה ברום עולם רפרפה?","hebrew_niqqud":"הַדְּמוּת כְּרוּב אִם עָב קַלָּה בְּרוּם עוֹלָם רִפְרֵפָה?","translit":"haddəmûṯ kərûḇ ʾim ʿāḇ qallâ bərûm ʿôlām rip̄rēp̄â?","translit_ru":"хадэмут кэрув им ав кала бэрум олам рифрефа?","russian":"Фигура, подобно херувиму, иль лёгкой туче, в вышине мира парила?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"אך גם-היא חיש הפליגה למדינת הים –","hebrew_niqqud":"אַךְ גַּם-הִיא חִישׁ הִפְלִיגָה לִמְדִינַת הַיָּם –","translit":"ʾaḵ gam-hîʾ ḥîš hip̄lîḡâ limḏînaṯ hayyām –","translit_ru":"ах гам-хи хиш хифлига лимдинат хайам –","russian":"Но и она быстро отплыла в заморскую страну –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"ואת-הרהורי הטהור כמוה ורם","hebrew_niqqud":"וְאֶת-הִרְהוּרִי הַטָּהוֹר כָּמוֹהָ וָרָם","translit":"wəʾeṯ-hirhûrî haṭṭāhôr kāmôhā wārām","translit_ru":"вээт-хирхури хатахор камоха варам","russian":"И мои чистые, как она, и столь же возвышенные помыслы","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"נשאה עמה לנצח על-כתפה.","hebrew_niqqud":"נָשְׂאָה עִמָּהּ לָנֶצַח עַל-כְּתֵפָהּ.","translit":"nāśəʾâ ʿimmāh lāneṣaḥ ʿal-kəṯēp̄āh.","translit_ru":"насэа имах ланэцах ал-кэтефах.","russian":"Она унесла с собой навек на плече.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"ושוב זהר רקיע, ושוב תכלת בלי-סוף,","hebrew_niqqud":"וְשׁוּב זֹהַר רָקִיעַ, וְשׁוּב תְּכֵלֶת בְּלִי-סוֹף,","translit":"wəšûḇ zōhar rāqîaʿ, wəšûḇ təḵēleṯ bəlî-sôp̄,","translit_ru":"вэшув зохар ракиа, вэшув тэхелэт бэли-соф,","russian":"И вновь сияет небо, и вновь бездонная лазурь,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"את הולכת בראש ואני כרוך אחריך,","hebrew_niqqud":"אַתְּ הוֹלֶכֶת בְּרֹאשׁ וַאֲנִי כָרוּךְ אַחֲרָיִךְ,","translit":"ʾat hôleḵeṯ bərōʾš waʾănî ḵārûḵ ʾaḥărāyiḵ,","translit_ru":"ат холэхэт бэрош ваани харух ахарайих,","russian":"Ты идёшь впереди, а я иду за тобой следом,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"ובקמותיו המלאות השתרע הנוף,","hebrew_niqqud":"וּבְקָמוֹתָיו הַמְלֵאוֹת הִשְׂתָּרַע הַנּוֹף,","translit":"ûḇəqāmôṯāyw haməlēʾôṯ hiśtāraʿ hannôp̄,","translit_ru":"увэкамотав хамэлеот хистара ханоф,","russian":"И полными нивами расстилался пейзаж,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"והכל בהיר בו כמו בעיניך.","hebrew_niqqud":"וְהַכֹּל בָּהִיר בּוֹ כְּמוֹ בְעֵינָיִךְ.","translit":"wəhakkōl bāhîr bô kəmô ḇəʿênāyiḵ.","translit_ru":"вэхакол бахир бо кэмо вэенайих.","russian":"И всё в нём ясно, как в твоих глазах.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"רגע אחד לי נדמה: ביער הלז,","hebrew_niqqud":"רֶגַע אֶחָד לִי נִדְמָה: בַּיַּעַר הַלָּז,","translit":"reḡaʿ ʾeḥāḏ lî niḏmâ: bayyaʿar hallāz,","translit_ru":"рэга эхад ли нидма: байаар халаз,","russian":"На миг мне кажется: в этом лесу,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"המאפיל ומשיב צנתו עלינו,","hebrew_niqqud":"הַמַּאֲפִיל וּמַשִּׁיב צִנָּתוֹ עָלֵינוּ,","translit":"hammaʾăp̄îl ûmaššîḇ ṣinnāṯô ʿālênû,","translit_ru":"хамаафил умашив цинато алену,","russian":"Что сумрачен и прохладой на нас веет,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"גנוז מטמון מסתרים, המשמר מאז","hebrew_niqqud":"גָּנוּז מַטְמוֹן מִסְתָּרִים, הַמְשֻׁמָּר מֵאָז","translit":"gānûz maṭmôn mistārîm, haməšūmmār mēʾāz","translit_ru":"гануз матмон мистарим, хамэшумар меаз","russian":"Сокрыт там клад тайн, что хранит с давних пор","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"ומעולם לשנינו –","hebrew_niqqud":"וּמֵעוֹלָם לִשְׁנֵינוּ –","translit":"ûmēʿôlām lišnênû –","translit_ru":"умеолам лишнену –","russian":"И от века для нас двоих –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"פתאם רחפה הקמה – ומפה אלי-פה","hebrew_niqqud":"פִּתְאֹם רָחֲפָה הַקָּמָה – וּמִפֶּה אֱלֵי-פֶה","translit":"piṯʾōm rāḥăp̄â haqqāmâ – ûmippê ʾĕlê-p̄ê","translit_ru":"питом рахафа хакама – умипэ эле-фэ","russian":"Вдруг заколыхались нивы – и отсюда туда","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"עבר רטט קרנים על-פני האוקינוס.","hebrew_niqqud":"עָבַר רֶטֶט קַרְנַיִם עַל-פְּנֵי הָאוֹקְיָנוֹס.","translit":"ʿāḇar reṭeṭ qarnayim ʿal-pənê hāʾôqəyānôs.","translit_ru":"авар рэтэт карнайим ал-пэне хаокэйанос.","russian":"Пробежала дрожь лучей по лицу океана.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"הו, מי השליג עלינו – ובשפע כזה,","hebrew_niqqud":"הוֹ, מִי הִשְׁלִיג עָלֵינוּ – וּבְשֶׁפַע כָּזֶה,","translit":"hô, mî hišlîḡ ʿālênû – ûḇəšep̄aʿ kāzê,","translit_ru":"хо, ми хишлиг алену – увэшэфа казэ,","russian":"О, кто осыпал нас – и в таком изобилии,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"חיל צפרות לבנות?","hebrew_niqqud":"חֵיל צִפֳּרוֹת לְבָנוֹת?","translit":"ḥêl ṣippŏrôṯ ləḇānôṯ?","translit_ru":"хел ципорот лэванот?","russian":"Стаю белых птичек?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"והנה נקלעה צפרת כפרח בקצה","hebrew_niqqud":"וְהִנֵּה נִקְלְעָה צִפֹּרֶת כְּפֶרַח בִּקְצֵה","translit":"wəhinnê niqləʿâ ṣippōreṯ kəp̄eraḥ biqṣê","translit_ru":"вэхине никлэа ципорэт кэфэрах бикце","russian":"И вот запуталась птичка, как цветок, на конце","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"שער מחלפתך המפזזה על-המחגרת,","hebrew_niqqud":"שְׂעַר מַחְלַפְתֵּךְ הַמְפַזְּזָה עַל-הַמַּחְגֹּרֶת,","translit":"śəʿar maḥlap̄tēḵ haməp̄azzəzâ ʿal-hammaḥgōreṯ,","translit_ru":"сэар махлафтех хамэфазэза ал-хамахгорэт,","russian":"Волоса твоей косы, что струится по поясу,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"וכמו רמזה לי: בחור, קום שקה-לה, ודמה","hebrew_niqqud":"וּכְמוֹ רָמְזָה לִּי: בָּחוּר, קוּם שְׁקָה-לָּהּ, וּדְמֵה","translit":"ûḵəmô rāməzâ lî: bāḥûr, qûm šəqâ-lāh, ûḏəmê","translit_ru":"ухэмо рамэза ли: бахур, кум шэка-лах, удэме","russian":"И словно шепнула мне: юноша, встань, поцелуй её, и уподобься","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"אלי הצפרת!","hebrew_niqqud":"אֵלַי הַצִּפֹּרֶת!","translit":"ʾēlay haṣṣippōreṯ!","translit_ru":"елай хаципорэт!","russian":"Мне, птичке!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"אולם את – ההרגשת בצפרת ובי?","hebrew_niqqud":"אוּלָם אַתְּ – הַהִרְגַּשְׁתְּ בַּצִּפֹּרֶת וָבִי?","translit":"ʾûlām ʾat – hahirgašt baṣṣippōreṯ wāḇî?","translit_ru":"улам ат – хахиргашт баципорэт вави?","russian":"Но ты – почувствовала ли в птичке и во мне?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"ההרגשת, כי גם-נפשי נתונה בשבי,","hebrew_niqqud":"הַהִרְגַּשְׁתְּ, כִּי גַּם-נַפְשִׁי נְתוּנָה בַשְּׁבִי,","translit":"hahirgašt, kî gam-nap̄šî nəṯûnâ ḇaššəḇî,","translit_ru":"хахиргашт, ки гам-нафши нэтуна вашэви,","russian":"Почувствовала ли, что и душа моя в плену,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"ומפרפרת ותלואה, ומצפה לישועה","hebrew_niqqud":"וּמְפַרְפֶּרֶת וּתְלוּאָה, וּמְצַפָּה לִישׁוּעָה","translit":"ûməp̄arpereṯ ûṯəlûʾâ, ûməṣappâ lîšûʿâ","translit_ru":"умэфарпэрэт утэлуа, умэцапа лишуа","russian":"И бьётся, и повисла, и ждёт спасенья","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"במחלפתך הקלועה?","hebrew_niqqud":"בְּמַחְלַפְתֵּךְ הַקְּלוּעָה?","translit":"bəmaḥlap̄tēḵ haqqəlûʿâ?","translit_ru":"бэмахлафтех хакэлуа?","russian":"В твоей заплетённой косе?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r33","order_index":33,"hebrew_plain":"ובעיניך שוב אציץ ואבקש שם תשובה –","hebrew_niqqud":"וּבְעֵינַיִךְ שׁוּב אָצִיץ וַאֲבַקֵּשׁ שָׁם תְּשׁוּבָה –","translit":"ûḇəʿênayiḵ šûḇ ʾāṣîṣ waʾăḇaqqēš šām təšûḇâ –","translit_ru":"увэенайих шув ациц ваавакеш шам тэшува –","russian":"И вновь взгляну в твои глаза, и там ищу ответ –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r34","order_index":34,"hebrew_plain":"וכבתחלה הן צנועות, שתי יוני החן;","hebrew_niqqud":"וּכְבַתְּחִלָּה הֵן צְנוּעוֹת, שְׁתֵּי יוֹנֵי הַחֵן;","translit":"ûḵəḇattəḥillâ hēn ṣənûʿôṯ, šətê yônê haḥēn;","translit_ru":"ухэватэхила хен цэнуот, шэте йоне хахен;","russian":"И как прежде скромны они, две голубки красы;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r35","order_index":35,"hebrew_plain":"מה-לי צניעות עיניך – ומחלפתך משובה,","hebrew_niqqud":"מַה-לִּי צְנִיעוּת עֵינַיִךְ – וּמַחְלַפְתֵּךְ מְשׁוּבָה,","translit":"mah-lî ṣənîʿûṯ ʿênayiḵ – ûmaḥlap̄tēḵ məšûḇâ,","translit_ru":"мах-ли цэниут енайих – умахлафтех мэшува,","russian":"Что мне скромность твоих глаз – когда коса твоя своевольна,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r36","order_index":36,"hebrew_plain":"היא אומרת לי: הן!","hebrew_niqqud":"הִיא אוֹמֶרֶת לִי: הֵן!","translit":"hîʾ ʾômereṯ lî: hēn!","translit_ru":"хи омэрэт ли: хен!","russian":"Она говорит мне: да!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r37","order_index":37,"hebrew_plain":"מהרי, מהרי, אחותי, נבואה היערה,","hebrew_niqqud":"מַהֲרִי, מַהֲרִי, אֲחוֹתִי, נָבוֹאָה הַיַּעֲרָה,","translit":"mahărî, mahărî, ʾăḥôṯî, nāḇôʾâ hayyaʿărâ,","translit_ru":"махари, махари, ахоти, навоа хайаара,","russian":"Спеши, спеши, сестра моя, пойдём в лес,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r38","order_index":38,"hebrew_plain":"תחת חפת אשריו לך כל-נפשי אפיקה,","hebrew_niqqud":"תַּחַת חֻפַּת אֲשֵׁרָיו לָךְ כָּל-נַפְשִׁי אָפִיקָה,","translit":"taḥaṯ ḥūppaṯ ʾăšērāyw lāḵ kāl-nap̄šî ʾāp̄îqâ,","translit_ru":"тахат хупат ашерав лах кал-нафши афика,","russian":"Под сенью его блаженства тебе всю душу излию,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r39","order_index":39,"hebrew_plain":"ואת-כל-אהבתי התלויה בשערה","hebrew_niqqud":"וְאֶת-כָּל-אַהֲבָתִי הַתְּלוּיָה בְשַׂעֲרָה","translit":"wəʾeṯkkāl--ʾahăḇāṯî hattəlûyâ ḇəśaʿărâ","translit_ru":"вээткал--ахавати хатэлуйа вэсаара","russian":"И всю любовь мою, что висит на волоске,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r40","order_index":40,"hebrew_plain":"נמית שנינו בנשיקה.","hebrew_niqqud":"נָמִית שְׁנֵינוּ בִּנְשִׁיקָה.","translit":"nāmîṯ šənênû binšîqâ.","translit_ru":"намит шэнену биншика.","russian":"Мы погубим нас обоих поцелуем.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r41","order_index":41,"hebrew_plain":"מרוזי, תמוז, תרס\"ד.","hebrew_niqqud":"מֵרוֹזִי, תַּמּוּז, תרס\"ד.","translit":"mērôzî, tammûz, ṯrsḏ\".","translit_ru":"мерози, тамуз, трсд\".","russian":"Из Марузи, Тамуз, 1904.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
updated_at":null,"audio_asset_key":null},{"row_id":"r74","order_index":74,"hebrew_plain":"ואם ערמים נותרנו","hebrew_niqqud":"וְאִם עֲרֻמִּים נוֹתַרְנוּ","translit":"wəʾim ʿărūmmîm nôṯarnû","translit_ru":"вэим арумим нотарну","russian":"И если мы остались нагими,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r75","order_index":75,"hebrew_plain":"מבלי לחם ובלי בגד,","hebrew_niqqud":"מִבְּלִי לֶחֶם וּבְלִי בֶגֶד,","translit":"mibbəlî leḥem ûḇəlî ḇeḡeḏ,","translit_ru":"мибэли лэхэм увэли вэгэд,","russian":"без хлеба и без одежды,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r76","order_index":76,"hebrew_plain":"ואם היינו חרפה לשכנינו,","hebrew_niqqud":"וְאִם הָיִינוּ חֶרְפָּה לִשְׁכֵנֵינוּ,","translit":"wəʾim hāyînû ḥerpâ lišḵēnênû,","translit_ru":"вэим хайину хэрпа лишхенену,","russian":"И если мы стали позором для соседей наших,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r77","order_index":77,"hebrew_plain":"לעג וקלס לסביבותינו –","hebrew_niqqud":"לַעַג וָקֶלֶס לִסְבִיבוֹתֵינוּ –","translit":"laʿaḡ wāqeles lisḇîḇôṯênû –","translit_ru":"лааг вакэлэс лисвивотену –","russian":"посмешищем и презрением для окружающих –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r78","order_index":78,"hebrew_plain":"הנה לכך נוצרנו,","hebrew_niqqud":"הִנֵּה לְכַךְ נוֹצַרְנוּ,","translit":"hinnê ləḵaḵ nôṣarnû,","translit_ru":"хине лэхах ноцарну,","russian":"то для этого мы и созданы,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r79","order_index":79,"hebrew_plain":"כי כן גזר האל:","hebrew_niqqud":"כִּי כֵן גָּזַר הָאֵל:","translit":"kî ḵēn gāzar hāʾēl:","translit_ru":"ки хен газар хаел:","russian":"ибо так предопределил Бог:","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r80","order_index":80,"hebrew_plain":"\"יאה עניותא לישראל!\" –","hebrew_niqqud":"\"יָאָה עֲנִיּוּתָא לְיִשְׂרָאֵל!\" –","translit":"\"yāʾâ ʿăniyyûṯāʾ ləyiśrāʾēl!\" –","translit_ru":"\"йаа анийута лэйисраел!\" –","russian":"«Подобает бедность Израилю!» –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r81","order_index":81,"hebrew_plain":"כן דברים בנו היעלים האכזרים,","hebrew_niqqud":"כֵּן דֹּבְרִים בָּנוּ הַיְּעֵלִים הָאַכְזָרִים,","translit":"kēn dōḇərîm bānû hayyəʿēlîm hāʾaḵzārîm,","translit_ru":"кен довэрим бану хайэелим хаахзарим,","russian":"так говорят нам жестокие козлы,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r82","order_index":82,"hebrew_plain":"אך האל ישאנו על כנפי נשרים.","hebrew_niqqud":"אַךְ הָאֵל יִשָּׂאֵנוּ עַל כַּנְפֵי נְשָׁרִים.","translit":"ʾaḵ hāʾēl yiśśāʾēnû ʿal kanp̄ê nəšārîm.","translit_ru":"ах хаел йисаену ал канфе нэшарим.","russian":"но Бог вознесет нас на орлиных крыльях.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r83","order_index":83,"hebrew_plain":"אם אתם לא בקשתם האלהים צונו –","hebrew_niqqud":"אִם אַתֶּם לֹא בקַּשְׁתָּם הָאֱלֹהִים צִוָּנוּ –","translit":"ʾim ʾattem lōʾ ḇqqaštām hāʾĕlōhîm ṣiwwānû –","translit_ru":"им атэм ло вкаштам хаэлохим цивану –","russian":"Даже если вы не просили, Бог повелел нам –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r84","order_index":84,"hebrew_plain":"האלהים הרעה מעודנו אותנו;","hebrew_niqqud":"הָאֱלֹהִים הָרֹעֶה מֵעוֹדֵנוּ אוֹתָנוּ;","translit":"hāʾĕlōhîm hārōʿê mēʿôḏēnû ʾôṯānû;","translit_ru":"хаэлохим хароэ меодену отану;","russian":"Бог пас нас от начала нашего бытия;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r85","order_index":85,"hebrew_plain":"האלהים אשר הבטיח לאבותינו","hebrew_niqqud":"הָאֱלֹהִים אֲשֶׁר הִבְטִיחַ לַאֲבוֹתֵינוּ","translit":"hāʾĕlōhîm ʾăšer hiḇṭîaḥ laʾăḇôṯênû","translit_ru":"хаэлохим ашэр хивтиах лаавотену","russian":"Бог, который обещал нашим отцам,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r86","order_index":86,"hebrew_plain":"כי לא יכרת לנצח זכרנו ושמנו!","hebrew_niqqud":"כִּי לֹא יִכָּרֵת לָנֶצַח זִכְרֵנוּ וּשְׁמֵנוּ!","translit":"kî lōʾ yikkārēṯ lāneṣaḥ ziḵrēnû ûšəmēnû!","translit_ru":"ки ло йикарет ланэцах зихрену ушэмену!","russian":"что не будет истреблена вовек наша память и имя наше!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r87","order_index":87,"hebrew_plain":"הלנצח ידעו הבנים חסר","hebrew_niqqud":"הֲלָנֶצַח יֵדְעוּ הַבָּנִים חֹסֶר","translit":"hălāneṣaḥ yēḏəʿû habbānîm ḥōser","translit_ru":"халанэцах йедэу хабаним хосэр","russian":"Неужели сыновья вечно будут знать нужду","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r88","order_index":88,"hebrew_plain":"יען כי אבותיהם אכלים בסר?","hebrew_niqqud":"יַעַן כִּי אֲבוֹתֵיהֶם אֹכְלִים בֹּסֶר?","translit":"yaʿan kî ʾăḇôṯêhem ʾōḵəlîm bōser?","translit_ru":"йаан ки авотехэм охэлим босэр?","russian":"оттого, что отцы их ели незрелое?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r89","order_index":89,"hebrew_plain":"הלעד יהיו היהודים","hebrew_niqqud":"הֲלָעַד יִהְיוּ הַיְּהוּדִים","translit":"hălāʿaḏ yihyû hayyəhûḏîm","translit_ru":"халаад йихйу хайэхудим","russian":"Неужели евреи будут вечно","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r90","order_index":90,"hebrew_plain":"עדת עניים ומרודים,","hebrew_niqqud":"עֲדַת עֲנִיִּים וּמְרוּדִים,","translit":"ʿăḏaṯ ʿăniyyîm ûmərûḏîm,","translit_ru":"адат анийим умэрудим,","russian":"общиной нищих и униженных,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r91","order_index":91,"hebrew_plain":"הרחוקים מטוב ונחת,","hebrew_niqqud":"הָרְחוֹקִים מִטּוֹב וָנַחַת,","translit":"hārəḥôqîm miṭṭôḇ wānaḥaṯ,","translit_ru":"харэхоким митов ванахат,","russian":"далеких от блага и покоя,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r92","order_index":92,"hebrew_plain":"נבזים ושנואים כגרים,","hebrew_niqqud":"נִבְזִים וּשְׂנוּאִים כַּגֵּרִים,","translit":"niḇzîm ûśənûʾîm kaggērîm,","translit_ru":"нивзим усэнуим кагерим,","russian":"презренных и ненавидимых, как чужеземцы,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r93","order_index":93,"hebrew_plain":"הקשים לאחרים","hebrew_niqqud":"הַקָּשִׁים לַאֲחֵרִים","translit":"haqqāšîm laʾăḥērîm","translit_ru":"хакашим лаахерим","russian":"жестких к другим","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r94","order_index":94,"hebrew_plain":"ולעצמם כספחת?","hebrew_niqqud":"וּלְעַצְמָם כַּסַּפַּחַת?","translit":"ûləʿaṣmām kassappaḥaṯ?","translit_ru":"улэацмам касапахат?","russian":"и для самих себя как язва?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r95","order_index":95,"hebrew_plain":"על אפכם וחמתכם בניכם ישכילו","hebrew_niqqud":"עַל אַפְּכֶם וַחֲמַתְכֶם בְּנֵיכֶם יַשְׂכִּילוּ","translit":"ʿal ʾappəḵem waḥămaṯḵem bənêḵem yaśkîlû","translit_ru":"ал апэхэм вахаматхэм бэнехэм йаскилу","russian":"Наперекор вашей злобе и гневу ваши сыновья станут мудрыми","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r96","order_index":96,"hebrew_plain":"ובאזרחי הארץ גורלם יפילו,","hebrew_niqqud":"וּבְאֶזְרָחֵי הָאָרָץ גּוֹרָלָם יַפִּילוּ,","translit":"ûḇəʾezrāḥê hāʾārāṣ gôrālām yappîlû,","translit_ru":"увээзрахе хаарац горалам йапилу,","russian":"и бросят жребий свой среди граждан страны,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r97","order_index":97,"hebrew_plain":"לאחרים תועלת יביאו,","hebrew_niqqud":"לַאֲחֵרִים תּוֹעֶלָת יָבִיאוּ,","translit":"laʾăḥērîm tôʿelāṯ yāḇîʾû,","translit_ru":"лаахерим тоэлат йавиу,","russian":"другим принесут пользу,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r98","order_index":98,"hebrew_plain":"גם נפשם בטובה ישביעו.","hebrew_niqqud":"גַּם נַפְשָׁם בַּטּוֹבָה יַשְׂבִּיעוּ.","translit":"gam nap̄šām baṭṭôḇâ yaśbîʿû.","translit_ru":"гам нафшам батова йасбиу.","russian":"и свои души насытят благом.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
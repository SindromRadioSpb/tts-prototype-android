{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-60","text_key":"08b9929e0125b6db94033564575fc26ef7697fe5840b686a09c207217fb324e1","title":"יַעֲלַת סֶלַע וְהַנֶּשֶׁר","level":null,"tags":["poetry","haskalah"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"60","content_hash":"sha256:8735c94a043b53a9879c55195c800c0447e52a04ce6f1a98584930bb72d98a30","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"literary","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/60","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"60","content_hash":"sha256:8735c94a043b53a9879c55195c800c0447e52a04ce6f1a98584930bb72d98a30","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"literary","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/60","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"יעלת סלע והנשר","hebrew_niqqud":"יַעֲלַת סֶלַע וְהַנֶּשֶׁר","translit":"yaʿălaṯ selaʿ wəhannešer","translit_ru":"йаалат сэла вэханэшэр","russian":"Горная коза и орёл –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"יעלה הרה ראתה","hebrew_niqqud":"יַעֲלָה הָרָה רָאָתָה","translit":"yaʿălâ hārâ rāʾāṯâ","translit_ru":"йаала хара раата","russian":"Беременная горная коза увидела,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"כי מלאו ללדת ימיה","hebrew_niqqud":"כִּי מָלְאוּ לָלֶדֶת יָמֶיהָ","translit":"kî māləʾû lāleḏeṯ yāmêhā","translit_ru":"ки малэу лалэдэт йамеха","russian":"Что срок её родов настал,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"ולראש סלע עלתה,","hebrew_niqqud":"וּלְרֹאשׁ סֶלַע עָלָתָה,","translit":"ûlərōʾš selaʿ ʿālāṯâ,","translit_ru":"улэрош сэла алата,","russian":"И на вершину скалы поднялась,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"בעבור עת יצא ילדה ממעיה","hebrew_niqqud":"בַּעֲבוּר עֵת יֵצֵא יַלְדָּהּ מִמֵּעֶיהָ","translit":"baʿăḇûr ʿēṯ yēṣēʾ yaldāh mimmēʿêhā","translit_ru":"баавур ет йеце йалдах мимееха","russian":"Чтобы, когда детёныш выйдет из её чрева,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"יפל מטה כנפל אבן מקלע","hebrew_niqqud":"יִפֹּל מַטָּה כִּנְפֹל אָבֶן מִקָּלַע","translit":"yippōl maṭṭâ kinp̄ōl ʾāḇen miqqālaʿ","translit_ru":"йипол мата кинфол авэн микала","russian":"Упал бы он вниз, как камень из пращи,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"וינפץ אל הסלע.","hebrew_niqqud":"וִינֻפַּץ אֶל הַסָּלַע.","translit":"wînūppaṣ ʾel hassālaʿ.","translit_ru":"винупац эл хасала.","russian":"И разбился бы о скалу.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"ותכרע ותלד","hebrew_niqqud":"וַתִּכְרַע וַתֵּלֶד","translit":"wattiḵraʿ wattēleḏ","translit_ru":"ватихра вателэд","russian":"И она присела и родила,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"ותשלך הילד","hebrew_niqqud":"וַתַּשְׁלֵךְ הַיֶּלֶד","translit":"wattašlēḵ hayyeleḏ","translit_ru":"ваташлех хайэлэд","russian":"И бросила детёныша","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"אל אחת הפחתים עמק מתחת,","hebrew_niqqud":"אֶל אַחַת הַפְּחָתִים עָמֹק מִתַּחַת,","translit":"ʾel ʾaḥaṯ happəḥāṯîm ʿāmōq mittaḥaṯ,","translit_ru":"эл ахат хапэхатим амок митахат,","russian":"В одну из расселин, глубоко внизу,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"ותשפל מבטה לשבע נחת","hebrew_niqqud":"וַתַּשְפַּל מַבָּטָהּ לִשְׂבֹּעַ נַחַת","translit":"wattašpal mabbāṭāh liśbōaʿ naḥaṯ","translit_ru":"ваташпал мабатах лисбоа нахат","russian":"И опустила взгляд, чтобы насладиться покоем,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"לראות בן-בטנה נבקע אל עיניה.","hebrew_niqqud":"לִרְאוֹת בֶּן-בִּטְנָהּ נִבְקָע אֶל עֵינֶיהָ.","translit":"lirʾôṯ ben-biṭnāh niḇqāʿ ʾel ʿênêhā.","translit_ru":"лирот бэн-битнах нивка эл енеха.","russian":"Увидеть, как детёныш её утробы разобьётся пред её взором.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"ותשתומם לראות בשפל","hebrew_niqqud":"וַתִּשְׁתּוֹמֵם לִרְאוֹת בַּשֵּׁפֶל","translit":"wattištômēm lirʾôṯ baššēp̄el","translit_ru":"ватиштомем лирот башефэл","russian":"И она изумилась, увидев внизу","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"נשר פורש הכנפים","hebrew_niqqud":"נֶשֶׁר פּוֹרֵשׂ הַכְּנָפָיִם","translit":"nešer pôrēś hakkənāp̄āyim","translit_ru":"нэшэр порес хакэнафайим","russian":"Орла, расправляющего крылья,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"ויקבל עלימו הנפל","hebrew_niqqud":"וַיְקַבֵּל עָלֵימוֹ הַנֵּפֶל","translit":"wayəqabbēl ʿālêmô hannēp̄el","translit_ru":"вайэкабел алемо ханефэл","russian":"И принявшего на них падающего детёныша,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"כמילדת על הברכים.","hebrew_niqqud":"כִּמְיַלֶּדֶת עַל הַבִּרְכָּיִם.","translit":"kimyalleḏeṯ ʿal habbirkāyim.","translit_ru":"кимйалэдэт ал хабиркайим.","russian":"Как повитуха на коленях.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"\"מה-לך פה, עוף כנף, שמה מתחת!","hebrew_niqqud":"\"מַה-לָּךְ פֹּה, עוֹף כָּנָף, שָׁמָּה מִתָּחַת!","translit":"\"mah-lāḵ pōh, ʿôp̄ kānāp̄, šāmmâ mittāḥaṯ!","translit_ru":"\"мах-лах пох, оф канаф, шама митахат!","russian":"«Что ты здесь делаешь, крылатый, там внизу!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"– קראה האם האכזריה אל הנשר –","hebrew_niqqud":"– קָרְאָה הָאֵם הָאַכְזְרִיָּה אֶל הַנֶּשֶׁר –","translit":"– qārəʾâ hāʾēm hāʾaḵzəriyyâ ʾel hannešer –","translit_ru":"– карэа хаем хаахзэрийа эл ханэшэр –","russian":"– вскричала жестокая мать орлу –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"מי בקש זאת מידך הצילו משחת?","hebrew_niqqud":"מִי בִקֵּשׁ זֹאת מִיָּדְךָ הַצִּילוֹ מִשָּׁחַת?","translit":"mî ḇiqqēš zōʾṯ miyyāḏəḵā haṣṣîlô miššāḥaṯ?","translit_ru":"ми викеш зот мийадэха хацило мишахат?","russian":"Кто просил тебя спасать его от гибели?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"הן בן-בטני הוא ואני אמו אני!","hebrew_niqqud":"הֵן בֶּן-בִּטְנִי הוּא וַאֲנִי אִמּוֹ אָנִי!","translit":"hēn ben-biṭnî hûʾ waʾănî ʾimmô ʾānî!","translit_ru":"хен бэн-битни ху ваани имо ани!","russian":"Ведь это мой детёныш, и я сама его мать!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"הגבול עולם תסיג, או תקשר קשר","hebrew_niqqud":"הַגְבוּל עוֹלָם תַּסִּיג, אוֹ תִקְשֹׁר קֶשֶׁר","translit":"haḡḇûl ʿôlām tassîḡ, ʾô ṯiqšōr qešer","translit_ru":"хагвул олам тасиг, о тикшор кэшэр","russian":"Разве ты нарушишь вечную границу, или свяжешь заговор,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"לאמר כי לא כל מעלות רוחמו","hebrew_niqqud":"לֵאמֹר כִּי לֹא כָל מַעֲלוֹת רוּחָמוֹ","translit":"lēʾmōr kî lōʾ ḵol maʿălôṯ rûḥāmô","translit_ru":"лемор ки ло хол маалот рухамо","russian":"Разве скажешь, что не вся власть родителей","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"יוכלו הורים לעשות בילידי בטנמו?!","hebrew_niqqud":"יוּכְלוּ הוֹרִים לַעֲשׂוֹת בִּילִידֵי בִטְנָמוֹ?!","translit":"yûḵəlû hôrîm laʿăśôṯ bîlîḏê ḇiṭnāmô?!","translit_ru":"йухэлу хорим лаасот билиде витнамо?!","russian":"Над рождёнными от их чрева?!»","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"– אם את לא בקשת, האלהים צוני","hebrew_niqqud":"– אִם אַתְּ לֹא בִקַּשְׁתְּ, הָאֱלֹהִים צִוָּנִי","translit":"– ʾim ʾat lōʾ ḇiqqašt, hāʾĕlōhîm ṣiwwānî","translit_ru":"– им ат ло викашт, хаэлохим цивани","russian":"«– Если ты не просила, то Бог повелел мне","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"לחוש הלם אל בן-בטנך לישע!","hebrew_niqqud":"לָחוּשׁ הֲלֹם אֶל בֶּן-בִּטְנֵךְ לַיֵּשַׁע!","translit":"lāḥûš hălōm ʾel ben-biṭnēḵ layyēšaʿ!","translit_ru":"лахуш халом эл бэн-битнех лайеша!","russian":"Поспешить сюда к твоему детёнышу на спасение!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"כי אם את, אכזריה, רחמיך תשחיתי","hebrew_niqqud":"כִּי אִם אַתְּ, אַכְזְרִיָּה, רַחֲמַיִךְ תַּשְׁחִיתִי","translit":"kî ʾim ʾat, ʾaḵzəriyyâ, raḥămayiḵ tašḥîṯî","translit_ru":"ки им ат, ахзэрийа, рахамайих ташхити","russian":"Ибо если ты, жестокая, своё милосердие погубишь,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"וילדים תמים לא ידעו כל רשע","hebrew_niqqud":"וִילָדִים תַּמִּים לֹא יָדְעוּ כָל רֶשַׁע","translit":"wîlāḏîm tammîm lōʾ yāḏəʿû ḵol rešaʿ","translit_ru":"виладим тамим ло йадэу хол рэша","russian":"И невинных детей, не познавших никакого зла,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"רגע הולדם מבלי רחם תמיתי,","hebrew_niqqud":"רֶגַע הִוָּלְדָם מִבְּלִי רַחֵם תָּמִיתִי,","translit":"reḡaʿ hiwwāləḏām mibbəlî raḥēm tāmîṯî,","translit_ru":"рэга хивалэдам мибэли рахем тамити,","russian":"В миг рождения безжалостно умертвишь,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"עוד יש אב רחום להם בשמים","hebrew_niqqud":"עוֹד יֵשׁ אָב רַחוּם לָהֶם בַּשָּׁמַיִם","translit":"ʿôḏ yēš ʾāḇ raḥûm lāhem baššāmayim","translit_ru":"од йеш ав рахум лахэм башамайим","russian":"Есть им ещё милосердный Отец в небесах,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"לא יחפץ מות זד אף כי תם וילד,","hebrew_niqqud":"לֹא יַחְפֹּץ מוֹת זֵד אַף כִּי תָּם וָיֶלֶד,","translit":"lōʾ yaḥpōṣ môṯ zēḏ ʾap̄ kî tām wāyeleḏ,","translit_ru":"ло йахпоц мот зед аф ки там вайэлэд,","russian":"Он не желает смерти злодея, тем паче невинного дитя,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"הוא שלח אותי לפרש הכנפים","hebrew_niqqud":"הוּא שָׁלַח אוֹתִי לִפְרֹשׂ הַכְּנָפַיִם","translit":"hûʾ šālaḥ ʾôṯî lip̄rōś hakkənāp̄ayim","translit_ru":"ху шалах оти лифрос хакэнафайим","russian":"Он послал меня распростереть крылья,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"בעבור הצילם הקימם בחיים –","hebrew_niqqud":"בַּעֲבוּר הַצִּילַם הֲקִימֵם בַּחַיִּים –","translit":"baʿăḇûr haṣṣîlam hăqîmēm baḥayyîm –","translit_ru":"баавур хацилам хакимем бахайим –","russian":"Дабы спасти их, дать им жизнь –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"אולי יהיו ילדי חפץ בחלד!!","hebrew_niqqud":"אוּלַי יִהְיוּ יִלְדֵי חֵפֶץ בֶּחָלֶד!!","translit":"ʾûlay yihyû yilḏê ḥēp̄eṣ beḥāleḏ!!","translit_ru":"улай йихйу йилде хефэц бэхалэд!!","russian":"Быть может, станут они желанными чадами в мире сем!!»","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r33","order_index":33,"hebrew_plain":"--------","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"--------","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r34","order_index":34,"hebrew_plain":"מי בקש מידכם בתי-ספר?","hebrew_niqqud":"מִי בִקַּשׁ מִיֶּדְכָם בָּתֵי-סֵפֶר?","translit":"mî ḇiqqaš miyyeḏḵām bāṯê-sēp̄er?","translit_ru":"ми викаш мийэдхам бате-сефэр?","russian":"Кто просил у вас школ?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r35","order_index":35,"hebrew_plain":"– יאמרו מורי שקר רעי-אפר –","hebrew_niqqud":"– יֹאמְרוּ מוֹרֵי שֶׁקֶר רֹעֵי-אֵפֶר –","translit":"– yōʾmərû môrê šeqer rōʿê-ʾēp̄er –","translit_ru":"– йомэру море шэкэр рое-ефэр –","russian":"– скажут лжеучители, пастыри пепла –","ed
ûḏâ ləśārâ haḥămûḏâ","translit_ru":"михтав меет йэхуда лэсара хахамуда","russian":"Письмо от Иегуды милой Саре","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"לשרה החמודה 1","hebrew_niqqud":"לְשָׂרָה הַחֲמוּדָה 1","translit":"ləśārâ haḥămûḏâ 1","translit_ru":"лэсара хахамуда 1","russian":"Милой Саре 1","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"לא שירים נשגבים עמל המליצים,","hebrew_niqqud":"לֹא שִׁירִים נִשְׂגָּבִים עֲמַל הַמְּלִיצִים,","translit":"lōʾ šîrîm niśgāḇîm ʿămal hamməlîṣîm,","translit_ru":"ло ширим нисгавим амал хамэлицим,","russian":"Не возвышенные песни, плод трудов поэтов,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"לא רזים ורמזים כמחשבי קצים","hebrew_niqqud":"לֹא רָזִים וּרְמָזִים כִּמְחַשְּׁבֵי קִצִּים","translit":"lōʾ rāzîm ûrəmāzîm kimḥaššəḇê qiṣṣîm","translit_ru":"ло разим урэмазим кимхашэве кицим","russian":"Не тайны и намёки, подобные расчётам пророков,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"לא דברי ריבות עם בעלי חצים,","hebrew_niqqud":"לֹא דִבְרֵי רִיבוֹת עִם בַּעֲלֵי חִצִּים,","translit":"lōʾ ḏiḇrê rîḇôṯ ʿim baʿălê ḥiṣṣîm,","translit_ru":"ло дивре ривот им баале хицим,","russian":"Не слова раздоров с метателями стрел,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"העושים בית ה' למערת פרצים,","hebrew_niqqud":"הָעוֹשִׂים בֵּית ה' לִמְעָרַת פָּרִצִים,","translit":"hāʿôśîm bêṯ h' limʿāraṯ pāriṣîm,","translit_ru":"хаосим бет х' лимарат парицим,","russian":"Тех, кто превращают дом Господень в логово разбойников,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"כותבים שטנה ומדברים לשנא בישא","hebrew_niqqud":"כּוֹתְבִים שִׂטְנָה וּמְדַבְּרִים לִשְׁנָא בִּישָׁא","translit":"kôṯəḇîm śiṭnâ ûməḏabbərîm lišnāʾ bîšāʾ","translit_ru":"котэвим ситна умэдабэрим лишна биша","russian":"Пишут клевету и говорят злословие,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"בגלל חלק רזה בסעדת חברה קדישא –","hebrew_niqqud":"בִּגְלַל חֵלֶק רָזֶה בִּסְעֻדַּת חֶבְרָה קַדִּישָׁא –","translit":"biḡlal ḥēleq rāzê bisʿūddaṯ ḥeḇrâ qaddîšāʾ –","translit_ru":"биглал хелэк разэ бисудат хэвра кадиша –","russian":"Из-за скудной доли на трапезе Хевра Кадиша –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"לא אחת מאלה לך היום אגישה,","hebrew_niqqud":"לֹא אַחַת מֵאֵלֶּה לָךְ הַיּוֹם אַגִּישָׁה,","translit":"lōʾ ʾaḥaṯ mēʾēllê lāḵ hayyôm ʾaggîšâ,","translit_ru":"ло ахат меелэ лах хайом агиша,","russian":"Ничего из этого сегодня я тебе не предложу,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"(להם הן אומרים: אל תגשו אל אשה!)","hebrew_niqqud":"(לָהֶם הֵן אוֹמְרִים: אַל תִּגְּשׁוּ אֶל אִשָּׁה!)","translit":"(lāhem hēn ʾômərîm: ʾal tiggəšû ʾel ʾiššâ!)","translit_ru":"(лахэм хен омэрим: ал тигэшу эл иша!)","russian":"(Им же говорят: «Не приближайся к женщине!»)","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"כי אם מעשה צעצועים ופטורי צצים","hebrew_niqqud":"כִּי אִם מַעֲשֵׂה צַעֲצוּעִים וּפְטוּרֵי צִצִּים","translit":"kî ʾim maʿăśê ṣaʿăṣûʿîm ûp̄əṭûrê ṣiṣṣîm","translit_ru":"ки им маасе цаацуим уфэтуре цицим","russian":"Но лишь игрушки и «Развязанные бутоны»,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"לעטר במו את ראש היפה בבנות.","hebrew_niqqud":"לְעַטֵּר בָּמוֹ אֶת רֹאשׁ הַיָּפָה בַּבָּנוֹת.","translit":"ləʿaṭṭēr bāmô ʾeṯ rōʾš hayyāp̄â babbānôṯ.","translit_ru":"лэатер бамо эт рош хайафа бабанот.","russian":"Чтобы украсить ими главу прекраснейшей из дочерей.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"ולמען יערבו דברי לחכה","hebrew_niqqud":"וּלְמַעַן יָעָרְבוּ דְבָרַי לְחִכָּהּ","translit":"ûləmaʿan yāʿārəḇû ḏəḇāray ləḥikkāh","translit_ru":"улэмаан йаарэву дэварай лэхиках","russian":"И чтобы слова мои были сладки тебе на вкус,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"הוספתי עליהם מיני מתיקה","hebrew_niqqud":"הוֹסַפְתִּי עֲלֵיהֶם מִינֵי מְתִיקָה","translit":"hôsap̄tî ʿălêhem mînê məṯîqâ","translit_ru":"хосафти алехэм мине мэтика","russian":"Я добавил к ним всякие сладости","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"מזמרת עיר הבירה תערובות מגדנות.","hebrew_niqqud":"מִזִּמְרַת עִיר הַבִּירָה תַּעֲרוּבוֹת מִגְדָּנוֹת.","translit":"mizzimraṯ ʿîr habbîrâ taʿărûḇôṯ miḡdānôṯ.","translit_ru":"мизимрат ир хабира таарувот мигданот.","russian":"Из урожая столичного города, смешение лакомств.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"והיו אלה המגדנות והטורים","hebrew_niqqud":"וְהָיוּ אֵלֶּה הַמִּגְדָּנוֹת וְהַטּוּרִים","translit":"wəhāyû ʾēllê hammiḡdānôṯ wəhaṭṭûrîm","translit_ru":"вэхайу елэ хамигданот вэхатурим","russian":"И пусть эти лакомства и строки","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"למנה לה מאתי בימי הפורים","hebrew_niqqud":"לְמָנָה לָהּ מֵאִתִּי בִּימֵי הַפּוּרִים","translit":"ləmānâ lāh mēʾittî bîmê happûrîm","translit_ru":"лэмана лах меити биме хапурим","russian":"Будут ей даром от меня в дни Пурима,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"לקים בה מצות משלוח מנות","hebrew_niqqud":"לְקַיֵּם בָּהּ מִצְוַת מִשְׁלוֹחַ מָנוֹת","translit":"ləqayyēm bāh miṣwaṯ mišlôaḥ mānôṯ","translit_ru":"лэкайем бах мицват мишлоах манот","russian":"Чтобы исполнить через них заповедь Мишлоах Манот,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"כשם שקימה בי היא – לאביונים מתנות.","hebrew_niqqud":"כְּשֵׁם שֶׁקִּיְמָה בִי הִיא – לָאֶבְיוֹנִים מַתָּנוֹת.","translit":"kəšēm šeqqiymâ ḇî hîʾ – lāʾeḇyônîm mattānôṯ.","translit_ru":"кэшем шэкийма ви хи – лаэвйоним матанот.","russian":"Так же, как она исполнила для меня – дары для бедных.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"***","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"ואני ימים רבים נמלכתי בכליותי","hebrew_niqqud":"וַאֲנִי יָמִים רַבִּים נִמְלַכְתִּי בְכִלְיוֹתַי","translit":"waʾănî yāmîm rabbîm nimlaḵtî ḇəḵilyôṯay","translit_ru":"ваани йамим рабим нимлахти вэхилйотай","russian":"И я много дней размышлял в глубине души,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"במה אשלם לידידתי הנדיבה","hebrew_niqqud":"בַּמָּה אֲשַׁלֵּם לִידִידָתִי הַנְּדִיבָה","translit":"bammâ ʾăšallēm lîḏîḏāṯî hannəḏîḇâ","translit_ru":"бама ашалем лидидати ханэдива","russian":"Чем мне отплатить моей щедрой подруге","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"את מנחתה הנחמדה לי הקריבה?","hebrew_niqqud":"אֶת מִנְחָתָהּ הַנֶּחְמָדָה לִי הִקְרִיבָה?","translit":"ʾeṯ minḥāṯāh hanneḥmāḏâ lî hiqrîḇâ?","translit_ru":"эт минхатах ханэхмада ли хикрива?","russian":"За её милый дар, который она мне преподнесла?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"נמלכתי, נועצתי,","hebrew_niqqud":"נִמְלַכְתִּי, נוֹעַצתִּי,","translit":"nimlaḵtî, nôʿaṣttî,","translit_ru":"нимлахти, ноацти,","russian":"Я обдумывал, я советовался,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"ובאחרנה חרצתי","hebrew_niqqud":"וּבָאַחֲרֹנָה חָרַצְתִּי","translit":"ûḇāʾaḥărōnâ ḥāraṣtî","translit_ru":"уваахарона харацти","russian":"И наконец я решил","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"למד לה במדתה","hebrew_niqqud":"לָמֹד לָהּ בְּמִדָּתָהּ","translit":"lāmōḏ lāh bəmiddāṯāh","translit_ru":"ламод лах бэмидатах","russian":"Отмерить ей той же мерой,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"לעשות כאשר עשתה","hebrew_niqqud":"לַעֲשׂוֹת כַּאֲשֶׁר עָשָׂתָה","translit":"laʿăśôṯ kaʾăšer ʿāśāṯâ","translit_ru":"лаасот каашэр асата","russian":"Поступить так, как поступила она,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"להביא לה מנחה ממעשה אצבעותי:","hebrew_niqqud":"לְהָבִיא לָהּ מִנְחָה מִמַּעֲשֵׂה אֶצְבְּעוֹתַי:","translit":"ləhāḇîʾ lāh minḥâ mimmaʿăśê ʾeṣbəʿôṯay:","translit_ru":"лэхави лах минха мимаасе эцбэотай:","russian":"Преподнести ей дар, плод моих рук:","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"אז אספתי את שירי שירי,","hebrew_niqqud":"אָז אָסַפְתִּי אֶת שְׁיָרֵי שִׁירַי,","translit":"ʾāz ʾāsap̄tî ʾeṯ šəyārê šîray,","translit_ru":"аз асафти эт шэйаре ширай,","russian":"Тогда я собрал лучшие из моих стихов,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"מהם חרוזים מפזרים","hebrew_niqqud":"מֵהֶם חֲרוּזִים מְפֻזָּרִים","translit":"mēhem ḥărûzîm məp̄ūzzārîm","translit_ru":"мехэм харузим мэфузарим","russian":"Среди них – разрозненные строфы,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"כתובים על גבי הספרים","hebrew_niqqud":"כְּתוּבִים עַל גַּבֵּי הַסְּפָרִים","translit":"kəṯûḇîm ʿal gabbê hassəp̄ārîm","translit_ru":"кэтувим ал габе хасэфарим","russian":"Написанные на обложках книг","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"אשר שלחתי ליודעי ומכירי,","hebrew_niqqud":"אֲשֶׁר שָׁלַחְתִּי לְיוֹדְעַי וּמַכִּירַי,","translit":"ʾăšer šālaḥtî ləyôḏəʿay ûmakkîray,","translit_ru":"ашэр шалахти лэйодэай умакирай,","russian":"Которые я отправлял своим знакомым и друзьям,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"ומהם מקאמא\"ת ודוגמאות","hebrew_niqqud":"וּמֵהֶם מקאמא\"ת וְדוּגְמָאוֹת","translit":"ûmēhem mqʾmʾṯ\" wəḏûḡəmāʾôṯ","translit_ru":"умехэм мкмт\" вэдугэмаот","russian":"А также макамат и образцы,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r33","order_index":33,"hebrew_plain":"ומכתמים ופרפראות.","hebrew_niqqud":"וּמִכְתָּמִים וּפַרְפְּרָאוֹת.","translit":"ûmiḵtāmîm ûp̄arpərāʾôṯ.","translit_ru":"умихтамим уфарпэраот.","russian":"И эпиграммы, и всякие мелочи.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r34","order_index":34,"hebrew_plain":"כי אמרתי הנה שרתי הידידה","hebrew_niqqud":"כִּי אָמַרְתִּי הִנֵּה שָׂרָתִי הַיְדִידָה","translit":"kî ʾāmartî hinnê śārāṯî hayəḏîḏâ","translit_ru":"ки амарти хине сарати хайэдида","russian":"Ибо я сказал: вот, моя подруга Сара,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r35","order_index":35,"hebrew_plain":"ממעשיה נכר כי היא חסידה,","hebrew_niqqud":"מִמַּעֲשֶׂיהָ נִכָּר כִּי הִיא חֲסִידָה,","translit":"mimmaʿăśêhā nikkār kî hîʾ ḥăsîḏâ,","translit_ru":"мимаасеха никар ки хи хасида,","russian":"По её делам видно, что она праведница,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r36","order_index":36,"hebrew_plain":"חסידה אנפה, חסידה בשמים,","hebrew_niqqud":"חֲסִידָה אֲנָפָה, חֲסִידָה בַּשָּׁמַיִם,","translit":"ḥăsîḏâ ʾănāp̄â, ḥăsîḏâ baššāmayim,","translit_ru":"хасида анафа, хасида башамайим,","russian":"Благочестивая цапля, благочестивая в небесах,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r37","order_index":37,"hebrew_plain":"מאמינה בצדיק וברבה אדוקה,","hebrew_niqqud":"מַאֲמִינָה בַּצַּדִּיק וּבְרַבָּהּ אֲדוּקָה,","translit":"maʾămînâ baṣṣaddîq ûḇərabbāh ʾăḏûqâ,","translit_ru":"маамина бацадик увэрабах адука,","russian":"Верующая в цадика и усердная в Рабби,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r38","order_index":38,"hebrew_plain":"ולבי בטוח כי תקבל בתשוקה","hebrew_niqqud":"וְלִבִּי בָּטוּחַ כִּי תְקַבֵּל בִּתְשׁוּקָה","translit":"wəlibbî bāṭûaḥ kî ṯəqabbēl biṯšûqâ","translit_ru":"вэлиби батуах ки тэкабел битшука","russian":"И моё сердце уверено, что она с увлечением примет","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r39","order_index":39,"hebrew_plain":"משלחן רבה אלה השירים,","hebrew_niqqud":"מִשֻּׁלְחַן רַבָּהּ אֵלָּה הַשִּׁירַיִּם,","translit":"miššūlḥan rabbāh ʾēllâ haššîrayyim,","translit_ru":"мишулхан рабах ела хаширайим,","russian":"Эти стихи от стола Рабби,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r40","order_index":40,"hebrew_plain":"ובזה תזכה להעלאת הנשמה","hebrew_niqqud":"וּבָזֶה תִּזְכֶּה לְהַעֲלָאַת הַנְּשָׁמָה","translit":"ûḇāzê tizkê ləhaʿălāʾaṯ hannəšāmâ","translit_ru":"увазэ тизкэ лэхаалаат ханэшама","russian":"И этим заслужит возвышение души","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r41","order_index":41,"hebrew_plain":"למדרגה רמה.","hebrew_niqqud":"לְמַדְרֵגָה רָמָה.","translit":"ləmaḏrēḡâ rāmâ.","translit_ru":"лэмадрега рама.","russian":"На высокий уровень.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r42","order_index":42,"hebrew_plain":"היא העלמה הבכורה מרת שרה שפירא בעיר דווינסק, אשר שלח לה המשורר ביום א' י\"ב אדר שני תרנ\"א (בתור משלוח מנות לפורים) קונטרס קטן בשם פטורי צצים בשני חלקים.","hebrew_niqqud":"הִיא הָעַלְמָה הַבְּכוֹרָה מָרַת שָׂרָה שַׁפִּירָא בָּעִיר דְּוִינְסְק, אֲשֶׁר שָׁלַח לָהּ הַמְּשׁוֹרֵר בְּיוֹם א' י\"ב אֲדָר שֵׁנִי תרנ\"א (בְּתוֹר מִשְׁלוֹחַ מָנוֹת לְפוּרִים) קוּנְטְרֵס קָטָן בְּשֵׁם פְּטוּרֵי צָצִים בִּשְׁנֵי חֲלָקִים.","translit":"hîʾ hāʿalmâ habbəḵôrâ māraṯ śārâ šappîrāʾ bāʿîr dəwînsq, ʾăšer šālaḥ lāh hamməšôrēr bəyôm ʾ' yḇ\" ʾăḏār šēnî ṯrnʾ\" (bəṯôr mišlôaḥ mānôṯ ləp̄ûrîm) qûnəṭərēs qāṭān bəšēm pəṭûrê ṣāṣîm bišnê ḥălāqîm.","translit_ru":"хи хаалма хабэхора марат сара шапира баир дэвинск, ашэр шалах лах хамэшорер бэйом ' йв\" адар шени трн\" (бэтор мишлоах манот лэфурим) кунэтэрес катан бэшем пэтуре цацим бишне халаким.","russian":"Она — старшая девица, госпожа Сара Шапира из города Двинска, которой поэт отправил в воскресенье, 12-го Адара Шэни 5651 года (в качестве пуримского подарка) небольшой сборник под названием «Питорей Цицим» (Развязанные бутоны) в двух частях.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r43","order_index":43,"hebrew_plain":"חלק א: כתובות שעל גבי הספרים, א) אצל הבאראן גינצבורג.","hebrew_niqqud":"חֵלֶק א: כְּתֻבּוֹת שֶׁעַל גַּבֵּי הַסְּפָרִים, א) אֵצֶל הַבָּרָן גִּינְצְבּוּרְג.","translit":"ḥēleq ʾ: kəṯūbbôṯ šeʿal gabbê hassəp̄ārîm, ʾ) ʾēṣel habbārān gînəṣəbûrḡ.","translit_ru":"хелэк : кэтубот шэал габе хасэфарим, ) ецэл хабаран гинэцэбург.","russian":"Часть 1: Надписи на обложках книг, а) Барону Гинцбургу.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r44","order_index":44,"hebrew_plain":"ב) להשר מונטיפיורי.","hebrew_niqqud":"ב) לְהַשֵּׁר מוֹנְטִיפְיוֹרִי.","translit":"ḇ) ləhaššēr mônəṭîp̄əyôrî.","translit_ru":"в) лэхашер монэтифэйори.","russian":"б) Сэру Монтефиори.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r45","order_index":45,"hebrew_plain":"ג) להמשורר פרוג.","hebrew_niqqud":"ג) לְהַמְשׁוֹרֵר פְּרוֹג.","translit":"ḡ) ləhaməšôrēr pərôḡ.","translit_ru":"г) лэхамэшорер пэрог.","russian":"в) Поэту Фругу.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r46","order_index":46,"hebrew_plain":"ד) לזקן.","hebrew_niqqud":"ד) לַזָּקֵן.","translit":"ḏ) lazzāqēn.","translit_ru":"д) лазакен.","russian":"г) Старцу.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r47","order_index":47,"hebrew_plain":"ה) לי\"ה סבר\"י.","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"д) Й.Г. Саври.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r48","order_index":48,"hebrew_plain":"ו) להחכם צה\"ר.","hebrew_niqqud":"ו) לְהֵחָכֵם צֹהַ\"ר.","translit":"w) ləhēḥāḵēm ṣōhar\".","translit_ru":"в) лэхехахем цохар\".","russian":"е) Мудрецу Ц.Г.Р.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r49","order_index":49,"hebrew_plain":"ז) למי שהיה ידידי.","hebrew_niqqud":"ז) לְמִי שֶׁהָיָה יְדִידִי.","translit":"z) ləmî šehāyâ yəḏîḏî.","translit_ru":"з) лэми шэхайа йэдиди.","russian":"ж) Тому, кто был моим другом.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r50","order_index":50,"hebrew_plain":"ח) לנגיד אבד שמיה.","hebrew_niqqud":"ח) לְנָגִיד אָבַד שְׁמֵהּ.","translit":"ḥ) lənāḡîḏ ʾāḇaḏ šəmê.","translit_ru":"х) лэнагид авад шэме.","russian":"з) Вельможе, чье имя кануло в забвение.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r51","order_index":51,"hebrew_plain":"ט) למגיה הספרים.","hebrew_niqqud":"ט) לְמַגִּיהַּ הַסְּפָרִים.","translit":"ṭ) ləmaggîah hassəp̄ārîm.","translit_ru":"т) лэмагиах хасэфарим.","russian":"(9) Корректору книг.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r52","order_index":52,"hebrew_plain":"י) לרייכערסאןץ יא) לחיו\"ג. יב) להרב פוחר.","hebrew_niqqud":"י) לרייכערסאןץ יָא) לחיו\"ג. יב) לְהָרַב פּוֹחֵר.","translit":"y) lryyḵʿrsʾnṣ yāʾ) lḥywḡ\". yḇ) ləhāraḇ pôḥēr.","translit_ru":"й) лрййхрснц йа) лхйвг\". йв) лэхарав похер.","russian":"(10) Рейхерзанцу. (11) Х.Й. Гурланду. (12) Раввину Похеру.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r53","order_index":53,"hebrew_plain":"יג) לפלוני אלמוני.","hebrew_niqqud":"יג) לִפְלֹנִי אַלְמוֹנִי.","translit":"yḡ) lip̄lōnî ʾalmônî.","translit_ru":"йг) лифлони алмони.","russian":"(13) Имяреку.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r54","order_index":54,"hebrew_plain":"יד) לבעלי החברה \"קדימה\" בוייען.","hebrew_niqqud":"יָד) לְבַעֲלֵי הַחֶבְרָה \"קָדִימָה\" בְּוַיְעָן.","translit":"yāḏ) ləḇaʿălê haḥeḇrâ \"qāḏîmâ\" bəwayəʿān.","translit_ru":"йад) лэваале хахэвра \"кадима\" бэвайэан.","russian":"(14) Членам общества «Кадима» в Вене.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r55","order_index":55,"hebrew_plain":"טו) לבני ציון בפאריז.","hebrew_niqqud":"טוּ) לִבְנֵי צִיּוֹן בְּפָּרִיז.","translit":"ṭû) liḇnê ṣiyyôn bəpārîz.","translit_ru":"ту) ливне цийон бэпариз.","russian":"(15) «Сынам Сиона» в Париже.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r56","order_index":56,"hebrew_plain":"טז) אחרון אחרון חביב.","hebrew_niqqud":"טז) אַחֲרוֹן אַחֲרוֹן חָבִיב.","translit":"ṭz) ʾaḥărôn ʾaḥărôn ḥāḇîḇ.","translit_ru":"тз) ахарон ахарон хавив.","russian":"(16) И последнее, но не менее важное.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r57","order_index":57,"hebrew_plain":"– חלק ב: שירי השירים אשר ליהודה הלוה (דוגמאות מספר אשר לא נשלם ולא ישלם), ואלו הם: א) גלגל החוזר.","hebrew_niqqud":"– חֵלֶק ב: שִׁירֵי הַשִּׁירִים אֲשֶׁר לִיהוּדָה הַלֹּהַּ (דֻּגְמָאוֹת מִסְפַּר אֲשֶׁר לֹא נִשְׁלַם וְלֹא יְשַׁלֵּם), וְאֵלּוּ הֵם: א) גַּלְגַּל הַחוֹזֵר.","translit":"– ḥēleq ḇ: šîrê haššîrîm ʾăšer lîhûḏâ hallōah (dūḡmāʾôṯ mispar ʾăšer lōʾ nišlam wəlōʾ yəšallēm), wəʾēllû hēm: ʾ) galgal haḥôzēr.","translit_ru":"– хелэк в: шире хаширим ашэр лихуда халоах (дугмаот миспар ашэр ло нишлам вэло йэшалем), вэелу хем: ) галгал хахозер.","russian":"— Часть Б: Песнь песней Иегуды Галеви (ряд примеров, которые не были и не будут завершены), и вот они: А) Вращающееся колесо.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r58","order_index":58,"hebrew_plain":"ב) אל מקאמת (במקום הקדמה).","hebrew_niqqud":"ב) אֶל מָקָאמַת (בִּמְקוֹם הַקְדָּמָה).","translit":"ḇ) ʾel māqāʾmaṯ (bimqôm haqdāmâ).","translit_ru":"в) эл макамат (бимком хакдама).","russian":"Б) Аль-Макамат (вместо предисловия).","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r59","order_index":59,"hebrew_plain":"ג) דבור מפוצץ.","hebrew_niqqud":"ג) דָּבוּר מְפוֹצֵץ.","translit":"ḡ) dāḇûr məp̄ôṣēṣ.","translit_ru":"г) давур мэфоцец.","russian":"В) Взрывная речь.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r60","order_index":60,"hebrew_plain":"ד) שמוע שמעתי אפרים מתנודד.","hebrew_niqqud":"ד) שָׁמוֹעַ שָׁמַעְתִּי אֶפְרַיִם מִתְנוֹדֵד.","translit":"ḏ) šāmôaʿ šāmaʿtî ʾep̄rayim miṯnôḏēḏ.","translit_ru":"д) шамоа шамати эфрайим митнодед.","russian":"Г) «Слышал я, как колеблется Ефрем».","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r61","order_index":61,"hebrew_plain":"ה) קול ברמה נשמע (מוסב שם: ורוח הקודש לעמתו מרעים).","hebrew_niqqud":"ה) קוֹל בְּרָמָה נִשְׁמָע (מוּסַב שֵׁם: וְרוּחַ הַקֹּדֶשׁ לְעַמְּתוֹ מְרֵעִים).","translit":"h) qôl bərāmâ nišmāʿ (mûsaḇ šēm: wərûaḥ haqqōḏeš ləʿamməṯô mərēʿîm).","translit_ru":"х) кол бэрама нишма (мусав шем: вэруах хакодэш лэамэто мэреим).","russian":"Д) «Голос слышен в Раме» (где говорится: и Дух Святой гремит против его народа).","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r62","order_index":62,"hebrew_plain":"ו) סוד העבור (שיחה בין ויזתא וחרבונה).","hebrew_niqqud":"ו) סוֹד הָעֲבוּר (שִׂיחָה בֵּין וַיְזָתָא וְחַרְבוֹנָה).","translit":"w) sôḏ hāʿăḇûr (śîḥâ bên wayəzāṯāʾ wəḥarḇônâ).","translit_ru":"в) сод хаавур (сиха бен вайэзата вэхарвона).","russian":"Е) Секрет интеркаляции (беседа между Визатой и Харбоной).","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r63","order_index":63,"hebrew_plain":"ז) על מפלת שטרוסבערג.","hebrew_niqqud":"ז) עַל מַפֶּלֶת שְׁטְרוּסְבֶּערְג.","translit":"z) ʿal mappeleṯ šəṭərûsəbeʿrḡ.","translit_ru":"з) ал мапэлэт шэтэрусэбэрг.","russian":"Ж) О падении Штраусберга.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r64","order_index":64,"hebrew_plain":"ח) לאיש עשיר כו'.","hebrew_niqqud":"ח) לְאִישׁ עָשִׁיר כו'.","translit":"ḥ) ləʾîš ʿāšîr ḵw'.","translit_ru":"х) лэиш ашир хв'.","russian":"З) Богатому человеку и т.д.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r65","order_index":65,"hebrew_plain":"ט) על האשה… במות בנה.","hebrew_niqqud":"ט) עַל הָאִשָּׁה... בְּמוֹת בְּנָהּ.","translit":"ṭ) ʿal hāʾiššâ... bəmôṯ bənāh.","translit_ru":"т) ал хаиша... бэмот бэнах.","russian":"И) О женщине... по смерти ее сына.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r66","order_index":66,"hebrew_plain":"י) על החנות החדשה לגרגרנים.","hebrew_niqqud":"י) עַל הַחֲנוּת הַחֲדָשָׁה לְגַרְגְּרָנִים.","translit":"y) ʿal haḥănûṯ haḥăḏāšâ ləḡargərānîm.","translit_ru":"й) ал хаханут хахадаша лэгаргэраним.","russian":"К) О новом магазине для обжор.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r67","order_index":67,"hebrew_plain":"יא) מה שהיו ליצני הדור אומרים.","hebrew_niqqud":"יָא) מָה שֶׁהָיוּ לֵיצָנֵי הַדּוֹר אוֹמְרִים.","translit":"yāʾ) mâ šehāyû lêṣānê haddôr ʾômərîm.","translit_ru":"йа) ма шэхайу лецане хадор омэрим.","russian":"Л) Что говорили шутники поколения.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r68","order_index":68,"hebrew_plain":"יב) סוף דבר.","hebrew_niqqud":"יב) סוֹף דָּבָר.","translit":"yḇ) sôp̄ dāḇār.","translit_ru":"йв) соф давар.","russian":"М) Заключение.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r69","order_index":69,"hebrew_plain":"– כל השירים האלה באים פה כל אחד במקומו.","hebrew_niqqud":"– כָּל הַשִּׁירִים הָאֵלֶּה בָּאִים פֹּה כָּל אֶחָד בִּמְקוֹמוֹ.","translit":"– kol haššîrîm hāʾēllê bāʾîm pōh kol ʾeḥāḏ bimqômô.","translit_ru":"– кол хаширим хаелэ баим пох кол эхад бимкомо.","russian":"— Все эти стихи представлены здесь, каждое на своем месте.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r70","order_index":70,"hebrew_plain":"&nbsp;↩︎","hebrew_niqqud":"","translit":"","translit_ru":"","russian":" ↩︎","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
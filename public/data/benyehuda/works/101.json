хашахар нидмох нидма","russian":"Померк рассвет, померк...","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"(תרכ\"א)","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"(1860-1861)","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"יפעת \"השחר\" עלינו נגלתה","hebrew_niqqud":"יִפְעַת \"הַשַּׁחַר\" עָלֵינוּ נִגְלָתָה","translit":"yip̄ʿaṯ \"haššaḥar\" ʿālênû niḡlāṯâ","translit_ru":"йифат \"хашахар\" алену ниглата","russian":"Явилась нам краса «Рассвета»,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"ונגהות בקר חיש לראות קוינו,","hebrew_niqqud":"וּנְגֹהוֹת בֹּקֶר חִישׁ לִרְאוֹת קִוִּינוּ,","translit":"ûnəḡōhôṯ bōqer ḥîš lirʾôṯ qiwwînû,","translit_ru":"унэгохот бокэр хиш лирот кивину,","russian":"И нежных утр лучи узреть спешили мы;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"סור סרו הצללים במו נטמינו –","hebrew_niqqud":"סוֹר סָרוּ הַצְּלָלִים בָּמוֹ נִטְמִינוּ –","translit":"sôr sārû haṣṣəlālîm bāmô niṭmînû –","translit_ru":"сор сару хацэлалим бамо нитмину –","russian":"Ушли тени, где мы таились –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"פתאם הה שבו ועלטה היתה!","hebrew_niqqud":"פִּתְאֹם הָהּ שָׁבוּ וַעֲלָטָה הָיָתָה!","translit":"piṯʾōm hāh šāḇû waʿălāṭâ hāyāṯâ!","translit_ru":"питом хах шаву ваалата хайата!","russian":"Внезапно, о, они вернулись, и мрак настал!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"ראש ירימו עתה ילדי עיפתה,","hebrew_niqqud":"רֹאשׁ יָרִימוּ עַתָּה יַלְדֵי עֵיפָתָה,","translit":"rōʾš yārîmû ʿattâ yalḏê ʿêp̄āṯâ,","translit_ru":"рош йариму ата йалде ефата,","russian":"Поднимут ныне главы чада скорби,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"אויבינו ישובו יהמו ילשינו,","hebrew_niqqud":"אוֹיְבֵינוּ יָשׁוּבוּ יֶהֱמוּ יַלְשִׁינוּ,","translit":"ʾôyəḇênû yāšûḇû yehĕmû yalšînû,","translit_ru":"ойэвену йашуву йэхэму йалшину,","russian":"Враги вернутся, зашумят и донесут,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"במגנת לב נדם, לא נפתח פינו,","hebrew_niqqud":"בִּמְגִנַּת לֵב נִדֹּם, לֹא נִפְתַּח פִּינוּ,","translit":"bimḡinnaṯ lēḇ niddōm, lōʾ nip̄taḥ pînû,","translit_ru":"бимгинат лев нидом, ло нифтах пину,","russian":"В сердечной скорби мы умолкнем, не разомкнём уст,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"יען מתוכו הלשון כרתה.","hebrew_niqqud":"יַעַן מִתּוֹכוֹ הַלָּשׁוֹן כֹּרָתָה.","translit":"yaʿan mittôḵô hallāšôn kōrāṯâ.","translit_ru":"йаан митохо халашон кората.","russian":"Ибо из него язык был отсечён.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"נסתרת הילל בן שחר ממנו,","hebrew_niqqud":"נִסְתַּרְתָּ הֵילֵל בֶּן שַׁחַר מִמֶּנּוּ,","translit":"nistartā hêlēl ben šaḥar mimmennû,","translit_ru":"нистарта хелел бэн шахар мимэну,","russian":"Сокрыт от нас Гелель, Сын Зари,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"אולם דרכך מנו לא נסתרה","hebrew_niqqud":"אוּלָם דַּרְכֶּךָ מֶנּוּ לֹא נִסְתָּרָה","translit":"ʾûlām darkeḵā mennû lōʾ nistārâ","translit_ru":"улам даркэха мэну ло нистара","russian":"Но путь Твой от нас не был сокрыт,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"ובעזך עוד נעז נהם קמינו.","hebrew_niqqud":"וּבְעֻזְּךָ עוֹד נָעֹז נַהַם קָמֵינוּ.","translit":"ûḇəʿūzzəḵā ʿôḏ nāʿōz naham qāmênû.","translit_ru":"увэузэха од наоз нахам камену.","russian":"И Твоей силой еще дерзнём мы на врагов реветь.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"יצהלו הסוסים וינגח האיל –","hebrew_niqqud":"יִצְהֲלוּ הַסּוּסִים וִינַגַּח הָאָיִל –","translit":"yiṣhălû hassûsîm wînaggaḥ hāʾāyil –","translit_ru":"йицхалу хасусим винагах хаайил –","russian":"Пусть кони заржат, и олень пусть ударит рогами –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"טהר יפעתך עוד כלה לא סרה,","hebrew_niqqud":"טֹהַר יִפְעָתְךָ עוֹד כָּלָה לֹא סָרָה,","translit":"ṭōhar yip̄ʿāṯəḵā ʿôḏ kālâ lōʾ sārâ,","translit_ru":"тохар йифатэха од кала ло сара,","russian":"Чистота Твоей красы еще не вся исчезла,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"שם על הר \"ציון\" עוד תאיר הליל.","hebrew_niqqud":"שָׁם עַל הַר \"צִיּוֹן\" עוֹד תָּאִיר הַלָּיִל.","translit":"šām ʿal har \"ṣiyyôn\" ʿôḏ tāʾîr hallāyil.","translit_ru":"шам ал хар \"цийон\" од таир халайил.","russian":"Там на горе Сион еще будет сиять в ночи.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
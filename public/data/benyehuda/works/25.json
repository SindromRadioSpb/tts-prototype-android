{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-25","text_key":"cbd59404c1270132ae0da3485e60890ce189b311cb9d089345ab9bda4444fac2","title":"בִּתְשׁוּבָתִי","level":null,"tags":["poetry","tehiya"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"25","content_hash":"sha256:ce4951bb7d7b3c5454d67a65857946b8eabf2cc8c213bfd43f38b199985e6c0f","author":"חיים נחמן ביאליק","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q359705","translator":null,"translator_uri":null,"orig_language":"he","era":"tehiya","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/25","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: תל אביב: דביר, תשל\"ג","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"25","content_hash":"sha256:ce4951bb7d7b3c5454d67a65857946b8eabf2cc8c213bfd43f38b199985e6c0f","author":"חיים נחמן ביאליק","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q359705","translator":null,"translator_uri":null,"orig_language":"he","era":"tehiya","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/25","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: תל אביב: דביר, תשל\"ג","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"בתשובתי","hebrew_niqqud":"בִּתְשׁוּבָתִי","translit":"biṯšûḇāṯî","translit_ru":"битшувати","russian":"В моём ответе","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"שוב לפני: זקן בלה,","hebrew_niqqud":"שׁוּב לְפָנַי: זָקֵן בָּלֶה,","translit":"šûḇ ləp̄ānay: zāqēn bālê,","translit_ru":"шув лэфанай: закен балэ,","russian":"Снова предо мной: старик дряхлый,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"פנים צמקים ומצררים,","hebrew_niqqud":"פָּנִים צֹמְקִים וּמְצֹרָרִים,","translit":"pānîm ṣōməqîm ûməṣōrārîm,","translit_ru":"паним цомэким умэцорарим,","russian":"Лик сморщенный и угрюмый,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"צל קש יבש, נד כעלה,","hebrew_niqqud":"צֵל קַשׁ יָבֵשׁ, נָד כְּעָלֶה,","translit":"ṣēl qaš yāḇēš, nāḏ kəʿālê,","translit_ru":"цел каш йавеш, над кэалэ,","russian":"Как тень сухой соломы, дрожит, как лист,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"נד ונע עלגבי ספרים.","hebrew_niqqud":"נָד וָנָע עַל־גַּבֵּי סְפָרִים.","translit":"nāḏ wānāʿ ʿal-gabbê səp̄ārîm.","translit_ru":"над вана ал-габе сэфарим.","russian":"Колеблется и движется над книгами.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"שוב לפני: זקנה בלה,","hebrew_niqqud":"שׁוּב לְפָנַי: זְקֵנָה בָלָה,","translit":"šûḇ ləp̄ānay: zəqēnâ ḇālâ,","translit_ru":"шув лэфанай: зэкена вала,","russian":"Снова предо мной: старуха дряхлая,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"ארגה, סרגה פזמקאות,","hebrew_niqqud":"אֹרְגָה, סֹרְגָה פֻזְמְקָאוֹת,","translit":"ʾōrəḡâ, sōrəḡâ p̄ūzməqāʾôṯ,","translit_ru":"орэга, сорэга фузмэкаот,","russian":"Ткала, вязала чулки,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"פיה מלא אלה, קללה,","hebrew_niqqud":"פִּיהָ מָלֵא אָלָה, קְלָלָה,","translit":"pîhā mālēʾ ʾālâ, qəlālâ,","translit_ru":"пиха мале ала, кэлала,","russian":"Уста её полны брани, проклятий,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"ושפתיה תמיד נעות.","hebrew_niqqud":"וּשְׂפָתֶיהָ תָּמִיד נָעוֹת.","translit":"ûśəp̄āṯêhā tāmîḏ nāʿôṯ.","translit_ru":"усэфатеха тамид наот.","russian":"И губы её вечно движутся.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"וכמאז לא מש ממקומו","hebrew_niqqud":"וּכְמֵאָז לֹא מָשׁ מִמְּקוֹמוֹ","translit":"ûḵəmēʾāz lōʾ māš mimməqômô","translit_ru":"ухэмеаз ло маш мимэкомо","russian":"И как всегда, не сходит с места","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"חתול ביתנו – עודו הזה","hebrew_niqqud":"חֲתוּל בֵּיתֵנוּ – עוֹדוֹ הֹזֶה","translit":"ḥăṯûl bêṯēnû – ʿôḏô hōzê","translit_ru":"хатул бетену – одо хозэ","russian":"Наш домашний кот – всё тот же –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"בין כירים, ובחלומו","hebrew_niqqud":"בֵּין כִּירַיִם, וּבַחֲלוֹמוֹ","translit":"bên kîrayim, ûḇaḥălômô","translit_ru":"бен кирайим, увахаломо","russian":"Меж очагов, и в своём сне","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"עםעכברים יעש חזה.","hebrew_niqqud":"עִם־עַכְבָּרִים יַעַשׂ חֹזֶה.","translit":"ʿim-ʿaḵbārîm yaʿaś ḥōzê.","translit_ru":"им-ахбарим йаас хозэ.","russian":"С мышами знатный пир творит.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"וכמאז באפל מתוחים","hebrew_niqqud":"וּכְמֵאָז בָּאֹפֶל מְתוּחִים","translit":"ûḵəmēʾāz bāʾōp̄el məṯûḥîm","translit_ru":"ухэмеаз баофэл мэтухим","russian":"И как всегда, во мраке натянуты","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"קורי ארג העכביש","hebrew_niqqud":"קוּרֵי אֶרֶג הָעַכָּבִישׁ","translit":"qûrê ʾereḡ hāʿakkāḇîš","translit_ru":"куре эрэг хаакавиш","russian":"Нити паутины,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"מלאי פגרי זבובים נפוחים","hebrew_niqqud":"מְלֵאֵי פִּגְרֵי זְבוּבִים נְפוּחִים","translit":"məlēʾê piḡrê zəḇûḇîm nəp̄ûḥîm","translit_ru":"мэлее пигре зэвувим нэфухим","russian":"Полны трупов раздутых мух,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"שם בזוית המערבית…","hebrew_niqqud":"שָׁם בַּזָּוִית הַמַּעֲרָבִית…","translit":"šām bazzāwîṯ hammaʿărāḇîṯ...","translit_ru":"шам базавит хамааравит...","russian":"Там, в западном углу…","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"לא שניתם מקדמתכם,","hebrew_niqqud":"לֹא שֻׁנֵּיתֶם מִקַּדְמַתְכֶם,","translit":"lōʾ šūnnêṯem miqqaḏmaṯḵem,","translit_ru":"ло шунетэм микадматхэм,","russian":"Вы не изменились с прежних пор,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"ישן נושן, אין חדשה; –","hebrew_niqqud":"יָשָׁן נוֹשָׁן, אֵין חֲדָשָׁה; –","translit":"yāšān nôšān, ʾên ḥăḏāšâ; –","translit_ru":"йашан ношан, ен хадаша; –","russian":"Всё старо, нет ничего нового; –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"אבא, אחי, בחברתכם!","hebrew_niqqud":"אָבֹא, אַחַי, בְּחֶבְרַתְכֶם!","translit":"ʾāḇōʾ, ʾaḥay, bəḥeḇraṯḵem!","translit_ru":"аво, ахай, бэхэвратхэм!","russian":"Отец, мой брат, в вашей компании!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"יחדו נרקב עדנבאשה!","hebrew_niqqud":"יַחְדָּו נִרְקַב עַד־נִבְאָשָׁה!","translit":"yaḥdāw nirqaḇ ʿaḏ-niḇʾāšâ!","translit_ru":"йахдав ниркав ад-ниваша!","russian":"Вместе сгнием до смрада!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-207","text_key":"efae01e657eee995e923a0713ca87d52e01805734348014cd55287c165afe33f","title":"מחמד","level":null,"tags":["poetry","tehiya"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"207","content_hash":"sha256:941bf248d1aa89dc8d9db28be515434baa5149f34cb4e124cd745d6ca303d9ee","author":"שאול טשרניחובסקי","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q521410","translator":null,"translator_uri":null,"orig_language":"he","era":"tehiya","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/207","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"שירי שאול טשרניחובסקי\", תל אביב: דביר, תשכ\"ח","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"207","content_hash":"sha256:941bf248d1aa89dc8d9db28be515434baa5149f34cb4e124cd745d6ca303d9ee","author":"שאול טשרניחובסקי","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q521410","translator":null,"translator_uri":null,"orig_language":"he","era":"tehiya","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/207","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"שירי שאול טשרניחובסקי\", תל אביב: דביר, תשכ\"ח","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"מחמד","hebrew_niqqud":"מֻחַמַּד","translit":"mūḥammaḏ","translit_ru":"мухамад","russian":"Мухаммед","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"והמדבר אז נרדם, וסביב אך הס,","hebrew_niqqud":"וְהַמִּדְבָּר אָז נִרְדָּם, וְסָבִיב אַךְ הָס,","translit":"wəhammiḏbār ʾāz nirdām, wəsāḇîḇ ʾaḵ hās,","translit_ru":"вэхамидбар аз нирдам, вэсавив ах хас,","russian":"И пустыня тогда заснула, и кругом лишь тишина,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"דומיה בהדר אימה ונפלאת;","hebrew_niqqud":"דוּמִיָּה בֶּהָדָר אֲיֻמָּה וְנִפְלָאת;","translit":"ḏûmiyyâ behāḏār ʾăyūmmâ wənip̄lāʾṯ;","translit_ru":"думийа бэхадар айума вэнифлат;","russian":"Безмолвие в величии грозном и чудесном;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"ומלאתי רזים ערבת אשמנים,","hebrew_niqqud":"וּמְלֵאֲתִי רָזִים עַרְבַת אַשְׁמַנִּים,","translit":"ûməlēʾăṯî rāzîm ʿarḇaṯ ʾašmannîm,","translit_ru":"умэлеати разим арват ашманим,","russian":"И полна тайн была небесная твердь,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"ומאירים ממעל שמים שאננים;","hebrew_niqqud":"וּמְאִירִים מִמַּעַל שָׁמַיִם שַׁאֲנָנִּים;","translit":"ûməʾîrîm mimmaʿal šāmayim šaʾănānnîm;","translit_ru":"умэирим мимаал шамайим шаананим;","russian":"И сияли свыше небеса безмятежные;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"וידם ויקשב היקום קשב רב","hebrew_niqqud":"וַיִּדֹּם וַיַּקְשֵׁב הַיְקוּם קֶשֶׁב רָב","translit":"wayyiddōm wayyaqšēḇ hayəqûm qešeḇ rāḇ","translit_ru":"вайидом вайакшев хайэкум кэшэв рав","russian":"И смолкла, и внимала вселенная с напряженьем,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"וכאלו הוא הוחיל לאללה יתן צו.","hebrew_niqqud":"וּכְאִלּוּ הוּא הוֹחִיל לְאַלְלַהּ יִתֵּן צָו.","translit":"ûḵəʾillû hûʾ hôḥîl ləʾallah yittēn ṣāw.","translit_ru":"ухэилу ху хохил лэаллах йитен цав.","russian":"И будто ждала, чтоб Аллах свой подал завет.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"ופתאם – וירעם הרעם בגלגל,","hebrew_niqqud":"וּפִתְאֹם – וַיַּרְעֵם הָרַעַם בַּגַּלְגַּל,","translit":"ûp̄iṯʾōm – wayyarʿēm hāraʿam baggalgal,","translit_ru":"уфитом – вайарем хараам багалгал,","russian":"И вдруг – прогремел гром в небесной сфере,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"במדבר מקצה עד קצהו התגלגל,","hebrew_niqqud":"בַּמִּדְבָּר מִקָּצֶה עַד קָצֵהוּ הִתְגַּלְגֵּל,","translit":"bammiḏbār miqqāṣê ʿaḏ qāṣēhû hiṯgalgēl,","translit_ru":"бамидбар микацэ ад кацеху хитгалгел,","russian":"По пустыне от края до края прокатился,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"וברחבי הישימון טס מכריז על איד,","hebrew_niqqud":"וּבְרַחֲבֵי הַיְּשִׁימוֹן טָס מַכְרִיז עַל אֵיד,","translit":"ûḇəraḥăḇê hayyəšîmôn ṭās maḵrîz ʿal ʾêḏ,","translit_ru":"увэрахаве хайэшимон тас махриз ал ед,","russian":"И по просторам пустыни летел, вещая беду,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"ובאפסי מרחקים לו ענה ההד","hebrew_niqqud":"וּבְאַפְסֵי מֶרְחַקִּים לוֹ עָנָה הַהֵד","translit":"ûḇəʾap̄sê merḥaqqîm lô ʿānâ hahēḏ","translit_ru":"увэафсе мэрхаким ло ана хахед","russian":"И в далёких далях ему отвечало эхо","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"בקול שאון חרישי, וכאלו לו לעג –","hebrew_niqqud":"בְּקוֹל שָׁאוֹן חֲרִישִׁי, וּכְאִלּוּ לוֹ לָעָג –","translit":"bəqôl šāʾôn ḥărîšî, ûḵəʾillû lô lāʿāḡ –","translit_ru":"бэкол шаон хариши, ухэилу ло лааг –","russian":"Шумным безмолвием, и будто издевкой –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"וימוג במרחק… גור-אריה זה שאג!","hebrew_niqqud":"וַיִּמּוֹג בַּמֶרְחַק… גּוּר-אַרְיֵה זֶה שָׁאָג!","translit":"wayyimmôḡ bamerḥaq... gûr-ʾaryê zê šāʾāḡ!","translit_ru":"вайимог бамэрхак... гур-арйе зэ шааг!","russian":"И растворилось вдаль… Львёнок это рычал!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"וברגע הרזים כי חלף הקול,","hebrew_niqqud":"וּבְרֶגַע הָרָזִים כִּי חָלַף הַקּוֹל,","translit":"ûḇəreḡaʿ hārāzîm kî ḥālap̄ haqqôl,","translit_ru":"увэрэга харазим ки халаф хакол,","russian":"И в миг таинственный, когда стих тот звук,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"ברטט וחלחלה התנער הכל:","hebrew_niqqud":"בְּרֶטֶט וְחַלְחָלָה הִתְנַעֵר הַכֹּל:","translit":"bəreṭeṭ wəḥalḥālâ hiṯnaʿēr hakkōl:","translit_ru":"бэрэтэт вэхалхала хитнаер хакол:","russian":"В трепете и дрожи всё встрепенулось:","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"הסוס הטה אזניו ויצהל ברמה,","hebrew_niqqud":"הַסּוּס הִטָּה אָזְנָיו וַיִצְהַל בָּרָמָה,","translit":"hassûs hiṭṭâ ʾoznāyw wayiṣhal bārāmâ,","translit_ru":"хасус хита ознав вайицхал барама,","russian":"Конь приподнял уши и заржал громко,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"וינחר הגמל, ויילל בדממה,","hebrew_niqqud":"וַיִנְחַר הַגָּמָל, וַיִּילֵל בִּדְמָמָה,","translit":"wayinḥar haggāmāl, wayyîlēl biḏmāmâ,","translit_ru":"вайинхар хагамал, вайилел бидмама,","russian":"И верблюд зафыркал, и завыл в тишине,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"וינבה הצבע מרבצו בגיא.","hebrew_niqqud":"וַיִנְבַּהּ הַצְּבֹעַ מֵרִבְצוֹ בַּגָּיְא.","translit":"wayinbah haṣṣəḇōaʿ mēriḇṣô baggāyʾ.","translit_ru":"вайинбах хацэвоа меривцо багай.","russian":"И гиена залаяла из логова в ущелье.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"ובהמוג הקול עוד באזנינו הוא חי.","hebrew_niqqud":"וּבְהִמּוֹג הַקּוֹל עוֹד בְּאָזְנֵינוּ הוּא חָי.","translit":"ûḇəhimmôḡ haqqôl ʿôḏ bəʾoznênû hûʾ ḥāy.","translit_ru":"увэхимог хакол од бэознену ху хай.","russian":"И когда звук стих, он ещё жил в наших ушах.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"וכרוח קר חלף ויקפיא דמנו…","hebrew_niqqud":"וּכְרוּחַ קַר חָלַף וַיַּקְפִּיא דָמֵנוּ…","translit":"ûḵərûaḥ qar ḥālap̄ wayyaqpîʾ ḏāmēnû...","translit_ru":"ухэруах кар халаф вайакпи дамену...","russian":"И как холодный ветер пронёсся, заморозив кровь…","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"אך שאנן הנביא אז ישב בינינו,","hebrew_niqqud":"אַךְ שַׁאֲנָן הַנָּבִיא אָז יָשַׁב בֵּינֵינוּ,","translit":"ʾaḵ šaʾănān hannāḇîʾ ʾāz yāšaḇ bênênû,","translit_ru":"ах шаанан ханави аз йашав бенену,","russian":"Но безмятежный Пророк тогда сидел среди нас,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"מאור הירח, אור תכלת, לו זיו","hebrew_niqqud":"מֵאוֹר הַיָּרֵחַ, אוֹר תְּכֵלֶת, לוֹ זִיו","translit":"mēʾôr hayyārēaḥ, ʾôr təḵēleṯ, lô zîw","translit_ru":"меор хайареах, ор тэхелэт, ло зив","russian":"От лунного света, сияния лазурного, ему был блеск","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"ויתקן סנדלו – ומלה אין בפיו…","hebrew_niqqud":"וַיְתַקֵּן סַנְדָּלוֹ – וּמִלָּה אֵין בְּפִיו…","translit":"wayəṯaqqēn sandālô – ûmillâ ʾên bəp̄îw...","translit_ru":"вайэтакен сандало – умила ен бэфив...","russian":"Он чинил сандаль – и ни слова из уст…","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"ותשב הדממה, ויישן המחנה,","hebrew_niqqud":"וַתָּשָׁב הַדְּמָמָה, וַיִּישַׁן הַמַּחֲנֶה,","translit":"wattāšoḇ haddəmāmâ, wayyîšan hammaḥănê,","translit_ru":"ваташов хадэмама, вайишан хамаханэ,","russian":"И вернулась тишина, и уснул лагерь,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"לא רגשו נסינו ונדום גם נחנו…","hebrew_niqqud":"לֹא רָגְשׁוּ נִסֵּינוּ וַנִּדּוֹם גַּם נָחְנוּ…","translit":"lōʾ rāḡəšû nissênû wanniddôm gam nāḥənû...","translit_ru":"ло рагэшу нисену ванидом гам нахэну...","russian":"Не дрогнули наши шатры, и смолкли мы тоже…","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"וישבת ממלאכתו הנביא ויקם,","hebrew_niqqud":"וַיִּשְׁבֹּת מִמְּלַאכְתּוֹ הַנָּבִיא וַיָּקָם,","translit":"wayyišbōṯ mimməlaʾḵtô hannāḇîʾ wayyāqom,","translit_ru":"вайишбот мимэлахто ханави вайаком,","russian":"И прекратил свой труд Пророк и встал,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"ועיניו מבריקות, כביום סערת-נקם,","hebrew_niqqud":"וְעֵינָיו מַבְרִיקוֹת, כִּבְיוֹם סַעֲרַת-נָקָם,","translit":"wəʿênāyw maḇrîqôṯ, kiḇyôm saʿăraṯ-nāqām,","translit_ru":"вэенав маврикот, кивйом саарат-накам,","russian":"И глаза его сияли, как в день бури возмездия,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"ויען ויאמר: לשלום לכו!","hebrew_niqqud":"וַיַּעַן וַיֹּאמַר: לְשָׁלוֹם לְכוּ!","translit":"wayyaʿan wayyōʾmar: ləšālôm ləḵû!","translit_ru":"вайаан вайомар: лэшалом лэху!","russian":"И ответил, и сказал: Идите с миром!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"ויגדל וירם ברגע ההוא","hebrew_niqqud":"וַיִּגְדַּל וַיָּרָם בָּרֶגַע הַהוּא","translit":"wayyiḡdal wayyārom bāreḡaʿ hahûʾ","translit_ru":"вайигдал вайаром барэга хаху","russian":"И возвеличился, и вознёсся в тот миг","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"בישימון העטוף תעלומות כמות,","hebrew_niqqud":"בַּיְשִׁימוֹן הֶעָטוּף תַּעֲלוּמוֹת כַּמָּוֶת,","translit":"bayšîmôn heʿāṭûp̄ taʿălûmôṯ kammāweṯ,","translit_ru":"байшимон хэатуф таалумот камавэт,","russian":"В пустыне, окутанной тайнами, подобными смерти,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"בעדת מעריציו שאותו סובבת,","hebrew_niqqud":"בַּעֲדַת מַעֲרִיצָיו שֶׁאוֹתוֹ סוֹבָבֶת,","translit":"baʿăḏaṯ maʿărîṣāyw šeʾôṯô sôḇāḇeṯ,","translit_ru":"баадат маарицав шэото совавэт,","russian":"Среди своих поклонников, что его окружали,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"כמחוקק היורד מחרב בסין,","hebrew_niqqud":"כִּמְחוֹקֵק הַיּוֹרֵד מֵחֹרֵב בְּסִין,","translit":"kimḥôqēq hayyôrēḏ mēḥōrēḇ bəsîn,","translit_ru":"кимхокек хайоред мехорев бэсин,","russian":"Как законодатель, спускающийся с Синая,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"כעזריאיל המלאך הבא ביום הדין,","hebrew_niqqud":"כְּעַזְרַיאִיל הַמַּלְאָךְ הַבָּא בְּיוֹם הַדִּין,","translit":"kəʿazrayʾîl hammalʾāḵ habbāʾ bəyôm haddîn,","translit_ru":"кэазрайил хамалах хаба бэйом хадин,","russian":"Как Азраил, ангел, приходящий в Судный день,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r33","order_index":33,"hebrew_plain":"כשמש מתהו ובהו מתפרץ,","hebrew_niqqud":"כַּשֶּׁמֶשׁ מִתֹּהוּ וָבֹהוּ מִתְפָּרֵץ,","translit":"kaššemeš mittōhû wāḇōhû miṯpārēṣ,","translit_ru":"кашэмэш митоху вавоху митпарец,","russian":"Как солнце, из хаоса и пустоты прорывающееся,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r34","order_index":34,"hebrew_plain":"כאללה ביום בראו שמים וארץ.","hebrew_niqqud":"כְּאַלְלַהּ בְּיוֹם בְּרָאוֹ שָׁמַיִם וָאָרֶץ.","translit":"kəʾallah bəyôm bərāʾô šāmayim wāʾāreṣ.","translit_ru":"кэаллах бэйом бэрао шамайим ваарэц.","russian":"Как Аллах в день, когда сотворил небо и землю.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r35","order_index":35,"hebrew_plain":"1903","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"1903","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
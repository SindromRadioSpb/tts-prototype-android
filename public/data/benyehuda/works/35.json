{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-35","text_key":"13d6bc53015f65a0c59b9ebf7535841cb1de8e2ef8b60705b21cf2260bdffce8","title":"הַשָּׂב וּשְׁלֹשֶת הַנְּעָרִים","level":null,"tags":["poetry","haskalah"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"35","content_hash":"sha256:459bc3503e50bd826f06ea90509b391fdef0f151b330ee0bb8ba073f0f58de47","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/35","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"35","content_hash":"sha256:459bc3503e50bd826f06ea90509b391fdef0f151b330ee0bb8ba073f0f58de47","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/35","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"השב ושלשת הנערים","hebrew_niqqud":"הַשָּׂב וּשְׁלֹשֶת הַנְּעָרִים","translit":"haśśāḇ ûšəlōšeṯ hannəʿārîm","translit_ru":"хасав ушэлошэт ханэарим","russian":"Притча о трёх юношах","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"נפישי גמלי סבי דטעיני משכי דהוגני (סנהדרין נ\"ב.)","hebrew_niqqud":"נְפִישֵׁי גַּמְלֵי סָבֵי דִּטְעִינִי מַשְׁכֵי דְהוּגְנֵי (סַנְהֶדְרִין נ\"ב.)","translit":"nəp̄îšê gamlê sāḇê diṭʿînî mašḵê ḏəhûḡənê (sanheḏrîn nḇ\".)","translit_ru":"нэфише гамле саве дитини машхе дэхугэне (санхэдрин нв\".)","russian":"Многи старые верблюды, навьюченные колючими шкурами (Санхедрин 52б).","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"שלשה נערים על פרדס עברו","hebrew_niqqud":"שְׁלֹשָׁה נְעָרִים עַל פַּרְדֵּס עָבָרוּ","translit":"šəlōšâ nəʿārîm ʿal pardēs ʿāḇārû","translit_ru":"шэлоша нэарим ал пардес авару","russian":"Три юноши проходили мимо сада","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"ויראו איש זקן אשל נוטע:","hebrew_niqqud":"וַיִּרְאוּ אִישׁ זָקֵן אֵשֶׁל נוֹטֵעַ:","translit":"wayyirʾû ʾîš zāqēn ʾēšel nôṭēaʿ:","translit_ru":"вайиру иш закен ешэл нотеа:","russian":"И увидели старого человека, сажающего тамариск:","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"\"בן שבעים לנטוע?\" – אליו אמרו –","hebrew_niqqud":"\"בֶּן שִׁבְעִים לִנְטוֹעַ?\" – אֵלָיו אָמָרוּ –","translit":"\"ben šiḇʿîm linṭôaʿ?\" – ʾēlāyw ʾāmārû –","translit_ru":"\"бэн шивим линтоа?\" – елав амару –","russian":"«Тебе семьдесят лет, и ты сажаешь?» – сказали они ему –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"\"אין זאת כי אם הנך משתגע!","hebrew_niqqud":"\"אֵין זֹאת כִּי אִם הִנְךָ מִשְׁתַּגֵּעַ!","translit":"\"ʾên zōʾṯ kî ʾim hinḵā mištaggēaʿ!","translit_ru":"\"ен зот ки им хинха миштагеа!","russian":"«Это не что иное, как ты сходишь с ума!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"העוד תוחיל לאכל מפרי האשל?","hebrew_niqqud":"הַעוֹד תּוֹחִיל לֶאֱכֹל מִפְּרִי הָאֵשֶׁל?","translit":"haʿôḏ tôḥîl leʾĕḵōl mippərî hāʾēšel?","translit_ru":"хаод тохил лээхол мипэри хаешэл?","russian":"Разве ты ещё надеешься вкусить плодов этого тамариска?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"התאמר האריך ימים כמתושלח?","hebrew_niqqud":"הֲתֹאמַר הַאֲרִיךְ יָמִים כִּמְתוּשֶׁלַח?","translit":"hăṯōʾmar haʾărîḵ yāmîm kimṯûšelaḥ?","translit_ru":"хатомар хаарих йамим кимтушэлах?","russian":"Неужто ты думаешь, что проживёшь так же долго, как Мафусал?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"וכבר הן שבת ותבא בכלח,","hebrew_niqqud":"וּכְבָר הֵן שַׂבְתָּ וַתָּבֹא בַּכֶּלַח,","translit":"ûḵəḇār hēn śaḇtā wattāḇōʾ bakkelaḥ,","translit_ru":"ухэвар хен савта ватаво бакэлах,","russian":"Ведь ты уже пришёл в преклонный возраст,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"עוד מצער ואלוה את נפשך ישל","hebrew_niqqud":"עוֹד מִצְעָר וֵאלוֹהַּ אֶת נַפְשְׁךָ יֵשָׁל","translit":"ʿôḏ miṣʿār wēʾlôah ʾeṯ nap̄šəḵā yēšāl","translit_ru":"од мицар велоах эт нафшэха йешал","russian":"Ещё немного, и Господь заберёт твою душу.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"ומה העבודה הזאת לך עתה?","hebrew_niqqud":"וּמָה הָעֲבוֹדָה הַזֹּאת לָךְ עָתָּה?","translit":"ûmâ hāʿăḇôḏâ hazzōʾṯ lāḵ ʿāttâ?","translit_ru":"ума хаавода хазот лах ата?","russian":"И что тебе теперь за эта работа?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"אתם הישישים קדמוניות התכוננו","hebrew_niqqud":"אַתֶּם הַיְשִׁישִׁים קדְמוֹנִיּוֹת הִתְכּוֹנָנוּ","translit":"ʾattem hayəšîšîm qḏəmôniyyôṯ hiṯkônānû","translit_ru":"атэм хайэшишим кдэмонийот хитконану","russian":"Вы, старики, готовьтесь к вечности,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"ועתידת לחוש לנו הנערים הניחו\".","hebrew_niqqud":"וַעֲתִידֹת לָחוּשׁ לָנוּ הַנְּעָרִים הַנִּיחוּ\".","translit":"waʿăṯîḏōṯ lāḥûš lānû hannəʿārîm hannîḥû\".","translit_ru":"ваатидот лахуш лану ханэарим ханиху\".","russian":"А о будущем нам, юношам, позаботиться предоставьте!»","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"לכם העתידת?","hebrew_niqqud":"לָכֶם הַעֲתִידֹת?","translit":"lāḵem haʿăṯîḏōṯ?","translit_ru":"лахэм хаатидот?","russian":"«Вам будущее?»","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"– ענם רב הדעת –","hebrew_niqqud":"– עָנָם רַב הַדָּעַת –","translit":"– ʿānām raḇ haddāʿaṯ –","translit_ru":"– анам рав хадаат –","russian":"– ответил им мудрый старец –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"הידעתם אל נכון כי ימים תאריכו?","hebrew_niqqud":"הַיְדַעְתֶּם אֶל נָכוֹן כִּי יָמִים תַּאֲרִיכוּ?","translit":"hayəḏaʿtem ʾel nāḵôn kî yāmîm taʾărîḵû?","translit_ru":"хайэдатэм эл нахон ки йамим таариху?","russian":"«Разве вы знаете наверняка, что проживёте долго?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"הן חרב המות לכל מרטה,","hebrew_niqqud":"הֵן חֶרֶב הַמָּוֶת לַכֹּל מֹרָטָה,","translit":"hēn ḥereḇ hammāweṯ lakkōl mōrāṭâ,","translit_ru":"хен хэрэв хамавэт лакол мората,","russian":"Ведь меч смерти обнажён для всех,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"ומי זה יודע מי מכלנו","hebrew_niqqud":"וּמִי זֶה יוֹדֵעַ מִי מִכֻּלָּנוּ","translit":"ûmî zê yôḏēaʿ mî mikkūllānû","translit_ru":"уми зэ йодеа ми микулану","russian":"И кто знает, кто из нас всех","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"יהיה ראשונה אכל לתולעת?","hebrew_niqqud":"יִהְיֶה רִאשׁוֹנָה אֹכֶל לַתּוֹלָעַת?","translit":"yihyê riʾšônâ ʾōḵel lattôlāʿaṯ?","translit_ru":"йихйэ ришона охэл латолаат?","russian":"Первым станет пищей для червей?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"ואני לא לי כיום עץ זה אטעה","hebrew_niqqud":"וַאֲנִי לֹא לִי כַּיּוֹם עֵץ זֶה אֶטָּעָה","translit":"waʾănî lōʾ lî kayyôm ʿēṣ zê ʾeṭṭāʿâ","translit_ru":"ваани ло ли кайом ец зэ этаа","russian":"И я сажаю это дерево сегодня не для себя,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"כי אם לדור אחרון יקום תחתני,","hebrew_niqqud":"כִּי אִם לְדוֹר אַחֲרוֹן יָקוּם תַּחְתֵּנִי,","translit":"kî ʾim ləḏôr ʾaḥărôn yāqûm taḥtēnî,","translit_ru":"ки им лэдор ахарон йакум тахтени,","russian":"Но для грядущего поколения, что придёт после меня.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"הוא יאכל פריו – יאכל ויברכני,","hebrew_niqqud":"הוּא יֹאכַל פִּרְיוֹ – יֹאכַל וִיבָרְכֵנִי,","translit":"hûʾ yōʾḵal piryô – yōʾḵal wîḇārəḵēnî,","translit_ru":"ху йохал пирйо – йохал виварэхени,","russian":"Он будет есть его плоды – будет есть и благословлять меня,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"וברכתו הוא פריי מעמלי אשבעה;","hebrew_niqqud":"וּבִרְכָתוֹ הוּא פִּרְיִי מֵעֲמָלִי אֶשְׂבָּעָה;","translit":"ûḇirḵāṯô hûʾ piryî mēʿămālî ʾeśbāʿâ;","translit_ru":"увирхато ху пирйи меамали эсбаа;","russian":"И его благословение – это мой плод, которым я насыщусь от своего труда;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"אך אולי עוד ימים רבים אחריכם","hebrew_niqqud":"אַךְ אוּלַי עוֹד יָמִים רַבִּים אַחֲרֵיכֶם","translit":"ʾaḵ ʾûlay ʿôḏ yāmîm rabbîm ʾaḥărêḵem","translit_ru":"ах улай од йамим рабим ахарехэм","russian":"Но, возможно, ещё много дней после вас","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"אתהלכה לשוח על קברותיכם!","hebrew_niqqud":"אֶתְהַלְּכָה לָשׂוּחַ עַל קִבְרוֹתֵיכֶם!","translit":"ʾeṯhalləḵâ lāśûaḥ ʿal qiḇrôṯêḵem!","translit_ru":"этхалэха ласуах ал кивротехэм!","russian":"Я буду ходить беседовать на ваших могилах!»","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"וכדברו כן היה.","hebrew_niqqud":"וּכְדַבְּרוֹ כֵּן הָיָה.","translit":"ûḵəḏabbərô kēn hāyâ.","translit_ru":"ухэдабэро кен хайа.","russian":"И как он сказал, так и случилось.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"כי קדמם המות","hebrew_niqqud":"כִּי קִדְּמָם הַמָּוֶת","translit":"kî qiddəmām hammāweṯ","translit_ru":"ки кидэмам хамавэт","russian":"Ибо смерть опередила их,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"ושלשתם מתו בנעוריהם,","hebrew_niqqud":"וּשְׁלָשְׁתָּם מֵתוּ בִּנְעוּרֵיהֶם,","translit":"ûšəlāšətām mēṯû binʿûrêhem,","translit_ru":"ушэлашэтам мету бинурехэм,","russian":"И все трое умерли в юности своей,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"ובן-השבעים חרת על קבריהם","hebrew_niqqud":"וּבֶן-הַשִּׁבְעִים חָרַת עַל קִבְרֵיהֶם","translit":"ûḇen-haššiḇʿîm ḥāraṯ ʿal qiḇrêhem","translit_ru":"увэн-хашивим харат ал киврехэм","russian":"А семидесятилетний старец высек на их могилах","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"דברי זה המשל על המצבת.","hebrew_niqqud":"דִּבְרֵי זֶה הַמָּשָׁל עַל הַמַּצָּבֶת.","translit":"diḇrê zê hammāšāl ʿal hammaṣṣāḇeṯ.","translit_ru":"дивре зэ хамашал ал хамацавэт.","russian":"Слова этой притчи на надгробии.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
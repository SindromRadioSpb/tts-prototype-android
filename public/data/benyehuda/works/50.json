и","russian":"Ты чаруешь меня,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"הרי את מקסמת לי כדת","hebrew_niqqud":"הֲרֵי אַתְּ מְקֻסֶּמֶת לִי כְדַת","translit":"hărê ʾat məqūssemeṯ lî ḵəḏaṯ","translit_ru":"харе ат мэкусэмэт ли хэдат","russian":"Ты чаруешь меня, как должно,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"אותו פרפר נברא לעולמו,","hebrew_niqqud":"אוֹתוֹ פַרְפָּר נִבְרָא לְעוֹלָמוֹ,","translit":"ʾôṯô p̄arpār niḇrāʾ ləʿôlāmô,","translit_ru":"ото фарпар нивра лэоламо,","russian":"Тот мотылек явился в свой мир,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"לחיי יום אחד, לשעת","hebrew_niqqud":"לְחַיֵּי יוֹם אֶחָד, לִשְׁעַת","translit":"ləḥayyê yôm ʾeḥāḏ, lišʿaṯ","translit_ru":"лэхайе йом эхад, лишат","russian":"на жизнь лишь однодневную, на час","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"חתנתו בכנפי צבעונין.","hebrew_niqqud":"חֲתֻנָּתוֹ בְּכַנְפֵי צִבְעוֹנִין.","translit":"ḥăṯūnnāṯô bəḵanp̄ê ṣiḇʿônîn.","translit_ru":"хатунато бэханфе цивонин.","russian":"венчания его, на крыльях цветистых.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"הרי את מקסמת לי בתור","hebrew_niqqud":"הֲרֵי אַתְּ מְקֻסֶּמֶת לִי בְתוֹר","translit":"hărê ʾat məqūssemeṯ lî ḇəṯôr","translit_ru":"харе ат мэкусэмэт ли вэтор","russian":"Ты чаруешь меня, подобно","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"מקהלות יתושים, הרוקדים","hebrew_niqqud":"מַקְהֲלוֹת יַתּוּשִׁים, הָרוֹקְדִים","translit":"maqhălôṯ yattûšîm, hārôqəḏîm","translit_ru":"макхалот йатушим, харокэдим","russian":"роям комаров, танцующим","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"על טהרה של חרשה, באור,","hebrew_niqqud":"עַל טָהֳרָהּ שֶׁל חֹרְשָׁה, בָּאוֹר,","translit":"ʿal ṭohŏrāh šel ḥōrəšâ, bāʾôr,","translit_ru":"ал тохорах шэл хорэша, баор,","russian":"на чистой лесной поляне, в свете,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"שיר-אלם עם חמי-יום יוקדים.","hebrew_niqqud":"שִׁיר-אֵלֶם עִם חֻמֵּי-יוֹם יוֹקְדִים.","translit":"šîr-ʾēlem ʿim ḥūmmê-yôm yôqəḏîm.","translit_ru":"шир-елэм им хуме-йом йокэдим.","russian":"немую песнь в пылу дневного зноя.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"הרי את מקסמת לי כדת","hebrew_niqqud":"הֲרֵי אַתְּ מְקֻסֶּמֶת לִי כְדַת","translit":"hărê ʾat məqūssemeṯ lî ḵəḏaṯ","translit_ru":"харе ат мэкусэмэт ли хэдат","russian":"Ты чаруешь меня, как должно,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"העשבים השוטים והאילן","hebrew_niqqud":"הָעֲשָׂבִים הַשּׁוֹטִים וְהָאִילָן","translit":"hāʿăśāḇîm haššôṭîm wəhāʾîlān","translit_ru":"хаасавим хашотим вэхаилан","russian":"сорных трав и дерева","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"המלבלב, המדברים בשפת","hebrew_niqqud":"הַמְּלַבְלֵב, הַמְּדַבְּרִים בִּשְׂפַת","translit":"hamməlaḇlēḇ, hamməḏabbərîm biśp̄aṯ","translit_ru":"хамэлавлев, хамэдабэрим бисфат","russian":"цветущего, что говорят на языке","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"ניחוחות ובשם וריחות.","hebrew_niqqud":"נִיחוֹחוֹת וּבֶשֶׂם וְרֵיחוֹת.","translit":"nîḥôḥôṯ ûḇeśem wərêḥôṯ.","translit_ru":"нихохот увэсэм вэрехот.","russian":"благоуханий и на наречии запахов.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"הרי את מקסמת לי כיד","hebrew_niqqud":"הֲרֵי אַתְּ מְקֻסֶּמֶת לִי כְּיַד","translit":"hărê ʾat məqūssemeṯ lî kəyaḏ","translit_ru":"харе ат мэкусэмэт ли кэйад","russian":"Ты чаруешь меня, как мощь","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"הכמיהה הגדולה השותקה לעד,","hebrew_niqqud":"הַכְּמִיהָה הַגְּדוֹלָה הַשּׁוֹתְקָה לָעַד,","translit":"hakkəmîhâ haggəḏôlâ haššôṯəqâ lāʿaḏ,","translit_ru":"хакэмиха хагэдола хашотэка лаад,","russian":"великой тоски, что умолкла навеки,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"הפורחה שוב שנה שנה.","hebrew_niqqud":"הַפּוֹרְחָה שׁוּב שָׁנָה שָׁנָה.","translit":"happôrəḥâ šûḇ šānâ šānâ.","translit_ru":"хапорэха шув шана шана.","russian":"но вновь расцветает из года в год.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"הרי את מקסמת לי כדת","hebrew_niqqud":"הֲרֵי אַתְּ מְקֻסֶּמֶת לִי כְדַת","translit":"hărê ʾat məqūssemeṯ lî ḵəḏaṯ","translit_ru":"харе ат мэкусэмэт ли хэдат","russian":"Ты чаруешь меня, как должно,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"עפר-אורזילא, הגועה","hebrew_niqqud":"עֹפֶר-אוּרְזִילָא, הַגּוֹעֶה","translit":"ʿōp̄er-ʾûrəzîlāʾ, haggôʿê","translit_ru":"офэр-урэзила, хагоэ","russian":"Бык Урзилы, ревущий","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"בדמדומי הצפירה, בפאת","hebrew_niqqud":"בְּדִמְדוּמֵי הַצְּפִירָה, בִּפְאַת","translit":"bəḏimḏûmê haṣṣəp̄îrâ, bip̄ʾaṯ","translit_ru":"бэдимдуме хацэфира, бифат","russian":"в сумерках призыва, на краю","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"יערות, כסופיו לרעיה.","hebrew_niqqud":"יְעָרוֹת, כִּסּוּפָיו לְרַעֲיָה.","translit":"yəʿārôṯ, kissûp̄āyw ləraʿăyâ.","translit_ru":"йэарот, кисуфав лэраайа.","russian":"лесов, в тоске по подруге.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"הרי את מקסמת לי באון","hebrew_niqqud":"הֲרֵי אַתְּ מְקֻסֶּמֶת לִי בְאוֹן","translit":"hărê ʾat məqūssemeṯ lî ḇəʾôn","translit_ru":"харе ат мэкусэмэт ли вэон","russian":"Ты чаруешь меня силой","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"כל כחות איתנים בחיה,","hebrew_niqqud":"כָּל כֹּחוֹת אֵיתָנִים בַּחַיָּה,","translit":"kol kōḥôṯ ʾêṯānîm baḥayyâ,","translit_ru":"кол кохот етаним бахайа,","russian":"всех могучих сил, что в живом существе,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"עולמות שחרבו ושוב קמו בשאון","hebrew_niqqud":"עוֹלָמוֹת שֶׁחָרְבוּ וְשׁוּב קָמוּ בִּשְׁאוֹן","translit":"ʿôlāmôṯ šeḥorḇû wəšûḇ qāmû bišʾôn","translit_ru":"оламот шэхорву вэшув каму бишон","russian":"миров, что пали и вновь восстали с шумом","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"כל אלפי שבטי הויה.","hebrew_niqqud":"כָּל אַלְפֵי שִׁבְטֵי הֲוָיָה.","translit":"kol ʾalp̄ê šiḇṭê hăwāyâ.","translit_ru":"кол алфе шивте хавайа.","russian":"всех тысяч племен Бытия.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"הרי את מקסמת לי בסוד","hebrew_niqqud":"הֲרֵי אַתְּ מְקֻסֶּמֶת לִי בְסוֹד","translit":"hărê ʾat məqūssemeṯ lî ḇəsôḏ","translit_ru":"харе ат мэкусэмэт ли вэсод","russian":"Ты чаруешь меня тайной","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"כל שירת האדם וזמרתו,","hebrew_niqqud":"כָּל שִׁירַת הָאָדָם וְזִמְרָתוֹ,","translit":"kol šîraṯ hāʾāḏām wəzimrāṯô,","translit_ru":"кол шират хаадам вэзимрато,","russian":"всего песнопения человека и его напева,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"במאמרי אשפיו, בהוד וביקוד","hebrew_niqqud":"בְּמַאַמְרֵי אַשָּׁפָיו, בַּהוֹד וּבַיְקוֹד","translit":"bəmaʾamrê ʾaššāp̄āyw, bahôḏ ûḇayqôḏ","translit_ru":"бэмаамре ашафав, баход увайкод","russian":"в речах его волхвов, в величии и пылу,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"הלנים במסתרי דתו,","hebrew_niqqud":"הַלָּנִים בְּמִסְתְּרֵי דָתוֹ,","translit":"hallānîm bəmistərê ḏāṯô,","translit_ru":"халаним бэмистэре дато,","russian":"обитающих в тайнах его веры,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"בנחש ולחש כל שבטי עם עם,","hebrew_niqqud":"בְּנַחַשׁ וְלַחַשׁ כָּל שִׁבְטֵי עָם עָם,","translit":"bənaḥaš wəlaḥaš kol šiḇṭê ʿām ʿām,","translit_ru":"бэнахаш вэлахаш кол шивте ам ам,","russian":"в заклинаньях и шепоте всех племен народных,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"ביסודות רקודם ומחולם.","hebrew_niqqud":"בִּיסוֹדוֹת רִקּוּדָם וּמְחוֹלָם.","translit":"bîsôḏôṯ riqqûḏām ûməḥôlām.","translit_ru":"бисодот рикудам умэхолам.","russian":"в основах их пляски и в их мечтаньях.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"הרי את מכשפת – השאר והדם –","hebrew_niqqud":"הֲרֵי אַתְּ מְכֻשֶּׁפֶת – הַשְּׁאֵר וְהַדָּם –","translit":"hărê ʾat məḵūššep̄eṯ – haššəʾēr wəhaddām –","translit_ru":"харе ат мэхушэфэт – хашэер вэхадам –","russian":"Ты же колдуешь — плоть и кровь —","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"מקסמת עד עולם… עד עולם…","hebrew_niqqud":"מְקֻסֶּמֶת עַד עוֹלָם… עַד עוֹלָם…","translit":"məqūssemeṯ ʿaḏ ʿôlām... ʿaḏ ʿôlām...","translit_ru":"мэкусэмэт ад олам... ад олам...","russian":"чаруешь вовеки… вовеки…","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"פיכטנגרונד, 1929","hebrew_niqqud":"פִּיכְּטַנְגְּרוֹנְד, 1929","translit":"pîkkəṭangərônḏ, 1929","translit_ru":"пикэтангэронд, 1929","russian":"Фиxтенгрунд, 1929","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
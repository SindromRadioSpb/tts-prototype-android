{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-23","text_key":"28a8aefdec61f88f7dfb6df9ff714df4bafa614c0096be580ba1ea547586ae60","title":"הִרְהוּרֵי לָיְלָה","level":null,"tags":["poetry","tehiya"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"23","content_hash":"sha256:7fb5aeddf4278f15d838638c6f5936892a64b61ae1db4b56bbdf2a064d6a5760","author":"חיים נחמן ביאליק","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q359705","translator":null,"translator_uri":null,"orig_language":"he","era":"tehiya","genre":"poetry","themes":[],"register":"poetic","track":"literary","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/23","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: תל אביב: דביר, תשל\"ג","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"23","content_hash":"sha256:7fb5aeddf4278f15d838638c6f5936892a64b61ae1db4b56bbdf2a064d6a5760","author":"חיים נחמן ביאליק","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q359705","translator":null,"translator_uri":null,"orig_language":"he","era":"tehiya","genre":"poetry","themes":[],"register":"poetic","track":"literary","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/23","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: תל אביב: דביר, תשל\"ג","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"הרהורי לילה","hebrew_niqqud":"הִרְהוּרֵי לָיְלָה","translit":"hirhûrê lāyəlâ","translit_ru":"хирхуре лайэла","russian":"Ночные думы.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"ידעתי כי בכיי –בכי כוס בין חרבות,","hebrew_niqqud":"יָדַעְתִּי כִּי בִכְיִי –בְּכִי כוֹס בֵּין חֳרָבוֹת,","translit":"yāḏaʿtî kî ḇiḵyî –bəḵî ḵôs bên ḥŏrāḇôṯ,","translit_ru":"йадати ки вихйи –бэхи хос бен хоравот,","russian":"Я знал: мой плач – плач чаши меж мечей,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"לא יגה אנשים, לא ישבר הלבבות;","hebrew_niqqud":"לֹא יַגֶּה אֲנָשִׁים, לֹא יִשְׁבֹּר הַלְּבָבוֹת;","translit":"lōʾ yaggê ʾănāšîm, lōʾ yišbōr halləḇāḇôṯ;","translit_ru":"ло йагэ анашим, ло йишбор халэвавот;","russian":"Не утешит людей, не сломит сердец;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"כי בכיי עםמטרות דמעותי השפוכים","hebrew_niqqud":"כּי בִכְיִי עִם־מִטְרוֹת דִּמְעוֹתַי הַשְּׁפוּכִים","translit":"ky ḇiḵyî ʿim-miṭrôṯ dimʿôṯay haššəp̄ûḵîm","translit_ru":"кй вихйи им-митрот димотай хашэфухим","russian":"Ибо мой плач, с потоками пролитых слёз,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"הם ענן בציה עם -מים מלוחים;","hebrew_niqqud":"הֵם עָנָן בַּצִּיָּה עִם -מַיִם מְלוּחִים;","translit":"hēm ʿānān baṣṣiyyâ ʿim -mayim məlûḥîm;","translit_ru":"хем анан бацийа им -майим мэлухим;","russian":"Он – туча в пустыне с солёной водой;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"כי דמעות שנושנו מבכי אלפי שנים –","hebrew_niqqud":"כִּי דְמָעוֹת שֶׁנּוֹשְׁנוּ מִבְּכִי אַלְפֵי שָׁנִים –","translit":"kî ḏəmāʿôṯ šennôšənû mibbəḵî ʾalp̄ê šānîm –","translit_ru":"ки дэмаот шэношэну мибэхи алфе шаним –","russian":"Ибо слёзы, что ветхи от плача тысячелетий,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"סר כחן ממוגג אתלבות אבנים –","hebrew_niqqud":"סָר כֹּחָן מִמּוֹגֵג אֶת־לִבּוֹת אֲבָנִים –","translit":"sār kōḥān mimmôḡēḡ ʾeṯ-libbôṯ ʾăḇānîm –","translit_ru":"сар кохан мимогег эт-либот аваним –","russian":"Их мощь ослабла, чтоб каменных плавить сердец –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"ולמה, לב אמלל, תבקש להבל","hebrew_niqqud":"וְלָמָּה, לֵב אֻמְלָל, תְּבַקֵּשׁ לַהֶבֶל","translit":"wəlāmmâ, lēḇ ʾūmlāl, təḇaqqēš laheḇel","translit_ru":"вэлама, лев умлал, тэвакеш лахэвэл","russian":"И зачем ты, жалкое сердце, ищешь напрасно,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"מרגע בבכי, נחומים באבל?","hebrew_niqqud":"מַרְגֹּעַ בַּבֶּכִי, נִחוּמִים בָּאֵבֶל?","translit":"margōaʿ babbeḵî, niḥûmîm bāʾēḇel?","translit_ru":"маргоа бабэхи, нихумим баевэл?","russian":"Мгновения покоя в плаче, утешенья в скорби?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"מבעד לאשנבי אתראשי אוציאה,","hebrew_niqqud":"מִבַּעַד לְאֶשְׁנַבִּי אֶת־רֹאשִׁי אוֹצִיאָה,","translit":"mibbaʿaḏ ləʾešnabbî ʾeṯ-rōʾšî ʾôṣîʾâ,","translit_ru":"мибаад лээшнаби эт-роши оциа,","russian":"Из окна я голову высуну,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"אףאקרא לסערה ואשאל אתפיה;","hebrew_niqqud":"אַף־אֶקְרָא לַסְּעָרָה וְאֶשְׁאַל אֶת־פִּיהָ;","translit":"ʾap̄-ʾeqrāʾ lassəʿārâ wəʾešʾal ʾeṯ-pîhā;","translit_ru":"аф-экра ласэара вээшал эт-пиха;","russian":"И призову бурю, и спрошу её уста;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"אביטה בעבים, אבינה בחשכה –","hebrew_niqqud":"אַבִּיטָה בֶעָבִים, אָבִינָה בַחֲשֵׁכָה –","translit":"ʾabbîṭâ ḇeʿāḇîm, ʾāḇînâ ḇaḥăšēḵâ –","translit_ru":"абита вэавим, авина вахашеха –","russian":"Взгляну на тучи, вгляжусь во мрак –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"היהי קץ לחשך?","hebrew_niqqud":"הַיְהִי קֵץ לַחֹשֶךְ?","translit":"hayəhî qēṣ laḥōšeḵ?","translit_ru":"хайэхи кец лахошэх?","russian":"Будет ли конец мраку?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"אםסוף למהפכה?","hebrew_niqqud":"אִם־סוֹף לַמַּהְפֵּכָה?","translit":"ʾim-sôp̄ lammahpēḵâ?","translit_ru":"им-соф ламахпеха?","russian":"Или конец смуте?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"הישך הסער ויפזרו העבים","hebrew_niqqud":"הֲיָשֹׁךְ הַסַּעַר וִיְפֻזְּרוּ הֶעָבִים","translit":"hăyāšōḵ hassaʿar wiyp̄ūzzərû heʿāḇîm","translit_ru":"хайашох хасаар вийфузэру хэавим","russian":"Утихнет ли буря, и рассеются ли облака,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"ונגה הסהר ונגהו כוכבים?","hebrew_niqqud":"וְנָגַהּ הַסַּהַר וְנָגְהוּ כוֹכָבִים?","translit":"wənāḡah hassahar wənāḡəhû ḵôḵāḇîm?","translit_ru":"вэнагах хасахар вэнагэху хохавим?","russian":"И озарит лись месяц, и звёзды воссияют?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"אביטה אלארץ אףאפן למעלה –","hebrew_niqqud":"אַבִּיטָה אֶל־אֶרץ אַף־אֵפֶן לְמָעְלָה –","translit":"ʾabbîṭâ ʾel-ʾerṣ ʾap̄-ʾēp̄en ləmāʿəlâ –","translit_ru":"абита эл-эрц аф-ефэн лэмаэла –","russian":"Взгляну на землю, и вновь обращусь вверх –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"אין חזון, אין קשב –רק סופה ולילה.","hebrew_niqqud":"אֵין חָזוֹן, אֵין קֶשֶׁב –רַק סוּפָה וָלָיְלָה.","translit":"ʾên ḥāzôn, ʾên qešeḇ –raq sûp̄â wālāyəlâ.","translit_ru":"ен хазон, ен кэшэв –рак суфа валайэла.","russian":"Нет видений, нет ответа – лишь буря и ночь.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"בבטן הקנני אל מסכן, חלכה,","hebrew_niqqud":"בַּבֶּטֶן הִקְנַנִי אֵל מִסְכֵּן, חֵלֵכָה,","translit":"babbeṭen hiqnanî ʾēl miskēn, ḥēlēḵâ,","translit_ru":"бабэтэн хикнани ел мискен, хелеха,","russian":"В утробе меня несчастным сотворил Бог, слабым,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"ויתןלי מקל ויאמר לי: לכה!","hebrew_niqqud":"וַיִּתֶּן־לִי מַקֵּל וַיֹּאמֶר לִי: לֵכָה!","translit":"wayyitten-lî maqqēl wayyōʾmer lî: lēḵâ!","translit_ru":"вайитэн-ли макел вайомэр ли: леха!","russian":"И дал мне посох, и сказал мне: «Иди!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"צא בקש משפטך שאבד בחיים,","hebrew_niqqud":"צֵא בַקֵּשׁ מִשְׁפָּטְךָ שֶׁאָבַד בַּחַיִּים,","translit":"ṣēʾ ḇaqqēš mišpāṭəḵā šeʾāḇaḏ baḥayyîm,","translit_ru":"це вакеш мишпатэха шэавад бахайим,","russian":"Иди, ищи свою правду, что утрачена в жизни,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"קנה אויר לנשימה, גנב אור לעינים;","hebrew_niqqud":"קְנֵה אַוִּיר לִנְשִׁימָה, גְּנֹב אוֹר לָעֵינָיִם;","translit":"qənê ʾawwîr linšîmâ, gənōḇ ʾôr lāʿênāyim;","translit_ru":"кэне авир линшима, гэнов ор лаенайим;","russian":"Купи воздуха для дыханья, укради света для глаз;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"לך סב עלהפתחים בילקוט עלשכם,","hebrew_niqqud":"לֵךְ סֹב עַל־הַפְּתָחִים בְּיַלְקוּט עַל־שָׁכֶם,","translit":"lēḵ sōḇ ʿal-happəṯāḥîm bəyalqûṭ ʿal-šāḵem,","translit_ru":"лех сов ал-хапэтахим бэйалкут ал-шахэм,","russian":"Иди, обходи пороги с котомкой за плечом,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"בא פתחי נדיבים ושחה עלפת לחם –","hebrew_niqqud":"בֹּא פִתְחֵי נְדִיבִים וּשְׁחֵה עַל־פַּת לָחֶם –","translit":"bōʾ p̄iṯḥê nəḏîḇîm ûšəḥê ʿal-paṯ lāḥem –","translit_ru":"бо фитхе нэдивим ушэхе ал-пат лахэм –","russian":"Приди к дверям щедрых, моля о куске хлеба –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"וכבר כשל כחי בנדודים וטרח –","hebrew_niqqud":"וּכְבָר כָּשַׁל כֹּחִי בִּנְדוּדִים וָטֹרַח –","translit":"ûḵəḇār kāšal kōḥî binḏûḏîm wāṭōraḥ –","translit_ru":"ухэвар кашал кохи биндудим ваторах –","russian":"И уже иссякли силы мои от скитаний и тягот –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"אהה אלי, אלי!","hebrew_niqqud":"אֲהָהּ אֵלִי, אֵלִי!","translit":"ʾăhāh ʾēlî, ʾēlî!","translit_ru":"ахах ели, ели!","russian":"Увы, Боже мой, Боже!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"היתם הארח?","hebrew_niqqud":"הֲיִתַּם הָאֹרַח?","translit":"hăyittam hāʾōraḥ?","translit_ru":"хайитам хаорах?","russian":"Ужели путь закончится?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"מרחם אלאשפה כסוחה הוטלתי,","hebrew_niqqud":"מֵרֶחֶם אֶל־אַשְׁפָּה כַּסּוּחָה הוּטָלְתִּי,","translit":"mēreḥem ʾel-ʾašpâ kassûḥâ hûṭālətî,","translit_ru":"мерэхэм эл-ашпа касуха хуталэти,","russian":"Из чрева на скудную свалку я был брошен,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"לא רחץ מחלאה בסחבות חתלתי;","hebrew_niqqud":"לֹא רֻחָץ מֵחֶלְאָה בִּסְחָבוֹת חֻתָּלְתִּי;","translit":"lōʾ rūḥāṣ mēḥelʾâ bisḥāḇôṯ ḥūttālətî;","translit_ru":"ло рухац мехэла бисхавот хуталэти;","russian":"Не омытый от грязи, в лохмотья я был завёрнут;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"שד צמק לי חלצה אם עטיה, אבלה,","hebrew_niqqud":"שַׁד צֹמֵק לִי חָלְצָה אֵם עֹטְיָה, אֲבֵלָה,","translit":"šaḏ ṣōmēq lî ḥāləṣâ ʾēm ʿōṭəyâ, ʾăḇēlâ,","translit_ru":"шад цомек ли халэца ем отэйа, авела,","russian":"Иссохшая грудь скорбящей, увядшей матери меня вскормила,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"ממנו מציתי אתכוס התרעלה.","hebrew_niqqud":"מִמֶנּוּ מָצִיתִי אֶת־כּוֹס הַתַּרְעֵלָה.","translit":"mimennû māṣîṯî ʾeṯ-kôs hattarʿēlâ.","translit_ru":"мимэну мацити эт-кос хатарела.","russian":"От неё испил я чашу яда.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"מאז שם אתקנו בלבבי צפעוני","hebrew_niqqud":"מֵאָז שָׂם אֶת־קִנּוֹ בִּלְבָבִי צִפְעוֹנִי","translit":"mēʾāz śām ʾeṯ-qinnô bilḇāḇî ṣip̄ʿônî","translit_ru":"меаз сам эт-кино билвави цифони","russian":"С тех пор гадюка свила гнездо в моём сердце,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"המטיל בי ארסו ומצץ אתאוני…","hebrew_niqqud":"הַמֵּטִיל בִּי אַרְסוֹ וּמֹצֵץ אֶת־אוֹנִי…","translit":"hammēṭîl bî ʾarsô ûmōṣēṣ ʾeṯ-ʾônî...","translit_ru":"хаметил би арсо умоцец эт-они...","russian":"Что вливает в меня свой яд и высасывает мою силу…","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r33","order_index":33,"hebrew_plain":"הוי, אנה מחמתו אברחה, אנוסה?","hebrew_niqqud":"הוֹי, אָנָה מֵחֲמָתוֹ אֶבְרָחָה, אָנוּסָה?","translit":"hôy, ʾānâ mēḥămāṯô ʾeḇrāḥâ, ʾānûsâ?","translit_ru":"хой, ана мехамато эвраха, ануса?","russian":"Увы, куда мне убежать от её ярости, скрыться?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r34","order_index":34,"hebrew_plain":"גםחיה לאאחיה, גםמות לא אמותה!","hebrew_niqqud":"גַּם־חָיֹה לֹא־אֶחְיֶה, גַּם־מוֹת לֹא אָמוּתָה!","translit":"gam-ḥāyōh lōʾ-ʾeḥyê, gam-môṯ lōʾ ʾāmûṯâ!","translit_ru":"гам-хайох ло-эхйэ, гам-мот ло амута!","russian":"Ни живым я не буду, ни мёртвым я не умру!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r35","order_index":35,"hebrew_plain":"שפרירי שמים הפרושים כסדינים,","hebrew_niqqud":"שַׁפְרִירֵי שָׁמַיִם הַפְּרוּשִׁים כִּסְדִינִים,","translit":"šap̄rîrê šāmayim happərûšîm kisḏînîm,","translit_ru":"шафрире шамайим хапэрушим кисдиним,","russian":"Небес сиянье, распростёртое, как полотно,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r36","order_index":36,"hebrew_plain":"ונקדים בנקדות כוכבים כפנינים;","hebrew_niqqud":"וּנְקֻדִּים בִּנְקֻדּוֹת כּוֹכָבִים כִּפְנִינִים;","translit":"ûnəqūddîm binqūddôṯ kôḵāḇîm kip̄nînîm;","translit_ru":"унэкудим бинкудот кохавим кифниним;","russian":"И усеянное звёздами, словно жемчугом;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r37","order_index":37,"hebrew_plain":"רך רוחות שאננות המרחפות בדממה","hebrew_niqqud":"רֹךְ רוּחוֹת שַׁאֲנַנּוֹת הַמְרַחֲפוֹת בִּדְמָמָה","translit":"rōḵ rûḥôṯ šaʾănannôṯ haməraḥăp̄ôṯ biḏmāmâ","translit_ru":"рох рухот шаананот хамэрахафот бидмама","russian":"И тихие, безмятежные ветры, что реют в безмолвии,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r38","order_index":38,"hebrew_plain":"עםכרובי השלום עלפני האדמה,","hebrew_niqqud":"עִם־כְּרוּבֵי הַשָּׁלוֹם עַל־פְּנֵי הָאֲדָמָה,","translit":"ʿim-kərûḇê haššālôm ʿal-pənê hāʾăḏāmâ,","translit_ru":"им-кэруве хашалом ал-пэне хаадама,","russian":"С херувимами мира над ликом земли,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r39","order_index":39,"hebrew_plain":"המספרות בלחש, בנשיקה, ברמזים","hebrew_niqqud":"הַמְסַפְּרוֹת בְּלַחַשׁ, בִּנְשִׁיקָה, בִּרְמָזִים","translit":"haməsappərôṯ bəlaḥaš, binšîqâ, birmāzîm","translit_ru":"хамэсапэрот бэлахаш, биншика, бирмазим","russian":"Что шепчут, целуют, намекают,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r40","order_index":40,"hebrew_plain":"לשיח השדה סוד יה, רזי רזים;","hebrew_niqqud":"לְשִׂיחַ הַשָּׂדֶה סוֹד יָהּ, רָזֵי רָזִים;","translit":"ləśîaḥ haśśāḏê sôḏ yāh, rāzê rāzîm;","translit_ru":"лэсиах хасадэ сод йах, разе разим;","russian":"Полевой траве тайны Бога, сокровеннейшие из тайн;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r41","order_index":41,"hebrew_plain":"שנת שלוה ושקט, שנת מרפא וגהה –","hebrew_niqqud":"שְׁנַת שַׁלְוָה וָשֶׁקֶט, שְׁנַת מַרְפֵּא וְגֵהָה –","translit":"šənaṯ šalwâ wāšeqeṭ, šənaṯ marpēʾ wəḡēhâ –","translit_ru":"шэнат шалва вашэкэт, шэнат марпе вэгеха –","russian":"Год покоя и тишины, год исцеления и здравия –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r42","order_index":42,"hebrew_plain":"לא לי הם, לא לי הם, בןאשפה, תולעה!","hebrew_niqqud":"לֹא לִי הֵם, לֹא לִי הֵם, בֶּן־אַשְׁפָּה, תּוֹלֵעָה!","translit":"lōʾ lî hēm, lōʾ lî hēm, ben-ʾašpâ, tôlēʿâ!","translit_ru":"ло ли хем, ло ли хем, бэн-ашпа, толеа!","russian":"Не для меня они, не для меня, сын свалки, червь!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r43","order_index":43,"hebrew_plain":"בלילה בלילה עת אשא כנורי,","hebrew_niqqud":"בַּלַּיְלָה בַּלַּיְלָה עֵת אֶשָּׂא כִּנּוֹרִי,","translit":"ballaylâ ballaylâ ʿēṯ ʾeśśāʾ kinnôrî,","translit_ru":"балайла балайла ет эса кинори,","russian":"Ночь за ночью, когда я поднимаю свою лиру,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r44","order_index":44,"hebrew_plain":"עת ערים רקשנים: אנכי ומזורי;","hebrew_niqqud":"עֵת עֵרִים רַק־שְׁנַיִם: אָנֹכִי וּמְזוֹרִי;","translit":"ʿēṯ ʿērîm raq-šənayim: ʾānōḵî ûməzôrî;","translit_ru":"ет ерим рак-шэнайим: анохи умэзори;","russian":"Когда бодрствуют лишь двое: я и моё горе;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r45","order_index":45,"hebrew_plain":"עת יצר העור לעצמותי הנמקות,","hebrew_niqqud":"עֵת יֵצַר הָעוֹר לְעַצְמוֹתַי הַנְּמַקּוֹת,","translit":"ʿēṯ yēṣar hāʿôr ləʿaṣmôṯay hannəmaqqôṯ,","translit_ru":"ет йецар хаор лэацмотай ханэмакот,","russian":"Когда кожа истончится на моих гниющих костях,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r46","order_index":46,"hebrew_plain":"ועיני הכלות תלאינה לבכות –","hebrew_niqqud":"וְעֵינַי הַכָּלוֹת תִּלְאֶינָה לְבַכּוֹת –","translit":"wəʿênay hakkālôṯ tilʾênâ ləḇakkôṯ –","translit_ru":"вэенай хакалот тилена лэвакот –","russian":"И утомлённые очи устанут рыдать –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r47","order_index":47,"hebrew_plain":"אז תעל כאור טבולת טל בתשירתי,","hebrew_niqqud":"אָז תַּעַל כָּאוֹר טְבוּלַת טַל בַּת־שִׁירָתִי,","translit":"ʾāz taʿal kāʾôr ṭəḇûlaṯ ṭal baṯ-šîrāṯî,","translit_ru":"аз таал каор тэвулат тал бат-ширати,","russian":"Тогда восходит, как свет, омытый росою, в моём напеве,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r48","order_index":48,"hebrew_plain":"במשי אברותיה תז טל עללבתי,","hebrew_niqqud":"בִּמְשִׁי אֶבְרוֹתֶיהָ תַּז טַל עַל־לִבָּתִי,","translit":"bimšî ʾeḇrôṯêhā taz ṭal ʿal-libbāṯî,","translit_ru":"бимши эвротеха таз тал ал-либати,","russian":"Шёлком крыльев своих она окропит росой моё сердце,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r49","order_index":49,"hebrew_plain":"ומחתה הדמעה שקפאה בעיני –","hebrew_niqqud":"וּמָחֲתָה הַדִּמְעָה שֶׁקָּפְאָה בְּעֵינִי –","translit":"ûmāḥăṯâ haddimʿâ šeqqāp̄əʾâ bəʿênî –","translit_ru":"умахата хадима шэкафэа бэени –","russian":"И сотрёт слезу, что застыла в моих глазах –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r50","order_index":50,"hebrew_plain":"אלטל, בתשירתי!","hebrew_niqqud":"אַל־טַל, בַּת־שִׁירָתִי!","translit":"ʾal-ṭal, baṯ-šîrāṯî!","translit_ru":"ал-тал, бат-ширати!","russian":"Альтал, о песня моя!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r51","order_index":51,"hebrew_plain":"נאד דמעות לי תני!","hebrew_niqqud":"נֹאד דְּמָעוֹת לִי תֵנִי!","translit":"nōʾḏ dəmāʿôṯ lî ṯēnî!","translit_ru":"нод дэмаот ли тени!","russian":"Мех слёз мне дай!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r52","order_index":52,"hebrew_plain":"נאד דמעות, בתשירי, נאד דמעות חדשות,","hebrew_niqqud":"נֹאד דְּמָעוֹת, בַּת־שִׁירִי, נֹאד דְּמָעוֹת חֲדָשׁוֹת,","translit":"nōʾḏ dəmāʿôṯ, baṯ-šîrî, nōʾḏ dəmāʿôṯ ḥăḏāšôṯ,","translit_ru":"нод дэмаот, бат-шири, нод дэмаот хадашот,","russian":"Мех слёз, о песня, мех слёз новых,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r53","order_index":53,"hebrew_plain":"מרגיזות לבבות, מרעישות נפשות.","hebrew_niqqud":"מַרְגִּיזוֹת לְבָבוֹת, מַרְעִישׁוֹת נְפָשׁוֹת.","translit":"margîzôṯ ləḇāḇôṯ, marʿîšôṯ nəp̄āšôṯ.","translit_ru":"маргизот лэвавот, маришот нэфашот.","russian":"Волнующих сердца, тревожащих души.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r54","order_index":54,"hebrew_plain":"התעופפי, נודי בין עיי חרבות,","hebrew_niqqud":"הִתְעוֹפְפִי, נוּדִי בֵּין עִיֵּי חֳרָבוֹת,","translit":"hiṯʿôp̄əp̄î, nûḏî bên ʿiyyê ḥŏrāḇôṯ,","translit_ru":"хитофэфи, нуди бен ийе хоравот,","russian":"Взлети, блуждай средь груд развалин,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r55","order_index":55,"hebrew_plain":"אל כתל מערבי, אל קברות האבות,","hebrew_niqqud":"אֶל כֹּתֶל מַעֲרָבִי, אֶל קִבְרוֹת הָאָבוֹת,","translit":"ʾel kōṯel maʿărāḇî, ʾel qiḇrôṯ hāʾāḇôṯ,","translit_ru":"эл котэл маарави, эл киврот хаавот,","russian":"К Стене Плача, к праотцев могилам,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r56","order_index":56,"hebrew_plain":"עליד דרך גולים התיצבי, עמדי,","hebrew_niqqud":"עַל־יַד דֶּרֶך גּוֹלִים הִתְיַצְּבִי, עֲמֹדִי,","translit":"ʿal-yaḏ dereḵ gôlîm hiṯyaṣṣəḇî, ʿămōḏî,","translit_ru":"ал-йад дэрэх голим хитйацэви, амоди,","russian":"На пути изгнанников стой, недвижна,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r57","order_index":57,"hebrew_plain":"איש איש לפי אידו יתנדב אלנאדי;","hebrew_niqqud":"אִישׁ אִישׁ לְפִי אֵידוֹ יִתְנַדֵּב אֶל־נֹאדִי;","translit":"ʾîš ʾîš ləp̄î ʾêḏô yiṯnaddēḇ ʾel-nōʾḏî;","translit_ru":"иш иш лэфи едо йитнадев эл-ноди;","russian":"И каждый, по судьбе своей, пусть к меху сам придет;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r58","order_index":58,"hebrew_plain":"ובעודן בחמן קחי, צקי אלכנורי","hebrew_niqqud":"וּבְעוֹדָן בְּחֻמָּן קְחִי, צְקִי אֶל־כִּנּוֹרִי","translit":"ûḇəʿôḏān bəḥūmmān qəḥî, ṣəqî ʾel-kinnôrî","translit_ru":"увэодан бэхуман кэхи, цэки эл-кинори","russian":"И пока они теплы, бери, лей в лиру","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r59","order_index":59,"hebrew_plain":"הדמעות עדתמן –ונח לי ממזורי!","hebrew_niqqud":"הַדְּמָעוֹת עַד־תֻּמָּן –וְנָח לִי מִמְּזוֹרִי!","translit":"haddəmāʿôṯ ʿaḏ-tūmmān –wənāḥ lî mimməzôrî!","translit_ru":"хадэмаот ад-туман –вэнах ли мимэзори!","russian":"Слёзы эти, до полноты – и мне от мук моих будет покой!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r60","order_index":60,"hebrew_plain":"ז' אדר, תרנ\"ב","hebrew_niqqud":"ז' אֲדָר, תרנ\"ב","translit":"z' ʾăḏār, ṯrnḇ\"","translit_ru":"з' адар, трнв\"","russian":"7 Адара, 5652 (1892)","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-21","text_key":"097c445baf0a510e7e49c1e4b7db34f33a8f462df2f3d51ac12e833f6be48645","title":"מִשּׁוּט בַּמֶּרְחַקִּים","level":null,"tags":["poetry","tehiya"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"21","content_hash":"sha256:313220e65c7f112cca18d4512d70208d5b8d209c979ef154c013e42300be48d9","author":"חיים נחמן ביאליק","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q359705","translator":null,"translator_uri":null,"orig_language":"he","era":"tehiya","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/21","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: תל אביב: דביר, תשל\"ג","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"21","content_hash":"sha256:313220e65c7f112cca18d4512d70208d5b8d209c979ef154c013e42300be48d9","author":"חיים נחמן ביאליק","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q359705","translator":null,"translator_uri":null,"orig_language":"he","era":"tehiya","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/21","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: תל אביב: דביר, תשל\"ג","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"משוט במרחקים","hebrew_niqqud":"מִשּׁוּט בַּמֶּרְחַקִּים","translit":"miššûṭ bammerḥaqqîm","translit_ru":"мишут бамэрхаким","russian":"Странствуя в далёких далях,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"משוט במרחקים, ממקומות נדדתי,","hebrew_niqqud":"מִשּׁוּט בַּמֶּרְחַקִּים, מִמְּקוֹמוֹת נָדַדְתִּי,","translit":"miššûṭ bammerḥaqqîm, mimməqômôṯ nāḏaḏtî,","translit_ru":"мишут бамэрхаким, мимэкомот нададти,","russian":"Странствуя в далёких далях, кочевал я с места на место,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"כצפור מים אלבית אמי חרדתי.","hebrew_niqqud":"כְּצִפּוֹר מִיָּם אֶל־בֵּית אִמִּי חָרַדְתִּי.","translit":"kəṣippôr miyyām ʾel-bêṯ ʾimmî ḥāraḏtî.","translit_ru":"кэципор мийам эл-бет ими харадти.","russian":"Как водоплавная птица, тосковал я по материнскому дому.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"ושנית לפני המקומות החביבים,","hebrew_niqqud":"וְשֵׁנִית לְפָנַי הַמְּקוֹמוֹת הַחֲבִיבִים,","translit":"wəšēnîṯ ləp̄ānay hamməqômôṯ haḥăḇîḇîm,","translit_ru":"вэшенит лэфанай хамэкомот хахавивим,","russian":"И вновь предстали предо мной места любимые,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"הקרובים אללבי ולבבי מעציבים;","hebrew_niqqud":"הַקְּרוֹבִים אֶל־לִבִּי וּלְבָבִי מַעֲצִיבִים;","translit":"haqqərôḇîm ʾel-libbî ûləḇāḇî maʿăṣîḇîm;","translit_ru":"хакэровим эл-либи улэвави маацивим;","russian":"Близкие сердцу моему и печалящие его;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"ושנית התמונות הנעימות לקראתי,","hebrew_niqqud":"וְשֵׁנִית הַתְּמוּנוֹת הַנְּעִימוֹת לִקְרָאתִי,","translit":"wəšēnîṯ hattəmûnôṯ hannəʿîmôṯ liqrāʾṯî,","translit_ru":"вэшенит хатэмунот ханэимот ликрати,","russian":"И вновь приятные образы явились мне навстречу,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"שכה כלתה עיני רותן דמעתי,","hebrew_niqqud":"שֶׁכֹּה כָלְתָה עֵינִי רַוֹּתָן דִּמְעָתִי,","translit":"šekkōh ḵāləṯâ ʿênî rawwōṯān dimʿāṯî,","translit_ru":"шэкох халэта ени равотан димати,","russian":"По которым так томились очи мои, проливая слёзы,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"שכה צמאה נפשי לבכות עלצוארן,","hebrew_niqqud":"שֶׁכֹּה צָמְאָה נַפְשִׁי לִבְכּוֹת עַל־צַוָּארָן,","translit":"šekkōh ṣāməʾâ nap̄šî liḇkôṯ ʿal-ṣawwāʾrān,","translit_ru":"шэкох цамэа нафши ливкот ал-цаваран,","russian":"По которым так жаждала душа моя рыдать на груди их,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"לחבקן ולנשקן ולחונן עפרן.","hebrew_niqqud":"לְחַבְּקָן וּלְנַשְּׁקָן וּלְחוֹנֵן עֲפָרָן.","translit":"ləḥabbəqān ûlənaššəqān ûləḥônēn ʿăp̄ārān.","translit_ru":"лэхабэкан улэнашэкан улэхонен афаран.","russian":"Обнять их, и целовать, и благоговеть перед их прахом.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"מכל תנחומותיו אל הותיר לי שתים:","hebrew_niqqud":"מִכֹּל תַּנְחוּמוֹתָיו אֵל הוֹתִיר לִי שְׁתָּיִם:","translit":"mikkōl tanḥûmôṯāyw ʾēl hôṯîr lî šətāyim:","translit_ru":"микол танхумотав ел хотир ли шэтайим:","russian":"Из всех утешений Своих Бог оставил мне два:","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"זכרונות מדאיבים עם דמעות עינים.","hebrew_niqqud":"זִכְרוֹנוֹת מַדְאִיבִים עִם דִּמְעוֹת עֵינָיִם.","translit":"ziḵrônôṯ maḏʾîḇîm ʿim dimʿôṯ ʿênāyim.","translit_ru":"зихронот мадивим им димот енайим.","russian":"Печальные воспоминания со слезами очей.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"וגם ימי עניי ונדודי גלותי","hebrew_niqqud":"וְגַם יְמֵי עָנְיִי וּנְדוּדֵי גָלוּתִי","translit":"wəḡam yəmê ʿonyî ûnəḏûḏê ḡālûṯî","translit_ru":"вэгам йэме онйи унэдуде галути","russian":"И дни моей скорби, и скитания моего изгнания","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"לא מחו מלבי זכרונות ילדותי,","hebrew_niqqud":"לֹא מָחוּ מִלִּבִּי זִכְרוֹנוֹת יַלְדוּתִי,","translit":"lōʾ māḥû millibbî ziḵrônôṯ yalḏûṯî,","translit_ru":"ло маху милиби зихронот йалдути,","russian":"Не стёрли из сердца моего воспоминаний детства,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"החתומים בנפשי ונשואים עמדי,","hebrew_niqqud":"הַחֲתוּמִים בְּנַפְשִׁי וּנְשׂוּאִים עִמָּדִי,","translit":"haḥăṯûmîm bənap̄šî ûnəśûʾîm ʿimmāḏî,","translit_ru":"хахатумим бэнафши унэсуим имади,","russian":"Запечатлённых в душе моей и носимых мною,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"כחותם עללבי, כחותם עלידי;","hebrew_niqqud":"כַּחוֹתָם עַל־לִבִּי, כַּחוֹתָם עַל־יָדִי;","translit":"kaḥôṯām ʿal-libbî, kaḥôṯām ʿal-yāḏî;","translit_ru":"кахотам ал-либи, кахотам ал-йади;","russian":"Как печать на сердце моём, как печать на руке моей;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"וגם דמעות עיני בנכר הורדתי -","hebrew_niqqud":"וְגַם דִּמְעוֹת עֵינַי בַּנֵּכָר הוֹרַדְתִּי -","translit":"wəḡam dimʿôṯ ʿênay bannēḵār hôraḏtî -","translit_ru":"вэгам димот енай банехар хорадти -","russian":"И слёзы очей моих в чужбине я проливал –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"אלנאדך נפלו, ערישת מולדתי!","hebrew_niqqud":"אֶל־נֹאדֵךְ נָפָלוּ, עֲרִישַׂת מוֹלַדְתִּי!","translit":"ʾel-nōʾḏēḵ nāp̄ālû, ʿărîśaṯ môlaḏtî!","translit_ru":"эл-нодех нафалу, арисат моладти!","russian":"На тебя они пали, колыбель родины моей!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"ובארץ מרחקים - גםשם לא מצאתי","hebrew_niqqud":"וּבְאֶרֶץ מֶרְחַקִּים - גַּם־שָׁם לֹא מָצָאתִי","translit":"ûḇəʾereṣ merḥaqqîm - gam-šām lōʾ māṣāʾṯî","translit_ru":"увээрэц мэрхаким - гам-шам ло мацати","russian":"И в далёких землях – и там не нашёл я","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"יד חסד שתמח מפני דמעתי.","hebrew_niqqud":"יַד חֶסֶד שֶׁתִּמַח מִפָּנַי דִּמְעָתִי.","translit":"yaḏ ḥeseḏ šettimaḥ mippānay dimʿāṯî.","translit_ru":"йад хэсэд шэтимах мипанай димати.","russian":"Руки милосердной, что смахнула бы слезу с моего лица.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"ומלאה כיום הוצאתיה, הבאתי","hebrew_niqqud":"וּמְלֵאָה כְּיוֹם הוֹצֵאתִיהָ, הֵבֵאתִי","translit":"ûməlēʾâ kəyôm hôṣēʾṯîhā, hēḇēʾṯî","translit_ru":"умэлеа кэйом хоцетиха, хевети","russian":"И полной, как сегодня, вынес я её, принёс","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"אתכוס התרעלה עמדי אלביתי.","hebrew_niqqud":"אֶת־כּוֹס הַתַּרְעֵלָה עִמָּדִי אֶל־בֵּיתִי.","translit":"ʾeṯ-kôs hattarʿēlâ ʿimmāḏî ʾel-bêṯî.","translit_ru":"эт-кос хатарела имади эл-бети.","russian":"Чашу отравы с собой в мой дом.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"וכיום עזבתיה, מלאה ורויה,","hebrew_niqqud":"וּכיוֹם עֲזַבְתִּיה, מְלֵאָה וּרְוָיָה,","translit":"ûḵyôm ʿăzaḇtîh, məlēʾâ ûrəwāyâ,","translit_ru":"ухйом азавтих, мэлеа урэвайа,","russian":"И как сегодня, оставил я её, полную и преисполненную,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"מצאתי גםכוסך - הכל כשהיה!","hebrew_niqqud":"מָצָאתִי גַם־כּוֹסֵךְ - הַכֹּל כְּשֶׁהָיָה!","translit":"māṣāʾṯî ḡam-kôsēḵ - hakkōl kəšehāyâ!","translit_ru":"мацати гам-косех - хакол кэшэхайа!","russian":"Нашёл я и твою чашу – всё как было!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"זה עניך, זה לחצך, זאת קדרות פניך -","hebrew_niqqud":"זֶה עָנְיֵךְ, זֶה לַחֲצֵךְ, זֹאת קַדְרוּת פָּנָיִךְ -","translit":"zê ʿonyēḵ, zê laḥăṣēḵ, zōʾṯ qaḏrûṯ pānāyiḵ -","translit_ru":"зэ онйех, зэ лахацех, зот кадрут панайих -","russian":"Вот твоё страдание, вот твоя угнетённость, вот мрачность лика твоего –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"מהכבד הענן הרבץ עליך!","hebrew_niqqud":"מַה־כָּבֵד הֶעָנָן הָרֹבֵץ עָלָיִךְ!","translit":"mah-kkāḇēḏ heʿānān hārōḇēṣ ʿālāyiḵ!","translit_ru":"мах-кавед хэанан харовец алайих!","russian":"Как тяжко облако, что нависло над тобой!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"אףנטף מר אחד לא נגרע מכוסך -","hebrew_niqqud":"אַף־נֵטֶף מַר אֶחָד לֹא נִגְרַע מִכּוֹסֵךְ -","translit":"ʾap̄-nēṭep̄ mar ʾeḥāḏ lōʾ niḡraʿ mikkôsēḵ -","translit_ru":"аф-нетэф мар эхад ло нигра микосех -","russian":"Даже одной горькой капли не убыло из чаши твоей –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"אל אסף אתשלומך, אל שכח חנותך.","hebrew_niqqud":"אֵל אָסַף אֶת־שְׁלוֹמֵךְ, אֵל שָׁכַח חַנּוֹתֵךְ.","translit":"ʾēl ʾāsap̄ ʾeṯ-šəlômēḵ, ʾēl šāḵaḥ ḥannôṯēḵ.","translit_ru":"ел асаф эт-шэломех, ел шахах ханотех.","russian":"Бог отнял твой мир, Бог забыл милость твою.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"מי ידע הדמעות שעוד תשפכנה,","hebrew_niqqud":"מִי יֵדַע הַדְּמָעוֹת שֶׁעוֹד תִּשָּׁפַכְנָה,","translit":"mî yēḏaʿ haddəmāʿôṯ šeʿôḏ tiššāp̄aḵnâ,","translit_ru":"ми йеда хадэмаот шэод тишафахна,","russian":"Кто знает, сколько ещё слёз прольётся,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"הסופות שעוד עלראשנו תגחנה -","hebrew_niqqud":"הַסּוּפוֹת שֶׁעוֹד עַל־רֹאשֵׁנוּ תָּגַחְנָה -","translit":"hassûp̄ôṯ šeʿôḏ ʿal-rōʾšēnû tāḡaḥnâ -","translit_ru":"хасуфот шэод ал-рошену тагахна -","russian":"Бури, которые ещё обрушатся на наши головы –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"עדפרץ רוח טובה, חזקה, נאדרה,","hebrew_niqqud":"עַד־פְּרֹץ רוּחַ טוֹבָה, חֲזָקָה, נֶאְדָּרָה,","translit":"ʿaḏ-pərōṣ rûaḥ ṭôḇâ, ḥăzāqâ, neʾdārâ,","translit_ru":"ад-пэроц руах това, хазака, нэдара,","russian":"Пока не прорвётся дух добрый, сильный, величественный,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"שתוכל לתקע העב המדברה;","hebrew_niqqud":"שֶׁתּוּכַל לִתְקֹעַ הָעָב הַמִּדְבָּרָה;","translit":"šettûḵal liṯqōaʿ hāʿāḇ hammiḏbārâ;","translit_ru":"шэтухал литкоа хаав хамидбара;","russian":"Который сможет отогнать тучу в пустыню;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"שתמח הענן הסוכך שמינו","hebrew_niqqud":"שֶׁתִּמַח הֶעָנָן הַסוֹכֵךְ שָׁמֵינוּ","translit":"šettimaḥ heʿānān hasôḵēḵ šāmênû","translit_ru":"шэтимах хэанан хасохех шамену","russian":"Который сотрёт облако, заслоняющее наше небо,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"מעלות צעקתנו, מעבר תפלתנו…","hebrew_niqqud":"מֵעֲלוֹת צַעֲקָתֵנוּ, מֵעֲבֹר תְּפִלָּתֵנוּ…","translit":"mēʿălôṯ ṣaʿăqāṯēnû, mēʿăḇōr təp̄illāṯēnû...","translit_ru":"меалот цаакатену, меавор тэфилатену...","russian":"Дабы поднялся наш вопль, дабы прошла наша молитва…","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r33","order_index":33,"hebrew_plain":"תרנ\"א","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"1891 год.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
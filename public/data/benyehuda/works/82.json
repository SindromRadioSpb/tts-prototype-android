{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-82","text_key":"2f803385735e9ef0ebdef008ffb4d0bfc2133125622b7d181100cde2971a3151","title":"נֹאד הֶחָלָב","level":null,"tags":["poetry","haskalah"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"82","content_hash":"sha256:ee78632816caf5df2aac45cf5f966f8b3256cedcfe61c6b4a51915a58ca6d058","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"literary","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/82","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"82","content_hash":"sha256:ee78632816caf5df2aac45cf5f966f8b3256cedcfe61c6b4a51915a58ca6d058","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"literary","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/82","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"נאד החלב","hebrew_niqqud":"נֹאד הֶחָלָב","translit":"nōʾḏ heḥālāḇ","translit_ru":"нод хэхалав","russian":"Бурдюк с молоком","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"נאד החלב על שכמה, על ראשה מטפחת","hebrew_niqqud":"נֹאד הֶחָלָב עַל שִׁכְמָהּ, עַל רֹאשָׁהּ מִטְפַּחַת","translit":"nōʾḏ heḥālāḇ ʿal šiḵmāh, ʿal rōʾšāh miṭpaḥaṯ","translit_ru":"нод хэхалав ал шихмах, ал рошах митпахат","russian":"Бурдюк с молоком на плече, на голове платок,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"נעלי אגמון על רגליה","hebrew_niqqud":"נַעֲלֵי אַגְמוֹן עַל רַגְלֶיהָ","translit":"naʿălê ʾaḡmôn ʿal raḡlêhā","translit_ru":"наале агмон ал раглеха","russian":"Тростниковые сандалии на ногах,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"וכתנת בד לבן עליה","hebrew_niqqud":"וּכְתֹנֶת בַּד לָבָן עָלֶיהָ","translit":"ûḵəṯōneṯ baḏ lāḇān ʿālêhā","translit_ru":"ухэтонэт бад лаван алеха","russian":"И белая льняная рубаха на ней.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"הלך הלכה בת-חוה אחת","hebrew_niqqud":"הָלֹךְ הָלְכָה בַּת-חַוָּה אַחַת","translit":"hālōḵ hāləḵâ baṯ-ḥawwâ ʾaḥaṯ","translit_ru":"халох халэха бат-хава ахат","russian":"Шла-шла одна женщина,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"בצעדים קלים ובנפש שומחת","hebrew_niqqud":"בִּצְעָדִים קַלִּים וּבְנֶפֶשׁ שׂוֹמַחַת","translit":"biṣʿāḏîm qallîm ûḇənep̄eš śômaḥaṯ","translit_ru":"бицадим калим увэнэфэш сомахат","russian":"Лёгкими шагами и с ликующей душой,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"לבוא העירה אל יום המכר.","hebrew_niqqud":"לָבוֹא הָעִירָה אֶל יוֹם הַמֶּכֶר.","translit":"lāḇôʾ hāʿîrâ ʾel yôm hammeḵer.","translit_ru":"лаво хаира эл йом хамэхэр.","russian":"Чтобы прийти в город на день торга.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"וכבר בלבבה","hebrew_niqqud":"וּכְבָר בִּלְבָבָהּ","translit":"ûḵəḇār bilḇāḇāh","translit_ru":"ухэвар билвавах","russian":"И уже в своём сердце","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"חשב חשבה","hebrew_niqqud":"חָשֹׁב חָשָׁבָה","translit":"ḥāšōḇ ḥāšāḇâ","translit_ru":"хашов хашава","russian":"Думала-думала","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"את כל השכר","hebrew_niqqud":"אֵת כָּל הַשֶּׂכֶר","translit":"ʾēṯ kol haśśeḵer","translit_ru":"ет кол хасэхэр","russian":"Обо всей прибыли,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"אשר תעשה מחלבה.","hebrew_niqqud":"אֲשֶׁר תַּעֲשֶׂה מֵחֲלָבָהּ.","translit":"ʾăšer taʿăśê mēḥălāḇāh.","translit_ru":"ашэр таасэ мехалавах.","russian":"Что она получит от молока.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"במחיר חלבי – אל נפשה אמרה –","hebrew_niqqud":"בִּמְחִיר חֲלָבִי – אֶל נַפְשָׁהּ אָמָרָה –","translit":"bimḥîr ḥălāḇî – ʾel nap̄šāh ʾāmārâ –","translit_ru":"бимхир халави – эл нафшах амара –","russian":"«На цену молока моего, — сказала она себе, —","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"אקנה בשוק ביצים עשרות שתים,","hebrew_niqqud":"אֶקְנֶה בַּשּׁוּק בֵּיצִים עֲשָׂרוֹת שְׁתַּיִם,","translit":"ʾeqnê baššûq bêṣîm ʿăśārôṯ šətayim,","translit_ru":"экнэ башук бецим асарот шэтайим,","russian":"Куплю на рынке яиц два десятка,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"עלימו ארביץ תרנגלת דגרה","hebrew_niqqud":"עָלֵימוֹ אַרְבִּיץ תַּרְנְגֹלֶת דָּגָרָה","translit":"ʿālêmô ʾarbîṣ tarnəḡōleṯ dāḡārâ","translit_ru":"алемо арбиц тарнэголэт дагара","russian":"На них посажу курицу-наседку,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"ותמלט ותבקע אפרחים כפלים;","hebrew_niqqud":"וּתְמַלֵּט וּתְבַקֵּעַ אֶפְרֹחִים כִּפְלַיִם;","translit":"ûṯəmallēṭ ûṯəḇaqqēaʿ ʾep̄rōḥîm kip̄layim;","translit_ru":"утэмалет утэвакеа эфрохим кифлайим;","russian":"И вылупит множество цыплят;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"אז מספר ימים אגדל אותמו","hebrew_niqqud":"אָז מִסְפַּר יָמִים אֲגַדֵּל אוֹתָמוֹ","translit":"ʾāz mispar yāmîm ʾăḡaddēl ʾôṯāmô","translit_ru":"аз миспар йамим агадел отамо","russian":"Потом несколько дней я их выращу,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"ובמיטב כסף אמכר כלמו,","hebrew_niqqud":"וּבְמֵיטַב כֶּסֶף אֶמְכֹּר כֻּלָּמוֹ,","translit":"ûḇəmêṭaḇ kesep̄ ʾemkōr kūllāmô,","translit_ru":"увэметав кэсэф эмкор куламо,","russian":"И за лучшую цену всех их продам,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"אקנה לי בן בקר רך ואכלכלהו","hebrew_niqqud":"אֶקְנֶה לִי בֶּן בָּקָר רַךְ וַאֲכַלְכְּלֵהוּ","translit":"ʾeqnê lî ben bāqār raḵ waʾăḵalkəlēhû","translit_ru":"экнэ ли бэн бакар рах ваахалкэлеху","russian":"Куплю себе нежного телёнка и буду кормить его,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"ובידי אשקהו גם אלעיטהו,","hebrew_niqqud":"וּבְיָדִי אַשְׁקֵהוּ גַּם אַלְעִיטֵהוּ,","translit":"ûḇəyāḏî ʾašqēhû gam ʾalʿîṭēhû,","translit_ru":"увэйади ашкеху гам алитеху,","russian":"И своими руками буду поить и откармливать его,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"עדי ישמן יתכס חלב ופדר","hebrew_niqqud":"עֲדֵי יִשְׁמַן יִתְכַּס חֵלֶב וָפֶדֶר","translit":"ʿăḏê yišman yiṯkas ḥēleḇ wāp̄eḏer","translit_ru":"аде йишман йиткас хелэв вафэдэр","russian":"Пока не разжиреет, не покроется жиром и салом,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"ולשר טבחים במחיר טוב אתנהו,","hebrew_niqqud":"וּלְשַׂר טַבָּחִים בִּמְחִיר טוֹב אֶתְּנֵהוּ,","translit":"ûləśar ṭabbāḥîm bimḥîr ṭôḇ ʾettənēhû,","translit_ru":"улэсар табахим бимхир тов этэнеху,","russian":"И старшему мяснику за хорошую цену я его отдам,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"ובכספו אקנה לי פרה ועגל,","hebrew_niqqud":"וּבְכַסְפּוֹ אֶקְנֶה לִי פָּרָה וָעֵגֶל,","translit":"ûḇəḵaspô ʾeqnê lî pārâ wāʿēḡel,","translit_ru":"увэхаспо экнэ ли пара ваегэл,","russian":"И на его деньги куплю себе корову с телёнком,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"שם ירעו יחד עם יתר העדר.","hebrew_niqqud":"שָׁם יִרְעוּ יַחַד עִם יֶתֶר הָעֵדֶר.","translit":"šām yirʿû yaḥaḏ ʿim yeṯer hāʿēḏer.","translit_ru":"шам йиру йахад им йэтэр хаедэр.","russian":"Там они будут пастись вместе с остальным стадом.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"האח האח!","hebrew_niqqud":"הֶאָח הֶאָח!","translit":"heʾāḥ heʾāḥ!","translit_ru":"хэах хэах!","russian":"Ах, ах!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"מה-מאד לבי יגל","hebrew_niqqud":"מַה-מְאֹד לִבִּי יָגֶל","translit":"mah-məʾōḏ libbî yāḡel","translit_ru":"мах-мэод либи йагэл","russian":"Как сильно возрадуется моё сердце,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"עת אראה עגלתי ככה מקפצת…","hebrew_niqqud":"עֵת אֶרְאֶה עֶגְלָתִי כָּכָה מְקַפֶּצֶת…","translit":"ʿēṯ ʾerʾê ʿeḡlāṯî kāḵâ məqappeṣeṯ...","translit_ru":"ет эрэ эглати каха мэкапэцэт...","russian":"Когда увижу, как мой телёнок так скачет…»","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"לדברים האלה גם היא רקדה,","hebrew_niqqud":"לַדְּבָרִים הָאֵלֶּה גַּם הִיא רָקָדָה,","translit":"laddəḇārîm hāʾēllê gam hîʾ rāqāḏâ,","translit_ru":"ладэварим хаелэ гам хи ракада,","russian":"При этих словах и она заплясала,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"וברקדה – אהה תפלצת מנאצת!","hebrew_niqqud":"וּבְרָקְדָהּ – אֲהָהּ תִּפְלֶצֶת מְנָאֶצֶת!","translit":"ûḇərāqəḏāh – ʾăhāh tip̄leṣeṯ mənāʾeṣeṯ!","translit_ru":"увэракэдах – ахах тифлэцэт мэнаэцэт!","russian":"И в танце своём — о, мерзкий ужас!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"נפל הנאד, החלב נשפך כמים,","hebrew_niqqud":"נָפַל הַנֹּאד, הֶחָלָב נִשְׁפַּך כַּמַּיִם,","translit":"nāp̄al hannōʾḏ, heḥālāḇ nišpaḵ kammayim,","translit_ru":"нафал ханод, хэхалав нишпах камайим,","russian":"Упал бурдюк, молоко пролилось как вода,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"אין מפריס פרסה, אין בעלי קרנים,","hebrew_niqqud":"אֵין מַפְרִיס פַּרְסָה, אֵין בַּעֲלֵי קַרְנַיִם,","translit":"ʾên map̄rîs parsâ, ʾên baʿălê qarnayim,","translit_ru":"ен мафрис парса, ен баале карнайим,","russian":"Нет ни копытных, ни рогатых,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"אין גם ביצים, אין אפרחים כפלים,","hebrew_niqqud":"אֵין גַּם בֵּיצִים, אֵין אֶפְרֹחִים כִּפְלַיִם,","translit":"ʾên gam bêṣîm, ʾên ʾep̄rōḥîm kip̄layim,","translit_ru":"ен гам бецим, ен эфрохим кифлайим,","russian":"Нет и яиц, нет множества цыплят,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"פס חזון לבה, תוחלתה אבדה.","hebrew_niqqud":"פַּס חֲזוֹן לִבָּהּ, תּוֹחַלְתָּהּ אָבָדָה.","translit":"pas ḥăzôn libbāh, tôḥaltāh ʾāḇāḏâ.","translit_ru":"пас хазон либах, тохалтах авада.","russian":"Исчезло видение её сердца, надежда её погибла.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"מי לא יבנה לו מגדלים בשמים?","hebrew_niqqud":"מִי לֹא יִבְנֶה לוֹ מִגְדָּלִים בַּשָּׁמָיִם?","translit":"mî lōʾ yiḇnê lô miḡdālîm baššāmāyim?","translit_ru":"ми ло йивнэ ло мигдалим башамайим?","russian":"Кто не строит себе замков на небесах?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r33","order_index":33,"hebrew_plain":"מי לא יחלם בהקץ, יראה חזיונות?","hebrew_niqqud":"מִי לֹא יַחֲלֹם בְּהָקֵץ, יִרְאֶה חֶזְיוֹנוֹת?","translit":"mî lōʾ yaḥălōm bəhāqēṣ, yirʾê ḥezyônôṯ?","translit_ru":"ми ло йахалом бэхакец, йирэ хэзйонот?","russian":"Кто не мечтает наяву, не видит видений?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r34","order_index":34,"hebrew_plain":"כאיש כאשה, כזקן כנער,","hebrew_niqqud":"כָּאִישׁ כָּאִשָּׁה, כַּזָּקֵן כַּנָּעַר,","translit":"kāʾîš kāʾiššâ, kazzāqēn kannāʿar,","translit_ru":"каиш каиша, казакен канаар,","russian":"Что мужчина, что женщина, что старик, что юноша,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r35","order_index":35,"hebrew_plain":"כעשיר כדל, כחכם כבער,","hebrew_niqqud":"כֶּעָשִׁיר כַּדָּל, כֶּחָכָם כַּבָּעַר,","translit":"keʿāšîr kaddāl, keḥāḵām kabbāʿar,","translit_ru":"кэашир кадал, кэхахам кабаар,","russian":"Что богатый, что бедный, что мудрый, что невежда,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r36","order_index":36,"hebrew_plain":"יחשבו מחשבות, יעשו עשתנות.","hebrew_niqqud":"יַחְשֹׁבוּ מַחְשָׁבוֹת, יַעֲשׂוּ עֶשְׁתֹּנוֹת.","translit":"yaḥšōḇû maḥšāḇôṯ, yaʿăśû ʿeštōnôṯ.","translit_ru":"йахшову махшавот, йаасу эштонот.","russian":"Думают думы, строят планы.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r37","order_index":37,"hebrew_plain":"כי אשב בדד מוזר לשאון קרת","hebrew_niqqud":"כִּי אֵשֵׁב בָּדָד מוּזָר לִשְׁאוֹן קָרֶת","translit":"kî ʾēšēḇ bāḏāḏ mûzār lišʾôn qāreṯ","translit_ru":"ки ешев бадад музар лишон карэт","russian":"Когда я сижу в одиночестве, далёкий от шума города,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r38","order_index":38,"hebrew_plain":"וירחף רוחי על ים הדמיונות,","hebrew_niqqud":"וִירַחֵף רוּחִי עַל יַם הַדִּמְיוֹנוֹת,","translit":"wîraḥēp̄ rûḥî ʿal yam haddimyônôṯ,","translit_ru":"вирахеф рухи ал йам хадимйонот,","russian":"И дух мой витает над морем фантазий,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r39","order_index":39,"hebrew_plain":"אז לי הכסף, לי הזהב,","hebrew_niqqud":"אָז לִי הַכֶּסֶף, לִי הַזָּהָב,","translit":"ʾāz lî hakkesep̄, lî hazzāhāḇ,","translit_ru":"аз ли хакэсэф, ли хазахав,","russian":"Тогда мне принадлежит серебро, мне принадлежит золото,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r40","order_index":40,"hebrew_plain":"לי הגדולה הגבורה התפארת,","hebrew_niqqud":"לִי הַגְּדוּלָה הַגְּבוּרָה הַתִּפְאָרֶת,","translit":"lî haggəḏûlâ haggəḇûrâ hattip̄ʾāreṯ,","translit_ru":"ли хагэдула хагэвура хатифарэт,","russian":"Мне — величие, могущество, слава,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r41","order_index":41,"hebrew_plain":"אז ארעץ אויב אמחץ רהב,","hebrew_niqqud":"אָז אֶרְעַץ אוֹיֵב אֶמְחַץ רָהַב,","translit":"ʾāz ʾerʿaṣ ʾôyēḇ ʾemḥaṣ rāhaḇ,","translit_ru":"аз эрац ойев эмхац рахав,","russian":"Тогда я сокрушу врага, я повергну гордыню,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r42","order_index":42,"hebrew_plain":"ובחלומי אראה כצפנת פענח","hebrew_niqqud":"וּבַחֲלוֹמִי אֶרְאֶה כְּצָפְנַת פַּעְנֵחַ","translit":"ûḇaḥălômî ʾerʾê kəṣāp̄ənaṯ paʿnēaḥ","translit_ru":"увахаломи эрэ кэцафэнат панеах","russian":"И во сне моём я увижу себя, как Цафнат-Панеах,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r43","order_index":43,"hebrew_plain":"משתחוים לי השמש עם הירח,","hebrew_niqqud":"מִשְׁתַּחֲוִים לִי הַשֶּׁמֶשׁ עִם הַיָּרֵחַ,","translit":"mištaḥăwîm lî haššemeš ʿim hayyārēaḥ,","translit_ru":"миштахавим ли хашэмэш им хайареах,","russian":"Где Солнце с Луной склоняются предо мной,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r44","order_index":44,"hebrew_plain":"ומקרה קטן יגע בי ויעירני","hebrew_niqqud":"וּמִקְרֶה קָטֹן יִגַּע בִּי וִיעִירֵנִי","translit":"ûmiqrê qāṭōn yiggaʿ bî wîʿîrēnî","translit_ru":"умикрэ катон йига би виирени","russian":"И малое происшествие тронет меня и пробудит,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r45","order_index":45,"hebrew_plain":"וכמקדם קדמתי אביון הנני.","hebrew_niqqud":"וּכְמִקֶּדֶם קַדְמָתִי אֶבְיוֹן הִנֵּנִי.","translit":"ûḵəmiqqeḏem qaḏmāṯî ʾeḇyôn hinnēnî.","translit_ru":"ухэмикэдэм кадмати эвйон хинени.","russian":"И, как прежде, я вновь нищ.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
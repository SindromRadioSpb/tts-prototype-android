ta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"בין צללי דליות גפן אדרת","hebrew_niqqud":"בֵּין צִלְלֵי דָלִיּוֹת גֶּפֶן אַדֶּרֶת","translit":"bên ṣillê ḏāliyyôṯ gep̄en ʾaddereṯ","translit_ru":"бен цилле далийот гэфэн адэрэт","russian":"Под сенью пышных виноградных лоз,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"התחבא הצבי מחץ הציד אויבהו","hebrew_niqqud":"הִתְחַבֵּא הַצְּבִי מֵחֵץ הַצַּיָּד אוֹיְבֵהוּ","translit":"hiṯḥabbēʾ haṣṣəḇî mēḥēṣ haṣṣayyāḏ ʾôyəḇēhû","translit_ru":"хитхабе хацэви мехец хацайад ойэвеху","russian":"Олень укрылся от охотничьей стрелы, врага своего,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"ומאחזת הכלבים עקביו שומרת.","hebrew_niqqud":"וּמֵאֲחֻזַּת הַכְּלָבִים עֲקֵבָיו שׁוֹמֶרֶת.","translit":"ûmēʾăḥūzzaṯ hakkəlāḇîm ʿăqēḇāyw šômereṯ.","translit_ru":"умеахузат хакэлавим акевав шомэрэт.","russian":"И от преследования псов, что по пятам за ним следили.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"ויהי כי נמלט וישקט לבהו","hebrew_niqqud":"וַיְהִי כִּי נִמְלַט וַיִּשְׁקֹט לִבֵהוּ","translit":"wayəhî kî nimlaṭ wayyišqōṭ liḇēhû","translit_ru":"вайэхи ки нимлат вайишкот ливеху","russian":"И когда он спасся, и сердце его успокоилось,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"תחת תת תודה וברכה עתרת","hebrew_niqqud":"תַּחַת תֵּת תּוֹדָה וּבְרָכָה עֲתֶרֶת","translit":"taḥaṯ tēṯ tôḏâ ûḇərāḵâ ʿăṯereṯ","translit_ru":"тахат тет тода увэраха атэрэт","russian":"Вместо того, чтобы вознести щедрую благодарность и благословение","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"לגפן החביאתו צל ידיה,","hebrew_niqqud":"לַגֶּפֶן הֶחְבִּיאַתּוּ צֵל יָדֶיהָ,","translit":"laggep̄en heḥbîʾattû ṣēl yāḏêhā,","translit_ru":"лагэфэн хэхбиату цел йадеха,","russian":"Виноградной лозе, что укрыла его тенью своих ветвей,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"היתה אתו רוח אחרת","hebrew_niqqud":"הָיְתָה אִתּוֹ רוּחַ אַחֶרֶת","translit":"hāyəṯâ ʾittô rûaḥ ʾaḥereṯ","translit_ru":"хайэта ито руах ахэрэт","russian":"Иной дух овладел им,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"וילחך פריה ויגרס בדיה.","hebrew_niqqud":"וַיְלַחֵךְ פִּרְיָהּ וַיִּגְרֹס בַּדֶּיהָ.","translit":"wayəlaḥēḵ piryāh wayyiḡrōs baddêhā.","translit_ru":"вайэлахех пирйах вайигрос бадеха.","russian":"И стал он объедать её плоды и ломать её ветви.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"אך אל קול הטחנה הרודפים שבו","hebrew_niqqud":"אַךְ אֶל קוֹל הַטַּחֲנָה הָרוֹדְפִים שָׁבוּ","translit":"ʾaḵ ʾel qôl haṭṭaḥănâ hārôḏəp̄îm šāḇû","translit_ru":"ах эл кол хатахана хародэфим шаву","russian":"Но на шум мельницы преследователи вернулись,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"וכדבשן הדברים אותו סבבו","hebrew_niqqud":"וּכְדִבְשָׁן הַדְּבֹרִים אוֹתוֹ סָבָבוּ","translit":"ûḵəḏiḇšān haddəḇōrîm ʾôṯô sāḇāḇû","translit_ru":"ухэдившан хадэворим ото сававу","russian":"И словно рой, его обступили напасти,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"ובשרו חצו שם במקום הרשע.","hebrew_niqqud":"וּבְשָׂרוֹ חָצוּ שָׁם בִּמְקוֹם הָרֶשַׁע.","translit":"ûḇəśārô ḥāṣû šām bimqôm hārešaʿ.","translit_ru":"увэсаро хацу шам бимком харэша.","russian":"И там, в месте том проклятом, плоть его разделили.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"ובעת מותו, בראותו כי אין ישע,","hebrew_niqqud":"וּבְעֵת מוּתוֹ, בִּרְאוֹתוֹ כִּי אֵין יֶשַׁע,","translit":"ûḇəʿēṯ mûṯô, birʾôṯô kî ʾên yešaʿ,","translit_ru":"увэет муто, бирото ки ен йэша,","russian":"И в час его смерти, видя, что нет спасения,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"קרא: \"צדיק הוא האל!","hebrew_niqqud":"קָרָא: \"צַדִּיק הוּא הָאֵל!","translit":"qārāʾ: \"ṣaddîq hûʾ hāʾēl!","translit_ru":"кара: \"цадик ху хаел!","russian":"Он воскликнул: \"Праведен Бог!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"בעוני נפלתי,","hebrew_niqqud":"בַּעֲוֹנִי נָפַלְתִּי,","translit":"baʿăwōnî nāp̄altî,","translit_ru":"баавони нафалти,","russian":"За беззаконие своё я пал,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"יען את שלמי טוב רעה גמלתי;","hebrew_niqqud":"יַעַן אֶת שֹׁלְמִי טוֹב רָעָה גָּמַלְתִּי;","translit":"yaʿan ʾeṯ šōləmî ṭôḇ rāʿâ gāmaltî;","translit_ru":"йаан эт шолэми тов раа гамалти;","russian":"Ибо за добро я злом воздал;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"כל שכחי גמולות אם רעה תבואתכם","hebrew_niqqud":"כָּל שְׁכֵחֵי גְמוּלוֹת אִם רָעָה תְּבוֹאַתְכֶם","translit":"kol šəḵēḥê ḡəmûlôṯ ʾim rāʿâ təḇôʾaṯḵem","translit_ru":"кол шэхехе гэмулот им раа тэвоатхэм","russian":"Все, кто забывает благодеяния, если зло постигнет ваш удел,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"אל נא תרגנו – אנכי מופתכם!\"","hebrew_niqqud":"אַל נָא תֵּרָגְנוּ – אָנֹכִי מוֹפֶתְכֶם!\"","translit":"ʾal nāʾ tērāḡənû – ʾānōḵî môp̄eṯḵem!\"","translit_ru":"ал на терагэну – анохи мофэтхэм!\"","russian":"Не ропщите – ибо я ваш пример!\"","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
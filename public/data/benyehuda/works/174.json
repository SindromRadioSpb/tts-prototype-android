ssian":"Пред изваянием Аполлона","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"באתי עדיך, אל נשכח מעולם,","hebrew_niqqud":"בָּאתִי עָדֶיךָ, אֵל נִשְׁכָּח מֵעוֹלָם,","translit":"bāʾṯî ʿāḏêḵā, ʾēl niškāḥ mēʿôlām,","translit_ru":"бати адеха, ел нишках меолам,","russian":"Я пришел к тебе, Боже, не забываемый вовек,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"אל ירחיקדם וימים אחרים,","hebrew_niqqud":"אֵל יַרְחֵי־קֶדֶם וְיָמִים אֲחֵרִים,","translit":"ʾēl yarḥê-qeḏem wəyāmîm ʾăḥērîm,","translit_ru":"ел йархе-кэдэм вэйамим ахерим,","russian":"Боже прадавних и грядущих дней,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"מולך על זרמי בניאדם רעננים,","hebrew_niqqud":"מוֹלֵךְ עַל זִרְמֵי בְנֵי־אָדָם רַעְנַנִּים,","translit":"môlēḵ ʿal zirmê ḇənê-ʾāḏām raʿnannîm,","translit_ru":"молех ал зирме вэне-адам рананим,","russian":"Владыка юных человечьих струй,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"משבריאונם בשפעת עלומים!","hebrew_niqqud":"מִשְׁבְּרֵי־אוֹנָם בְּשִׁפְעַת עֲלוּמִים!","translit":"mišbərê-ʾônām bəšip̄ʿaṯ ʿălûmîm!","translit_ru":"мишбэре-онам бэшифат алумим!","russian":"Волн мощи их в изобилии юности!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"אל דור אדירים ונפילים בארץ,","hebrew_niqqud":"אֵל דּוֹר אַדִּירִים וּנְפִילִים בָּאָרֶץ,","translit":"ʾēl dôr ʾaddîrîm ûnəp̄îlîm bāʾāreṣ,","translit_ru":"ел дор адирим унэфилим баарэц,","russian":"Боже века исполинов и титанов на земле,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"כובש בזרועו גם גבול שוכני רמים","hebrew_niqqud":"כּוֹבֵשׁ בִּזְרוֹעוֹ גַּם גְּבוּל שׁוֹכְנֵי רָמִים","translit":"kôḇēš bizrôʿô gam gəḇûl šôḵənê rāmîm","translit_ru":"ковеш бизроо гам гэвул шохэне рамим","russian":"Покоряющий десницей даже рубежи гордых обитателей,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"למושב גבורים בבניו בעטרת","hebrew_niqqud":"לְמוֹשַׁב גִּבּוֹרִים בְּבָנָיו בַּעֲטֶרֶת","translit":"ləmôšaḇ gibbôrîm bəḇānāyw baʿăṭereṯ","translit_ru":"лэмошав гиборим бэванав баатэрэт","russian":"Для обители героев, средь сынов своих, в венце,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"עליהדפנה על מצחם הגאה,","hebrew_niqqud":"עֲלֵי־הַדַּפְנָה עַל מִצְחָם הַגֵּאֶה,","translit":"ʿălê-haddap̄nâ ʿal miṣḥām haggēʾê,","translit_ru":"але-хадафна ал мицхам хагеэ,","russian":"Лаврового венка на гордом челе их,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"רודה באליליו ונדמה להמה,","hebrew_niqqud":"רוֹדֶה בֶאֱלִילָיו וְנִדְמֶה לָהֵמָּה,","translit":"rôḏê ḇeʾĕlîlāyw wəniḏmê lāhēmmâ,","translit_ru":"родэ вээлилав вэнидмэ лахема,","russian":"Властвующий над богами своими, и подобный им,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"לשית נוספות על סוד מושלי תבל;","hebrew_niqqud":"לָשִׁית נוֹסָפוֹת עַל סוֹד מוֹשְׁלֵי תֵבֵל;","translit":"lāšîṯ nôsāp̄ôṯ ʿal sôḏ môšəlê ṯēḇēl;","translit_ru":"лашит носафот ал сод мошэле тевел;","russian":"Дабы прибавить к тайне владык мира,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"דור אל בארץ, שכור שפע החיים,","hebrew_niqqud":"דּוֹר אֵל בָּאָרֶץ, שְׁכוּר שֶׁפַע הַחַיִּים,","translit":"dôr ʾēl bāʾāreṣ, šəḵûr šep̄aʿ haḥayyîm,","translit_ru":"дор ел баарэц, шэхур шэфа хахайим,","russian":"Род божественный на земле, жизнью опьяненный,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"נכרי לגוי חולה ולבית הכואבים.","hebrew_niqqud":"נָכְרִי לְגוֹי חוֹלֶה וּלְבֵית הַכּוֹאֲבִים.","translit":"nāḵərî ləḡôy ḥôlê ûləḇêṯ hakkôʾăḇîm.","translit_ru":"нахэри лэгой холэ улэвет хакоавим.","russian":"Чуждый народу больному и дому скорбящих.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"אלנער, נאדר, רענן, כליליפי,","hebrew_niqqud":"אֵל־נַעַר, נֶאְדָּר, רַעֲנָן, כְּלִיל־יֹפִי,","translit":"ʾēl-naʿar, neʾdār, raʿănān, kəlîl-yōp̄î,","translit_ru":"ел-наар, нэдар, раанан, кэлил-йофи,","russian":"Бог-юноша, славный, свежий, красой увенчанный,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"חולש על שמש ומסתריחיים","hebrew_niqqud":"חוֹלֵשׁ עַל שֶׁמֶשׁ וּמִסְתְּרֵי־חַיִּים","translit":"ḥôlēš ʿal šemeš ûmistərê-ḥayyîm","translit_ru":"холеш ал шэмэш умистэре-хайим","russian":"Властвующий над солнцем и над тайнами жизни,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"בערפלי השירה ובגנזיגוניה,","hebrew_niqqud":"בְּעַרְפִלֵּי הַשִּׁירָה וּבְגִנְזֵי־גְוָנֶיהָ,","translit":"bəʿarp̄illê haššîrâ ûḇəḡinzê-ḡəwānêhā,","translit_ru":"бэарфиле хашира увэгинзе-гэванеха,","russian":"В туманах песни и в потаенных цветах ее,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"בים הנגונים באלפי גלימו;","hebrew_niqqud":"בְּיָם הַנִּגּוּנִים בְּאַלְפֵי גַּלֵּימוֹ;","translit":"bəyām hanniggûnîm bəʾalp̄ê gallêmô;","translit_ru":"бэйам ханигуним бэалфе галемо;","russian":"В море напевов, тысячью волн его;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"אל גיל החיים בכל עשרם והדרם,","hebrew_niqqud":"אֵל גִּיל הַחַיִּים בְּכָל עָשְׁרָם וַהֲדָרָם,","translit":"ʾēl gîl haḥayyîm bəḵol ʿošrām wahăḏārām,","translit_ru":"ел гил хахайим бэхол ошрам вахадарам,","russian":"Бог ликования жизни, во всем ее богатстве и блеске,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"תקפם וצפוני משכיות גוניהם.","hebrew_niqqud":"תָּקְפָּם וּצְפוּנֵי מַשְׂכִּיוֹת גַּוְנֵיהֶם.","translit":"tāqəpām ûṣəp̄ûnê maśkiyôṯ gawnêhem.","translit_ru":"такэпам уцэфуне маскийот гавнехэм.","russian":"Мощи их и сокрытых драгоценностей их красок.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"באתי עדיך, - האם הכרתני?","hebrew_niqqud":"בָּאתִי עָדֶיךָ, - הַאִם הִכַּרְתָּנִי?","translit":"bāʾṯî ʿāḏêḵā, - haʾim hikkartānî?","translit_ru":"бати адеха, - хаим хикартани?","russian":"Я пришел к тебе, - ты узнал меня?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"הנני היהודי: ריב לנו לעולמים!…","hebrew_niqqud":"הִנְנִי הַיְּהוּדִי: רִיב לָנוּ לְעוֹלָמִים!…","translit":"hinnî hayyəhûḏî: rîḇ lānû ləʿôlāmîm!...","translit_ru":"хинни хайэхуди: рив лану лэоламим!...","russian":"Я - еврей: спор наш навеки!…","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"ממיאוקינוס בין חלקי יבשת","hebrew_niqqud":"מִמֵּי־אוֹקְיָנוֹס בֵּין חֶלְקֵי יַבֶּשֶׁת","translit":"mimmê-ʾôqəyānôs bên ḥelqê yabbešeṯ","translit_ru":"миме-окэйанос бен хэлке йабэшэт","russian":"Из вод океана, меж частей континентов,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"תהום הרובצת בינינו יבצר","hebrew_niqqud":"תְּהוֹם הָרוֹבֶצֶת בֵּינֵינוּ יִבָּצֵר","translit":"təhôm hārôḇeṣeṯ bênênû yibbāṣēr","translit_ru":"тэхом харовэцэт бенену йибацер","russian":"Бездна, что меж нами лежит, воспрепятствует","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"למלא עד פיה בשאונם והמונם.","hebrew_niqqud":"לְמַלֵּא עַד פִּיהָ בִּשְׁאוֹנָם וַהֲמוֹנָם.","translit":"ləmallēʾ ʿaḏ pîhā bišʾônām wahămônām.","translit_ru":"лэмале ад пиха бишонам вахамонам.","russian":"Наполнить до краев шумом и гомоном их.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"שחקים ורחב ערבות הן קצרו","hebrew_niqqud":"שְׁחָקִים וְרַחַב עֲרָבוֹת הֵן קָצְרוּ","translit":"šəḥāqîm wəraḥaḇ ʿărāḇôṯ hēn qāṣərû","translit_ru":"шэхаким вэрахав аравот хен кацэру","russian":"Небеса и ширь равнин оказались малы,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"מהשתרע בפרץ, המפריד","hebrew_niqqud":"מֵהִשְׂתָּרֵעַ בַּפֶּרֶץ, הַמַּפְרִיד","translit":"mēhiśtārēaʿ bappereṣ, hammap̄rîḏ","translit_ru":"мехистареа бапэрэц, хамафрид","russian":"Чтоб распростереться в бездне, что разделяет","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"תורת אבותי מדת מעריציך.","hebrew_niqqud":"תּוֹרַת אֲבוֹתַי מִדַּת מַעֲרִיצֶיךָ.","translit":"tôraṯ ʾăḇôṯay middaṯ maʿărîṣêḵā.","translit_ru":"торат авотай мидат маарицеха.","russian":"Учение отцов моих от веры поклонников твоих.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"עינך הרואה בי!","hebrew_niqqud":"עֵינְךָ הָרוֹאָה בִי!","translit":"ʿênəḵā hārôʾâ ḇî!","translit_ru":"енэха хароа ви!","russian":"Глядящее на меня око твое!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"יען הרחקתי","hebrew_niqqud":"יַעַן הִרְחַקְתִּי","translit":"yaʿan hirḥaqtî","translit_ru":"йаан хирхакти","russian":"Ибо я удалился","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"לכת מכל אשר היו לפני","hebrew_niqqud":"לֶכֶת מִכָּל אֲשֶׁר הָיוּ לְפָנַי","translit":"leḵeṯ mikkol ʾăšer hāyû ləp̄ānay","translit_ru":"лэхэт микол ашэр хайу лэфанай","russian":"Дальше всех, кто был до меня,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"ואחרי בנתיב יתע אדם בןתמותה, -","hebrew_niqqud":"וְאַחֲרַי בִּנְתִיב יֵתַע אָדָם בֶּן־תְּמוּתָה, -","translit":"wəʾaḥăray binṯîḇ yēṯaʿ ʾāḏām ben-təmûṯâ, -","translit_ru":"вэахарай бинтив йета адам бэн-тэмута, -","russian":"И после меня на пути, где заблудится смертный,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"הנני הראשון לשבים אליך,","hebrew_niqqud":"הִנְנִי הָרִאשׁוֹן לַשָּׁבִים אֵלֶיךָ,","translit":"hinnî hāriʾšôn laššāḇîm ʾēlêḵā,","translit_ru":"хинни харишон лашавим елеха,","russian":"Я первый из вернувшихся к тебе,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"רגע בו קצתי בגסיסה לדורות,","hebrew_niqqud":"רֶגַע בּוֹ קַצְתִּי בִּגְסִיסָה לַדּוֹרוֹת,","translit":"reḡaʿ bô qaṣtî biḡsîsâ laddôrôṯ,","translit_ru":"рэга бо кацти бигсиса ладорот,","russian":"В миг, когда я устал от вековой агонии,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r33","order_index":33,"hebrew_plain":"במועד בו אשבר אזקי הנפש,","hebrew_niqqud":"בְּמוֹעֵד בּוֹ אֶשְׁבֹּר אֲזִקֵּי הַנֶּפֶשׁ,","translit":"bəmôʿēḏ bô ʾešbōr ʾăziqqê hannep̄eš,","translit_ru":"бэмоед бо эшбор азике ханэфэш,","russian":"В срок, когда сломлю оковы души,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r34","order_index":34,"hebrew_plain":"נפשי החיה, הדבקה בארץ.","hebrew_niqqud":"נַפְשִׁי הַחַיָּה, הַדְּבֵקָה בָּאָרֶץ.","translit":"nap̄šî haḥayyâ, haddəḇēqâ bāʾāreṣ.","translit_ru":"нафши хахайа, хадэвека баарэц.","russian":"Души моей живой, что к земле прильнула.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r35","order_index":35,"hebrew_plain":"זקן העם – אלהיו זקנו עמו!","hebrew_niqqud":"זָקֵן הָעָם – אֱלֹהָיו זָקְנוּ עִמּוֹ!","translit":"zāqēn hāʿām – ʾĕlōhāyw zāqənû ʿimmô!","translit_ru":"закен хаам – элохав закэну имо!","russian":"Народ стар – состарился с ним и Бог его!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r36","order_index":36,"hebrew_plain":"רגשות נצמתים בידי חדליאונים,","hebrew_niqqud":"רְגָשׁוֹת נִצְמָתִים בִּידֵי חִדְלֵי־אוֹנִים,","translit":"rəḡāšôṯ niṣmāṯîm bîḏê ḥiḏlê-ʾônîm,","translit_ru":"рэгашот ницматим биде хидле-оним,","russian":"Чувства, скованные руками бессильных,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r37","order_index":37,"hebrew_plain":"קמו לתחיה ממסגר מאת דורות.","hebrew_niqqud":"קָמוּ לִתְחִיָּה מִמַּסְגֵּר מְאַת דּוֹרוֹת.","translit":"qāmû liṯḥiyyâ mimmasgēr məʾaṯ dôrôṯ.","translit_ru":"каму литхийа мимасгер мэат дорот.","russian":"Воскресли из оков многих поколений.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r38","order_index":38,"hebrew_plain":"אוריה לי!","hebrew_niqqud":"אוֹר־יָהּ לִי!","translit":"ʾôr-yāh lî!","translit_ru":"ор-йах ли!","russian":"Свет мне!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r39","order_index":39,"hebrew_plain":"אוריה!","hebrew_niqqud":"אוֹר־יָהּ!","translit":"ʾôr-yāh!","translit_ru":"ор-йах!","russian":"Свет!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r40","order_index":40,"hebrew_plain":"בי קורא כל גרם,","hebrew_niqqud":"בִּי קוֹרֵא כָּל גֶּרֶם,","translit":"bî qôrēʾ kol gerem,","translit_ru":"би коре кол гэрэм,","russian":"Во мне зовет каждая частица,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r41","order_index":41,"hebrew_plain":"חיים, הוי חיים!","hebrew_niqqud":"חַיִּים, הוֹי חַיִּים!","translit":"ḥayyîm, hôy ḥayyîm!","translit_ru":"хайим, хой хайим!","russian":"Жизнь, о жизнь!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r42","order_index":42,"hebrew_plain":"על עצם כל עורק.","hebrew_niqqud":"עַל עֶצֶם כָּל עוֹרֵק.","translit":"ʿal ʿeṣem kol ʿôrēq.","translit_ru":"ал эцэм кол орек.","russian":"В самой сути каждой жилы.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r43","order_index":43,"hebrew_plain":"אוריה וחיים!","hebrew_niqqud":"אוֹר־יָהּ וְחַיִּים!","translit":"ʾôr-yāh wəḥayyîm!","translit_ru":"ор-йах вэхайим!","russian":"Свет и жизнь!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r44","order_index":44,"hebrew_plain":"ואבא אליך.","hebrew_niqqud":"וָאָבֹא אֵלֶיךָ.","translit":"wāʾāḇōʾ ʾēlêḵā.","translit_ru":"вааво елеха.","russian":"И прихожу к тебе.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r45","order_index":45,"hebrew_plain":"באתי עדיך.","hebrew_niqqud":"בָּאתִי עָדֶיךָ.","translit":"bāʾṯî ʿāḏêḵā.","translit_ru":"бати адеха.","russian":"Я пришел к тебе.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r46","order_index":46,"hebrew_plain":"מול פסלך אקדה.","hebrew_niqqud":"מוּל פִּסְלָךְ אֶקֹדָּה.","translit":"mûl pislāḵ ʾeqōddâ.","translit_ru":"мул пислах экода.","russian":"Пред твоим изваянием я преклонюсь.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r47","order_index":47,"hebrew_plain":"פסלך – סמל המאור בחיים;","hebrew_niqqud":"פִּסְלְךָ – סֵמֶל הַמָּאוֹר בַּחַיִּים;","translit":"pisləḵā – sēmel hammāʾôr baḥayyîm;","translit_ru":"пислэха – семэл хамаор бахайим;","russian":"Твое изваянье – символ света в жизни;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r48","order_index":48,"hebrew_plain":"אקד, אכרעה לטוב ולנעלה,","hebrew_niqqud":"אֶקֹּד, אֶכְרָעָה לַטּוֹב וְלַנַּעֲלֶה,","translit":"ʾeqqōḏ, ʾeḵrāʿâ laṭṭôḇ wəlannaʿălê,","translit_ru":"экод, эхраа латов вэланаалэ,","russian":"Склонюсь, преклоню колени пред добрым и возвышенным,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r49","order_index":49,"hebrew_plain":"לאשר הוא נשא במלא כל העולם,","hebrew_niqqud":"לַאֲשֶׁר הוּא נִשָּׂא בִּמְלֹא כָּל הָעוֹלָם,","translit":"laʾăšer hûʾ niśśāʾ bimlōʾ kol hāʿôlām,","translit_ru":"лаашэр ху ниса бимло кол хаолам,","russian":"Пред тем, что оно несло по всему миру,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r50","order_index":50,"hebrew_plain":"לאשר הוא נהדר במלא כל הבריאה,","hebrew_niqqud":"לַאֲשֶׁר הוּא נֶהְדָּר בִּמְלֹא כָּל הַבְּרִיאָה,","translit":"laʾăšer hûʾ nêdār bimlōʾ kol habbərîʾâ,","translit_ru":"лаашэр ху нэдар бимло кол хабэриа,","russian":"Ибо он величественен во всей полноте творения,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r51","order_index":51,"hebrew_plain":"לאשר יש מרומם בסודסודות היצירה.","hebrew_niqqud":"לַאֲשֶׁר יֵשׁ מְרוֹמָם בְּסוֹד־סוֹדוֹת הַיְצִירָה.","translit":"laʾăšer yēš mərômām bəsôḏ-sôḏôṯ hayəṣîrâ.","translit_ru":"лаашэр йеш мэромам бэсод-содот хайэцира.","russian":"Ибо есть возвышенное в сокровенных тайнах бытия.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r52","order_index":52,"hebrew_plain":"אכרע לחיים, לגבורה וליפי,","hebrew_niqqud":"אֶכְרַע לַחַיִּים, לַגְּבוּרָה וְלַיֹּפִי,","translit":"ʾeḵraʿ laḥayyîm, laggəḇûrâ wəlayyōp̄î,","translit_ru":"эхра лахайим, лагэвура вэлайофи,","russian":"Я преклонюсь пред жизнью, доблестью и красотой,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r53","order_index":53,"hebrew_plain":"אכרע לכל שכיותהחמדה, ששדדו","hebrew_niqqud":"אֶכְרַע לְכָל שְׂכִיּוֹת־הַחֶמְדָּה, שֶׁשָּׁדְדוּ","translit":"ʾeḵraʿ ləḵol śəḵiyyôṯ-haḥemdâ, šeššāḏəḏû","translit_ru":"эхра лэхол сэхийот-хахэмда, шэшадэду","russian":"Я преклонюсь пред всеми сокровищами, что похитили","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r54","order_index":54,"hebrew_plain":"פגרי אנשים ורקב זרע אדם,","hebrew_niqqud":"פִּגְרֵי אֲנָשִׁים וּרְקַב זֶרַע אָדָם,","translit":"piḡrê ʾănāšîm ûrəqaḇ zeraʿ ʾāḏām,","translit_ru":"пигре анашим урэкав зэра адам,","russian":"Трупы людей и тлен семени человеческого,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r55","order_index":55,"hebrew_plain":"מורדי החיים מיד צורי שדי,","hebrew_niqqud":"מוֹרְדֵי הַחַיִּים מִיַּד צוּרִי שַׁדַּי,","translit":"môrəḏê haḥayyîm miyyaḏ ṣûrî šadday,","translit_ru":"морэде хахайим мийад цури шадай,","russian":"Бунтари жизни из рук Скалы Вседержителя,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r56","order_index":56,"hebrew_plain":"אל אלהי מדברות הפלי,","hebrew_niqqud":"אֵל אֱלֹהֵי מִדְבְּרוֹת הַפֶּלִי,","translit":"ʾēl ʾĕlōhê miḏbərôṯ happelî,","translit_ru":"ел элохе мидбэрот хапэли,","russian":"К Богу дивных пустынь,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r57","order_index":57,"hebrew_plain":"אל אלהי כובשי כנען בסופה, -","hebrew_niqqud":"אֵל אֱלֹהֵי כּוֹבְשֵׁי כְּנַעַן בְּסוּפָה, -","translit":"ʾēl ʾĕlōhê kôḇəšê kənaʿan bəsûp̄â, -","translit_ru":"ел элохе ковэше кэнаан бэсуфа, -","russian":"К Богу завоевателей Ханаана в буре, -","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r58","order_index":58,"hebrew_plain":"ויאסרוהו ברצועות של תפילין…","hebrew_niqqud":"וַיַאַסְרוּהוּ בִרְצוּעוֹת שֶׁל תְּפִילִין…","translit":"wayaʾasrûhû ḇirṣûʿôṯ šel təp̄îlîn...","translit_ru":"вайаасруху вирцуот шэл тэфилин...","russian":"И связали его ремешками тфилин…","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r59","order_index":59,"hebrew_plain":"1899","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"1899","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
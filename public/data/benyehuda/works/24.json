{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-24","text_key":"d647febeccc7c2347af96f16e3246cf13cb2bdc9b7b20ef95d554fc02d066f2a","title":"על אילת השחר","level":null,"tags":["poetry","tehiya"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"24","content_hash":"sha256:28ae259d093cf6b173c44e57ce3ff2fe5a154d6c0b439b1068c6b245969b6456","author":"חיים נחמן ביאליק","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q359705","translator":null,"translator_uri":null,"orig_language":"he","era":"tehiya","genre":"poetry","themes":[],"register":"poetic","track":"literary","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/24","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: תל אביב: דביר, תשל\"ג","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"24","content_hash":"sha256:28ae259d093cf6b173c44e57ce3ff2fe5a154d6c0b439b1068c6b245969b6456","author":"חיים נחמן ביאליק","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q359705","translator":null,"translator_uri":null,"orig_language":"he","era":"tehiya","genre":"poetry","themes":[],"register":"poetic","track":"literary","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/24","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: תל אביב: דביר, תשל\"ג","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"על אילת השחר","hebrew_niqqud":"עַל אַיֶּלֶת הַשַּׁחַר","translit":"ʿal ʾayyeleṯ haššaḥar","translit_ru":"ал айэлэт хашахар","russian":"При утренней заре","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"מאורה עלפי נוסח ספרד","hebrew_niqqud":"מְאוֹרָה עַל־פִּי נוּסַח סְפָרַד","translit":"məʾôrâ ʿal-pî nûsaḥ səp̄āraḏ","translit_ru":"мэора ал-пи нусах сэфарад","russian":"Его свет, по сефардскому обряду,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"נחשפו שולי רקיע, וידרך עלספו","hebrew_niqqud":"נֶחְשְׂפוּ שׁוּלֵי רָקִיעַ, וַיִּדְרֹךְ עַל־סִפּוֹ","translit":"neḥśəp̄û šûlê rāqîaʿ, wayyiḏrōḵ ʿal-sippô","translit_ru":"нэхсэфу шуле ракиа, вайидрох ал-сипо","russian":"Обнажились края небосвода, и ступил он на его порог.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"השחר, ויצו עלליל: צא מפו!","hebrew_niqqud":"הַשַּׁחַר, וַיְצַו עַל־לֵיל: צֵא מִפּוֹ!","translit":"haššaḥar, wayəṣaw ʿal-lêl: ṣēʾ mippô!","translit_ru":"хашахар, вайэцав ал-лел: це мипо!","russian":"Рассвет, и ночи повелел: Прочь отсюда!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"וישנה פני הכושי וישלחהו,","hebrew_niqqud":"וַיְשַׁנֶּה פְנֵי הַכּוּשִׁי וַיְשַלְּחֵהוּ,","translit":"wayəšannê p̄ənê hakkûšî wayəšalləḥēhû,","translit_ru":"вайэшанэ фэне хакуши вайэшалэхеху,","russian":"И изменил облик Кушита, и прогнал его.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"ויאסף נרותיו, ויכבה כוכבי נשפו,","hebrew_niqqud":"וַיֶּאֱסֹף נֵרוֹתָיו, וַיְכַבֶּה כוֹכְבֵי נִשְׁפּוֹ,","translit":"wayyeʾĕsōp̄ nērôṯāyw, wayəḵabbê ḵôḵəḇê nišpô,","translit_ru":"вайээсоф неротав, вайэхабэ хохэве нишпо,","russian":"И собрал свои лампады, и погасил ночные звезды.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"וילט פניו באדרתו השחרחרה,","hebrew_niqqud":"וַיָּלֶט פָּנָיו בְּאַדַּרְתּוֹ הַשְּׁחַרְחֹרָה,","translit":"wayyāleṭ pānāyw bəʾaddartô haššəḥarḥōrâ,","translit_ru":"вайалэт панав бэадарто хашэхархора,","russian":"И закутал лицо в свой черноватый плащ.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"ויתפרק נזמי הזהב, ויצא אט בגפו,","hebrew_niqqud":"וַיִּתְפָּרֶק נִזְמֵי הַזָּהָב, וַיֵּצֵא אַט בְּגַפּוֹ,","translit":"wayyiṯpāreq nizmê hazzāhāḇ, wayyēṣēʾ ʾaṭ bəḡappô,","translit_ru":"вайитпарэк низме хазахав, вайеце ат бэгапо,","russian":"И снял золотые кольца, и вышел тихонько один,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"ללין בעמקים ובחרשים מצלים,","hebrew_niqqud":"לָלִין בַּעֲמָקִים וּבָחֳרָשִׁים מְצִלִּים,","translit":"lālîn baʿămāqîm ûḇoḥŏrāšîm məṣillîm,","translit_ru":"лалин баамаким увохорашим мэцилим,","russian":"Чтобы переночевать в долинах и в тенистых лесах,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"לשית בכפים עלעטלפים כפו.","hebrew_niqqud":"לָשִׁית בַּכֵּפִים עַל־עֲטַלֵּפִים כַּפּוֹ.","translit":"lāšîṯ bakkēp̄îm ʿal-ʿăṭallēp̄îm kappô.","translit_ru":"лашит бакефим ал-аталефим капо.","russian":"Чтобы в ладонях летучих мышей лежала его длань.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"רק הילל בןשחר עוד קורץ עינו,","hebrew_niqqud":"רַק הֵילֵל בֶּן־שַׁחַר עוֹד קוֹרֵץ עֵינוֹ,","translit":"raq hêlēl ben-šaḥar ʿôḏ qôrēṣ ʿênô,","translit_ru":"рак хелел бэн-шахар од корец ено,","russian":"Лишь Утренняя Звезда всё ещё подмигивает глазом,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"לא יכבה נרו ולא יכהה רשפו;","hebrew_niqqud":"לֹא יִכְבֶּה נֵרוֹ וְלֹא יִכְהֶה רִשְׁפּוֹ;","translit":"lōʾ yiḵbê nērô wəlōʾ yiḵhê rišpô;","translit_ru":"ло йихбэ неро вэло йиххэ ришпо;","russian":"Не погасит свой светильник и не потускнеет его искра;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"קבוע כנפך ביריעת תכלת","hebrew_niqqud":"קָבוּעַ כַּנֹּפֶךְ בִּירִיעַת תְּכֵלֶת","translit":"qāḇûaʿ kannōp̄eḵ bîrîʿaṯ təḵēleṯ","translit_ru":"кавуа канофэх бириат тэхелэт","russian":"Утверждённый, как сапфир, в лазурном покрове","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"יפץ אור צחר מנקדת כספו.","hebrew_niqqud":"יָפֵץ אוֹר צַחַר מִנְּקֻדַּת כַּסְפּוֹ.","translit":"yāp̄ēṣ ʾôr ṣaḥar minnəqūddaṯ kaspô.","translit_ru":"йафец ор цахар минэкудат каспо.","russian":"Разольёт свет чистый из своей серебряной точки.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"חבאו כוכבי בקר, תמוג עיפתה","hebrew_niqqud":"חֻבְּאוּ כּוֹכְבֵי בֹקֶר, תִּמּוֹג עֵיפָתָה","translit":"ḥūbbəʾû kôḵəḇê ḇōqer, timmôḡ ʿêp̄āṯâ","translit_ru":"хубэу кохэве вокэр, тимог ефата","russian":"Скрылись утренние звёзды, растает мрак","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"מנשמת השחר ומניד עפעפו.","hebrew_niqqud":"מִנִּשְׁמַת הַשַּׁחַר וּמִנִּיד עַפְעַפּוֹ.","translit":"minnišmaṯ haššaḥar ûminnîḏ ʿap̄ʿappô.","translit_ru":"минишмат хашахар уминид афапо.","russian":"От дыхания рассвета и от взмаха его ресниц.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"ושפת היריעה קדמה מתלבנת,","hebrew_niqqud":"וּשְׂפַת הַיְרִיעָה קֵדְמָה מִתְלַבֶּנֶת,","translit":"ûśəp̄aṯ hayərîʿâ qēḏəmâ miṯlabbeneṯ,","translit_ru":"усэфат хайэриа кедэма митлабэнэт,","russian":"И кромка покрова на востоке белеет,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"ובאחרית ים עוד יעיב באפו.","hebrew_niqqud":"וּבְאַחֲרִית יָם עוֹד יָעִיב בְּאַפּוֹ.","translit":"ûḇəʾaḥărîṯ yām ʿôḏ yāʿîḇ bəʾappô.","translit_ru":"увэахарит йам од йаив бэапо.","russian":"А на краю моря ещё хмурится в гневе.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"ושחקים יחורו ילכו הלוך ואור,","hebrew_niqqud":"וּשְׁחָקִים יֶחֶוְרוּ יֵלְכוּ הָלוֹךְ וָאוֹר,","translit":"ûšəḥāqîm yeḥewrû yēləḵû hālôḵ wāʾôr,","translit_ru":"ушэхаким йэхэвру йелэху халох ваор,","russian":"И небеса светлеют, всё светлеют и светлеют,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"יחור היקום וכלאגפו;","hebrew_niqqud":"יֶחֱוַר הַיְקוּם וְכָל־אֲגַפּוֹ;","translit":"yeḥĕwar hayəqûm wəḵol-ʾăḡappô;","translit_ru":"йэхэвар хайэкум вэхол-агапо;","russian":"Светлеет мироздание и все его крылья;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"יגיחו יגלו מבטן החשך,","hebrew_niqqud":"יָגִיחוּ יִגָּלוּ מִבֶּטֶן הַחֹשֶך,","translit":"yāḡîḥû yiggālû mibbeṭen haḥōšeḵ,","translit_ru":"йагиху йигалу мибэтэн хахошэх,","russian":"Выйдут, явятся из утробы тьмы,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"ויקא האפל אתבלעו וטרפו.","hebrew_niqqud":"וְיָקֵא הָאֹפֶל אֶת־בִּלְעוֹ וְטַרְפּוֹ.","translit":"wəyāqēʾ hāʾōp̄el ʾeṯ-bilʿô wəṭarpô.","translit_ru":"вэйаке хаофэл эт-било вэтарпо.","russian":"И извергнет Тьма то, что поглотила, и свою добычу.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"ואד לבן יעל מחמי הנחל,","hebrew_niqqud":"וְאֵד לָבָן יַעַל מֵחַמֵּי הַנָּחַל,","translit":"wəʾēḏ lāḇān yaʿal mēḥammê hannāḥal,","translit_ru":"вэед лаван йаал мехаме ханахал,","russian":"И белый пар поднимется от теплоты ручья,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"ודיג משכים משיט צנה מחפו.","hebrew_niqqud":"וְדַיָּג מַשְׁכִּים מֵשִׁיט צִנָּה מֵחֻפּוֹ.","translit":"wəḏayyāḡ maškîm mēšîṭ ṣinnâ mēḥūppô.","translit_ru":"вэдайаг машким мешит цина мехупо.","russian":"И рыбак, рано встав, пустит челн из своего укрытия.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"ובעשבים רטבים מרסיסי לילה","hebrew_niqqud":"וּבַעֲשָׂבִים רְטֻבִּים מֵרְסִיסֵי לַיְלָה","translit":"ûḇaʿăśāḇîm rəṭūbbîm mērəsîsê laylâ","translit_ru":"уваасавим рэтубим мерэсисе лайла","russian":"И в травах, влажных от ночной росы,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"מפלג בעמק הפלג לשטפו;","hebrew_niqqud":"מְפַלֵּג בָּעֵמֶק הַפֶּלֶג לְשִׁטְפּוֹ;","translit":"məp̄allēḡ bāʿēmeq happeleḡ ləšiṭpô;","translit_ru":"мэфалег баемэк хапэлэг лэшитпо;","russian":"Ручей в долине потечёт, чтобы омыть их;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"ירעד עלחצציו הומה ומבעבע,","hebrew_niqqud":"יִרְעַד עַל־חֲצָצָיו הוֹמֶה וּמְבַעְבֵּעַ,","translit":"yirʿaḏ ʿal-ḥăṣāṣāyw hômê ûməḇaʿbēaʿ,","translit_ru":"йирад ал-хацацав хомэ умэвабеа,","russian":"Дрожит над своей галькой, шумит и пузырится,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"יקפץ כילד –ומהיפה קצפו.","hebrew_niqqud":"יְקַפֵּץ כַּיֶּלֶד –וּמַה־יָּפֶה קִצְפּוֹ.","translit":"yəqappēṣ kayyeleḏ –ûmah-yyāp̄ê qiṣpô.","translit_ru":"йэкапец кайэлэд –умах-йафэ кицпо.","russian":"Скачет, как дитя – и как прекрасен его гнев.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"ומלא תבל יחריש דומם ויחיל","hebrew_niqqud":"וּמְלֹא תֵבֵל יַחֲרִישׁ דּוּמָם וְיָחִיל","translit":"ûməlōʾ ṯēḇēl yaḥărîš dûmām wəyāḥîl","translit_ru":"умэло тевел йахариш думам вэйахил","russian":"И весь мир замолчит безмолвно и затаится","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"לצאת השמש בעזוז תקפו.","hebrew_niqqud":"לְצֵאת הַשֶּׁמֶשׁ בֶּעֱזוּז תָּקְפּוֹ.","translit":"ləṣēʾṯ haššemeš beʿĕzûz tāqəpô.","translit_ru":"лэцет хашэмэш бээзуз такэпо.","russian":"В ожидании восхода солнца во всей мощи его силы.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"הכלב עז הנפש נלאה לנבח,","hebrew_niqqud":"הַכֶּלֶב עַז הַנֶּפֶשׁ נִלְאָה לִנְבֹּחַ,","translit":"hakkeleḇ ʿaz hannep̄eš nilʾâ linbōaḥ,","translit_ru":"хакэлэв аз ханэфэш нила линбоах,","russian":"Отважный пёс изнемог от лая,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"הזה במלונתו ונח מזעפו.","hebrew_niqqud":"הֹזֶה בִּמְלוּנָתוֹ וְנָח מִזַעְפּוֹ.","translit":"hōzê bimlûnāṯô wənāḥ mizaʿpô.","translit_ru":"хозэ бимлунато вэнах мизапо.","russian":"Задремал в своём логове и отдохнул от своего гнева.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"ושכוי אלרעהו מרחוק קורא,","hebrew_niqqud":"וְשֶׂכְוִי אֶל־רֵעֵהוּ מֵרָחוֹק קוֹרֵא,","translit":"wəśeḵwî ʾel-rēʿēhû mērāḥôq qôrēʾ,","translit_ru":"вэсэхви эл-рееху мерахок коре,","russian":"И петух к товарищу своему издали взывает,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r33","order_index":33,"hebrew_plain":"יעיר הבקר בגרונו ומחי גפו;","hebrew_niqqud":"יָעִיר הַבֹּקֶר בִּגְרוֹנוֹ וּמְחִי גַפּוֹ;","translit":"yāʿîr habbōqer biḡrônô ûməḥî ḡappô;","translit_ru":"йаир хабокэр бигроно умэхи гапо;","russian":"Будит утро голосом своим и взмахом крыла;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r34","order_index":34,"hebrew_plain":"אור אור, ברקאי!","hebrew_niqqud":"אוֹר אוֹר, בַּרְקָאי!","translit":"ʾôr ʾôr, barqāʾy!","translit_ru":"ор ор, баркай!","russian":"Свет, свет, Зарница!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r35","order_index":35,"hebrew_plain":"השמש הציצה!","hebrew_niqqud":"הַשֶּׁמֶשׁ הֵצִיצָה!","translit":"haššemeš hēṣîṣâ!","translit_ru":"хашэмэш хецица!","russian":"Солнце выглянуло!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r36","order_index":36,"hebrew_plain":"–","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"–","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r37","order_index":37,"hebrew_plain":"ראה הלילה ויהפך אתערפו;","hebrew_niqqud":"רָאָה הַלַּיְלָה וַיַּהֲפֹךְ אֶת־עָרְפּוֹ;","translit":"rāʾâ hallaylâ wayyahăp̄ōḵ ʾeṯ-ʿorpô;","translit_ru":"раа халайла вайахафох эт-орпо;","russian":"Увидела ночь и повернулась спиной;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r38","order_index":38,"hebrew_plain":"התלקח המזרח, הטל הבריק מטה,","hebrew_niqqud":"הִתְלַקַּח הַמִּזְרָח, הַטַּל הִבְרִיק מָטָּה,","translit":"hiṯlaqqaḥ hammizrāḥ, haṭṭal hiḇrîq māṭṭâ,","translit_ru":"хитлаках хамизрах, хатал хиврик мата,","russian":"Вспыхнул Восток, роса заблестела вниз,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r39","order_index":39,"hebrew_plain":"מקדם זהב יאתה אלנטפו.","hebrew_niqqud":"מִקֶּדֶם זָהָב יֶאֱתֶה אֶל־נִטְפּוֹ.","translit":"miqqeḏem zāhāḇ yeʾĕṯê ʾel-niṭpô.","translit_ru":"микэдэм захав йээтэ эл-нитпо.","russian":"С востока золото к своим каплям придёт.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r40","order_index":40,"hebrew_plain":"ויעור החרוץ ויצא למלאכתו,","hebrew_niqqud":"וַיֵּעוֹר הֶחָרוּץ וַיֵּצֵא לִמְלַאכְתּוֹ,","translit":"wayyēʿôr heḥārûṣ wayyēṣēʾ limlaʾḵtô,","translit_ru":"вайеор хэхаруц вайеце лимлахто,","russian":"И пробудился прилежный, и вышел на труд свой,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r41","order_index":41,"hebrew_plain":"כי אכף עליו פיהו ופיות טפו.","hebrew_niqqud":"כִּי אָכַף עָלָיו פִּיהוּ וּפִיּוֹת טַפּוֹ.","translit":"kî ʾāḵap̄ ʿālāyw pîhû ûp̄iyyôṯ ṭappô.","translit_ru":"ки ахаф алав пиху уфийот тапо.","russian":"Ибо давили на него его уста и уста его детей.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r42","order_index":42,"hebrew_plain":"וירא עםשמש ירוץ בית אדני","hebrew_niqqud":"וְיָרֵא עִם־שֶׁמֶשׁ יָרוּץ בֵּית אֲדֹנָי","translit":"wəyārēʾ ʿim-šemeš yārûṣ bêṯ ʾăḏōnāy","translit_ru":"вэйаре им-шэмэш йаруц бет адонай","russian":"И увидел, как с солнцем бежит к дому Господню","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r43","order_index":43,"hebrew_plain":"ואשר בנה לאלהיו בית בשעפו.","hebrew_niqqud":"וַאֲשֶׁר בָּנָה לֵאלֹהָיו בַּיִת בִּשְׂעִפּוֹ.","translit":"waʾăšer bānâ lēʾlōhāyw bayiṯ biśʿippô.","translit_ru":"ваашэр бана лелохав байит бисипо.","russian":"И тот, кто построил Богу своему дом по своему стремлению.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r44","order_index":44,"hebrew_plain":"ולב חלל כלבי יעור עםפצעו,","hebrew_niqqud":"וְלֵב חָלָל כְּלִבִּי יֵעוֹר עִם־פִּצְעוֹ,","translit":"wəlēḇ ḥālāl kəlibbî yēʿôr ʿim-piṣʿô,","translit_ru":"вэлев халал кэлиби йеор им-пицо,","russian":"И пронзённое сердце, подобно псу, проснётся с раной своей,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r45","order_index":45,"hebrew_plain":"אשר כלה קיצו ויבא חרפו;","hebrew_niqqud":"אֲשֶׁר כָּלָה קֵיצוֹ וַיָּבֹא חָרְפּוֹ;","translit":"ʾăšer kālâ qêṣô wayyāḇōʾ ḥorpô;","translit_ru":"ашэр кала кецо вайаво хорпо;","russian":"Чьё лето кончилось и наступила его зима;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r46","order_index":46,"hebrew_plain":"יראה זיו אדני מתחדש לבקרים,","hebrew_niqqud":"יִרְאֶה זִיו אֲדֹנָי מִתְחַדֵּשׁ לַבְּקָרִים,","translit":"yirʾê zîw ʾăḏōnāy miṯḥaddēš labbəqārîm,","translit_ru":"йирэ зив адонай митхадеш лабэкарим,","russian":"Увидит сияние Господа, обновляющееся по утрам,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r47","order_index":47,"hebrew_plain":"ושב לימי עלומיו וזכר ימי חרפו,","hebrew_niqqud":"וְשָׁב לִימֵי עֲלוּמָיו וְזָכַר יְמֵי חָרְפּוֹ,","translit":"wəšāḇ lîmê ʿălûmāyw wəzāḵar yəmê ḥorpô,","translit_ru":"вэшав лиме алумав вэзахар йэме хорпо,","russian":"И вернется к дням своей юности и вспомнит дни своего позора,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r48","order_index":48,"hebrew_plain":"בשכן חסד אל ואמתו בקרבו,","hebrew_niqqud":"בִּשְׁכֹּן חֶסֶד אֵל וַאֲמִתּוֹ בְּקִרְבּוֹ,","translit":"biškōn ḥeseḏ ʾēl waʾămittô bəqirbô,","translit_ru":"бишкон хэсэд ел ваамито бэкирбо,","russian":"Когда милость Божья и истина Его обитали в нём,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r49","order_index":49,"hebrew_plain":"בהלו נר אדני עלי שרעפו;","hebrew_niqqud":"בְּהִלּוֹ נֵר אֲדֹנָי עֲלֵי שַׂרְעַפּוֹ;","translit":"bəhillô nēr ʾăḏōnāy ʿălê śarʿappô;","translit_ru":"бэхило нер адонай але сарапо;","russian":"Когда светильник Господа сиял над его мыслями;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r50","order_index":50,"hebrew_plain":"ויחלם כיוסף והוא דגול מרבבה,","hebrew_niqqud":"וַיַּחֲלֹם כְּיוֹסֵף וְהוּא דָגוּל מֵרְבָבָה,","translit":"wayyaḥălōm kəyôsēp̄ wəhûʾ ḏāḡûl mērəḇāḇâ,","translit_ru":"вайахалом кэйосеф вэху дагул мерэвава,","russian":"И мечтал, как Иосиф, и был знаменем десяти тысяч,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r51","order_index":51,"hebrew_plain":"ועתה, אהה!","hebrew_niqqud":"וְעַתָּה, אֲהָהּ!","translit":"wəʿattâ, ʾăhāh!","translit_ru":"вэата, ахах!","russian":"А ныне, увы!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r52","order_index":52,"hebrew_plain":"–והוא צעיר אלפו.","hebrew_niqqud":"–וְהוּא צְעִיר אַלְפּוֹ.","translit":"–wəhûʾ ṣəʿîr ʾalpô.","translit_ru":"–вэху цэир алпо.","russian":"–А он наименьший из тысячи своих.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r53","order_index":53,"hebrew_plain":"וידע כי אולתו סלפה דרכו","hebrew_niqqud":"וַיֵּדַע כִּי אִוַּלְתּוֹ סִלְּפָה דַרְכּוֹ","translit":"wayyēḏaʿ kî ʾiwwaltô silləp̄â ḏarkô","translit_ru":"вайеда ки ивалто силэфа дарко","russian":"И он знал, что его безумие извратило его путь,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r54","order_index":54,"hebrew_plain":"ואלהים שך בעדו מישר סלפו.","hebrew_niqqud":"וְאלֹהִים שָׂךְ בַּעֲדוֹ מִיַּשֵׁר סִלְפּוֹ.","translit":"wəʾlōhîm śāḵ baʿăḏô miyyašēr silpô.","translit_ru":"вэлохим сах баадо мийашер силпо.","russian":"И Бог оградил его от прямоты, которую он сам извратил.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r55","order_index":55,"hebrew_plain":"לבקרים תדלף עינו אולי ירפא,","hebrew_niqqud":"לַבְּקָרִים תִּדְלֹף עֵינוֹ אוּלַי יֵרָפֵא,","translit":"labbəqārîm tiḏlōp̄ ʿênô ʾûlay yērāp̄ēʾ,","translit_ru":"лабэкарим тидлоф ено улай йерафе,","russian":"По утрам будут течь слёзы из его глаз, быть может, он исцелится,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r56","order_index":56,"hebrew_plain":"ופצעו יעמיק אף ימק מדלפו.","hebrew_niqqud":"וּפִצְעוֹ יַעֲמִיק אַף יִמַּק מִדִּלְפּוֹ.","translit":"ûp̄iṣʿô yaʿămîq ʾap̄ yimmaq middilpô.","translit_ru":"уфицо йаамик аф йимак мидилпо.","russian":"А его рана углубится, даже будет гнить от её истечения.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r57","order_index":57,"hebrew_plain":"לולא נפשי לאדני משומרים לבקר,","hebrew_niqqud":"לוּלֵא נַפְשִׁי לַאדֹנָי מִשּׁוֹמְרִים לַבֹּקֶר,","translit":"lûlēʾ nap̄šî laʾḏōnāy miššômərîm labbōqer,","translit_ru":"луле нафши ладонай мишомэрим лабокэр,","russian":"Если бы душа моя не была Господом хранима до утра,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r58","order_index":58,"hebrew_plain":"כי יך אף ישלח דברו לרפא.","hebrew_niqqud":"כִּי יַךְ אַף יִשְׁלַח דְּבָרוֹ לִרְפֹּא.","translit":"kî yaḵ ʾap̄ yišlaḥ dəḇārô lirpōʾ.","translit_ru":"ки йах аф йишлах дэваро лирпо.","russian":"Ибо Он ранит, но и посылает Слово Своё, чтоб исцелить.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r59","order_index":59,"hebrew_plain":"תרנ\"ב","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"1892 г.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
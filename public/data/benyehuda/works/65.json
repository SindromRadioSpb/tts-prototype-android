e":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r78","order_index":78,"hebrew_plain":"בעבור דבר אתכה","hebrew_niqqud":"בַּעֲבוּר דַּבֵּר אֹתָכָה","translit":"baʿăḇûr dabbēr ʾōṯāḵâ","translit_ru":"баавур дабер отаха","russian":"Дабы сказать тебе:","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r79","order_index":79,"hebrew_plain":"שלום, טובה וברכה","hebrew_niqqud":"שָׁלוֹם, טוֹבָה וּבְרָכָה","translit":"šālôm, ṭôḇâ ûḇərāḵâ","translit_ru":"шалом, това увэраха","russian":"Мир, добро и благословение!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r80","order_index":80,"hebrew_plain":"ולהגיד כי על לוח","hebrew_niqqud":"וּלְהַגִּיד כִּי עַל לוּחַ","translit":"ûləhaggîḏ kî ʿal lûaḥ","translit_ru":"улэхагид ки ал луах","russian":"И поведать, что на скрижалях","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r81","order_index":81,"hebrew_plain":"לבי, ובמחבא רוח,","hebrew_niqqud":"לִבִּי, וּבְמַחֲבֵא רוּחַ,","translit":"libbî, ûḇəmaḥăḇēʾ rûaḥ,","translit_ru":"либи, увэмахаве руах,","russian":"Сердца моего и в тайнике души","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r82","order_index":82,"hebrew_plain":"את שמך חקותי","hebrew_niqqud":"אֶת שִׁמְךָ חַקּוֹתִי","translit":"ʾeṯ šimḵā ḥaqqôṯî","translit_ru":"эт шимха хакоти","russian":"Твоё имя я высек","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r83","order_index":83,"hebrew_plain":"לעד עד יום מותי,","hebrew_niqqud":"לָעַד עַד יוֹם מוֹתִי,","translit":"lāʿaḏ ʿaḏ yôm môṯî,","translit_ru":"лаад ад йом моти,","russian":"Навечно, до дня моей кончины,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r84","order_index":84,"hebrew_plain":"עד ארד שם מטה.","hebrew_niqqud":"עַד אֵרֵד שָׁם מָטָּה.","translit":"ʿaḏ ʾērēḏ šām māṭṭâ.","translit_ru":"ад еред шам мата.","russian":"Пока не сойду туда вниз.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r85","order_index":85,"hebrew_plain":"זכרני גם אתה!","hebrew_niqqud":"זָכְרֵנִי גַם אָתָּה!","translit":"zāḵərēnî ḡam ʾāttâ!","translit_ru":"захэрени гам ата!","russian":"Помни же и ты меня!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r86","order_index":86,"hebrew_plain":"ובשובך בי לדבר","hebrew_niqqud":"וּבְשׁוּבְךָ בִּי לְדַבֵּר","translit":"ûḇəšûḇəḵā bî ləḏabbēr","translit_ru":"увэшувэха би лэдабер","russian":"И когда вновь заговоришь со мной,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r87","order_index":87,"hebrew_plain":"אז חילים אגבר","hebrew_niqqud":"אָז חֲיָלִים אֲגַבֵּר","translit":"ʾāz ḥăyālîm ʾăḡabbēr","translit_ru":"аз хайалим агабер","russian":"Тогда я наберусь сил,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r88","order_index":88,"hebrew_plain":"לענותך דברי טעם","hebrew_niqqud":"לַעֲנוֹתְךָ דִּבְרֵי טַעַם","translit":"laʿănôṯəḵā diḇrê ṭaʿam","translit_ru":"лаанотэха дивре таам","russian":"Чтоб отвечать тебе разумными словами","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r89","order_index":89,"hebrew_plain":"מדי פעם בפעם,","hebrew_niqqud":"מִדֵּי פַעַם בְּפַעַם,","translit":"middê p̄aʿam bəp̄aʿam,","translit_ru":"миде фаам бэфаам,","russian":"Время от времени,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r90","order_index":90,"hebrew_plain":"וברגעי המרגוע","hebrew_niqqud":"וּבְּרִגְעֵי הַמַּרְגּוֹעַ","translit":"ûbəriḡʿê hammargôaʿ","translit_ru":"убэриге хамаргоа","russian":"И в минуты покоя","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r91","order_index":91,"hebrew_plain":"בך אשתעשע,","hebrew_niqqud":"בָּךְ אֶשְׁתַּעֲשֵׁעַ,","translit":"bāḵ ʾeštaʿăšēaʿ,","translit_ru":"бах эштаашеа,","russian":"Буду тобой тешиться,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r92","order_index":92,"hebrew_plain":"כי חמודות אתה","hebrew_niqqud":"כִּי חֲמוֹדוֹת אַתָּה","translit":"kî ḥămôḏôṯ ʾattâ","translit_ru":"ки хамодот ата","russian":"Ибо ты дорог","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r93","order_index":93,"hebrew_plain":"לידידך מנער","hebrew_niqqud":"לִידִידְךָ מִנֹּעַר","translit":"lîḏîḏəḵā minnōʿar","translit_ru":"лидидэха миноар","russian":"Своему другу с юности,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r94","order_index":94,"hebrew_plain":"היושב עתה פה בעיר צער …","hebrew_niqqud":"הַיּוֹשֵׁב עַתָּה פֹּה בָּעִיר צֹעַר …","translit":"hayyôšēḇ ʿattâ pōh bāʿîr ṣōʿar ...","translit_ru":"хайошев ата пох баир цоар ...","russian":"Который ныне здесь, в городе Печали, сидит…","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
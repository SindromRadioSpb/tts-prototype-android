{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-92","text_key":"9064fe73584c9078b5e9a508a1d697b7ac6520f60239fa7d5aa5bad303a82155","title":"חִידוֹת בְּמִלּוֹת יְחִידוֹת","level":null,"tags":["poetry","haskalah"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"92","content_hash":"sha256:193ad7c43a5cc47be01bb8fbfe11276b513ed6276d724ccc2eb9b0ba8f2ce2fe","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/92","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"92","content_hash":"sha256:193ad7c43a5cc47be01bb8fbfe11276b513ed6276d724ccc2eb9b0ba8f2ce2fe","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/92","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"חידות במלות יחידות","hebrew_niqqud":"חִידוֹת בְּמִלּוֹת יְחִידוֹת","translit":"ḥîḏôṯ bəmillôṯ yəḥîḏôṯ","translit_ru":"хидот бэмилот йэхидот","russian":"Словесные загадки","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"Palindrom","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"Палиндром","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"א","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"А","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"ששה פנים לי שונים מכל עבר,","hebrew_niqqud":"שִׁשָּׁה פָנִים לִי שׁוֹנִים מִכָּל עֵבֶר,","translit":"šiššâ p̄ānîm lî šônîm mikkol ʿēḇer,","translit_ru":"шиша фаним ли шоним микол евэр,","russian":"У меня шесть различных ликов со всех сторон,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"פה מעון אני לבהמה וגבר,","hebrew_niqqud":"פֹּה מָעוֹן אֲנִי לִבְהֵמָה וָגֵבֶר,","translit":"pōh māʿôn ʾănî liḇhēmâ wāḡēḇer,","translit_ru":"пох маон ани ливхема вагевэр,","russian":"Здесь я обитель для зверя и человека,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"ופה אשמיע קול קורא בכח,","hebrew_niqqud":"וּפֹה אַשְׁמִיעַ קוֹל קוֹרֵא בַּכֹּח,","translit":"ûp̄ōh ʾašmîaʿ qôl qôrēʾ bakkōḥ,","translit_ru":"уфох ашмиа кол коре бакох,","russian":"И здесь я мощный зов издам,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"ופה גם ככלב אוכל לנבח.","hebrew_niqqud":"וּפֹה גַּם כַּכֶּלֶב אוּכַל לִנְבֹּחַ.","translit":"ûp̄ōh gam kakkeleḇ ʾûḵal linbōaḥ.","translit_ru":"уфох гам какэлэв ухал линбоах.","russian":"И здесь, как пёс, могу я лаять.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"לפעמים דם אדם אזיל כפלג","hebrew_niqqud":"לִפְעָמִים דַּם אָדַם אַזִּיל כַּפָּלָג","translit":"lip̄ʿāmîm dam ʾāḏam ʾazzîl kappālāḡ","translit_ru":"лифамим дам адам азил капалаг","russian":"Порой я кровь людскую лью ручьём,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"ובלי משפט למו מטבח אכינה.","hebrew_niqqud":"וּבְלִי מִשְׁפָּט לָמוֹ מַטְבֵּחַ אָכִינָה.","translit":"ûḇəlî mišpāṭ lāmô maṭbēaḥ ʾāḵînâ.","translit_ru":"увэли мишпат ламо матбеах ахина.","russian":"И безо всякого суда готовлю им бойню.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"וכרגע אדיח דמי בשלג","hebrew_niqqud":"וכְרֶגַע אָדִיחַ דָּמִי בַּשָּׁלָג","translit":"wḵəreḡaʿ ʾāḏîaḥ dāmî baššālāḡ","translit_ru":"вхэрэга адиах дами башалаг","russian":"И в тот же миг я смою кровь мою в снегу,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"אז אהפך וכלבנת צמר אלבינה","hebrew_niqqud":"אָז אֵהָפֵךְ וּכְלִבְנַת צֶמֶר אַלְבִּינָה","translit":"ʾāz ʾēhāp̄ēḵ ûḵəliḇnaṯ ṣemer ʾalbînâ","translit_ru":"аз ехафех ухэливнат цэмэр албина","russian":"Тогда я преображусь и стану белым, как шерсть.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"ב","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"Б","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"גם פני ששת על כל צד ישתנו;","hebrew_niqqud":"גַּם פָּנַי שַׁשֶׁת עַל כָּל צַד ישְׁתַּנּוּ;","translit":"gam pānay šašeṯ ʿal kol ṣaḏ yštannû;","translit_ru":"гам панай шашэт ал кол цад йштану;","russian":"И мои шесть ликов на каждой стороне изменятся;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"כאופן תוך אופן יחד הוכנו;","hebrew_niqqud":"כְּאוֹפָן תּוֹך אוֹפָן יַחַד הוּכַנּוּ;","translit":"kəʾôp̄ān tôḵ ʾôp̄ān yaḥaḏ hûḵannû;","translit_ru":"кэофан тох офан йахад хухану;","russian":"Как колесо в колесе, так вместе они сотворены;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"בי ימצא האדם מרגוע לנצח","hebrew_niqqud":"בִּי יִמְצָא הָאָדָם מַרְגוֹעַ לְנֶצַח","translit":"bî yimṣāʾ hāʾāḏām marḡôaʿ ləneṣaḥ","translit_ru":"би йимца хаадам маргоа лэнэцах","russian":"Во мне найдёт человек вечный покой","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"מעמל החיים, מרגז ורצח.","hebrew_niqqud":"מַעֲמַל הַחַיִים, מֵרֹגֶז וָרֶצַח.","translit":"maʿămal haḥayîm, mērōḡez wāreṣaḥ.","translit_ru":"маамал хахайим, мерогэз варэцах.","russian":"От жизненной суеты, от гнева и убийства.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"עת אעלה כאר אז אתאזר חיל","hebrew_niqqud":"עֵת אַעֲלֶה כָּאֹר אָז אֶתְאַזַּר חַיִל","translit":"ʿēṯ ʾaʿălê kāʾōr ʾāz ʾeṯʾazzar ḥayil","translit_ru":"ет аалэ каор аз этазар хайил","russian":"Когда я взойду как свет, тогда облекусь силой,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"ואגלה כל נסתר ואגרש ליל,","hebrew_niqqud":"וַאֲגַלֶּה כָּל נִסְתָּר וַאֲגָרֵשׁ לַיִל,","translit":"waʾăḡallê kol nistār waʾăḡārēš layil,","translit_ru":"ваагалэ кол нистар ваагареш лайил,","russian":"И всё сокрытое открою, и ночь прогоню,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"אז גם חי הנני ומאכלי עשב.","hebrew_niqqud":"אָז גַּם חַי הִנֵּני וּמַאֲכָלִי עֵשׂב.","translit":"ʾāz gam ḥay hinnēny ûmaʾăḵālî ʿēśḇ.","translit_ru":"аз гам хай хиненй умаахали есв.","russian":"Тогда я жив, и пища мне — трава.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"לפעמים אלעיטה לשור לכשב,","hebrew_niqqud":"לִפְעָמִים אֲלְעיטָה לַשׁוֹר לַכֶּשֶׂב,","translit":"lip̄ʿāmîm ʾălʿyṭâ lašôr lakkeśeḇ,","translit_ru":"лифамим алйта лашор лакэсэв,","russian":"Порой я ею кормлю быка и ягнёнка,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"לפעמים אבלה כל עץ ועצמות","hebrew_niqqud":"לִפעָמים אֲבַלֶּה כֹּל עֵץ וַעֲצָמוֹת","translit":"lip̄ʿāmym ʾăḇallê kōl ʿēṣ waʿăṣāmôṯ","translit_ru":"лифамйм авалэ кол ец ваацамот","russian":"Порой я пожираю всякое дерево и кости,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"גם שם רשע אכחיד מעל אדמות.","hebrew_niqqud":"גַּם שֵׁם רָשָׁע אַכחִיד מַעַל אָדָמוֹת.","translit":"gam šēm rāšāʿ ʾaḵḥîḏ maʿal ʾāḏāmôṯ.","translit_ru":"гам шем раша аххид маал адамот.","russian":"И имя нечестивца сотру с лица земли.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"פה בלבב איש עמק פני אסתירה,","hebrew_niqqud":"פֹּה בִּלְבַב אִישׁ עְמֹק פָּנַי אַסְתִּירָה,","translit":"pōh bilḇaḇ ʾîš ʿəmōq pānay ʾastîrâ,","translit_ru":"пох билвав иш эмок панай астира,","russian":"Здесь, глубоко в сердце человека, я лик свой сокрою,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"אז אתראה פנים, אשפך דם כמים;","hebrew_niqqud":"אָז אֶתְרָאֶה פָנִים, אֵשְׁפֹּךְ דָּם כַּמָּיִם;","translit":"ʾāz ʾeṯrāʾê p̄ānîm, ʾēšəpōḵ dām kammāyim;","translit_ru":"аз этраэ фаним, ешэпох дам камайим;","russian":"Тогда явлю я лик свой, проливая кровь, как воду;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"ופה אצא אור וכרגע אזהירה,","hebrew_niqqud":"וּפֹה אֵצֵא אוֹר וּכְרֶגַע אַַזְהִירָה,","translit":"ûp̄ōh ʾēṣēʾ ʾôr ûḵəreḡaʿ ʾaazhîrâ,","translit_ru":"уфох еце ор ухэрэга аазхира,","russian":"И здесь я выйду светом, и тотчас засверкаю,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"אעוף ביעף עד לקצות השמים.","hebrew_niqqud":"אָעוּף בִּיעָף עַד לִקְצוֹת הַשָׁמָיִם.","translit":"ʾāʿûp̄ bîʿāp̄ ʿaḏ liqṣôṯ hašāmāyim.","translit_ru":"ауф биаф ад ликцот хашамайим.","russian":"Быстро помчусь я до краёв небес.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
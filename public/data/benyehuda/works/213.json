{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-213","text_key":"f9bd005ff1ca672cd532ef2a2ad771a038ac8ba2c6dfe340c96b6057b53db43f","title":"וְזֹאת בְּיִשְׂרָאֵל כִּי תִּפְרוֹֹץ מִלְחָמָה","level":null,"tags":["poetry","tehiya"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"213","content_hash":"sha256:f803cdb606ac883c52f317fac2f0a694b8efe9ef06208a0eea2cb1288445dffc","author":"שאול טשרניחובסקי","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q521410","translator":null,"translator_uri":null,"orig_language":"he","era":"tehiya","genre":"poetry","themes":[],"register":"poetic","track":"literary","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/213","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"שירי שאול טשרניחובסקי\", תל אביב: דביר, תשכ\"ח","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"213","content_hash":"sha256:f803cdb606ac883c52f317fac2f0a694b8efe9ef06208a0eea2cb1288445dffc","author":"שאול טשרניחובסקי","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q521410","translator":null,"translator_uri":null,"orig_language":"he","era":"tehiya","genre":"poetry","themes":[],"register":"poetic","track":"literary","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/213","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"שירי שאול טשרניחובסקי\", תל אביב: דביר, תשכ\"ח","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"וזאת בישראל כי תפרוץ מלחמה","hebrew_niqqud":"וְזֹאת בְּיִשְׂרָאֵל כִּי תִּפְרוֹֹץ מִלְחָמָה","translit":"wəzōʾṯ bəyiśrāʾēl kî tip̄rōwōṣ milḥāmâ","translit_ru":"вэзот бэйисраел ки тифровоц милхама","russian":"И вот в Израиле, когда разразится война,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"וזאת בישראל כי תפרוץ מלחמה!","hebrew_niqqud":"וְזֹאת בְּיִשְׂרָאֵל כִּי תִּפְרוֹץ מִלְחָמָה!","translit":"wəzōʾṯ bəyiśrāʾēl kî tip̄rôṣ milḥāmâ!","translit_ru":"вэзот бэйисраел ки тифроц милхама!","russian":"И вот в Израиле, когда разразится война!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"ועלה הכהן במעלות הבמה,","hebrew_niqqud":"וְעָלָה הַכֹּהֵן בְּמַעֲלוֹת הַבָּמָה,","translit":"wəʿālâ hakkōhēn bəmaʿălôṯ habbāmâ,","translit_ru":"вэала хакохен бэмаалот хабама,","russian":"И поднимется священник по ступеням возвышения,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"יתפלל על העם בשדה ומשמר,","hebrew_niqqud":"יִתְפַּלֵּל עַל הָעָם בַּשָּׂדֶה וּמִשְׁמָר,","translit":"yiṯpallēl ʿal hāʿām baśśāḏê ûmišmār,","translit_ru":"йитпалел ал хаам басадэ умишмар,","russian":"Будет молиться за народ в поле и на страже,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"ויפרש את-כפיו השמימה ואמר:","hebrew_niqqud":"וִיפָרֵשׂ אֶת-כַּפָּיו הַשָּׁמַיְמָה וְאָמָר:","translit":"wîp̄ārēś ʾeṯ-kappāyw haššāmaymâ wəʾāmār:","translit_ru":"вифарес эт-капав хашамайма вэамар:","russian":"И прострет свои ладони к небесам и скажет:","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"\"אל אלהים, אלהי צבאות!","hebrew_niqqud":"\"אֵל אֱלֹהִים, אֱלֹהֵי צְבָאוֹת!","translit":"\"ʾēl ʾĕlōhîm, ʾĕlōhê ṣəḇāʾôṯ!","translit_ru":"\"ел элохим, элохе цэваот!","russian":"\"О, Боже богов, Бог воинств!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"אתה היודע עבר ובאות,","hebrew_niqqud":"אַתָּה הַיּוֹדֵעַ עָבָר וּבָאוֹת,","translit":"ʾattâ hayyôḏēaʿ ʿāḇār ûḇāʾôṯ,","translit_ru":"ата хайодеа авар уваот,","russian":"Ты, Знающий прошлое и грядущее,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"אי חרב תצמא וחנית אי תרעב,","hebrew_niqqud":"אֵי חֶרֶב תִּצְמָא וַחֲנִית אֵי תִּרְעָב,","translit":"ʾê ḥereḇ tiṣmāʾ waḥănîṯ ʾê tirʿāḇ,","translit_ru":"е хэрэв тицма ваханит е тирав,","russian":"Где меч жаждет, и копье голодает,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"תוצאות מלחמה, עתידות פני הקרב;","hebrew_niqqud":"תּוֹצְאוֹת מִלְחָמָה, עֲתִידוֹת פְּנֵי הַקְּרָב;","translit":"tôṣəʾôṯ milḥāmâ, ʿăṯîḏôṯ pənê haqqərāḇ;","translit_ru":"тоцэот милхама, атидот пэне хакэрав;","russian":"Исходы войны, грядущий лик сраженья;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"אתה הזורע עפרות הברזל","hebrew_niqqud":"אַתָּה הַזּוֹרֵעַ עַפְרוֹת הַבַּרְזֶל","translit":"ʾattâ hazzôrēaʿ ʿap̄rôṯ habbarzel","translit_ru":"ата хазореа афрот хабарзэл","russian":"Ты, Сеющий железные руды","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"ובמאמרך וריד נחשת נוזל,","hebrew_niqqud":"וּבְמַאֲמָרְךָ וְרִיד נְחֹשֶׁת נוֹזֵל,","translit":"ûḇəmaʾămārəḵā wərîḏ nəḥōšeṯ nôzēl,","translit_ru":"увэмаамарэха вэрид нэхошэт нозел,","russian":"И по Твоему слову течет медная жила,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"צררתם אוצרות במכרה ומחצב","hebrew_niqqud":"צְרַרְתָּם אוֹצָרוֹת בְּמִכְרֶה וּמַחְצָב","translit":"ṣərartām ʾôṣārôṯ bəmiḵrê ûmaḥṣāḇ","translit_ru":"цэрартам оцарот бэмихрэ умахцав","russian":"Ты заключил сокровища в руднике и каменоломне,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"לתת בידי עבד עומד על חייו.","hebrew_niqqud":"לָתֵת בִּידֵי עֶבֶד עוֹמֵד עַל חַיָּיו.","translit":"lāṯēṯ bîḏê ʿeḇeḏ ʿômēḏ ʿal ḥayyāyw.","translit_ru":"латет биде эвэд омед ал хайав.","russian":"Чтобы дать их в руки раба, борющегося за свою жизнь.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"מדוע הכית אותם בסנורים,","hebrew_niqqud":"מַדּוּעַ הִכִּיתָ אוֹתָם בְּסַנְוֵרִים,","translit":"maddûaʿ hikkîṯā ʾôṯām bəsanwērîm,","translit_ru":"мадуа хикита отам бэсанверим,","russian":"Почему Ты поразил их слепотой,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"קהים וקשים כטרשים בהרים,","hebrew_niqqud":"קֵהִים וְקָשִׁים כַּטְּרָשִׁים בֶּהָרִים,","translit":"qēhîm wəqāšîm kaṭṭərāšîm behārîm,","translit_ru":"кехим вэкашим катэрашим бэхарим,","russian":"Отупевших и твердых, как скалы в горах,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"אשר לא יבחינו צדיק ורשע,","hebrew_niqqud":"אֲשֶׁר לֹא יַבְחִינוּ צַדִּיק וְרָשָׁע,","translit":"ʾăšer lōʾ yaḇḥînû ṣaddîq wərāšāʿ,","translit_ru":"ашэр ло йавхину цадик вэраша,","russian":"Которые не различают праведника и злодея,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"אוכלים בטובים ואשר לא פשע?","hebrew_niqqud":"אוֹכְלִים בַּטּוֹבִים וַאֲשֶׁר לֹא פָּשָׁע?","translit":"ʾôḵəlîm baṭṭôḇîm waʾăšer lōʾ pāšāʿ?","translit_ru":"охэлим батовим ваашэр ло паша?","russian":"Пожирающих добрых и неповинных?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"תן און למתכת ונטע בה בינה,","hebrew_niqqud":"תֵּן אוֹן לַמַּתֶּכֶת וּנְטַע בָּהּ בִּינָה,","translit":"tēn ʾôn lammatteḵeṯ ûnəṭaʿ bāh bînâ,","translit_ru":"тен он ламатэхэт унэта бах бина,","russian":"Дай силу металлу и вложи в него разум,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"אשר לא תבגד בידה-ימינה,","hebrew_niqqud":"אֲשֶׁר לֹא תִּבְגֹד בְּיָדָהּ-יְמִינָהּ,","translit":"ʾăšer lōʾ tiḇḡōḏ bəyāḏāh-yəmînāh,","translit_ru":"ашэр ло тивгод бэйадах-йэминах,","russian":"Чтобы не предал он правую руку,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"וכף משטיננו תדל ותאחר,","hebrew_niqqud":"וְכַף מַשְׂטִינֵנוּ תִּדַּל וּתְאַחֵר,","translit":"wəḵap̄ maśṭînēnû tiddal ûṯəʾaḥēr,","translit_ru":"вэхаф мастинену тидал утэахер,","russian":"И рука наших врагов ослабнет и замедлится,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"תיעף בתנופה, ברזלה יתפורר,","hebrew_niqqud":"תִּיעַף בַּתְּנוּפָה, בַּרְזִלָּהּ יִתְפּוֹרֵר,","translit":"tîʿap̄ battənûp̄â, barzillāh yiṯpôrēr,","translit_ru":"тиаф батэнуфа, барзилах йитпорер,","russian":"Утомится в замахе, железо их рассыплется,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"תסגור עד תליו, על חציו הקלים,","hebrew_niqqud":"תִּסְגּוֹר עַד תֶּלְיוֹ, עַל חִצָּיו הַקַּלִּים,","translit":"tisgôr ʿaḏ telyô, ʿal ḥiṣṣāyw haqqallîm,","translit_ru":"тисгор ад тэлйо, ал хицав хакалим,","russian":"Да сомкнутся его колчаны над легкими его стрелами,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"יצר נדנו וילין הכלים.","hebrew_niqqud":"יִצַּר נְדָנוֹ וְיָלִין הַכֵּלִים.","translit":"yiṣṣar nəḏānô wəyālîn hakkēlîm.","translit_ru":"йицар нэдано вэйалин хакелим.","russian":"Да сожмется его ножна, и да стонут орудья.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"\"אל אלהים, אלהי התקומה!","hebrew_niqqud":"\"אֵל אֱלֹהִים, אֱלֹהֵי הַתְּקוּמָה!","translit":"\"ʾēl ʾĕlōhîm, ʾĕlōhê hattəqûmâ!","translit_ru":"\"ел элохим, элохе хатэкума!","russian":"\"О, Боже богов, Бог Возрождения!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"אתה היודע נגעי האמה,","hebrew_niqqud":"אַתָּה הַיּוֹדֵעַ נִגְעֵי הָאֻמָּה,","translit":"ʾattâ hayyôḏēaʿ niḡʿê hāʾūmmâ,","translit_ru":"ата хайодеа ниге хаума,","russian":"Ты, Знающий язвы народа,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"מונה פצעיה לא-גלודי דורות","hebrew_niqqud":"מוֹנֶה פְּצָעֶיהָ לֹא-גְלוּדֵי דּוֹרוֹת","translit":"mônê pəṣāʿêhā lōʾ-ḡəlûḏê dôrôṯ","translit_ru":"монэ пэцаеха ло-гэлуде дорот","russian":"Считающий ее незаживающие раны поколений,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"את כל הנגלות והנסתרות,","hebrew_niqqud":"אֶת כָּל הַנִּגְלוֹת וְהַנִּסְתָּרוֹת,","translit":"ʾeṯ kol hanniḡlôṯ wəhannistārôṯ,","translit_ru":"эт кол ханиглот вэханистарот,","russian":"Все явные и скрытые,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"ורקב-בשר לבנו אוכל מבפנים,","hebrew_niqqud":"וּרְקַב-בְּשַׂר לִבֵּנוּ אוֹכֵל מִבִּפְנִים,","translit":"ûrəqaḇ-bəśar libbēnû ʾôḵēl mibbip̄nîm,","translit_ru":"урэкав-бэсар либену охел мибифним,","russian":"И гниль плоти нашего сердца разъедает изнутри,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"פשעי ראשי-עם וחטאת-כהנים,","hebrew_niqqud":"פִּשְׁעֵי רָאשֵׁי-עָם וְחַטַּאת-כֹּהֲנִים,","translit":"pišʿê rāʾšê-ʿām wəḥaṭṭaʾṯ-kōhănîm,","translit_ru":"пише раше-ам вэхатат-коханим,","russian":"Преступления вождей народа и грехи священников,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"הסר מקרבנו לב דל וקטן,","hebrew_niqqud":"הָסֵר מִקִּרְבֵּנוּ לֵב דַּל וְקָטָן,","translit":"hāsēr miqqirbēnû lēḇ dal wəqāṭān,","translit_ru":"хасер микирбену лев дал вэкатан,","russian":"Удали из нашей среды сердце скудное и мелкое,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"אמר ולא ירקוד בתוכנו שטן.","hebrew_niqqud":"אֱמָר וְלֹא יִרְקוֹד בְּתוֹכֵנוּ שָׂטָן.","translit":"ʾĕmār wəlōʾ yirqôḏ bəṯôḵēnû śāṭān.","translit_ru":"эмар вэло йиркод бэтохену сатан.","russian":"Повелевай, и да не будет плясать среди нас сатана.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"אשר לא יכנו מחנות מחנות","hebrew_niqqud":"אֲשֶׁר לֹא יַכֵּנוּ מַחֲנוֹת מַחֲנוֹת","translit":"ʾăšer lōʾ yakkēnû maḥănôṯ maḥănôṯ","translit_ru":"ашэр ло йакену маханот маханот","russian":"Чтобы не поражали друг друга полки полков,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"(שמחה לאויבנו ועיניו נהנות).","hebrew_niqqud":"(שִׂמְחָה לְאוֹיְבֵנוּ וְעֵינָיו נֵהָנוֹת).","translit":"(śimḥâ ləʾôyəḇēnû wəʿênāyw nēhānôṯ).","translit_ru":"(симха лэойэвену вэенав неханот).","russian":"(Радость нашим врагам, и глаза их наслаждаются).","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r33","order_index":33,"hebrew_plain":"בזים זה לזה ואחים-משנאים,","hebrew_niqqud":"בָּזִים זֶה לָזֶה וְאַחִים-מְשַׂנְּאִים,","translit":"bāzîm zê lāzê wəʾaḥîm-məśannəʾîm,","translit_ru":"базим зэ лазэ вэахим-мэсанэим,","russian":"Презирающие друг друга, и братья, полные ненависти,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r34","order_index":34,"hebrew_plain":"ללא ניב-אחד וללבבות משנים.","hebrew_niqqud":"לְלֹא נִיב-אֶחָד וְלִלְבָבוֹת מְשֻׁנִּים.","translit":"ləlōʾ nîḇ-ʾeḥāḏ wəlilḇāḇôṯ məšūnnîm.","translit_ru":"лэло нив-эхад вэлилвавот мэшуним.","russian":"Без единой речи, с раздвоенными сердцами.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r35","order_index":35,"hebrew_plain":"נורא, טהרנו בדם, במארה,","hebrew_niqqud":"נוֹרָא, טַהֲרֵנוּ בַּדָּם, בַּמְּאֵרָה,","translit":"nôrāʾ, ṭahărēnû baddām, bamməʾērâ,","translit_ru":"нора, тахарену бадам, бамэера,","russian":"О, Грозный, очисти нас кровью и проклятьем,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r36","order_index":36,"hebrew_plain":"חדש נעורינו כזיז בבערה.","hebrew_niqqud":"חַדֵּשׁ נְעוּרֵינוּ כַּזִּיז בַּבְּעֵרָה.","translit":"ḥaddēš nəʿûrênû kazzîz babbəʿērâ.","translit_ru":"хадеш нэурену казиз бабэера.","russian":"Обнови нашу юность, как Феникс в пожаре.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r37","order_index":37,"hebrew_plain":"בער מתוכנו את עש-האדם,","hebrew_niqqud":"בָּעֵר מִתּוֹכֵנוּ אֶת עָשׁ-הָאָדָם,","translit":"bāʿēr mittôḵēnû ʾeṯ ʿāš-hāʾāḏām,","translit_ru":"баер митохену эт аш-хаадам,","russian":"Искорени из нашей среды человека-мотылька,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r38","order_index":38,"hebrew_plain":"טפיל-העדה אשר פיו מאדם","hebrew_niqqud":"טַפִּיל-הָעֵדָה אֲשֶׁר פִּיו מְאָדָּם","translit":"ṭappîl-hāʿēḏâ ʾăšer pîw məʾāddām","translit_ru":"тапил-хаеда ашэр пив мэадам","russian":"Паразита общины, чей рот обагрен кровью,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r39","order_index":39,"hebrew_plain":"משתות בדליו הגדול דם-דלים,","hebrew_niqqud":"מִשְּׁתוֹת בִּדְלִיּוֹ הַגָּדוֹל דַּם-דַּלִּים,","translit":"miššəṯôṯ biḏliyyô haggāḏôl dam-dallîm,","translit_ru":"мишэтот бидлийо хагадол дам-далим,","russian":"Пьющего из своих кубков великую кровь бедняков,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r40","order_index":40,"hebrew_plain":"מפקיע השער ושבר מעלים,","hebrew_niqqud":"מַפְקִיעַ הַשַּׁעַר וְשֶׁבֶר מַעְלִים,","translit":"map̄qîaʿ haššaʿar wəšeḇer maʿlîm,","translit_ru":"мафкиа хашаар вэшэвэр малим,","russian":"Взвинчивающего цены и разоряющего доходы,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r41","order_index":41,"hebrew_plain":"אותו השמח לצוק העתים,","hebrew_niqqud":"אוֹתוֹ הַשָּׂמֵחַ לְצוֹק הָעִתִּים,","translit":"ʾôṯô haśśāmēaḥ ləṣôq hāʿittîm,","translit_ru":"ото хасамеах лэцок хаитим,","russian":"Того, кто радуется бедам времен,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r42","order_index":42,"hebrew_plain":"השש לבלהות בני-עמו הנחתים","hebrew_niqqud":"הַשָּׂשׂ לְבַלְהוֹת בְּנֵי-עַמּוֹ הַנְחִתִּים","translit":"haśśāś ləḇalhôṯ bənê-ʿammô hanḥittîm","translit_ru":"хасас лэвалхот бэне-амо ханхитим","russian":"Ликующего ужасам своего народа, повергнутого","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r43","order_index":43,"hebrew_plain":"בשדה מלחמה ורמות המשמר,","hebrew_niqqud":"בִּשְׂדֵה מִלְחָמָה וְרָמוֹת הַמִּשְׁמָר,","translit":"biśḏê milḥāmâ wərāmôṯ hammišmār,","translit_ru":"бисде милхама вэрамот хамишмар,","russian":"На поле брани и на высоких постах,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r44","order_index":44,"hebrew_plain":"השש אל רעב, ומהומה וליום מר,","hebrew_niqqud":"הַשָּׂשׂ אֶל רָעָב, וּמְהוּמָה וּלְיוֹם מָר,","translit":"haśśāś ʾel rāʿāḇ, ûməhûmâ ûləyôm mār,","translit_ru":"хасас эл раав, умэхума улэйом мар,","russian":"Ликующего голоду, смятению и горькому дню,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r45","order_index":45,"hebrew_plain":"דואג לשמנו וכואב אך לעורו, –","hebrew_niqqud":"דּוֹאֵג לְשַׁמְנוֹ וְכוֹאֵב אַךְ לְעוֹרוֹ, –","translit":"dôʾēḡ ləšamnô wəḵôʾēḇ ʾaḵ ləʿôrô, –","translit_ru":"доег лэшамно вэхоев ах лэоро, –","russian":"Заботящегося о своем имени и скорбящего лишь о своей шкуре, –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r46","order_index":46,"hebrew_plain":"יבער אסמו, יבקע בכורו,","hebrew_niqqud":"יִבְעַר אֲסָמוֹ, יִבָּקַע בְּכוֹרוֹ,","translit":"yiḇʿar ʾăsāmô, yibbāqaʿ bəḵôrô,","translit_ru":"йивар асамо, йибака бэхоро,","russian":"Пусть сгорит его амбар, пусть разверзнется его первенец,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r47","order_index":47,"hebrew_plain":"ימק במו אסם ועינו רעבה,","hebrew_niqqud":"יִמַּק בְּמוֹ אֹסֶם וְעֵינוֹ רְעֵבָה,","translit":"yimmaq bəmô ʾōsem wəʿênô rəʿēḇâ,","translit_ru":"йимак бэмо осэм вэено рэева,","russian":"Пусть сгниет в своем амбаре, и глаз его пусть останется голодным,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r48","order_index":48,"hebrew_plain":"צמוק ושט, כבד-פה, צבה מעי וקיבה!\"","hebrew_niqqud":"צְמוּק וֶשֶׁט, כְּבַד-פֶּה, צְבֵה מְעִי וְקֵיבָה!\"","translit":"ṣəmûq wešeṭ, kəḇaḏ-pê, ṣəḇê məʿî wəqêḇâ!\"","translit_ru":"цэмук вэшэт, кэвад-пэ, цэве мэи вэкева!\"","russian":"Иссохший язык, тяжелоротый, опухшие кишки и желудок!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r49","order_index":49,"hebrew_plain":"תל-אביב, 1939","hebrew_niqqud":"תֵּל-אָבִיב, 1939","translit":"tēl-ʾāḇîḇ, 1939","translit_ru":"тел-авив, 1939","russian":"Тель-Авив, 1939","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-54","text_key":"c16751f7378d11bc771f0bbf32529d4a4f17e5951efba5b71aff6138f37782b9","title":"מִקְרָאֵי צִיּוֹן","level":null,"tags":["poetry","tehiya"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"54","content_hash":"sha256:32434b74e456ed66cdb6fcfb5c35f9e0d1b52db0be960d09984f5d48ae98c820","author":"חיים נחמן ביאליק","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q359705","translator":null,"translator_uri":null,"orig_language":"he","era":"tehiya","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/54","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: תל אביב: דביר, תשל\"ג","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"54","content_hash":"sha256:32434b74e456ed66cdb6fcfb5c35f9e0d1b52db0be960d09984f5d48ae98c820","author":"חיים נחמן ביאליק","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q359705","translator":null,"translator_uri":null,"orig_language":"he","era":"tehiya","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/54","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: תל אביב: דביר, תשל\"ג","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"מקראי ציון","hebrew_niqqud":"מִקְרָאֵי צִיּוֹן","translit":"miqrāʾê ṣiyyôn","translit_ru":"микрае цийон","russian":"Воззвания Сиона","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"לזכר הקונגרס בבזיליאה","hebrew_niqqud":"לְזֵכֶר הַקּוֹנְגְּרֵס בִּבְּזִילִיאָה","translit":"ləzēḵer haqqônəgərēs bibbəzîlîʾâ","translit_ru":"лэзехэр хаконэгэрес бибэзилиа","russian":"В память о Базельском конгрессе","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"איד עמכם קבצכם מפנות הגלה,","hebrew_niqqud":"אֵיד עַמְּכֶם קִבֶּצְכֶם מִפִּנּוֹת הַגֹּלָה,","translit":"ʾêḏ ʿamməḵem qibbeṣḵem mippinnôṯ haggōlâ,","translit_ru":"ед амэхэм кибэцхэм мипинот хагола,","russian":"О горе вам! Оно созвало вас из углов изгнания,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"נאקתו המרה את-כלכם הקימה –","hebrew_niqqud":"נַאֲקָתוֹ הַמָּרָה אֶת-כֻּלְּכֶם הֵקִימָה –","translit":"naʾăqāṯô hammārâ ʾeṯ-kūlləḵem hēqîmâ –","translit_ru":"наакато хамара эт-кулэхэм хекима –","russian":"Его горький стон всех вас поднял –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"והנה נהיתה המראה הגדולה,","hebrew_niqqud":"וְהִנֵּה נִהְיְתָה הַמַּרְאָה הַגְּדוֹלָה,","translit":"wəhinnê nihyəṯâ hammarʾâ haggəḏôlâ,","translit_ru":"вэхине нихйэта хамара хагэдола,","russian":"И вот, свершилось великое видение,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"ותפרץ ממקורה הנאמן הדמעה","hebrew_niqqud":"וַתִּפְרֹץ מִמְּקוֹרָהּ הַנֶּאֱמָן הַדִּמְעָה","translit":"wattip̄rōṣ mimməqôrāh hanneʾĕmān haddimʿâ","translit_ru":"ватифроц мимэкорах ханээман хадима","russian":"И прорвалась из верного источника слеза,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"הגדולה, הנעימה, הבהירה, החמה,","hebrew_niqqud":"הַגְּדוֹלָה, הַנְּעִימָה, הַבְּהִירָה, הַחַמָּה,","translit":"haggəḏôlâ, hannəʿîmâ, habbəhîrâ, haḥammâ,","translit_ru":"хагэдола, ханэима, хабэхира, хахама,","russian":"Великая, приятная, светлая, тёплая,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"אליה נתפלל זה-כמה.","hebrew_niqqud":"אֵלֶיהָ נִתְפַּלֵּל זֶה-כַּמָּה.","translit":"ʾēlêhā niṯpallēl zê-kammâ.","translit_ru":"елеха нитпалел зэ-кама.","russian":"О которой мы молились столько времени.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"אין זאת כי אם-באו עד-נפש המים,","hebrew_niqqud":"אֵין זֹאת כִּי אִם-בָּאוּ עַד-נֶפֶשׁ הַמָּיִם,","translit":"ʾên zōʾṯ kî ʾim-bāʾû ʿaḏ-nep̄eš hammāyim,","translit_ru":"ен зот ки им-бау ад-нэфэш хамайим,","russian":"Это не что иное, как воды дошли до души,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"ובבבת העין הרעה נגעה,","hebrew_niqqud":"וּבְבָבַת הָעַיִן הָרָעָה נָגָעָה,","translit":"ûḇəḇāḇaṯ hāʿayin hārāʿâ nāḡāʿâ,","translit_ru":"увэвават хаайин хараа нагаа,","russian":"И коснулась зрачка злого ока,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"כי קרעה הזעקה את-לב השמים,","hebrew_niqqud":"כִּי קָרְעָה הַזְּעָקָה אֶת-לֵב הַשָּׁמָיִם,","translit":"kî qārəʿâ hazzəʿāqâ ʾeṯ-lēḇ haššāmāyim,","translit_ru":"ки карэа хазэака эт-лев хашамайим,","russian":"Ибо вопль разорвал сердце небес,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"ושאול בעדנו לרחמים קראה.","hebrew_niqqud":"וּשְׁאוֹל בַּעֲדֵנוּ לְרַחֲמִים קָרָאָה.","translit":"ûšəʾôl baʿăḏēnû ləraḥămîm qārāʾâ.","translit_ru":"ушэол баадену лэрахамим караа.","russian":"И Шеол о нас взывал о милости.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"ולבב מי לא-עלץ ברעדה לקראתכם,","hebrew_niqqud":"וּלְבַב מִי לֹא-עָלַץ בִּרְעָדָה לִקְרַאתְכֶם,","translit":"ûləḇaḇ mî lōʾ-ʿālaṣ birʿāḏâ liqraʾṯḵem,","translit_ru":"улэвав ми ло-алац бирада ликратхэм,","russian":"И чьё сердце не возрадовалось в трепете навстречу вам,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"לא ברך מרחוק עדתכם?","hebrew_niqqud":"לֹא בֵרַךְ מֵרָחוֹק עֲדַתְכֶם?","translit":"lōʾ ḇēraḵ mērāḥôq ʿăḏaṯḵem?","translit_ru":"ло верах мерахок адатхэм?","russian":"Не благословило издалека ваше собрание?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"מכנפות הארץ לא-זמירות הבאתם –","hebrew_niqqud":"מִכַּנְפוֹת הָאָרֶץ לֹא-זְמִירוֹת הֲבֵאתֶם –","translit":"mikkanp̄ôṯ hāʾāreṣ lōʾ-zəmîrôṯ hăḇēʾṯem –","translit_ru":"миканфот хаарэц ло-зэмирот хаветэм –","russian":"Из концов земли вы принесли не песнопения –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"כי קינות נושנות החדשות לבקרים,","hebrew_niqqud":"כִּי קִינוֹת נוֹשָׁנוֹת הַחֲדָשׁוֹת לַבְּקָרִים,","translit":"kî qînôṯ nôšānôṯ haḥăḏāšôṯ labbəqārîm,","translit_ru":"ки кинот ношанот хахадашот лабэкарим,","russian":"Но старинные плачи, что обновляются по утрам,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"ולעיני השמש את-עמכם הראיתם","hebrew_niqqud":"וּלְעֵינֵי הַשֶּׁמֶשׁ אֶת-עַמְּכֶם הֶרְאֵיתֶם","translit":"ûləʿênê haššemeš ʾeṯ-ʿamməḵem herʾêṯem","translit_ru":"улэене хашэмэш эт-амэхэм хэретэм","russian":"И перед очами солнца вы показали ваш народ,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"מגולל בדמיו כמים מגרים;","hebrew_niqqud":"מְגוֹלָל בְּדָמָיו כְּמַיִם מֻגָּרִים;","translit":"məḡôlāl bəḏāmāyw kəmayim mūggārîm;","translit_ru":"мэголал бэдамав кэмайим мугарим;","russian":"Валяющимся в крови своей, как потоки вод;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"ובעמדם נד אחד וברדתם יחד –","hebrew_niqqud":"וּבְעָמְדָם נֵד אֶחָד וּבְרִדְתָּם יָחַד –","translit":"ûḇəʿāməḏām nēḏ ʾeḥāḏ ûḇəriḏtām yāḥaḏ –","translit_ru":"увэамэдам нед эхад увэридтам йахад –","russian":"И когда они встали единой стеной и пали вместе –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"בשר מי אז לא-יסמר מפחד?","hebrew_niqqud":"בְּשַׂר מִי אָז לֹא-יִסְמַר מִפָּחַד?","translit":"bəśar mî ʾāz lōʾ-yismar mippāḥaḏ?","translit_ru":"бэсар ми аз ло-йисмар мипахад?","russian":"Чья плоть тогда не содрогнулась от страха?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"תרדנה נא יחדו גם-דמעות עמנו,","hebrew_niqqud":"תֵּרַדְנָה נָא יַחְדָּו גַּם-דִמְעוֹת עַמֵּנוּ,","translit":"tēraḏnâ nāʾ yaḥdāw gam-ḏimʿôṯ ʿammēnû,","translit_ru":"терадна на йахдав гам-димот амену,","russian":"Пусть же вместе потекут и слёзы нашего народа,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"תבאנה נאד אחד מתפוצות הגלה.","hebrew_niqqud":"תָּבֹאנָה נֹאד אֶחָד מִתְּפוּצוֹת הַגֹּלָה.","translit":"tāḇōʾnâ nōʾḏ ʾeḥāḏ mittəp̄ûṣôṯ haggōlâ.","translit_ru":"тавона нод эхад митэфуцот хагола.","russian":"Пусть соберутся как в единый мех из рассеяний изгнания.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"אם-פדות אין עמנו – עוד חי גאלנו,","hebrew_niqqud":"אִם-פְּדוּת אֵין עִמָּנוּ – עוֹד חַי גֹּאֲלֵנוּ,","translit":"ʾim-pəḏûṯ ʾên ʿimmānû – ʿôḏ ḥay gōʾălēnû,","translit_ru":"им-пэдут ен иману – од хай гоалену,","russian":"Если нет у нас искупления – наш Искупитель ещё жив,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"וקמה ובאה השעה הגדולה.","hebrew_niqqud":"וְקָמָה וּבָאָה הַשָּׁעָה הַגְּדוֹלָה.","translit":"wəqāmâ ûḇāʾâ haššāʿâ haggəḏôlâ.","translit_ru":"вэкама уваа хашаа хагэдола.","russian":"И настанет и придёт великий час.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"ואחרון על-עפר את-קולכם יעלה","hebrew_niqqud":"וְאַחֲרוֹן עַל-עָפָר אֶת-קוֹלְכֶם יַעֲלֶה","translit":"wəʾaḥărôn ʿal-ʿāp̄ār ʾeṯ-qôləḵem yaʿălê","translit_ru":"вэахарон ал-афар эт-колэхэм йаалэ","russian":"И последний из праха вознесёт ваш голос,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"הראשון ליסד המעלה.","hebrew_niqqud":"הָרִאשׁוֹן לִיסֻד הַמַּעֲלָה.","translit":"hāriʾšôn lîsūḏ hammaʿălâ.","translit_ru":"харишон лисуд хамаала.","russian":"Первый, кто положит начало восхождению.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"ובדברי ימינו המלאים אנחות","hebrew_niqqud":"וּבְדִבְרֵי יָמֵינוּ הַמְלֵאִים אֲנָחוֹת","translit":"ûḇəḏiḇrê yāmênû haməlēʾîm ʾănāḥôṯ","translit_ru":"увэдивре йамену хамэлеим анахот","russian":"И в летописях наших дней, полных стенаний,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"תאצר כפנינה דמעתכם הקדושה.","hebrew_niqqud":"תֵּאָצֵר כִּפְנִינָה דִּמְעַתְכֶם הַקְּדוֹשָׁה.","translit":"tēʾāṣēr kip̄nînâ dimʿaṯḵem haqqəḏôšâ.","translit_ru":"теацер кифнина диматхэм хакэдоша.","russian":"Сохранится как жемчужина ваша святая слеза.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"מציבי הדלתות ובני הטפחות","hebrew_niqqud":"מַצִּיבֵי הַדְּלָתוֹת וּבֹנֵי הַטְפָחוֹת","translit":"maṣṣîḇê haddəlāṯôṯ ûḇōnê haṭp̄āḥôṯ","translit_ru":"мациве хадэлатот увоне хатфахот","russian":"Возводившие врата и строившие стропила","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"יכירו מי-ירה האבן הראשה –","hebrew_niqqud":"יַכִּירוּ מִי-יָרָה הָאֶבֶן הָרֹאשָׁה –","translit":"yakkîrû mî-yārâ hāʾeḇen hārōʾšâ –","translit_ru":"йакиру ми-йара хаэвэн хароша –","russian":"Узнают, кто заложил краеугольный камень –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"אך גם-במחשכים כשמש בל-ידעך","hebrew_niqqud":"אַךְ גַּם-בְּמַחֲשַׁכִּים כַּשֶּׁמֶשׁ בַּל-יִדְעָךְ","translit":"ʾaḵ gam-bəmaḥăšakkîm kaššemeš bal-yiḏʿāḵ","translit_ru":"ах гам-бэмахашаким кашэмэш бал-йидах","russian":"Но даже во мраке, подобно солнцу, не угаснет","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"זכרונכם בעמכם הנדח.","hebrew_niqqud":"זִכְרוֹנְכֶם בְּעַמְּכֶם הַנִּדָּח.","translit":"ziḵrônəḵem bəʿamməḵem hanniddāḥ.","translit_ru":"зихронэхэм бэамэхэм ханидах.","russian":"Ваша память в вашем рассеянном народе.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"תשרי, תרנ\"ח, סוסנוביצא.","hebrew_niqqud":"תִּשְׁרֵי, תרנ\"ח, סוֹסְנוֹבִיצָא.","translit":"tišrê, ṯrnḥ\", sôsənôḇîṣāʾ.","translit_ru":"тишре, трнх\", сосэновица.","russian":"Тишрей, 5658, Сосновице.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
:"эшэт барзэл вахацоцэра","russian":"Железная болванка и труба,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"מחמר אחד","hebrew_niqqud":"מֵחֹמֶר אַחַד","translit":"mēḥōmer ʾaḥaḏ","translit_ru":"мехомэр ахад","russian":"Из одного вещества,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"הן קרצנו יחד","hebrew_niqqud":"הֵן קֹרַצְנוּ יַחַד","translit":"hēn qōraṣnû yaḥaḏ","translit_ru":"хен корацну йахад","russian":"Мы ведь сотворены вместе.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"– את פי העשת החצצרה שאלה –","hebrew_niqqud":"– אֶת פִּי הָעֶשֶׁת הַחֲצֹצְרָה שָׁאָלָה –","translit":"– ʾeṯ pî hāʿešeṯ haḥăṣōṣərâ šāʾālâ –","translit_ru":"– эт пи хаэшэт хахацоцэра шаала –","russian":"– Спросила труба железный слиток –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"ומדוע כה את מני נבדלה?","hebrew_niqqud":"וּמַדּוּעַ כֹּה אַתְּ מֶנִּי נִבְדָּלָה?","translit":"ûmaddûaʿ kōh ʾat mennî niḇdālâ?","translit_ru":"умадуа кох ат мэни нивдала?","russian":"И чем ты так от меня отлична?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"אני כמעט רוח","hebrew_niqqud":"אֲנִי כִּמְעַט רוּחַ","translit":"ʾănî kimʿaṭ rûaḥ","translit_ru":"ани кимат руах","russian":"Я почти дух,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"צח בי יפוח","hebrew_niqqud":"צַח בִּי יָפוּחַ","translit":"ṣaḥ bî yāp̄ûaḥ","translit_ru":"цах би йафуах","russian":"Чистый вздох во мне рождается,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"ובקול פחדים חיש הנני צוללה;","hebrew_niqqud":"וּבְקוֹל פְּחָדִים חִישׁ הִנְנִי צוֹלֵלָה;","translit":"ûḇəqôl pəḥāḏîm ḥîš hinnî ṣôlēlâ;","translit_ru":"увэкол пэхадим хиш хинни цолела;","russian":"И в глас тревог я быстро погружаюсь;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"ואת לו במטה אותך יחבטו,","hebrew_niqqud":"וָאַתְּ לוּ בַּמַּטֶּה אוֹתְךָ יַחְבֹּטוּ,","translit":"wāʾat lû bammaṭṭê ʾôṯəḵā yaḥbōṭû,","translit_ru":"ваат лу баматэ отэха йахботу,","russian":"А тебя, коль даже прутом побьют,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"לו גם לפתותים את גוך יכתו,","hebrew_niqqud":"לוּ גַּם לִפְתוֹתִים אֶת גֵּוֵךְ יִכֹּתּוּ,","translit":"lû gam lip̄ṯôṯîm ʾeṯ gēwēḵ yikkōttû,","translit_ru":"лу гам лифтотим эт гевех йикоту,","russian":"Пусть тело твое на куски разобьют,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"לא תשמיעי קול אך תדמי סלה.","hebrew_niqqud":"לֹא תַשְׁמִיעִי קוֹל אַךְ תִּדֹּמִּי סֶלָה.","translit":"lōʾ ṯašmîʿî qôl ʾaḵ tiddōmmî selâ.","translit_ru":"ло ташмии кол ах тидоми сэла.","russian":"Не издашь ты звука, навек замолчишь.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"זה פשר הדבר לדעת תשאלי","hebrew_niqqud":"זֶה פֵּשֶׁר הַדָּבָר לָדַעַת תִּשְׁאָלִי","translit":"zê pēšer haddāḇār lāḏaʿaṯ tišʾālî","translit_ru":"зэ пешэр хадавар ладаат тишали","russian":"Ты спрашиваешь, в чем тут смысл?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"– ענתה העשת","hebrew_niqqud":"– עָנַתָּהּ הָעֶשֶׁת","translit":"– ʿānattāh hāʿešeṯ","translit_ru":"– анатах хаэшэт","russian":"– Ответило железо,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"לא ידעה בשת –","hebrew_niqqud":"לֹא יָדְעָה בּשֶׁת –","translit":"lōʾ yāḏəʿâ bšeṯ –","translit_ru":"ло йадэа бшэт –","russian":"Не ведая стыда –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"יען כי רקה את לכן תצללי.","hebrew_niqqud":"יַעַן כִּי רֵקָה אַתְּ לָכֵן תִּצְלָלִי.","translit":"yaʿan kî rēqâ ʾat lāḵēn tiṣlālî.","translit_ru":"йаан ки река ат лахен тицлали.","russian":"Потому что ты пуста, оттого и звучишь.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
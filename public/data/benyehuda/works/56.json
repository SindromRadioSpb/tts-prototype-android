{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-56","text_key":"884c7feb618516e15316498c8422d5bbe00d3272fe219b9bf770a1e2ab328cc9","title":"תל־אביב","level":null,"tags":["poetry","haskalah"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"56","content_hash":"sha256:57eacead8f39782e28b1f96f6e958bc448e19ad6348f11d17e09e5160776f6d0","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/56","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"56","content_hash":"sha256:57eacead8f39782e28b1f96f6e958bc448e19ad6348f11d17e09e5160776f6d0","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/56","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"תלאביב","hebrew_niqqud":"תל־אביב","translit":"ṯl-ʾḇyḇ","translit_ru":"тл-вйв","russian":"Тель-Авив","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"במישור הלז כי אצא לשוח","hebrew_niqqud":"בַּמִּישׁוֹר הַלָּז כִּי אֵצֵא לָשׂוּחַ","translit":"bammîšôr hallāz kî ʾēṣēʾ lāśûaḥ","translit_ru":"бамишор халаз ки еце ласуах","russian":"Когда я выйду побродить по этой равнине,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"ירחב לבי, יערה עלי רוח","hebrew_niqqud":"יֵרְחַב לִבִּי, יֵעָרֶה עָלַי רוּחַ","translit":"yērəḥaḇ libbî, yēʿārê ʿālay rûaḥ","translit_ru":"йерэхав либи, йеарэ алай руах","russian":"Расширится сердце, снизойдёт на меня дух,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"וקרבי כלם יערו יכנו;","hebrew_niqqud":"וּקְרָבַי כֻּלָּם יֵעֹרוּ יִכֹּנוּ;","translit":"ûqərāḇay kūllām yēʿōrû yikkōnû;","translit_ru":"укэравай кулам йеору йикону;","russian":"И всё нутро моё пробудится и утвердится;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"ובסתר כליותי רעיון יולד","hebrew_niqqud":"וּבְסֵתֶר כִּלְיוֹתַי רַעְיוֹן יִוָּלֶד","translit":"ûḇəsēṯer kilyôṯay raʿyôn yiwwāleḏ","translit_ru":"увэсетэр килйотай район йивалэд","russian":"И в тайниках души родится мысль,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"ושעפי יאבירו לקצות החלד","hebrew_niqqud":"וּשְׂעִפַּי יַאֲבִירוּ לִקְצוֹת הֶחָלֶד","translit":"ûśəʿippay yaʾăḇîrû liqṣôṯ heḥāleḏ","translit_ru":"усэипай йаавиру ликцот хэхалэд","russian":"И помыслы мои окрепнут до краёв света,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"ובגאון יוצר כל יצהלו ירנו.","hebrew_niqqud":"וּבִגְאוֹן יוֹצֵר כֹּל יִצְהֲלוּ יָרֹנוּ.","translit":"ûḇiḡʾôn yôṣēr kōl yiṣhălû yārōnû.","translit_ru":"увигон йоцер кол йицхалу йарону.","russian":"И в величии Творца всего восторжествуют и воспоют.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"יוצר כל באמר בתעופת עין,","hebrew_niqqud":"יוֹצֵר כֹּל בָּאֹמֶר בִּתְעוּפַת עָיִן,","translit":"yôṣēr kōl bāʾōmer biṯʿûp̄aṯ ʿāyin,","translit_ru":"йоцер кол баомэр битуфат айин,","russian":"Творец всего, лишь словом, во мгновение ока,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"בורא תבל מהבל, כל מאין,","hebrew_niqqud":"בּוֹרֵא תֵבֵל מֵהֶבֶל, כֹּל מֵאָיִן,","translit":"bôrēʾ ṯēḇēl mēheḇel, kōl mēʾāyin,","translit_ru":"боре тевел мехэвэл, кол меайин,","russian":"Сотворивший мир из дуновения, всё из ничего,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"הוא שכן שמש זאת פה ברקיע,","hebrew_niqqud":"הוּא שִׁכֵּן שֶׁמֶשׁ זֹאת פֹּה בָּרָקִיעַ,","translit":"hûʾ šikkēn šemeš zōʾṯ pōh bārāqîaʿ,","translit_ru":"ху шикен шэмэш зот пох баракиа,","russian":"Он поселил это солнце здесь, в небесах,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"הוא אמר ויזל זה פלג מים","hebrew_niqqud":"הוּא אָמַר וַיִּזַּל זֶה פֶּלֶג מָיִם","translit":"hûʾ ʾāmar wayyizzal zê peleḡ māyim","translit_ru":"ху амар вайизал зэ пэлэг майим","russian":"Он сказал – и потёк этот поток воды,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"ונאות השדה הלביש רקמתים,","hebrew_niqqud":"וּנְאוֹת הַשָּׂדֶה הִלְבִּישׁ רִקְמָתָיִם,","translit":"ûnəʾôṯ haśśāḏê hilbîš riqmāṯāyim,","translit_ru":"унэот хасадэ хилбиш рикматайим,","russian":"И поля облёк в дивные ткани,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"הוא הר חמד זה על עמדו הטביע.","hebrew_niqqud":"הוּא הַר חֶמֶד זֶה עַל עָמְדוֹ הִטְבִּיעַ.","translit":"hûʾ har ḥemeḏ zê ʿal ʿāməḏô hiṭbîaʿ.","translit_ru":"ху хар хэмэд зэ ал амэдо хитбиа.","russian":"Эту прекрасную гору Он утвердил на её месте.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"הוא גם בי הרוח נפח נפח","hebrew_niqqud":"הוּא גַם בִּי הָרוּחַ נָפַח נָפֹחַ","translit":"hûʾ ḡam bî hārûaḥ nāp̄aḥ nāp̄ōaḥ","translit_ru":"ху гам би харуах нафах нафоах","russian":"Он и в меня вдохнул дух,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"ובלבי שם דעת ובמתני כח,","hebrew_niqqud":"וּבְלִבִּי שָׂם דַּעַת וּבְמָתְנַי כֹּחַ,","translit":"ûḇəlibbî śām daʿaṯ ûḇəmoṯnay kōaḥ,","translit_ru":"увэлиби сам даат увэмотнай коах,","russian":"И в сердце моё вложил знание, а в чресла – силу,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"בלשוני מלה ובחכי טוב טעם","hebrew_niqqud":"בִּלְשׁוֹנִי מִלָּה וּבְחִכִּי טוּב טָעַם","translit":"bilšônî millâ ûḇəḥikkî ṭûḇ ṭāʿam","translit_ru":"билшони мила увэхики тув таам","russian":"В язык мой – слово, а в нёбо – добрый вкус,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"לשוח פה בשדה למצוא נחת","hebrew_niqqud":"לָשׂוּחַ פֹּה בַּשָּׂדֶה לִמְצוֹא נַחַת","translit":"lāśûaḥ pōh baśśāḏê limṣôʾ naḥaṯ","translit_ru":"ласуах пох басадэ лимцо нахат","russian":"Чтобы здесь, в поле, бродить и находить покой,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"ביקר שחק מעל, ארץ מתחת,","hebrew_niqqud":"בִּיקַר שַׁחַק מֵעָל, אֶרֶץ מִתָּחַת,","translit":"bîqar šaḥaq mēʿāl, ʾereṣ mittāḥaṯ,","translit_ru":"бикар шахак меал, эрэц митахат,","russian":"Взирая на величие неба сверху, земли снизу,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"לדעת כי אחד עשה כלהם.","hebrew_niqqud":"לָדַעַת כִּי אֶחָד עָשָׂה כֻּלָּהַם.","translit":"lāḏaʿaṯ kî ʾeḥāḏ ʿāśâ kūllāham.","translit_ru":"ладаат ки эхад аса кулахам.","russian":"Чтобы знать, что Один сотворил их всех.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"הוא ישב רוחו יבל זה הפרח,","hebrew_niqqud":"הוּא יַשֵּׁב רוּחוֹ יִבֹּל זֶה הַפֶּרַח,","translit":"hûʾ yaššēḇ rûḥô yibbōl zê happeraḥ,","translit_ru":"ху йашев рухо йибол зэ хапэрах,","russian":"Он отнимет Свой дух – завянет этот цветок,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"נהר זה יקפא כי יתעלם-קרח,","hebrew_niqqud":"נָהָר זֶה יִקְפָּא כִּי יִתְעַלֶּם-קֶרַח,","translit":"nāhār zê yiqpāʾ kî yiṯʿallem-qeraḥ,","translit_ru":"нахар зэ йикпа ки йиталэм-кэрах,","russian":"Эта река замёрзнет, когда покроется льдом,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"הר זה יתגלע, תתקדר השמש;","hebrew_niqqud":"הַר זֶה יִתְגַּלָּע, תִּתְקַדֵּר הַשֶּׁמֶשׁ;","translit":"har zê yiṯgallāʿ, tiṯqaddēr haššemeš;","translit_ru":"хар зэ йитгала, титкадер хашэмэш;","russian":"Эта гора расколется, померкнет солнце;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"הוא יאסף רוחו גם אני אבלה,","hebrew_niqqud":"הוּא יֶאֱסֹף רוּחוֹ גַּם אֲנִי אֶבֹּלָה,","translit":"hûʾ yeʾĕsōp̄ rûḥô gam ʾănî ʾebbōlâ,","translit_ru":"ху йээсоф рухо гам ани эбола,","russian":"Он заберёт Свой дух – и я истлею,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"יתפרדו עצמותי, אשוב לשאולה,","hebrew_niqqud":"יִתְפָּרְדוּ עַצְמוֹתַי, אָשׁוּב לִשְׁאוֹלָה,","translit":"yiṯpārəḏû ʿaṣmôṯay, ʾāšûḇ lišʾôlâ,","translit_ru":"йитпарэду ацмотай, ашув лишола,","russian":"Распадутся кости мои, вернусь в Шеол,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"אז חרבות מחי יאכל עש ורמש.","hebrew_niqqud":"אָז חָרְבוֹת מֹחִי יֹאכַל עָש וָרֶמֶשׂ.","translit":"ʾāz ḥorḇôṯ mōḥî yōʾḵal ʿāš wāremeś.","translit_ru":"аз хорвот мохи йохал аш варэмэс.","russian":"Тогда руины моей жизни съедят моль и червь.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"הוא יצהיל פניו אז ישוב כל הדר,","hebrew_niqqud":"הוּא יַצְהִיל פָּנָיו אָז יָשׁוּב כָּל הֶדֶר,","translit":"hûʾ yaṣhîl pānāyw ʾāz yāšûḇ kol heḏer,","translit_ru":"ху йацхил панав аз йашув кол хэдэр,","russian":"Он озарит Своё лицо – тогда вернётся всё великолепие,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"אז יצא אביב כחתן מחדר","hebrew_niqqud":"אָז יֵצֵא אָבִיב כֶּחָתָן מֵחֶדֶר","translit":"ʾāz yēṣēʾ ʾāḇîḇ keḥāṯān mēḥeḏer","translit_ru":"аз йеце авив кэхатан мехэдэр","russian":"Тогда весна выйдет, как жених из чертога,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"ואדמה כלתו יעטף-שית זהר;","hebrew_niqqud":"וַאֲדָמָה כַּלָּתוֹ יַעֲטֹף-שִׁית זֹהַר;","translit":"waʾăḏāmâ kallāṯô yaʿăṭōp̄-šîṯ zōhar;","translit_ru":"ваадама калато йаатоф-шит зохар;","russian":"И землю, невесту свою, окутает сияющим одеянием;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"להקות צפרים ישובו וישוררו,","hebrew_niqqud":"לַהֲקוֹת צִפֳּרִים יָשׁוּבוּ וִישׁוֹרֵרוּ,","translit":"lahăqôṯ ṣippŏrîm yāšûḇû wîšôrērû,","translit_ru":"лахакот ципорим йашуву вишореру,","russian":"Стаи птиц возвратятся и запоют,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"הרים וגבעות ירקדון ויכרכרו,","hebrew_niqqud":"הָרִים וּגְבָעוֹת יִרְקְדוּן וִיכַרְכֵּרוּ,","translit":"hārîm ûḡəḇāʿôṯ yirqəḏûn wîḵarkērû,","translit_ru":"харим угэваот йиркэдун вихаркеру,","russian":"Горы и холмы будут плясать и кружиться,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"על כל-כבוד חפה שמים לטהר!","hebrew_niqqud":"עַל כָּל-כָּבוֹד חֻפָּה שָׁמַיִם לָטֹהַר!","translit":"ʿal kāl-kāḇôḏ ḥūppâ šāmayim lāṭōhar!","translit_ru":"ал кал-кавод хупа шамайим латохар!","russian":"Над всей славой очистятся небеса!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"גם עלי לא תאטר בור תחתית פיה","hebrew_niqqud":"גַּם עָלַי לֹא תֶאְטַר בּוֹר תַּחְתִּית פִּיהָ","translit":"gam ʿālay lōʾ ṯeʾṭar bôr taḥtîṯ pîhā","translit_ru":"гам алай ло тэтар бор тахтит пиха","russian":"И для меня не затворится пасть преисподней,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"כי תשוב נשמתי אל בית אביה","hebrew_niqqud":"כִּי תָשׁוּב נִשְׁמָתִי אֶל בֵּית אָבִיהָ","translit":"kî ṯāšûḇ nišmāṯî ʾel bêṯ ʾāḇîhā","translit_ru":"ки ташув нишмати эл бет авиха","russian":"Ибо душа моя вернётся в дом Отца своего,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r33","order_index":33,"hebrew_plain":"לגור כנעוריה בין כוכבי לילה;","hebrew_niqqud":"לָגוּר כִּנְעוּרֶיהָ בֵּין כּוֹכְבֵי לָיְלָה;","translit":"lāḡûr kinʿûrêhā bên kôḵəḇê lāyəlâ;","translit_ru":"лагур кинуреха бен кохэве лайэла;","russian":"Чтобы обитать, как в юности, среди ночных звёзд;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r34","order_index":34,"hebrew_plain":"תבל עם תבליתה תשכח שכח,","hebrew_niqqud":"תֵּבֵל עִם תַּבְלִיתָהּ תִּשְׁכַּח שָׁכֹחַ,","translit":"tēḇēl ʿim taḇlîṯāh tiškaḥ šāḵōaḥ,","translit_ru":"тевел им тавлитах тишках шахоах,","russian":"Мир со всем своим тлением будет забыт,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r35","order_index":35,"hebrew_plain":"על שדי תתענג, תשמח שמח,","hebrew_niqqud":"עַל שַׁדַּי תִּתְעַנֵּג, תִּשְׂמַח שָׂמֹחַ,","translit":"ʿal šadday tiṯʿannēḡ, tiśmaḥ śāmōaḥ,","translit_ru":"ал шадай титанег, тисмах самоах,","russian":"Будет наслаждаться Всевышним, радоваться от радости,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r36","order_index":36,"hebrew_plain":"תדע דעת עליון מטה ומעלה.","hebrew_niqqud":"תֵּדַע דַּעַת עֶלְיוֹן מַטָּה וָמָעְלָה.","translit":"tēḏaʿ daʿaṯ ʿelyôn maṭṭâ wāmāʿəlâ.","translit_ru":"теда даат элйон мата вамаэла.","russian":"Познает знание Всевышнего, внизу и вверху.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
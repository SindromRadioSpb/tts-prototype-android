{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-186","text_key":"a6f5ebe00673e72505929153c1ae764e560f6dc92c0c2254b898a88fb229bbd1","title":"הם מתנערים מעפר","level":null,"tags":["poetry","tehiya"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"186","content_hash":"sha256:a23c8071952e0cc216aa380d65d3672373082d8103d10f84faf81209bc2892f8","author":"חיים נחמן ביאליק","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q359705","translator":null,"translator_uri":null,"orig_language":"he","era":"tehiya","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/186","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: תל אביב: דביר, תשל\"ג","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"186","content_hash":"sha256:a23c8071952e0cc216aa380d65d3672373082d8103d10f84faf81209bc2892f8","author":"חיים נחמן ביאליק","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q359705","translator":null,"translator_uri":null,"orig_language":"he","era":"tehiya","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/186","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: תל אביב: דביר, תשל\"ג","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"הם מתנערים מעפר","hebrew_niqqud":"הֵם מִתְנַעֲרִים מֵעָפָר","translit":"hēm miṯnaʿărîm mēʿāp̄ār","translit_ru":"хем митнаарим меафар","russian":"Они стряхивают прах,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"הם מתנערים מעפר / חיים נחמן ביאליק","hebrew_niqqud":"הֵם מִתְנַעֲרִים מֵעָפָר / חיים נחמן ביאליק","translit":"hēm miṯnaʿărîm mēʿāp̄ār / ḥyym nḥmn ḇyʾlyq","translit_ru":"хем митнаарим меафар / хййм нхмн вйлйк","russian":"Они стряхивают прах / Хаим Нахман Бялик","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"א","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"А","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"הם מתנערים מעפר, הם כבר קמים מאבלם –","hebrew_niqqud":"הֵם מִתְנַעֲרִים מֵעָפָר, הֵם כְּבָר קָמִים מֵאֶבְלָם –","translit":"hēm miṯnaʿărîm mēʿāp̄ār, hēm kəḇār qāmîm mēʾeḇlām –","translit_ru":"хем митнаарим меафар, хем кэвар камим меэвлам –","russian":"Они стряхивают прах, они уже восстают из траура –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"ואני ביום קומם","hebrew_niqqud":"וַאֲנִי בְּיוֹם קוּמָם","translit":"waʾănî bəyôm qûmām","translit_ru":"ваани бэйом кумам","russian":"А я в день их восстанья","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"חלץ אחלץ נעלי, ראשי אתן באפר,","hebrew_niqqud":"חָלֹץ אֶחְלֹץ נְעָלַי, רֹאשִׁי אֶתֵּן בָּאֵפֶר,","translit":"ḥālōṣ ʾeḥlōṣ nəʿālay, rōʾšî ʾettēn bāʾēp̄er,","translit_ru":"халоц эхлоц нэалай, роши этен баефэр,","russian":"Сниму обувь свою, голову предам праху,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"אשב יחיל ודומם.","hebrew_niqqud":"אֵשֵׁב יָחִיל וְדוּמָם.","translit":"ʾēšēḇ yāḥîl wəḏûmām.","translit_ru":"ешев йахил вэдумам.","russian":"Сяду я, скорбен и нем.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"אלם אשב לפני קיר מקדשם האלם,","hebrew_niqqud":"אִלֵּם אֵשֵׁב לִפְנֵי קִיר מִקְדָּשָׁם הָאִלֵּם,","translit":"ʾillēm ʾēšēḇ lip̄nê qîr miqdāšām hāʾillēm,","translit_ru":"илем ешев лифне кир микдашам хаилем,","russian":"Немой я сяду пред стеной их немого храма,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"ותפלתי לא תבא –","hebrew_niqqud":"וּתְפִלָּתִי לֹא תָבֹא –","translit":"ûṯəp̄illāṯî lōʾ ṯāḇōʾ –","translit_ru":"утэфилати ло таво –","russian":"И молитва моя не вознесётся –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"אל-מי ועל-מה?","hebrew_niqqud":"אֶל-מִי וְעַל-מָה?","translit":"ʾel-mî wəʿal-mâ?","translit_ru":"эл-ми вэал-ма?","russian":"К кому и о чём?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"עוד על-תלו מקדשם –","hebrew_niqqud":"עוֹד עַל-תִּלּוֹ מִקְדָּשָׁם –","translit":"ʿôḏ ʿal-tillô miqdāšām –","translit_ru":"од ал-тило микдашам –","russian":"Ещё на развалинах их храм –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"ואלהים כבר עזבו.","hebrew_niqqud":"וֵאלֹהִים כְּבָר עֲזָבוֹ.","translit":"wēʾlōhîm kəḇār ʿăzāḇô.","translit_ru":"велохим кэвар азаво.","russian":"А Бог уже оставил его.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"אבל כבד ללבבי, יגון קודר בלבבי –","hebrew_niqqud":"אֵבֶל כָּבֵד לִלְבָבִי, יָגוֹן קוֹדֵר בִּלְבָבִי –","translit":"ʾēḇel kāḇēḏ lilḇāḇî, yāḡôn qôḏēr bilḇāḇî –","translit_ru":"евэл кавед лилвави, йагон кодер билвави –","russian":"Тяжкая скорбь на сердце моём, угрюмая печаль в моём сердце –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"כלם עוברים לתמם,","hebrew_niqqud":"כֻּלָּם עוֹבְרִים לְתֻמָּם,","translit":"kūllām ʿôḇərîm ləṯūmmām,","translit_ru":"кулам овэрим лэтумам,","russian":"Все переходят к завершенью,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"ואנכי חלוץ נעל אבל יחיד אשבה,","hebrew_niqqud":"וְאָנֹכִי חֲלוּץ נַעַל אֵבֶל יָחִיד אֵשֵׁבָה,","translit":"wəʾānōḵî ḥălûṣ naʿal ʾēḇel yāḥîḏ ʾēšēḇâ,","translit_ru":"вэанохи халуц наал евэл йахид ешева,","russian":"А я, босой, скорбящий в одиночестве, сяду,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"אשבה יחיל ודומם –","hebrew_niqqud":"אֵשְׁבָה יָחִיל וְדוּמָם –","translit":"ʾēšəḇâ yāḥîl wəḏûmām –","translit_ru":"ешэва йахил вэдумам –","russian":"Сяду я, скорбен и нем –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"ב","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"Б","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"ואם-אגוע מזה חרון על מפלת מקדשכם –","hebrew_niqqud":"וְאִם-אֶגְוַע מְזֵה חָרוֹן עַל מַפֶּלֶת מִקְדַּשְׁכֶם –","translit":"wəʾim-ʾeḡwaʿ məzê ḥārôn ʿal mappeleṯ miqdašḵem –","translit_ru":"вэим-эгва мэзе харон ал мапэлэт микдашхэм –","russian":"И если сгину я от гнева сего за падение храма вашего –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"יהי מותי דומיה;","hebrew_niqqud":"יְהִי מוֹתִי דּוּמִיָּה;","translit":"yəhî môṯî dûmiyyâ;","translit_ru":"йэхи моти думийа;","russian":"Пусть смерть моя будет безмолвьем;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"אל-תרגיזו עצמותי, אל-תטמאו את-זכרי","hebrew_niqqud":"אַל-תַּרְגִּיזוּ עַצְמוֹתַי, אַל-תְּטַמְּאוּ אֶת-זִכְרִי","translit":"ʾal-targîzû ʿaṣmôṯay, ʾal-təṭamməʾû ʾeṯ-ziḵrî","translit_ru":"ал-таргизу ацмотай, ал-тэтамэу эт-зихри","russian":"Не тревожьте костей моих, не оскверняйте память мою","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"בדמעתכם רמיה.","hebrew_niqqud":"בְּדִמְעַתְכֶם רְמִיָּה.","translit":"bəḏimʿaṯḵem rəmiyyâ.","translit_ru":"бэдиматхэм рэмийа.","russian":"Вашими слезами обманными.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"שבעה מדורות לגיהנם – הם שרפוני בחיי –","hebrew_niqqud":"שִׁבְעָה מְדוֹרוֹת לְגֵיהִנֹּם – הֵם שְׂרָפוּנִי בְּחַיָּי –","translit":"šiḇʿâ məḏôrôṯ ləḡêhinnōm – hēm śərāp̄ûnî bəḥayyāy –","translit_ru":"шива мэдорот лэгехином – хем сэрафуни бэхайай –","russian":"Семь пламен Ада – они сожгли меня при жизни –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"ישרפוני במותי,","hebrew_niqqud":"יִשְׂרְפוּנִי בְּמוֹתִי,","translit":"yiśrəp̄ûnî bəmôṯî,","translit_ru":"йисрэфуни бэмоти,","russian":"Сожгут меня и в смерти,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"קלו את-לבי, זרו אפרי, אך ביורת דמעתכם","hebrew_niqqud":"קְלוּ אֶת-לִבִּי, זְרוּ אֶפְרִי, אַךְ בְּיוֹרַת דִּמְעַתְכֶם","translit":"qəlû ʾeṯ-libbî, zərû ʾep̄rî, ʾaḵ bəyôraṯ dimʿaṯḵem","translit_ru":"кэлу эт-либи, зэру эфри, ах бэйорат диматхэм","russian":"Сожгите моё сердце, развейте прах мой, но в тигле слез ваших","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"אל-נא תשפטו אותי.","hebrew_niqqud":"אַל-נָא תִשְׁפְּטוּ אוֹתִי.","translit":"ʾal-nāʾ ṯišpəṭû ʾôṯî.","translit_ru":"ал-на тишпэту оти.","russian":"Прошу, не судите меня.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"ואם-ארקב בקבר – הבו ארקב לבטח,","hebrew_niqqud":"וְאִם-אֶרְקַב בַּקֶּבֶר – הָבוּ אֶרְקַב לָבֶטַח,","translit":"wəʾim-ʾerqaḇ baqqeḇer – hāḇû ʾerqaḇ lāḇeṭaḥ,","translit_ru":"вэим-эркав бакэвэр – хаву эркав лавэтах,","russian":"И если сгнию я в гробу – дайте мне истлеть спокойно,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"ואחלם רקבונכם;","hebrew_niqqud":"וְאֶחֱלֹם רִקְבוֹנְכֶם;","translit":"wəʾeḥĕlōm riqḇônəḵem;","translit_ru":"вээхэлом риквонэхэм;","russian":"И приснится мне тление ваше;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"ואכול התולעים שלדי ישחק לאידכם","hebrew_niqqud":"וַאֲכוּל הַתּוֹלָעִים שִׁלְדִּי יִשְׂחַק לְאֵידְכֶם","translit":"waʾăḵûl hattôlāʿîm šildî yiśḥaq ləʾêḏəḵem","translit_ru":"ваахул хатолаим шилди йисхак лэедэхэм","russian":"И червивый скелет мой посмеётся над вашим горем","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"והתפלץ לקלונכם.","hebrew_niqqud":"וְהִתְפַּלֵּץ לִקְלוֹנְכֶם.","translit":"wəhiṯpallēṣ liqlônəḵem.","translit_ru":"вэхитпалец ликлонэхэм.","russian":"И содрогнётся от позора вашего.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"תרס\"ח.","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"1908.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-70","text_key":"865efef2c17474660d8c9873c947c355491c727a1b43dff933fa508767b5852d","title":"אל יאשם יהודה","level":null,"tags":["poetry","haskalah"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"70","content_hash":"sha256:85df1cb369f754cf55dd029cf02949e23ab2acaa3fffbe23c190b549c9a8e486","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"literary","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/70","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"70","content_hash":"sha256:85df1cb369f754cf55dd029cf02949e23ab2acaa3fffbe23c190b549c9a8e486","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"literary","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/70","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"אל יאשם יהודה","hebrew_niqqud":"אֶל יֶאֱשַׁם יְהוּדָה","translit":"ʾel yeʾĕšam yəhûḏâ","translit_ru":"эл йээшам йэхуда","russian":"Да не будет Иуда виновен","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"אל יאשם יהודה / יהודה ליב גורדון","hebrew_niqqud":"אַל יֶאֱשַׁם יְהוּדָה / יְהוּדָה לֵיבּ גּוֹרְדּוֹן","translit":"ʾal yeʾĕšam yəhûḏâ / yəhûḏâ lêb gôrədôn","translit_ru":"ал йээшам йэхуда / йэхуда леб горэдон","russian":"Да не будет Иуда виновен / Иегуда Лейб Гордон","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"\"חמסי עליך, יאמר הקורא,","hebrew_niqqud":"\"חֲמָסִי עָלֶיךָ, יֹאמַר הַקּוֹרֵא,","translit":"\"ḥămāsî ʿālêḵā, yōʾmar haqqôrēʾ,","translit_ru":"\"хамаси алеха, йомар хакоре,","russian":"«О, какая несправедливость, – скажет читатель, –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"ובספוריך לא מצאתי נחת,","hebrew_niqqud":"וּבְסִפּוּרֶיךָ לֹא מָצָאתִי נָחַת,","translit":"ûḇəsippûrêḵā lōʾ māṣāʾṯî nāḥaṯ,","translit_ru":"увэсипуреха ло мацати нахат,","russian":"в твоих рассказах я не нашёл утешения,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"כי כל העולמות שאתה בורא","hebrew_niqqud":"כִּי כָל הָעוֹלָמוֹת שֶׁאַתָּה בּוֹרֵא","translit":"kî ḵol hāʿôlāmôṯ šeʾattâ bôrēʾ","translit_ru":"ки хол хаоламот шэата боре","russian":"ибо все миры, тобой сотворённые,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"תשוב תחריבם, תקריבם לשחת.","hebrew_niqqud":"תָּשׁוּב תַּחֲרִיבֵם, תַּקְרִיבֵם לַשָּׁחַת.","translit":"tāšûḇ taḥărîḇēm, taqrîḇēm laššāḥaṯ.","translit_ru":"ташув тахаривем, такривем лашахат.","russian":"ты вновь разрушаешь, их повергая в тлен.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"מדוע כל אביריך נסחפו","hebrew_niqqud":"מַדּוּעַ כָּל אַבִּירֶיךָ נִסְחָפוּ","translit":"maddûaʿ kol ʾabbîrêḵā nisḥāp̄û","translit_ru":"мадуа кол абиреха нисхафу","russian":"Отчего твои витязи все погибают,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"ויצריך כצל כלם יאבדו?","hebrew_niqqud":"וִיצֻרֶיךָ כַּצֵּל כֻּלָּם יֹאבֵדוּ?","translit":"wîṣūrêḵā kaṣṣēl kūllām yōʾḇēḏû?","translit_ru":"вицуреха кацел кулам йоведу?","russian":"и праведники все, как тени, истлеют?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"טפחתם, רביתם, טבו גם יפו,","hebrew_niqqud":"טִפַּחְתָּם, רִבִּיתָם, טֹבוּ גַּם יָפוּ,","translit":"ṭippaḥtām, ribbîṯām, ṭōḇû gam yāp̄û,","translit_ru":"типахтам, рибитам, тову гам йафу,","russian":"Ты их лелеял, растил, они были и добры, и прекрасны,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"וכאילי אשמות לטבח ירדו:","hebrew_niqqud":"וּכְאֵילֵי אֲשָׁמוֹת לַטֶּבַח יֵרֵדוּ:","translit":"ûḵəʾêlê ʾăšāmôṯ laṭṭeḇaḥ yērēḏû:","translit_ru":"ухэеле ашамот латэвах йереду:","russian":"но, как агнцы повинности, шли на заклание:","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"בת -שוע הנאוה על הפתחים מחזרת,","hebrew_niqqud":"בַּת -שׁוּעַ הַנָּאוָה עַל הַפְּתָחִים מַחֲזֶרֶת,","translit":"baṯ -šûaʿ hannāʾwâ ʿal happəṯāḥîm maḥăzereṯ,","translit_ru":"бат -шуа ханава ал хапэтахим махазэрэт,","russian":"Прекрасная Бат-Шева у дверей нищенствует,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"היונה התמה יבמה שומרת,","hebrew_niqqud":"הַיּוֹנָה הַתַּמָּה יְבָמָהּ שׁוֹמֶרֶת,","translit":"hayyônâ hattammâ yəḇāmāh šômereṯ,","translit_ru":"хайона хатама йэвамах шомэрэт,","russian":"Невинная голубка ждёт деверя,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"אשת אליפלט מביתו גרשת","hebrew_niqqud":"אֵשֶׁת אֲלִיפֶלֶט מִבֵּיתוֹ גֵּרַשְׁתָּ","translit":"ʾēšeṯ ʾălîp̄eleṭ mibbêṯô gēraštā","translit_ru":"ешэт алифэлэт мибето герашта","russian":"Жену Элифелета ты из дома изгнал,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"וילדיה יתומים חיים נטשת,","hebrew_niqqud":"וִילָדֶיהָ יְתוֹמִים חַיִּים נָטַשְׁתָּ,","translit":"wîlāḏêhā yəṯômîm ḥayyîm nāṭaštā,","translit_ru":"виладеха йэтомим хайим наташта,","russian":"её детей живыми сиротами покинул,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"את קלמן הפתי עצרת בדרך","hebrew_niqqud":"אֶת קַלְמָן הַפֶּתִי עָצַרְתָּ בַּדֶּרֶךְ","translit":"ʾeṯ qalmān happeṯî ʿāṣartā baddereḵ","translit_ru":"эт калман хапэти ацарта бадэрэх","russian":"Калмана-простака ты задержал в пути,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"ובתו הבגרת לאיש לא תת;","hebrew_niqqud":"וּבִתּוֹ הַבֹּגֶרֶת לָאִישׁ לֹא תַּתָּ;","translit":"ûḇittô habbōḡereṯ lāʾîš lōʾ tattā;","translit_ru":"увито хабогэрэт лаиш ло тата;","russian":"и его взрослую дочь ты замуж не выдашь;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"את יוסף שלחת לעבדת פרך,","hebrew_niqqud":"אֶת יוֹסֵף שִׁלַּחְתָּ לַעֲבֹדַת פֶּרֶךְ,","translit":"ʾeṯ yôsēp̄ šillaḥtā laʿăḇōḏaṯ pereḵ,","translit_ru":"эт йосеф шилахта лааводат пэрэх,","russian":"Иосифа ты отправил на каторгу,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"את אמו העניה בלי-עת המת.","hebrew_niqqud":"אֶת אִמּוֹ הַעֲנִיָּה בְּלִי-עֵת הֵמַתָּ.","translit":"ʾeṯ ʾimmô haʿăniyyâ bəlî-ʿēṯ hēmattā.","translit_ru":"эт имо хаанийа бэли-ет хемата.","russian":"его бедную мать умертвил безвременно.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"ככה כל הנפשות אשר עשית","hebrew_niqqud":"כָּכָה כָּל הַנְּפָשׁוֹת אֲשֶׁר עָשִׂיתָ","translit":"kāḵâ kol hannəp̄āšôṯ ʾăšer ʿāśîṯā","translit_ru":"каха кол ханэфашот ашэр асита","russian":"Так все души, тобой сотворённые,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"הפלת למשואות, כחללים דכאת;","hebrew_niqqud":"הִפַּלְתָּ לְמַשּׁוּאוֹת, כַּחֲלָלִים דִּכֵּאתָ;","translit":"hippaltā ləmaššûʾôṯ, kaḥălālîm dikkēʾṯā;","translit_ru":"хипалта лэмашуот, кахалалим дикета;","russian":"ты поверг в руины, как трупы, раздавил;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"לא אחת מהן יצאה לראות אורה –","hebrew_niqqud":"לֹא אַחַת מֵהֶן יָצְאָה לִרְאוֹת אוֹרָה –","translit":"lōʾ ʾaḥaṯ mēhen yāṣəʾâ lirʾôṯ ʾôrâ –","translit_ru":"ло ахат мехэн йацэа лирот ора –","russian":"ни одна из них свет не увидела –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"אין זה כי אם מרע לב ומרה שחורה!\"","hebrew_niqqud":"אֵין זֶה כִּי אִם מֵרֹעַ לֵב וּמָרָה שְׁחוֹרָה!\"","translit":"ʾên zê kî ʾim mērōaʿ lēḇ ûmārâ šəḥôrâ!\"","translit_ru":"ен зэ ки им мероа лев умара шэхора!\"","russian":"это лишь злоба сердца и чёрная желчь!»","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"– אל נא, אחי, אל תדבר אתי קשות,","hebrew_niqqud":"– אַל נָא, אָחִי, אַל תְּדַבֵּר אִתִּי קָשׁוֹת,","translit":"– ʾal nāʾ, ʾāḥî, ʾal təḏabbēr ʾittî qāšôṯ,","translit_ru":"– ал на, ахи, ал тэдабер ити кашот,","russian":"– О нет, мой брат, не говори со мной так строго,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"אל נא תפקד עלי עון הנפשות!","hebrew_niqqud":"אַל נָא תִּפְקֹד עָלַי עֲוֹן הַנְּפָשׁוֹת!","translit":"ʾal nāʾ tip̄qōḏ ʿālay ʿăwōn hannəp̄āšôṯ!","translit_ru":"ал на тифкод алай авон ханэфашот!","russian":"не возлагай на меня грех этих душ!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"גם לבי יכאב, גם נפשי לי מרה","hebrew_niqqud":"גַּם לִבִּי יִכְאַב, גַּם נַפְשִׁי לִי מָרָה","translit":"gam libbî yiḵʾaḇ, gam nap̄šî lî mārâ","translit_ru":"гам либи йихав, гам нафши ли мара","russian":"И моё сердце болит, и душа моя горька","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"על מעשי ידי הטובעים בים צרה,","hebrew_niqqud":"עַל מַעֲשֵׂי יָדַי הַטּוֹבְעִים בְּיַם צָרָה,","translit":"ʿal maʿăśê yāḏay haṭṭôḇəʿîm bəyam ṣārâ,","translit_ru":"ал маасе йадай хатовэим бэйам цара,","russian":"за дела рук моих, тонущих в море бед,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"אך לא בי האשם, לא עלי הפקדה –","hebrew_niqqud":"אַךְ לֹא בִי הָאָשָׁם, לֹא עָלַי הַפְּקֻדָּה –","translit":"ʾaḵ lōʾ ḇî hāʾāšām, lōʾ ʿālay happəqūddâ –","translit_ru":"ах ло ви хаашам, ло алай хапэкуда –","russian":"но не на мне вина, не на мне эта ноша –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"אם זנה ישראל אל יאשם יהודה!","hebrew_niqqud":"אִם זֹנֶה יִשְׂרָאֵל אַל יֶאְשַׁם יְהוּדָה!","translit":"ʾim zōnê yiśrāʾēl ʾal yeʾšam yəhûḏâ!","translit_ru":"им зонэ йисраел ал йэшам йэхуда!","russian":"если Израиль блудил, да не будет виновен Иуда!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"אני אינני בורא יש מאין,","hebrew_niqqud":"אֲנִי אֵינֶנִּי בּוֹרֵא יֵשׁ מֵאַיִן,","translit":"ʾănî ʾênennî bôrēʾ yēš mēʾayin,","translit_ru":"ани енэни боре йеш меайин,","russian":"Я не творец, создающий из ничего,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"ציר אנכי ובימיני חרט,","hebrew_niqqud":"צַיָּר אָנֹכִי וּבִימִינִי חֶרֶט,","translit":"ṣayyār ʾānōḵî ûḇîmînî ḥereṭ,","translit_ru":"цайар анохи увимини хэрэт,","russian":"я лишь художник, и в правой руке моей – резец,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"את אשר אראה עין לעין","hebrew_niqqud":"אֵת אֲשֶׁר אֶרְאֶה עַיִן לַעַיִן","translit":"ʾēṯ ʾăšer ʾerʾê ʿayin laʿayin","translit_ru":"ет ашэр эрэ айин лаайин","russian":"что вижу я воочию,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"אותו אתאר על לוח בשרד;","hebrew_niqqud":"אוֹתוֹ אֲתָאֵר עַל לוּחַ בַּשֶּׂרֶד;","translit":"ʾôṯô ʾăṯāʾēr ʿal lûaḥ baśśereḏ;","translit_ru":"ото атаер ал луах басэрэд;","russian":"то я изображаю на доске резцом;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"ומה אעשה אם אחי היהודים","hebrew_niqqud":"וּמָה אֶעֱשֶׂה אִם אַחַי הַיְּהוּדִים","translit":"ûmâ ʾeʿĕśê ʾim ʾaḥay hayyəhûḏîm","translit_ru":"ума ээсэ им ахай хайэхудим","russian":"Что делать мне, если братья-евреи","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r33","order_index":33,"hebrew_plain":"יראוני רק שמות, רק עני ומרודים,","hebrew_niqqud":"יַרְאוּנִי רַק שַׁמּוֹת, רַק עֹנִי וּמְרוּדִים,","translit":"yarʾûnî raq šammôṯ, raq ʿōnî ûmərûḏîm,","translit_ru":"йаруни рак шамот, рак они умэрудим,","russian":"мне являют лишь запустение, лишь нищету и нужду,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r34","order_index":34,"hebrew_plain":"ובכל פנות העם ממסד עד הטפחות","hebrew_niqqud":"וּבְכָל פִּנּוֹת הָעָם מִמַּסָּד עַד הַטְּפָחוֹת","translit":"ûḇəḵol pinnôṯ hāʿām mimmassāḏ ʿaḏ haṭṭəp̄āḥôṯ","translit_ru":"увэхол пинот хаам мимасад ад хатэфахот","russian":"и во всех уголках народа, от основания до кровли,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r35","order_index":35,"hebrew_plain":"רק דמעות נגרות ובכי ואנחות?!","hebrew_niqqud":"רַק דְּמָעוֹת נִגָּרוֹת וּבְכִי וַאֲנָחוֹת?!","translit":"raq dəmāʿôṯ niggārôṯ ûḇəḵî waʾănāḥôṯ?!","translit_ru":"рак дэмаот нигарот увэхи ваанахот?!","russian":"лишь слёзы текущие, и плач, и стенанья?!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r36","order_index":36,"hebrew_plain":"על כן אמרתי אאסף דמעותינו","hebrew_niqqud":"עַל כֵּן אָמַרְתִּי אֶאֱסֹף דִּמְעוֹתֵינוּ","translit":"ʿal kēn ʾāmartî ʾeʾĕsōp̄ dimʿôṯênû","translit_ru":"ал кен амарти ээсоф димотену","russian":"Потому я сказал: я соберу наши слёзы","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r37","order_index":37,"hebrew_plain":"ואשימן בנאד, הלא בספרתנו,","hebrew_niqqud":"וַאֲשִׂימֵן בַּנֹאד, הֲלֹא בְּסִפְרָתֵנוּ,","translit":"waʾăśîmēn banōʾḏ, hălōʾ bəsip̄rāṯēnû,","translit_ru":"ваасимен банод, хало бэсифратену,","russian":"и помещу их в сосуд – не записано ли это?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r38","order_index":38,"hebrew_plain":"להיות לנו משמרת לבני בנים,","hebrew_niqqud":"לִהְיוֹת לָנוּ מִשְׁמֶרֶת לִבְנֵי בָנִים,","translit":"lihyôṯ lānû mišmereṯ liḇnê ḇānîm,","translit_ru":"лихйот лану мишмэрэт ливне ваним,","russian":"чтоб служили они нам хранилищем для потомков,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r39","order_index":39,"hebrew_plain":"ליום אשר ייטיב האל אחריתנו","hebrew_niqqud":"לַיּוֹם אֲשֶׁר יֵיטִיב הָאֵל אַחֲרִיתֵנוּ","translit":"layyôm ʾăšer yêṭîḇ hāʾēl ʾaḥărîṯēnû","translit_ru":"лайом ашэр йетив хаел ахаритену","russian":"до дня, когда Бог улучшит нашу участь","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r40","order_index":40,"hebrew_plain":"ומחה דמעה מעל כל פנים.","hebrew_niqqud":"וּמָחָה דִּמְעָה מֵעַל כָּל פָּנִים.","translit":"ûmāḥâ dimʿâ mēʿal kol pānîm.","translit_ru":"умаха дима меал кол паним.","russian":"и отрёт слёзы со всех лиц.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
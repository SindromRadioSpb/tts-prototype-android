ֵחַ]","translit":"haššûʿāl wəhazzəʾēḇ [maddûaʿ zê taḥaṯ yārēaḥ]","translit_ru":"хашуал вэхазэев [мадуа зэ тахат йареах]","russian":"Лис и Волк [Отчего сие под луною]","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"מדוע זה תחת ירח","hebrew_niqqud":"מַדּוּעַ זֶה תַּחַת יָרֵחַ","translit":"maddûaʿ zê taḥaṯ yārēaḥ","translit_ru":"мадуа зэ тахат йареах","russian":"Отчего сие под луною,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"אין איש במנת חלקו שמח?","hebrew_niqqud":"אֵין אִישׁ בִּמְנת חֶלְקוֹ שָׂמֵחַ?","translit":"ʾên ʾîš bimnṯ ḥelqô śāmēaḥ?","translit_ru":"ен иш бимнт хэлко самеах?","russian":"Неужто никто своей доле не рад?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"באשר יש לו תבחל נפשהו","hebrew_niqqud":"בַּאֲשֶׁר יֵשׁ לוֹ תִּבְחַל נַפְשֵׁהוּ","translit":"baʾăšer yēš lô tiḇḥal nap̄šēhû","translit_ru":"баашэр йеш ло тивхал нафшеху","russian":"Ибо тем, что имеет, душа его брезгует,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"בעבור התאות את אשר לרעהו!","hebrew_niqqud":"בַּעֲבוּר הִתְאַוֹּת אֵת אֲשֶׁר לְרֵעֵהוּ!","translit":"baʿăḇûr hiṯʾawwōṯ ʾēṯ ʾăšer lərēʿēhû!","translit_ru":"баавур хитавот ет ашэр лэрееху!","russian":"Потому что жаждет того, что есть у ближнего!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"כן קנא שועל בזאב פעם אחת.","hebrew_niqqud":"כֵּן קִנֵּא שׁוּעָל בַּזְּאֵב פַּעַם אַחַת.","translit":"kēn qinnēʾ šûʿāl bazzəʾēḇ paʿam ʾaḥaṯ.","translit_ru":"кен кине шуал базэев паам ахат.","russian":"Вот так однажды лис позавидовал волку.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"בתשמת-ידו לא מצא עוד נחת","hebrew_niqqud":"בִּתְשֻׂמֶת-יָדוֹ לֹא מָצָא עוֹד נַחַת","translit":"biṯśūmeṯ-yāḏô lōʾ māṣāʾ ʿôḏ naḥaṯ","translit_ru":"битсумэт-йадо ло маца од нахат","russian":"В своей добыче не находил он утешенья,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"ובלחם הקלקל נפשו קצה;","hebrew_niqqud":"וּבַלֶּחֶם הַקְּלֹקֵל נַפְשׁוֹ קָצָה;","translit":"ûḇalleḥem haqqəlōqēl nap̄šô qāṣâ;","translit_ru":"увалэхэм хакэлокел нафшо каца;","russian":"И скудным хлебом душа его пресытилась;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"בבשר צפור ובשר אפרח","hebrew_niqqud":"בִּבְשַׂר צִפּוֹר וּבְשַׂר אֶפְרֹחַ","translit":"biḇśar ṣippôr ûḇəśar ʾep̄rōaḥ","translit_ru":"бивсар ципор увэсар эфроах","russian":"В мясе птицы и в мясе птенца","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"לא מצאה עוד ריח ניחח","hebrew_niqqud":"לֹא מָצְאָה עוֹד רֵיחַ נִיחֹחַ","translit":"lōʾ māṣəʾâ ʿôḏ rêaḥ nîḥōaḥ","translit_ru":"ло мацэа од реах нихоах","russian":"Не чуяла более благоуханья,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"ובשר צאן וכבשים לאכל חפצה.","hebrew_niqqud":"וּבְשַׂר צֹאן וּכְבָשִׂים לֶאֱכֹל חָפֵצָה.","translit":"ûḇəśar ṣōʾn ûḵəḇāśîm leʾĕḵōl ḥāp̄ēṣâ.","translit_ru":"увэсар цон ухэвасим лээхол хафеца.","russian":"А мясо овец и ягнят желала есть.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"על כן אמר לזאב: אחי ורע!","hebrew_niqqud":"עַל כֵּן אָמַר לַזְּאֵב: אָחִי וְרֵעַ!","translit":"ʿal kēn ʾāmar lazzəʾēḇ: ʾāḥî wərēaʿ!","translit_ru":"ал кен амар лазэев: ахи вэреа!","russian":"Поэтому сказал волку: «Брат мой и друг!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"הן כי דל חלקי גם אתה יודע,","hebrew_niqqud":"הֵן כִּי דַּל חֶלְקִי גַּם אַתָּה יוֹדֵעַ,","translit":"hēn kî dal ḥelqî gam ʾattâ yôḏēaʿ,","translit_ru":"хен ки дал хэлки гам ата йодеа,","russian":"Ты ведь знаешь, как беден мой удел,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"אני אבוא כגנב במחתרת","hebrew_niqqud":"אֲנִי אָבוֹא כַּגַּנָּב בַּמַּחְתֶּרֶת","translit":"ʾănî ʾāḇôʾ kaggannāḇ bammaḥtereṯ","translit_ru":"ани аво каганав бамахтэрэт","russian":"Я, как вор, приду украдкой,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"לחתוף בעמל רב לי עוף כזרת,","hebrew_niqqud":"לַחְתּוֹף בְּעָמָל רַב לִי עוֹף כַּזֶּרֶת,","translit":"laḥtôp̄ bəʿāmāl raḇ lî ʿôp̄ kazzereṯ,","translit_ru":"лахтоф бэамал рав ли оф казэрэт,","russian":"Чтоб с трудом великим птичку-невеличку схватить,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"אתה כגבור נאדר בכח","hebrew_niqqud":"אַתָּה כַּגִּבּוֹר נֶאְדָּר בַּכֹּחַ","translit":"ʾattâ kaggibbôr neʾdār bakkōaḥ","translit_ru":"ата кагибор нэдар бакоах","russian":"Ты, как могучий герой,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"תקח לך מבחר הצאן לקח,","hebrew_niqqud":"תִּקַּח לָךְ מִבְחַר הַצֹּאן לָקֹחַ,","translit":"tiqqaḥ lāḵ miḇḥar haṣṣōʾn lāqōaḥ,","translit_ru":"тиках лах мивхар хацон лакоах,","russian":"Лучших овец себе в добычу возьмёшь.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"הורני אפוא חית ידך","hebrew_niqqud":"הוֹרֵנִי אֵפוֹא חַיַּת יָדֶךָ","translit":"hôrēnî ʾēp̄ôʾ ḥayyaṯ yāḏeḵā","translit_ru":"хорени ефо хайат йадэха","russian":"Научи же меня своему ремеслу,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"ובישר לבב תמיד אודך\".","hebrew_niqqud":"וּבְיֹשֶר לֵבָב תָּמִיד אוֹדֶךָ\".","translit":"ûḇəyōšer lēḇāḇ tāmîḏ ʾôḏeḵā\".","translit_ru":"увэйошэр левав тамид одэха\".","russian":"И от чистого сердца всегда благодарным буду».","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"טוב!","hebrew_niqqud":"טוֹב!","translit":"ṭôḇ!","translit_ru":"тов!","russian":"«Хорошо! –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"ענה הזאב ­­– הן בזה הליל","hebrew_niqqud":"עָנָה הַזְּאֵב ­­– הֵן בָּזֶה הַלַּיִל","translit":"ʿānâ hazzəʾēḇ ­­– hēn bāzê hallayil","translit_ru":"ана хазэев ­­– хен базэ халайил","russian":"Ответил волк. – Ведь этой же ночью","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"מת אחד מאחי (זכרו לברכה!)","hebrew_niqqud":"מֵת אֶחָד מֵאַחַי (זִכְרוֹ לִבְרָכָה!)","translit":"mēṯ ʾeḥāḏ mēʾaḥay (ziḵrô liḇrāḵâ!)","translit_ru":"мет эхад меахай (зихро ливраха!)","russian":"Умер один из братьев моих (да упокоится с миром!)","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"בוא אפוא עמדי והיה לבן חיל,","hebrew_niqqud":"בּוֹא אֵפוֹא עִמָּדִי וֶהְיֵה לְבֶן חַיִל,","translit":"bôʾ ʾēp̄ôʾ ʿimmāḏî wêyê ləḇen ḥayil,","translit_ru":"бо ефо имади вэйе лэвэн хайил,","russian":"Пойди же со мной и будь смелым,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"אלבישך עורו ואלמד אותכה","hebrew_niqqud":"אַלְבִּישְׁךָ עוֹרוֹ וַאֲלַמֵּד אוֹתָכָה","translit":"ʾalbîšəḵā ʿôrô waʾălammēḏ ʾôṯāḵâ","translit_ru":"албишэха оро вааламед отаха","russian":"Я надену на тебя его шкуру и научу тебя,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"איככה","hebrew_niqqud":"אֵיכָכָה","translit":"ʾêḵāḵâ","translit_ru":"ехаха","russian":"Как","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"תחתף מהעדר שה עז ואיל.","hebrew_niqqud":"תַּחְתֹּף מֵהָעֵדֶר שֶׂה עֵז וָאַיִל.","translit":"taḥtōp̄ mēhāʿēḏer śê ʿēz wāʾayil.","translit_ru":"тахтоф мехаедэр сэ ез ваайил.","russian":"Выхватишь из стада ягнёнка, козла и овна».","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"וילבש השועל עליו עורהו,","hebrew_niqqud":"וַיִּלְבַּשׁ הַשּׁוּעָל עָלָיו עוֹרֵהוּ,","translit":"wayyilbaš haššûʿāl ʿālāyw ʿôrēhû,","translit_ru":"вайилбаш хашуал алав ореху,","russian":"И надел лис на себя его шкуру,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"ויצר בלבבו תורת מורהו;","hebrew_niqqud":"וַיִּצֹּר בִּלְבָבוֹ תּוֹרַת מוֹרֵהוּ;","translit":"wayyiṣṣōr bilḇāḇô tôraṯ môrēhû;","translit_ru":"вайицор билваво торат мореху;","russian":"И запечатлел в своём сердце наставление учителя;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"כמעט כלה ללמוד תורתו","hebrew_niqqud":"כִּמְעַט כִּלָּה לִלְמוֹד תּוֹרָתוֹ","translit":"kimʿaṭ killâ lilmôḏ tôrāṯô","translit_ru":"кимат кила лилмод торато","russian":"Едва закончил изучать его науку,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"וירא והנה עדר לקראתו.","hebrew_niqqud":"וַיַּרְא וְהִנֵּה עֵדֶר לִקְרָאתוֹ.","translit":"wayyarʾ wəhinnê ʿēḏer liqrāʾṯô.","translit_ru":"вайар вэхине едэр ликрато.","russian":"Увидел он, вот стадо идёт ему навстречу.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"וירץ המתחפש בחמת רוח","hebrew_niqqud":"וַיָּרָץ הַמִּתְחַפֵּשׂ בַּחֲמַת רוּחַ","translit":"wayyārāṣ hammiṯḥappēś baḥămaṯ rûaḥ","translit_ru":"вайарац хамитхапес бахамат руах","russian":"И побежал переодетый в неистовстве,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"ויזרה אימה ורתת אל כל רוח.","hebrew_niqqud":"וַיְזָרֶה אֵימָה וּרְתֵת אֶל כָּל רוּחַ.","translit":"wayəzārê ʾêmâ ûrəṯēṯ ʾel kol rûaḥ.","translit_ru":"вайэзарэ ема урэтет эл кол руах.","russian":"И рассеял ужас и дрожь повсюду.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"העדר נפץ כי אחזו פחד,","hebrew_niqqud":"הָעֵדֶר נָפֹץ כִּי אֲחָזוֹ פַּחַד,","translit":"hāʿēḏer nāp̄ōṣ kî ʾăḥāzô paḥaḏ,","translit_ru":"хаедэр нафоц ки ахазо пахад,","russian":"Стадо разбежалось, ибо охватил их страх,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r33","order_index":33,"hebrew_plain":"הרעים, הכלבים ברחו גם יחד,","hebrew_niqqud":"הָרֹעִים, הַכְּלָבִים בָּרְחוּ גַּם יַחַד,","translit":"hārōʿîm, hakkəlāḇîm bārəḥû gam yaḥaḏ,","translit_ru":"хароим, хакэлавим барэху гам йахад,","russian":"Пастухи, собаки убежали разом,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r34","order_index":34,"hebrew_plain":"ולשלל לשודד כבשה נשארה,","hebrew_niqqud":"וּלְשָׁלָל לַשּׁוֹדֵד כִּבְשָׂה נִשְׁאָרָה,","translit":"ûləšālāl laššôḏēḏ kiḇśâ nišʾārâ,","translit_ru":"улэшалал лашодед кивса нишара,","russian":"И в добычу разбойнику осталась овца,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r35","order_index":35,"hebrew_plain":"לנוס על נפשה כח לא עצרה","hebrew_niqqud":"לָנוּס עַל נַפְשָׁהּ כֹּחַ לֹא עָצָרָה","translit":"lānûs ʿal nap̄šāh kōaḥ lōʾ ʿāṣārâ","translit_ru":"ланус ал нафшах коах ло ацара","russian":"Сил для бегства не собрала,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r36","order_index":36,"hebrew_plain":"ובכף השועל באה ותתפש,","hebrew_niqqud":"וּבְכַף הַשּׁוּעָל בָּאָה וַתִּתָּפֶשׂ,","translit":"ûḇəḵap̄ haššûʿāl bāʾâ wattittāp̄eś,","translit_ru":"увэхаф хашуал баа ватитафэс,","russian":"И в лапу лису попалась.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r37","order_index":37,"hebrew_plain":"אך פתאם שמע קול שכוי מנגד","hebrew_niqqud":"אַךְ פִּתְאֹם שָׁמַע קוֹל שֶׂכְוִי מִנֶּגֶד","translit":"ʾaḵ piṯʾōm šāmaʿ qôl śeḵwî minneḡeḏ","translit_ru":"ах питом шама кол сэхви минэгэд","russian":"Но вдруг услышал голос петуха издалека,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r38","order_index":38,"hebrew_plain":"וימהר ויתן לכשבה חפש,","hebrew_niqqud":"וַיְמַהֵר וַיִּתֵּן לַכִּשְׂבָּה חֹפֶשׁ,","translit":"wayəmahēr wayyittēn lakkiśbâ ḥōp̄eš,","translit_ru":"вайэмахер вайитен лакисба хофэш,","russian":"И поспешил, и отпустил овцу,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r39","order_index":39,"hebrew_plain":"התפשט עור הזאב, השליך הבגד,","hebrew_niqqud":"הִתְפַּשֵּׁט עוֹר הָזְּאֵב, הִשְׁלִיךְ הַבָּגֶד,","translit":"hiṯpaššēṭ ʿôr hāzzəʾēḇ, hišlîḵ habbāḡeḏ,","translit_ru":"хитпашет ор хазэев, хишлих хабагэд,","russian":"Снял шкуру волка, отбросил одежду,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r40","order_index":40,"hebrew_plain":"וירץ לשכוי ורצחו נפש.","hebrew_niqqud":"וַיָּרָץ לַשֶּׂכְוֵי וּרְצָחוֹ נָפֶשׁ.","translit":"wayyārāṣ laśśeḵwê ûrəṣāḥô nāp̄eš.","translit_ru":"вайарац ласэхве урэцахо нафэш.","russian":"И побежал к петуху, и зарезал его.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r41","order_index":41,"hebrew_plain":"על יד הלמוד שבע","hebrew_niqqud":"עַל יַד הַלִּמּוּד שֶׁבַע","translit":"ʿal yaḏ hallimmûḏ šeḇaʿ","translit_ru":"ал йад халимуд шэва","russian":"Над всяким обученьем,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r42","order_index":42,"hebrew_plain":"חזקה יד הטבע.","hebrew_niqqud":"חֲזָקָה יַד הַטֶּבַע.","translit":"ḥăzāqâ yaḏ haṭṭeḇaʿ.","translit_ru":"хазака йад хатэва.","russian":"Рука Природы сильней.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
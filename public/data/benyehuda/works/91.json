{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-91","text_key":"9f8f54e96b245df94c50f33148c2e48cf8436780eeabb41b5088c1a2ab19da50","title":"העלמה וצלמה","level":null,"tags":["poetry","haskalah"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"91","content_hash":"sha256:c4dd5ae545f477ca4864930dc420e86d0db32a7053ba6b93870cdc5679a9172b","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"literary","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/91","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"91","content_hash":"sha256:c4dd5ae545f477ca4864930dc420e86d0db32a7053ba6b93870cdc5679a9172b","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"literary","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/91","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"העלמה וצלמה","hebrew_niqqud":"הָעַלְמָה וְצַלְמָהּ","translit":"hāʿalmâ wəṣalmāh","translit_ru":"хаалма вэцалмах","russian":"Дева и её образ","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"כמים הפנים לפנים כן מליצה חידה לרעיון.","hebrew_niqqud":"כּמים הפנים לפנים כן מליצה חידה לרעיון.","translit":"kmym hp̄nym lp̄nym ḵn mlyṣh ḥyḏh lrʿywn.","translit_ru":"кмйм хфнйм лфнйм хн млйцх хйдх лрйвн.","russian":"Как в воде отражается лицо, так загадочная речь – мысли.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"(אסף ל\"ז נ')","hebrew_niqqud":"(אָסָף ל\"ז נ')","translit":"(ʾāsāp̄ lz\" n')","translit_ru":"(асаф лз\" н')","russian":"(Асаф 37:50)","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"עלמה ככשית משחת מראה","hebrew_niqqud":"עַלְמָה כַּכֻּשִׁית מִשְׁחַת מַרְאֶהָ","translit":"ʿalmâ kakkūšîṯ mišḥaṯ marʾehā","translit_ru":"алма какушит мишхат марэха","russian":"Дева, словно кушитка, с повреждённым ликом,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"נשאה את נפשה כי יפה הנה,","hebrew_niqqud":"נִשְּׂאָה אֶת נַפְשָׁהּ כִּי יָפָה הִנֶּהָ,","translit":"niśśəʾâ ʾeṯ nap̄šāh kî yāp̄â hinnehā,","translit_ru":"нисэа эт нафшах ки йафа хинэха,","russian":"Она превозносила себя, ибо была прекрасна,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"כי אין כמוה בארץ ליפי;","hebrew_niqqud":"כִּי אֵין כָּמוֹהָ בָּאָרֶץ לָיֹפִי;","translit":"kî ʾên kāmôhā bāʾāreṣ lāyōp̄î;","translit_ru":"ки ен камоха баарэц лайофи;","russian":"Ибо не было ей равных на земле по красоте;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"ובכל הגליונים שראו עיניה","hebrew_niqqud":"וּבְכָל הַגִּלְיוֹנִים שֶׁרָאוּ עֵינֶיהָ","translit":"ûḇəḵol haggilyônîm šerāʾû ʿênêhā","translit_ru":"увэхол хагилйоним шэрау енеха","russian":"И во всех отражениях, что глаза её встречали,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"חרה אפה ותתן דפי,","hebrew_niqqud":"חָרָה אַפָּהּ וַתִּתֵּן דֹּפִי,","translit":"ḥārâ ʾappāh wattittēn dōp̄î,","translit_ru":"хара апах ватитен дофи,","russian":"Пылал её гнев, и она наносила удары,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"ותאמר כי כלמו","hebrew_niqqud":"וַתֹּאמֶר כִּי כֻלָּמוֹ","translit":"wattōʾmer kî ḵūllāmô","translit_ru":"ватомэр ки хуламо","russian":"И говорила она, что все они","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"יעשו ברמיה פעלמו,","hebrew_niqqud":"יַעֲשׂוּ בִּרְמִיָּה פָּעֳלָמוֹ,","translit":"yaʿăśû birmiyyâ poʿŏlāmô,","translit_ru":"йаасу бирмийа пооламо,","russian":"В обмане творят своё дело,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"ולדאבון נפשה ולמרת רוח","hebrew_niqqud":"וְּלַדֲאבוֹן נַפְשָׁהּ וּלְמֹרַת רוּחַ","translit":"wəlaḏăʾḇôn nap̄šāh ûləmōraṯ rûaḥ","translit_ru":"вэладавон нафшах улэморат руах","russian":"К скорби её души и к горечи духа,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"על כל אשר רגליה דרכו","hebrew_niqqud":"עַל כָּל אֲשֶׁר רַגְלֶיהָ דָּרָכוּ","translit":"ʿal kol ʾăšer raḡlêhā dārāḵû","translit_ru":"ал кол ашэр раглеха дараху","russian":"На каждом шагу, куда ступали её ноги,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"שם גליון גלוי בספר פתוח","hebrew_niqqud":"שָׁם גִּלְיוֹן גָּלוּי בַּסֵּפֶר פָּתוּחַ","translit":"šām gilyôn gālûy bassēp̄er pāṯûaḥ","translit_ru":"шам гилйон галуй басефэр патуах","russian":"Там ясный образ в книге открытой,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"יראה לה פניה משחור חשכו.","hebrew_niqqud":"יַרְאֶה לָהּ פָּנֶיהָ מִשְּׁחוֹר חָשָׁכוּ.","translit":"yarʾê lāh pānêhā miššəḥôr ḥāšāḵû.","translit_ru":"йарэ лах панеха мишэхор хашаху.","russian":"Отразит ей лик её, омрачённый чернотой.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"במעון ביתה כי תנוח","hebrew_niqqud":"בִּמְעוֹן בֵּיתָהּ כִּי תָנוּחַ","translit":"bimʿôn bêṯāh kî ṯānûaḥ","translit_ru":"бимон бетах ки тануах","russian":"В обители дома её, когда отдыхала,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"קירתיו גליונים ימלאו,","hebrew_niqqud":"קִירֹתָיו גִּלְיוֹנִים יִמְלָאוּ,","translit":"qîrōṯāyw gilyônîm yimlāʾû,","translit_ru":"киротав гилйоним йимлау,","russian":"Стены его отражениями полны,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"ופעם בחוץ כי תצא לשוח","hebrew_niqqud":"וּפַּעַם בַּחוּץ כִּי תֵצֵא לָשׂוּחַ","translit":"ûpaʿam baḥûṣ kî ṯēṣēʾ lāśûaḥ","translit_ru":"упаам бахуц ки теце ласуах","russian":"А раз на улицу выйдет погулять,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"גם שם אל עיניה יראו.","hebrew_niqqud":"גַּם שָׁם אֶל עֵינֶיהָ יֵרָאוּ.","translit":"gam šām ʾel ʿênêhā yērāʾû.","translit_ru":"гам шам эл енеха йерау.","russian":"И там её глазам они явятся.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"אל אחת החניות כי תסור פעם","hebrew_niqqud":"אֶל אַחַת הַחֲנֻיּוֹת כִּי תָסוּר פַּעַם","translit":"ʾel ʾaḥaṯ haḥănūyyôṯ kî ṯāsûr paʿam","translit_ru":"эл ахат хахануйот ки тасур паам","russian":"В одну из лавок коль свернёт она раз,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"לקנות קשורים ובתי-הנפש","hebrew_niqqud":"לִקְנוֹת קִשּׁוּרִים וּבָתֵּי-הַנֶּפֶשׁ","translit":"liqnôṯ qiššûrîm ûḇāttê-hannep̄eš","translit_ru":"ликнот кишурим увате-ханэфэш","russian":"Купить украшенья и наряды,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"גם שם לא תחן, לא תדע חפש,","hebrew_niqqud":"גַּם שָׁם לֹא תֻחַן, לֹא תֵדַע חֹפֶשׁ,","translit":"gam šām lōʾ ṯūḥan, lōʾ ṯēḏaʿ ḥōp̄eš,","translit_ru":"гам шам ло тухан, ло теда хофэш,","russian":"И там не обретёт покоя, не познает свободы,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"גם שם מראה מוראה – הוי מראה זעם","hebrew_niqqud":"גַּם שָׁם מַרְאָה מוֹרְאָה – הוֹי מַרְאֵה זַעַם","translit":"gam šām marʾâ môrəʾâ – hôy marʾê zaʿam","translit_ru":"гам шам мара морэа – хой маре заам","russian":"И там ужасный лик её – о, гневный взор!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"בצדיה תכעיסנה בעבור הרעימה.","hebrew_niqqud":"בִּצְדִיָּה תַּכְעִיסֶנָּה בַּעֲבוּר הַרְעִימָהּ.","translit":"biṣḏiyyâ taḵʿîsennâ baʿăḇûr harʿîmāh.","translit_ru":"бицдийа тахисэна баавур харимах.","russian":"Повсюду он её злил из-за рокота того.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"גם כי תעזב ביתה מימים ימימה","hebrew_niqqud":"גַּם כִּי תַעֲזֹב בֵּיתָהּ מִיָּמִים יָמִימָה","translit":"gam kî ṯaʿăzōḇ bêṯāh miyyāmîm yāmîmâ","translit_ru":"гам ки таазов бетах мийамим йамима","russian":"Даже когда покидала дом свой надолго,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"לבוא בית מרזח למצא בית חבר,","hebrew_niqqud":"לָבוֹא בֵּית מַרְזֵחַ לִמְצֹא בֵּית חָבֶר,","translit":"lāḇôʾ bêṯ marzēaḥ limṣōʾ bêṯ ḥāḇer,","translit_ru":"лаво бет марзеах лимцо бет хавэр,","russian":"Прийти в таверну, найти приют у друга,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"אז מראת הנשים הצבאת שמה","hebrew_niqqud":"אָז מַרְאֹת הַנָּשִׁים הַצֹּבְאֹת שָׁמָּה","translit":"ʾāz marʾōṯ hannāšîm haṣṣōḇəʾōṯ šāmmâ","translit_ru":"аз марот ханашим хацовэот шама","russian":"Тогда зеркало женщин, что там собрались,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"תורינה תמיד כבאצבע נעלמה","hebrew_niqqud":"תּוֹרֶינָה תָּמִיד כִּבְאֶצְבַּע נַעְלָמָה","translit":"tôrênâ tāmîḏ kiḇʾeṣbaʿ naʿlāmâ","translit_ru":"торена тамид кивэцба налама","russian":"Всегда указует, как незримый перст,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"את חסרון יפיה כל מום בה ושבר.","hebrew_niqqud":"אֶת חֶסְרוֹן יָפְיָהּ כָּל מוּם בָּהּ וָשָׁבֶר.","translit":"ʾeṯ ḥesrôn yop̄yāh kol mûm bāh wāšāḇer.","translit_ru":"эт хэсрон йофйах кол мум бах вашавэр.","russian":"На недостаток её красоты, изъян и излом в ней.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"ותבחל נפשה בתשאות הקרת!","hebrew_niqqud":"וַתִּבְחַל נַפְשָׁהּ בִּתְשֻׁאוֹת הַקָּרֶת!","translit":"wattiḇḥal nap̄šāh biṯšūʾôṯ haqqāreṯ!","translit_ru":"вативхал нафшах битшуот хакарэт!","russian":"И душа её возненавидела хвалу города!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"כי מה-ימריצה תענוג וזהר","hebrew_niqqud":"כִּי מַה-יַּמְרִיצָהּ תַּעֲנוּג וָזֹהַר","translit":"kî mah-yamrîṣāh taʿănûḡ wāzōhar","translit_ru":"ки мах-йамрицах таануг вазохар","russian":"Ибо что за наслажденье и блеск,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"אם חבלה נמרץ, אם רוחה נעכרת!","hebrew_niqqud":"אִם חֶבְלָהּ נִמְרָץ, אִם רוּחָה נֶעְכֶּרֶת!","translit":"ʾim ḥeḇlāh nimrāṣ, ʾim rûḥâ neʿkereṯ!","translit_ru":"им хэвлах нимрац, им руха нэкэрэт!","russian":"Когда урон тяжёл, когда дух её омрачён!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"ותרא לה משכן בדד כסהר","hebrew_niqqud":"וַתֵּרֶא לָה מִשְׁכָּן בָּדָד כַּסֹּהַר","translit":"wattēreʾ lâ miškān bāḏāḏ kassōhar","translit_ru":"ватерэ ла мишкан бадад касохар","russian":"И увидела она себе одинокое жилище, подобное луне,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"תוך פרדס נחמד בין עצי תפארת","hebrew_niqqud":"תּוֹךְ פַּרְדֵּס נֶחְמָד בֵּין עֲצֵי תִפְאָרֶת","translit":"tôḵ pardēs neḥmāḏ bên ʿăṣê ṯip̄ʾāreṯ","translit_ru":"тох пардес нэхмад бен аце тифарэт","russian":"В прекрасном саду, среди величественных деревьев,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r33","order_index":33,"hebrew_plain":"במקום אין אדם ודממה שררת.","hebrew_niqqud":"בִּמְקוֹם אֵין אָדָם וּדְמָמָה שׂרָרֶת.","translit":"bimqôm ʾên ʾāḏām ûḏəmāmâ śrāreṯ.","translit_ru":"бимком ен адам удэмама срарэт.","russian":"В безлюдном месте, где царила тишина.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r34","order_index":34,"hebrew_plain":"אך הה!","hebrew_niqqud":"אַךְ הָהּ!","translit":"ʾaḵ hāh!","translit_ru":"ах хах!","russian":"Но увы!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r35","order_index":35,"hebrew_plain":"גם שמה לא מצאה מנוח!","hebrew_niqqud":"גַּם שָׁמָּה לֹא מָצְאָה מָנוֹחַ!","translit":"gam šāmmâ lōʾ māṣəʾâ mānôaḥ!","translit_ru":"гам шама ло мацэа маноах!","russian":"И там не обрела покоя!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r36","order_index":36,"hebrew_plain":"כי אובל מים כבדלח לטהר","hebrew_niqqud":"כִּי אוּבַל מַיִם כִּבְדֹלַח לָטֹהַר","translit":"kî ʾûḇal mayim kiḇḏōlaḥ lāṭōhar","translit_ru":"ки увал майим кивдолах латохар","russian":"Ибо поток вод, кристально чистый,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r37","order_index":37,"hebrew_plain":"על עפרת זהב בין פרחי ניחח","hebrew_niqqud":"עַל עַפְרֹת זָהָב בֵּין פִּרְחֵי נִיחֹחַ","translit":"ʿal ʿap̄rōṯ zāhāḇ bên pirḥê nîḥōaḥ","translit_ru":"ал афрот захав бен пирхе нихоах","russian":"Над золотой пылью, среди благоуханных цветов,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r38","order_index":38,"hebrew_plain":"בראי מוצק יזל, יתנהל שפי,","hebrew_niqqud":"בִּרְאִי מוּצָק יִזַּל, יִתְנַהֵל שֶׁפִי,","translit":"birʾî mûṣāq yizzal, yiṯnahēl šep̄î,","translit_ru":"бири муцак йизал, йитнахел шэфи,","russian":"Как в сплошном зеркале струился, плавно нёсся,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r39","order_index":39,"hebrew_plain":"וכגליון גלוי גליו יתגלגלו,","hebrew_niqqud":"וּכְגִלְיוֹן גָּלוּי גַּלָּיו יִתְגַּלְגָּלוּ,","translit":"ûḵəḡilyôn gālûy gallāyw yiṯgalgālû,","translit_ru":"ухэгилйон галуй галав йитгалгалу,","russian":"И как в ясном зеркале волны его катились,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r40","order_index":40,"hebrew_plain":"בם ראתה האמללה כי תחת יפי","hebrew_niqqud":"בָּם רָאֲתָה הָאֻמְלָלָה כִּי תַחַת יֹפִי","translit":"bām rāʾăṯâ hāʾūmlālâ kî ṯaḥaṯ yōp̄î","translit_ru":"бам раата хаумлала ки тахат йофи","russian":"В них несчастная увидела, что под красотой,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r41","order_index":41,"hebrew_plain":"רק נקפה, רק קרחה בלחייה עלו;","hebrew_niqqud":"רַק נִקְפָּה, רַק קָרְחָה בִּלְחָיֶיהָ עָלוּ;","translit":"raq niqpâ, raq qorḥâ bilḥāyêhā ʿālû;","translit_ru":"рак никпа, рак корха билхайеха алу;","russian":"Лишь пятна, лишь изъяны на щеках её проступили;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r42","order_index":42,"hebrew_plain":"שוא גם משמה לברוח אמרה –","hebrew_niqqud":"שָׁוְא גַּם מִשָּׁמָּה לִבְרוֹחַ אָמָרָה –","translit":"šāwʾ gam miššāmmâ liḇrôaḥ ʾāmārâ –","translit_ru":"шав гам мишама ливроах амара –","russian":"Напрасно и оттуда она бежать хотела –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r43","order_index":43,"hebrew_plain":"ברתקות קסם תחתיה אסרה,","hebrew_niqqud":"בִּרְתֻקוֹת קֶסֶם תַּחְתֶּיהָ אֻסָּרָה,","translit":"birṯūqôṯ qesem taḥtêhā ʾūssārâ,","translit_ru":"биртукот кэсэм тахтеха усара,","russian":"Волшебными цепями её место сковало,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r44","order_index":44,"hebrew_plain":"כבריח ארמון סגר הגן עליה","hebrew_niqqud":"כִּבְרִיחַ אַרְמוֹן סָגַר הַגָּן עָלֶיהָ","translit":"kiḇrîaḥ ʾarmôn sāḡar haggān ʿālêhā","translit_ru":"кивриах армон сагар хаган алеха","russian":"Как дворцовым засовом сад заперся за нею,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r45","order_index":45,"hebrew_plain":"ומבחר עמקיו לא נטשו רגליה.","hebrew_niqqud":"וּמִבְחַר עֲמָקָיו לֹא נָטְשׁוּ רַגְלֶיהָ.","translit":"ûmiḇḥar ʿămāqāyw lōʾ nāṭəšû raḡlêhā.","translit_ru":"умивхар амакав ло натэшу раглеха.","russian":"И лучших долин его не покидали ноги её.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r46","order_index":46,"hebrew_plain":"לעלמה הזאת נדמינו גם אנו,","hebrew_niqqud":"לָעַלְמָה הַזֹּאת נִדְמִינוּ גַּם אָנוּ,","translit":"lāʿalmâ hazzōʾṯ niḏmînû gam ʾānû,","translit_ru":"лаалма хазот нидмину гам ану,","russian":"Этой деве подобны и мы,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r47","order_index":47,"hebrew_plain":"מכי סנורים כמוה כלנו;","hebrew_niqqud":"מֻכֵּי סַנְוֵרִים כָּמוֹהָ כֻּלָּנוּ;","translit":"mūkkê sanwērîm kāmôhā kūllānû;","translit_ru":"муке санверим камоха кулану;","russian":"Все мы, как она, ослеплены;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r48","order_index":48,"hebrew_plain":"את געל תארנו","hebrew_niqqud":"אֶת גֹּעַל תָּאֳרֵנוּ","translit":"ʾeṯ gōʿal toʾŏrēnû","translit_ru":"эт гоал тоорену","russian":"Мерзость облика нашего","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r49","order_index":49,"hebrew_plain":"לא נוכל נבינה,","hebrew_niqqud":"לֹא נוּכַל נָבִינָה,","translit":"lōʾ nûḵal nāḇînâ,","translit_ru":"ло нухал навина,","russian":"Не можем мы постигнуть.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r50","order_index":50,"hebrew_plain":"למגלה מחסורינו","hebrew_niqqud":"לִמְגַלֵּה מַחְסוֹרֵינוּ","translit":"limḡallê maḥsôrênû","translit_ru":"лимгале махсорену","russian":"Тому, кто наши изъяны обнажит,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r51","order_index":51,"hebrew_plain":"לא נחפץ נאמינה –","hebrew_niqqud":"לֹא נַחְפֹּץ נַאֲמִינָה –","translit":"lōʾ naḥpōṣ naʾămînâ –","translit_ru":"ло нахпоц наамина –","russian":"Не пожелаем мы верить ему –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r52","order_index":52,"hebrew_plain":"אך איהו הגן אדמת הצבי,","hebrew_niqqud":"אַךְ אַיֵּהוּ הַגָּן אַדְמַת הַצֶּבִי,","translit":"ʾaḵ ʾayyēhû haggān ʾaḏmaṯ haṣṣeḇî,","translit_ru":"ах айеху хаган адмат хацэви,","russian":"Но где же он, защитник Земли Красы,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r53","order_index":53,"hebrew_plain":"אי אובל הבהיר רב הפעלים","hebrew_niqqud":"אֵי אוּבָל הַבָּהִיר רַב הַפְּעָלִים","translit":"ʾê ʾûḇāl habbāhîr raḇ happəʿālîm","translit_ru":"е увал хабахир рав хапэалим","russian":"Где тот блистательный, что славен множеством деяний,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r54","order_index":54,"hebrew_plain":"ירא פנינו ולבבנו ישב שבי?","hebrew_niqqud":"יַרְא פָּנֵינוּ וּלְבָבֵנוּ יִשְׁבְּ שֶׁבִי?","translit":"yarʾ pānênû ûləḇāḇēnû yišb šeḇî?","translit_ru":"йар панену улэвавену йишб шэви?","russian":"Кто лик наш убоится, и сердце наше в плен возьмёт?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r55","order_index":55,"hebrew_plain":"הוא ספר מוסר השכל – ספר המשלים.","hebrew_niqqud":"הוּא סֵפֶר מוּסַר הַשְׂכֵּל – סֵפֶר הַמְּשָׁלִים.","translit":"hûʾ sēp̄er mûsar haśkēl – sēp̄er hamməšālîm.","translit_ru":"ху сефэр мусар хаскел – сефэр хамэшалим.","russian":"Он – Книга Нравоучений, Книга Притч.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
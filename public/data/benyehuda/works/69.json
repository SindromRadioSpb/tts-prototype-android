{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-69","text_key":"361e59d874314af0c4f64af9ad62c1fdaa5c455525191138e3d2e6dcaa4e7808","title":"בִּקּוּר חֹלִים","level":null,"tags":["poetry","haskalah"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"69","content_hash":"sha256:50d26191a6930b9d42286b92d225c0a87b3564597bf041e6285128989ff7d8be","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"literary","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/69","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"69","content_hash":"sha256:50d26191a6930b9d42286b92d225c0a87b3564597bf041e6285128989ff7d8be","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"literary","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/69","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"בקור חלים","hebrew_niqqud":"בִּקּוּר חֹלִים","translit":"biqqûr ḥōlîm","translit_ru":"бикур холим","russian":"Посещение больных","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"הצבי חלה וישכב בפאת ערש","hebrew_niqqud":"הַצְּבִי חָלָה וַיִּשְׁכַּב בִּפְאַת עֶרֶשׂ","translit":"haṣṣəḇî ḥālâ wayyiškaḇ bip̄ʾaṯ ʿereś","translit_ru":"хацэви хала вайишкав бифат эрэс","russian":"Занемог олень и лёг в углу на ложе,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"וצבא צבאים רבים לראותו באו,","hebrew_niqqud":"וּצְבָא צְבָאִים רַבִּים לִרְאוֹתוֹ בָּאוּ,","translit":"ûṣəḇāʾ ṣəḇāʾîm rabbîm lirʾôṯô bāʾû,","translit_ru":"уцэва цэваим рабим лирото бау,","russian":"И множество оленей пришло его проведать,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"ויקיפהו ויתחרשו חרש,","hebrew_niqqud":"וַיַּקִּיפֻהוּ וַיִּתְחָרְשׁוּ חֶרֶשׁ,","translit":"wayyaqqîp̄ūhû wayyiṯḥārəšû ḥereš,","translit_ru":"вайакифуху вайитхарэшу хэрэш,","russian":"Они окружили его и затихли неслышно,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"לא בעבור גהה למזרו ימצאו,","hebrew_niqqud":"לֹא בַּעֲבוּר גֵּהָה לִמְזֹרוֹ יִמְצָאוּ,","translit":"lōʾ baʿăḇûr gēhâ limzōrô yimṣāʾû,","translit_ru":"ло баавур геха лимзоро йимцау,","russian":"Не для того, чтоб исцеленье ему сыскать,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"כי אם איש אל אחיו ספרו, ערכו,","hebrew_niqqud":"כִּי אִם אִישׁ אֶל אָחִיו סִפְּרוּ, עָרְכוּ,","translit":"kî ʾim ʾîš ʾel ʾāḥîw sippərû, ʿārəḵû,","translit_ru":"ки им иш эл ахив сипэру, арэху,","russian":"Но каждый другу начал рассказывать, советоваться,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"קרת בתימו וחדשות צמחו.","hebrew_niqqud":"קֹרֹת בָּתֵימוֹ וַחֲדָשׁוֹת צָמָחוּ.","translit":"qōrōṯ bāṯêmô waḥăḏāšôṯ ṣāmāḥû.","translit_ru":"корот батемо вахадашот цамаху.","russian":"О домашних делах и о новых событиях.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"\"הה – קרא החלה – אנא צאוני","hebrew_niqqud":"\"הָהּ – קָרָא הַחֹלֶה – אָנָּא צְאוּנִי","translit":"\"hāh – qārāʾ haḥōlê – ʾānnāʾ ṣəʾûnî","translit_ru":"\"хах – кара хахолэ – ана цэуни","russian":"«О! — вскричал больной, — прошу, оставьте меня,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"ובשלום למות כיום הניחוני!\"","hebrew_niqqud":"וּבְשָׁלוֹם לָמוּת כַּיּוֹם הַנִּיחוּנִי!\"","translit":"ûḇəšālôm lāmûṯ kayyôm hannîḥûnî!\"","translit_ru":"увэшалом ламут кайом ханихуни!\"","russian":"И в мире дайте спокойно умереть мне ныне!»","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"אך אל קול תחנוניו הם לא שמעו,","hebrew_niqqud":"אַךְ אֶל קוֹל תַחֲנוּנָיו הֵם לֹא שָׁמָעוּ,","translit":"ʾaḵ ʾel qôl ṯaḥănûnāyw hēm lōʾ šāmāʿû,","translit_ru":"ах эл кол таханунав хем ло шамау,","russian":"Но на его мольбы они не откликнулись,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"כי לראות אותו עוד רבים נקהלו","hebrew_niqqud":"כִּי לִרְאוֹת אוֹתוֹ עוֹד רַבִּים נִקְהָלוּ","translit":"kî lirʾôṯ ʾôṯô ʿôḏ rabbîm niqhālû","translit_ru":"ки лирот ото од рабим никхалу","russian":"Ибо увидеть его ещё многие собрались,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"ובשבתם שם הן רעב לא ישאו!","hebrew_niqqud":"וּבְשִׁבְתָּם שָׁם הֵן רָעָב לֹא יִשָּׂאוּ!","translit":"ûḇəšiḇtām šām hēn rāʿāḇ lōʾ yiśśāʾû!","translit_ru":"увэшивтам шам хен раав ло йисау!","russian":"И пребывая там, голода они не стерпят!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"כי כל אשר מצאו בלעו אכלו,","hebrew_niqqud":"כִּי כָל אֲשֶׁר מָצְאוּ בָּלְעוּ אָכָלוּ,","translit":"kî ḵol ʾăšer māṣəʾû bāləʿû ʾāḵālû,","translit_ru":"ки хол ашэр мацэу балэу ахалу,","russian":"Ибо всё, что нашли, поглотили, съели,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"כל טרפי כל עץ עם נצניו רעו,","hebrew_niqqud":"כָּל טַרְפֵּי כָּל עֵץ עִם נִצָּנָיו רָעוּ,","translit":"kol ṭarpê kol ʿēṣ ʿim niṣṣānāyw rāʿû,","translit_ru":"кол тарпе кол ец им ницанав рау,","russian":"Все листья с каждого дерева, и бутоны объели,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"כל צמח כל דשא בשדה הזרע:","hebrew_niqqud":"כָּל צֶמַח כָּל דֶּשֶׁא בִּשְׂדֵה הַזֶּרַע:","translit":"kol ṣemaḥ kol dešeʾ biśḏê hazzeraʿ:","translit_ru":"кол цэмах кол дэшэ бисде хазэра:","russian":"Всю зелень, всю траву на засеянном поле:","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"לא יעזבהו משם לא ילכו","hebrew_niqqud":"לֹא יַעַזְבֻהוּ מִשָּׁם לֹא יֵלֵכוּ","translit":"lōʾ yaʿazḇūhû miššām lōʾ yēlēḵû","translit_ru":"ло йаазвуху мишам ло йелеху","russian":"Они не покинут того места, не уйдут,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"עדי כל עשב השדה לחכו,","hebrew_niqqud":"עֲדֵי כָל עֵשֶׂב הַשָּׂדֶה לִחֵכוּ,","translit":"ʿăḏê ḵol ʿēśeḇ haśśāḏê liḥēḵû,","translit_ru":"аде хол есэв хасадэ лихеху,","russian":"Покуда всю траву поля не изгложут,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"או אז נפצו מעליו, וירע","hebrew_niqqud":"אוֹ אָז נָפֹצוּ מֵעָלָיו, וַיֵּרַע","translit":"ʾô ʾāz nāp̄ōṣû mēʿālāyw, wayyēraʿ","translit_ru":"о аз нафоцу меалав, вайера","russian":"Лишь тогда рассеялись от него, и стало хуже,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"זה לצבי יותר ממחלתו,","hebrew_niqqud":"זֶה לַצְּבִי יוֹתֵר מִמַּחֲלָתוֹ,","translit":"zê laṣṣəḇî yôṯēr mimmaḥălāṯô,","translit_ru":"зэ лацэви йотер мимахалато,","russian":"Для оленя это было хуже, чем сама болезнь,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"כי עתה אין לו כל לאכל לשבע,","hebrew_niqqud":"כִּי עַתָּה אֵין לוֹ כֹּל לֶאֱכֹל לִשְׂבֹּעַ,","translit":"kî ʿattâ ʾên lô kōl leʾĕḵōl liśbōaʿ,","translit_ru":"ки ата ен ло кол лээхол лисбоа,","russian":"Ибо теперь у него нет ничего, чтоб наесться,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"והוא לא יוכל קום ממטתו,","hebrew_niqqud":"וְהוּא לֹא יוּכַל קוּם מִמִּטָּתוֹ,","translit":"wəhûʾ lōʾ yûḵal qûm mimmiṭṭāṯô,","translit_ru":"вэху ло йухал кум мимитато,","russian":"И он не может подняться с ложа своего,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"ויהי גורלו ברעב לגוע","hebrew_niqqud":"וַיְהִי גּוֹרָלוֹ בָּרָעָב לִגְוֹעַ","translit":"wayəhî gôrālô bārāʿāḇ liḡwōaʿ","translit_ru":"вайэхи горало бараав лигвоа","russian":"И жребий его – от голода скончаться.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"דומה רופא לצבי!","hebrew_niqqud":"דּוֹמֶה רוֹפֵא לִצְבִי!","translit":"dômê rôp̄ēʾ liṣḇî!","translit_ru":"домэ рофе лицви!","russian":"Больной подобен оленю!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"עת יחלה גבר","hebrew_niqqud":"עֵת יֶחֱלֶה גֶּבֶר","translit":"ʿēṯ yeḥĕlê geḇer","translit_ru":"ет йэхэлэ гэвэр","russian":"Когда человек заболеет,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"רפאי אלל רבים עליו נזעקו","hebrew_niqqud":"רֹפְאֵי אֱלִל רַבִּים עָלָיו נִזְעָקוּ","translit":"rōp̄əʾê ʾĕlil rabbîm ʿālāyw nizʿāqû","translit_ru":"рофэе элил рабим алав низаку","russian":"Множество врачей-шарлатанов на него слетаются,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"– בלתם לא ידע הדרך לקבר –","hebrew_niqqud":"– בִּלְתָּם לֹא יֵדַע הַדֶּרֶךְ לַקֶּבֶר –","translit":"– biltām lōʾ yēḏaʿ haddereḵ laqqeḇer –","translit_ru":"– билтам ло йеда хадэрэх лакэвэр –","russian":"— без них к могиле б он дороги не знал —","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"הונו עם אונו כעלוקות יינקו,","hebrew_niqqud":"הוֹנוֹ עִם אוֹנוֹ כַּעֲלוּקוֹת יִינָקוּ,","translit":"hônô ʿim ʾônô kaʿălûqôṯ yînāqû,","translit_ru":"хоно им оно каалукот йинаку,","russian":"Богатство с силой его, как пиявки, сосут,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"ומאומה לא יועילו,","hebrew_niqqud":"וּמְאוּמָה לֹא יוֹעִילוּ,","translit":"ûməʾûmâ lōʾ yôʿîlû,","translit_ru":"умэума ло йоилу,","russian":"И ничем не помогут,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"את נפשו לא יצילו!","hebrew_niqqud":"אֶת נַפְשׁוֹ לֹא יַצִילוּ!","translit":"ʾeṯ nap̄šô lōʾ yaṣîlû!","translit_ru":"эт нафшо ло йацилу!","russian":"И душу его не спасут!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"גם עוד רעה זאת חולה בין אנשים","hebrew_niqqud":"גַּם עוֹד רָעָה זֹאת חוֹלָה בֵּין אֲנָשׁים","translit":"gam ʿôḏ rāʿâ zōʾṯ ḥôlâ bên ʾănāšym","translit_ru":"гам од раа зот хола бен анашйм","russian":"Ещё и такое зло постигает больных средь людей,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"(מדי דברי גם זאת לפניהם אשים!)","hebrew_niqqud":"(מִדֵּי דַּבְּרִי גַּם זֹאת לִפְנֵיהֶם אָשׂים!)","translit":"(middê dabbərî gam zōʾṯ lip̄nêhem ʾāśym!)","translit_ru":"(миде дабэри гам зот лифнехэм асйм!)","russian":"(И это пред ними я тоже сейчас изложу!)","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"עת נתחל עד שערי מות נגיע,","hebrew_niqqud":"עֵת נִתְחַל עַד שַׁעֲרֵי מָוֶת נַגִּיעַ,","translit":"ʿēṯ niṯḥal ʿaḏ šaʿărê māweṯ naggîaʿ,","translit_ru":"ет нитхал ад шааре мавэт нагиа,","russian":"Когда мы занеможем, дойдём до врат смерти,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"בגדל המחלה עד כי אין מושיע,","hebrew_niqqud":"בִּגְדֹל הַמַּחֲלָה עַד כִּי אֵין מוֹשִׁיעַ,","translit":"biḡḏōl hammaḥălâ ʿaḏ kî ʾên môšîaʿ,","translit_ru":"бигдол хамахала ад ки ен мошиа,","russian":"Когда столь болезнь сильна, что нет спасенья,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r33","order_index":33,"hebrew_plain":"אזי יבאו רבים לראותנו,","hebrew_niqqud":"אֲזַי יָבֹאוּ רַבִּים לִרְאוֹתֵנוּ,","translit":"ʾăzay yāḇōʾû rabbîm lirʾôṯēnû,","translit_ru":"азай йавоу рабим лиротену,","russian":"Тогда многие придут нас проведать,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r34","order_index":34,"hebrew_plain":"אויבי נפשנו אתנו ישלמו","hebrew_niqqud":"אוֹיְבֵי נַפְשֵׁנוּ אִתָּנוּ יִשְׁלָמוּ","translit":"ʾôyəḇê nap̄šēnû ʾittānû yišlāmû","translit_ru":"ойэве нафшену итану йишламу","russian":"Враги души нашей с нами расплатятся,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r35","order_index":35,"hebrew_plain":"וקרובינו הגאים עינימו רמו","hebrew_niqqud":"וּקְרוֹבֵינוּ הַגֵּאִים עֵינֵימוֹ רָמוּ","translit":"ûqərôḇênû haggēʾîm ʿênêmô rāmû","translit_ru":"укэровену хагеим енемо раму","russian":"И близкие наши гордые, чей взор надменен был,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r36","order_index":36,"hebrew_plain":"לא דרכו עד כה על מפתן ביתנו.","hebrew_niqqud":"לֹא דָרְכוּ עַד כֹּה עַל מִפְתַּן בֵּיתֵנוּ.","translit":"lōʾ ḏārəḵû ʿaḏ kōh ʿal mip̄tan bêṯēnû.","translit_ru":"ло дарэху ад кох ал мифтан бетену.","russian":"Доселе не ступавшие на наш порог.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r37","order_index":37,"hebrew_plain":"גש-הלאה, דור תהפכות ומתי-תבל!","hebrew_niqqud":"גֶּשׁ-הָלְאָה, דּוֹר תַּהְפֻּכוֹת וּמְתֵי-תֶבֶל!","translit":"geš-hāləʾâ, dôr tahpūḵôṯ ûməṯê-ṯeḇel!","translit_ru":"гэш-халэа, дор тахпухот умэте-тэвэл!","russian":"Прочь, поколение смуты и живых мертвецов!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r38","order_index":38,"hebrew_plain":"למה עת נחיה תרוונו עצבת","hebrew_niqqud":"לָמָּה עֵת נִחְיֶה תַּרְווּנוּ עַצָּבֶת","translit":"lāmmâ ʿēṯ niḥyê tarwûnû ʿaṣṣāḇeṯ","translit_ru":"лама ет нихйэ тарвуну ацавэт","russian":"Зачем, пока мы живы, вы скорбью нас напояете,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r39","order_index":39,"hebrew_plain":"עד נקוץ בחיים, נשאף המות,","hebrew_niqqud":"עַד נָקוּץ בַּחַיִּים, נִשְׁאַף הַמָּוֶת,","translit":"ʿaḏ nāqûṣ baḥayyîm, nišʾap̄ hammāweṯ,","translit_ru":"ад накуц бахайим, нишаф хамавэт,","russian":"Чтоб жизнь опротивела, и смерти жаждали,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r40","order_index":40,"hebrew_plain":"ובהגיע יומנו לעזוב תבל","hebrew_niqqud":"וּבְהַגִּיעַ יוֹמֵנוּ לַעֲזוֹב תֵּבֶל","translit":"ûḇəhaggîaʿ yômēnû laʿăzôḇ tēḇel","translit_ru":"увэхагиа йомену лаазов тевэл","russian":"А когда наступит день наш покинуть мир,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r41","order_index":41,"hebrew_plain":"תשובו ותיפו לנו פניה,","hebrew_niqqud":"תָּשׁוּבוּ וּתְיַפּוּ לָנוּ פָּנֶיהָ,","translit":"tāšûḇû ûṯəyappû lānû pānêhā,","translit_ru":"ташуву утэйапу лану панеха,","russian":"Вы снова жизнь нам приукрасите,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r42","order_index":42,"hebrew_plain":"עד יכבד לנו הפרד מעליה.","hebrew_niqqud":"עַד יִכְבַּד לָנוּ הִפָּרֵד מֵעָלֶיהָ.","translit":"ʿaḏ yiḵbaḏ lānû hippārēḏ mēʿālêhā.","translit_ru":"ад йихбад лану хипаред меалеха.","russian":"Чтоб трудно было нам с ней расставаться.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
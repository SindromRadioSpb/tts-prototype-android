{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-306","text_key":"b03e454a97a76940a278ac0954e176e5607de2ce3d9640642acb4b8bbc0ec4ec","title":"בְּצֵאתִי מִטֶּלְז","level":null,"tags":["poetry","haskalah"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"306","content_hash":"sha256:701c6002ddc727f29e2b336fc2c133bd3e67a8c107720b10bd3ead1766bb0d82","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/306","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"306","content_hash":"sha256:701c6002ddc727f29e2b336fc2c133bd3e67a8c107720b10bd3ead1766bb0d82","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/306","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"בצאתי מטלז","hebrew_niqqud":"בְּצֵאתִי מִטֶּלְז","translit":"bəṣēʾṯî miṭṭelz","translit_ru":"бэцети митэлз","russian":"По выходе моём из Тельза,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"שש שנים את אחי בתם-לב עבדתי","hebrew_niqqud":"שֵׁשׁ שָׁנִים אֶת אַחַי בְּתָם-לֵב עָבַדְתִּי","translit":"šēš šānîm ʾeṯ ʾaḥay bəṯām-lēḇ ʿāḇaḏtî","translit_ru":"шеш шаним эт ахай бэтам-лев авадти","russian":"Шесть лет братьям моим чистосердечно я служил.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"ובשביעית יצאתי לחפשי – חנם.","hebrew_niqqud":"וּבַשְּׁבִיעִית יָצָאתִי לַחָפְשִׁי – חִנָּם.","translit":"ûḇaššəḇîʿîṯ yāṣāʾṯî laḥop̄šî – ḥinnām.","translit_ru":"увашэвиит йацати лахофши – хинам.","russian":"А в седьмой вышел на свободу — даром.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"שש שנים בחשך יצועי רפדתי","hebrew_niqqud":"שֵׁשׁ שָׁנִים בַּחשֶׁךְ יְצוּעִי רִפַּדְתִּי","translit":"šēš šānîm baḥšeḵ yəṣûʿî rippaḏtî","translit_ru":"шеш шаним бахшэх йэцуи рипадти","russian":"Шесть лет во мраке я ложе своё устилал,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"לשום לעטלפים עינים, לאיר קנם:","hebrew_niqqud":"לָשׂוּם לַעֲטֵלֵּפִים עֵינַיִם, לָאִיר קִנָּם:","translit":"lāśûm laʿăṭēllēp̄îm ʿênayim, lāʾîr qinnām:","translit_ru":"ласум лаателефим енайим, лаир кинам:","russian":"Чтоб дать глаза летучим мышам, осветить их гнездо:","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"לשון וספר לבניהם למדתי.","hebrew_niqqud":"לָשׁוֹן וָסֵפֶר לִבְנֵיהֶם לִמַּדְתִּי.","translit":"lāšôn wāsēp̄er liḇnêhem limmaḏtî.","translit_ru":"лашон васефэр ливнехэм лимадти.","russian":"Языку и Писанию сыновей их учил я.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"זכיתי לבם ארח עולם להבינם,","hebrew_niqqud":"זִכִּיתִי לִבָּם אֹרַח עוֹלָם לַהֲבִינָם,","translit":"zikkîṯî libbām ʾōraḥ ʿôlām lahăḇînām,","translit_ru":"зикити либам орах олам лахавинам,","russian":"Суждено мне было на путь вечный сердца их наставить,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"על נקיון גום ובשרם שקדתי,","hebrew_niqqud":"עַל נִקְיוֹן גֵּוָם וּבְשָׂרָם שָׁקַדְתִּי,","translit":"ʿal niqyôn gēwām ûḇəśārām šāqaḏtî,","translit_ru":"ал никйон гевам увэсарам шакадти,","russian":"О чистоте их плоти и тела радел я,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"סרקתי פאותיהם, הוצאתי הכנם,","hebrew_niqqud":"סָרַקְתִּי פֵּאוֹתֵיהֶם, הוֹצֵאתִי הַכִּנָּם,","translit":"sāraqtî pēʾôṯêhem, hôṣēʾṯî hakkinnām,","translit_ru":"саракти пеотехэм, хоцети хакинам,","russian":"Расчёсывал я их пейсы, выводил вшей,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"צאת בית-רבם מעליהם הורדתי,","hebrew_niqqud":"צֹאַת בֵּית-רַבָּם מֵעֲלֵיהֶם הוֹרַדְתִּי,","translit":"ṣōʾaṯ bêṯ-rabbām mēʿălêhem hôraḏtî,","translit_ru":"цоат бет-рабам меалехэм хорадти,","russian":"Снимал с них скверну их господского дома,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"רחצתי חלאתם, רפאתי שחינם.","hebrew_niqqud":"רָחַצְתִּי חֶלְאָתָם, רִפֵּאתִי שְׁחִינָם.","translit":"rāḥaṣtî ḥelʾāṯām, rippēʾṯî šəḥînām.","translit_ru":"рахацти хэлатам, рипети шэхинам.","russian":"Омывал я их нечистоты, исцелял их чирьи.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"בית-ספר לנערות למו יסדתי,","hebrew_niqqud":"בֵּית-סֵפֶר לִנְעָרוֹת לָמוֹ יִסַּדְתִּי,","translit":"bêṯ-sēp̄er linʿārôṯ lāmô yissaḏtî,","translit_ru":"бет-сефэр линарот ламо йисадти,","russian":"Школу для девочек для них я основал,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"אמות טובות ונשי-חיל להכינם;","hebrew_niqqud":"אִמּוֹת טוֹבוֹת וּנְשֵׁי-חַיִל לַהֲכִינָם;","translit":"ʾimmôṯ ṭôḇôṯ ûnəšê-ḥayil lahăḵînām;","translit_ru":"имот товот унэше-хайил лахахинам;","russian":"Чтоб добрых матерей и жён доблестных из них воспитать;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"בשנת בצרת גם אני נפקדתי","hebrew_niqqud":"בִּשְׁנַת בַּצֹּרֶת גַּם אֲנִי נִפְקַדְתִּי","translit":"bišnaṯ baṣṣōreṯ gam ʾănî nip̄qaḏtî","translit_ru":"бишнат бацорэт гам ани нифкадти","russian":"В год засухи и я был призван,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"להיות למזי רעב סתרם ומגנם.","hebrew_niqqud":"לִהְיוֹת לִמְזֵי רָעָב סִתְרָם וּמָגִנָּם.","translit":"lihyôṯ limzê rāʿāḇ siṯrām ûmāḡinnām.","translit_ru":"лихйот лимзе раав ситрам умагинам.","russian":"Чтобы стать голодающим кровом и защитой.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"למשמרי הבלי שוא קבל-עם הגדתי","hebrew_niqqud":"לִמְשַׁמְּרֵי הַבְלֵי שָׁוְא קֳבָל-עָם הִגַּדְתִּי","translit":"limšammərê haḇlê šāwʾ qŏḇāl-ʿām higgaḏtî","translit_ru":"лимшамэре хавле шав ковал-ам хигадти","russian":"Хранителям суетных призраков всенародно я объявил,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"כי רוח נסכם, כי שקר בימינם,","hebrew_niqqud":"כִּי רוּחַ נִסְכָּם, כִּי שֶׁקֶר בִּימִינָם,","translit":"kî rûaḥ niskām, kî šeqer bîmînām,","translit_ru":"ки руах нискам, ки шэкэр биминам,","russian":"Что дух их — обман, что ложь в деснице их,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"ולחטאת הקהל קראתי לא כחדתי:","hebrew_niqqud":"וּלְחַטֹּאת הַקָּהָל קָרָאתִי לֹא כִחַדְתִּי:","translit":"ûləḥaṭṭōʾṯ haqqāhāl qārāʾṯî lōʾ ḵiḥaḏtî:","translit_ru":"улэхатот хакахал карати ло хихадти:","russian":"И к греху общины взывал я, не скрывая:","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"\"אלה מומיך, ישראל, הנה הנם!\"","hebrew_niqqud":"\"אֵלֶּה מוּמֶיךָ, יִשְׂרָאֵל, הִנֵּה הִנָּם!\"","translit":"\"ʾēllê mûmêḵā, yiśrāʾēl, hinnê hinnām!\"","translit_ru":"\"елэ мумеха, йисраел, хине хинам!\"","russian":"«Вот изъяны твои, Израиль, вот они!»","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"אך חנפי לב אמרו לי \"ביי מרדתי\"","hebrew_niqqud":"אַךְ חַנְפֵי לֵב אָמְרוּ לִי \"בַּיְיָ מָרַדְתִּי\"","translit":"ʾaḵ ḥanp̄ê lēḇ ʾāmərû lî \"bayyā māraḏtî\"","translit_ru":"ах ханфе лев амэру ли \"баййа марадти\"","russian":"Но лицемеры сердец сказали мне: «Восстал я против Господа!»","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"וישימוני לאויב למו, למקטרגם ולמשטינם","hebrew_niqqud":"וַיְשִׂימוּנִי לְאוֹיֵב לָמוֹ, לִמְקַטְרְגָם וּלְמַשְׂטִינָם","translit":"wayəśîmûnî ləʾôyēḇ lāmô, limqaṭrəḡām ûləmaśṭînām","translit_ru":"вайэсимуни лэойев ламо, лимкатрэгам улэмастинам","russian":"И сделали меня врагом себе, их обвинителем и клеветником.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"ועדת \"כלבי שמים\" ממנוחתם החרדתי","hebrew_niqqud":"וַעֲדַת \"כַּלְבֵי שָׁמַיִם\" מִמְּנוּחָתָם הֶחֱרַדְתִּי","translit":"waʿăḏaṯ \"kalḇê šāmayim\" mimmənûḥāṯām heḥĕraḏtî","translit_ru":"ваадат \"калве шамайим\" мимэнухатам хэхэрадти","russian":"И сонм «псов небесных» от покоя их я пробудил,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"התנפלו עלי וישלחו בי שנם,","hebrew_niqqud":"הִתְנַפְּלוּ עָלַי וַיִּשְׁלְחוּ בִי שִׁנָּם,","translit":"hiṯnappəlû ʿālay wayyišləḥû ḇî šinnām,","translit_ru":"хитнапэлу алай вайишлэху ви шинам,","russian":"Набросились на меня и вонзили в меня свои зубы,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"לפני כס דינים קשים העמדתי","hebrew_niqqud":"לפְנֵי כֵס דַּיָּנִים קָשִׁים הָעֳמַדְתִּי","translit":"lp̄ənê ḵēs dayyānîm qāšîm hoʿŏmaḏtî","translit_ru":"лфэне хес дайаним кашим хоомадти","russian":"Перед престолом судов жестоких я предстал,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"וידינוני לצאה רותחת במדורת גיהנם.","hebrew_niqqud":"וַיְדִינוּנִי לְצֹאָה רוֹתַחַת בִּמְדוּרַת גֵּיהִנָּם.","translit":"wayəḏînûnî ləṣōʾâ rôṯaḥaṯ bimḏûraṯ gêhinnām.","translit_ru":"вайэдинуни лэцоа ротахат бимдурат гехинам.","russian":"И осудили меня на кипящую скверну в огне Геенны.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"ואני – לבי כצור, לא חלתי לא רעדתי","hebrew_niqqud":"וַאֲנִי – לִבִּי כַּצּוּר, לֹא חַלְתִּי לֹא רָעַדְתִּי","translit":"waʾănî – libbî kaṣṣûr, lōʾ ḥaltî lōʾ rāʿaḏtî","translit_ru":"ваани – либи кацур, ло халти ло раадти","russian":"А я — моё сердце как скала, не дрогнул я, не устрашился","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"מהם ומהמונם ומגזר דינם,","hebrew_niqqud":"מֵהֶם וּמֵהֲמוֹנָם וּמִגְּזַר דִּינָם,","translit":"mēhem ûmēhămônām ûmiggəzar dînām,","translit_ru":"мехэм умехамонам умигэзар динам,","russian":"Ни их, ни их толпы, ни приговора их суда.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"בבני עליה המעטים לבי סעדתי","hebrew_niqqud":"בִּבְנֵי עֲלִיָּה הַמְּעַטִּים לִבִּי סָעַדְתִּי","translit":"biḇnê ʿăliyyâ hamməʿaṭṭîm libbî sāʿaḏtî","translit_ru":"бивне алийа хамэатим либи саадти","russian":"Сердце своё я утешал немногими сынами возвышенными,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"– אלהים יגמל צדקם, יוסיף חנם!","hebrew_niqqud":"– אֱלֹהִים יִגְמֹל צִדְקָם, יוֹסִיף חִנָּם!","translit":"– ʾĕlōhîm yiḡmōl ṣiḏqām, yôsîp̄ ḥinnām!","translit_ru":"– элохим йигмол цидкам, йосиф хинам!","russian":"— Да воздаст им Бог за праведность их, да прибавит благодати!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"–","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"–","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"ובכן שש שנים את אחי עבדתי","hebrew_niqqud":"וּבְכֵן שֵׁשׁ שָׁנִים אֶת אַחַי עָבַדְתִּי","translit":"ûḇəḵēn šēš šānîm ʾeṯ ʾaḥay ʿāḇaḏtî","translit_ru":"увэхен шеш шаним эт ахай авадти","russian":"И вот, шесть лет я служил братьям моим,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"עתה אצא אין כסף – אך לא חנם,","hebrew_niqqud":"עַתָּה אֵצֵא אֵין כָּסֶף – אַךְ לֹא חִנָּם,","translit":"ʿattâ ʾēṣēʾ ʾên kāsep̄ – ʾaḵ lōʾ ḥinnām,","translit_ru":"ата еце ен касэф – ах ло хинам,","russian":"Ныне я уйду без серебра — но не даром,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"לא לתהו והבל כחי אבדתי,","hebrew_niqqud":"לֹא לְתֹהוּ וָהֶבֶל כֹּחִי אִבַּדְתִּי,","translit":"lōʾ ləṯōhû wāheḇel kōḥî ʾibbaḏtî,","translit_ru":"ло лэтоху вахэвэл кохи ибадти,","russian":"Не на тщету и суету я силы свои растратил,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r33","order_index":33,"hebrew_plain":"עוד יראה פעלי על נכדם, על נינם.","hebrew_niqqud":"עוֹד יֵרָאֶה פָּעֳלִי עַל נֶכְדָּם, עַל נִינָם.","translit":"ʿôḏ yērāʾê poʿŏlî ʿal neḵdām, ʿal nînām.","translit_ru":"од йераэ пооли ал нэхдам, ал нинам.","russian":"Ещё узрится деяние моё на внуках их, на правнуках.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r34","order_index":34,"hebrew_plain":"תרל\"ב","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"5632 год.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
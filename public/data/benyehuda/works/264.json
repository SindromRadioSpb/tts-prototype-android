{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-264","text_key":"f0b3763f4a625168bf750d81f39bd72b355c5f530d168551f662a1ebb5b86a6b","title":"אֶל לֵב-הָאֶבֶן","level":null,"tags":["poetry","haskalah"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"264","content_hash":"sha256:96c74bcf13b814168177b9795e3eb4d1b7e7ecf17713ece696d1d7b9362220d7","author":"שמואל לייב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q4143909","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/264","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"264","content_hash":"sha256:96c74bcf13b814168177b9795e3eb4d1b7e7ecf17713ece696d1d7b9362220d7","author":"שמואל לייב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q4143909","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/264","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"אל לב-האבן","hebrew_niqqud":"אֶל לֵב-הָאֶבֶן","translit":"ʾel lēḇ-hāʾeḇen","translit_ru":"эл лев-хаэвэн","russian":"К каменному сердцу","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"– ואל לב-האבן, לב חלמיש","hebrew_niqqud":"– וְאֶל לֵב-הָאֶבֶן, לֵב חַלָּמִישׁ","translit":"– wəʾel lēḇ-hāʾeḇen, lēḇ ḥallāmîš","translit_ru":"– вээл лев-хаэвэн, лев халамиш","russian":"– И к каменному сердцу, к сердцу-кремню,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"אמר אדני:","hebrew_niqqud":"אָמַר אֲדֹנָי:","translit":"ʾāmar ʾăḏōnāy:","translit_ru":"амар адонай:","russian":"Сказал Господь:","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"הצתי בך אש אוכלה אש,","hebrew_niqqud":"הִצַּתִּי בְךָ אֵשׁ אוֹכְלָה אֵשׁ,","translit":"hiṣṣattî ḇəḵā ʾēš ʾôḵəlâ ʾēš,","translit_ru":"хицати вэха еш охэла еш,","russian":"Я возжёг в тебе огонь всепожирающий,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"ואתה – קר היית;","hebrew_niqqud":"וְאַתָּה – קַר הָיִיתָ;","translit":"wəʾattâ – qar hāyîṯā;","translit_ru":"вэата – кар хайита;","russian":"А ты – ты был холоден;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"יריתי בך חצי אורה,","hebrew_niqqud":"יָרִיתִי בְךָ חִצֵּי אוֹרָה,","translit":"yārîṯî ḇəḵā ḥiṣṣê ʾôrâ,","translit_ru":"йарити вэха хице ора,","russian":"Я метал в тебя стрелы света,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"ואתה – לא ראית;","hebrew_niqqud":"וְאַתָּה – לֹא רָאִיתָ;","translit":"wəʾattâ – lōʾ rāʾîṯā;","translit_ru":"вэата – ло раита;","russian":"А ты не видел;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"הרעמתי עליך כל רעמי-הזעם,","hebrew_niqqud":"הִרְעַמְתִּי עָלֶיךָ כָּל רַעֲמֵי-הַזַּעַם,","translit":"hirʿamtî ʿālêḵā kol raʿămê-hazzaʿam,","translit_ru":"хирамти алеха кол рааме-хазаам,","russian":"Я обрушивал на тебя все громы гнева,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"ואתה לא שמעת;","hebrew_niqqud":"וְאַתָּה לֹא שׁמַעְתָּ;","translit":"wəʾattâ lōʾ šmaʿtā;","translit_ru":"вэата ло шмата;","russian":"А ты не слышал;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"הרעשתי תחתיך כל מצוקי הארץ,","hebrew_niqqud":"הִרְעַשׁתִּי תַחְתֶּיךָ כָּל מְצוּקֵי הָאָרֶץ,","translit":"hirʿašttî ṯaḥtêḵā kol məṣûqê hāʾāreṣ,","translit_ru":"хирашти тахтеха кол мэцуке хаарэц,","russian":"Я сотрясал под тобой все устои земли,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"ואתה לא נבקעת;","hebrew_niqqud":"וְאַתָּה לֹא נִבְקַעְתָּ;","translit":"wəʾattâ lōʾ niḇqaʿtā;","translit_ru":"вэата ло нивката;","russian":"А ты не раскололся;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"הזרמתי עליך ים-דמע חם,","hebrew_niqqud":"הִזְרַמְתִּי עָלֶיךָ יַם-דֶּמַע חַם,","translit":"hizramtî ʿālêḵā yam-demaʿ ḥam,","translit_ru":"хизрамти алеха йам-дэма хам,","russian":"Я изливал на тебя горячее море слёз,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"ואתה לא רכות;","hebrew_niqqud":"וְאַתָּה לֹא רַכּוֹתָ;","translit":"wəʾattâ lōʾ rakkôṯā;","translit_ru":"вэата ло ракота;","russian":"А ты не смягчился;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"הריקותי עליך אוקינוס-הדם –","hebrew_niqqud":"הֲרִיקוֹתִי עָלֶיךָ אוֹקְיָנוּס-הַדָּם –","translit":"hărîqôṯî ʿālêḵā ʾôqəyānûs-haddām –","translit_ru":"харикоти алеха окэйанус-хадам –","russian":"Я изливал на тебя океан крови –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"ולא נמסות;","hebrew_niqqud":"וְלֹא נְמַסּוֹתָ;","translit":"wəlōʾ nəmassôṯā;","translit_ru":"вэло нэмасота;","russian":"И ты не таял;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"ואשי עוד תוקד – ולא התפוצצת,","hebrew_niqqud":"וְאִשׁי עוֹד תּוּקַד – וְלֹא הִתְפּוֹצַצְתָּ,","translit":"wəʾišy ʿôḏ tûqaḏ – wəlōʾ hiṯpôṣaṣtā,","translit_ru":"вэишй од тукад – вэло хитпоцацта,","russian":"И огонь Мой всё ещё пылал – а ты не взорвался,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"והדם עוד רותח – ובו התרחצת.","hebrew_niqqud":"וְהַדָּם עוֹד רוֹתֵחַ – וּבוֹ הִתְרַחַצְתָּ.","translit":"wəhaddām ʿôḏ rôṯēaḥ – ûḇô hiṯraḥaṣtā.","translit_ru":"вэхадам од ротеах – уво хитрахацта.","russian":"И кровь всё ещё кипела – а ты в ней омывался.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"לכן כה אמר אדני:","hebrew_niqqud":"לָכֵן כֹּה אָמַר אֲדֹנָי:","translit":"lāḵēn kōh ʾāmar ʾăḏōnāy:","translit_ru":"лахен кох амар адонай:","russian":"Посему так сказал Господь:","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"הנני הנני עליך הפעם!","hebrew_niqqud":"הִנְנִי הִנְנִי עָלֶיךָ הַפָּעַם!","translit":"hinnî hinnî ʿālêḵā happāʿam!","translit_ru":"хинни хинни алеха хапаам!","russian":"Вот Я, вот Я над тобой на этот раз!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"וחצבתי לי אני","hebrew_niqqud":"וְחָצַבְתִּי לִי אָנִי","translit":"wəḥāṣaḇtî lî ʾānî","translit_ru":"вэхацавти ли ани","russian":"И высек Я Себе","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"מכל להבי תפת וחזיזי הרום","hebrew_niqqud":"מִכָּל לַהֲבֵי תֹפֶת וַחֲזִיזֵי הָרוֹם","translit":"mikkol lahăḇê ṯōp̄eṯ waḥăzîzê hārôm","translit_ru":"микол лахаве тофэт вахазизе харом","russian":"Из всего пламени Тофета и вспышек высот","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"וברקי-אבדון של אחרון היום","hebrew_niqqud":"וּבִרְקֵי-אֲבַדּוֹן שֶל אַחֲרוֹן הַיּוֹם","translit":"ûḇirqê-ʾăḇaddôn šel ʾaḥărôn hayyôm","translit_ru":"увирке-авадон шэл ахарон хайом","russian":"И гибельных молний последнего дня","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"מטה-רשע אים,","hebrew_niqqud":"מַטֵּה-רֶשַע אָיֹם,","translit":"maṭṭê-rešaʿ ʾāyōm,","translit_ru":"мате-рэша айом,","russian":"Жезл нечестия ужасный,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"פטיש זעם ושד,","hebrew_niqqud":"פַּטִּישׁ זַעַם וָשׁד,","translit":"paṭṭîš zaʿam wāšḏ,","translit_ru":"патиш заам вашд,","russian":"Молот гнева и разрушения,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"וטבלתיו בתהום-דם וביקוד –","hebrew_niqqud":"וּטְבַלְתִּיו בִּתְהוֹם-דָּם וּבִיקוֹד –","translit":"ûṭəḇaltîw biṯhôm-dām ûḇîqôḏ –","translit_ru":"утэвалтив битхом-дам увикод –","russian":"И окунул его в бездну крови и пламени –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"ונקמני!","hebrew_niqqud":"וּנְקָמָנִי!","translit":"ûnəqāmānî!","translit_ru":"унэкамани!","russian":"И отомстит Мне!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"והונף בחזק זה פטיש-הפלא,","hebrew_niqqud":"וְהוּנַף בְּחָזָק זֶה פַטִּישׁ-הַפֶּלֶא,","translit":"wəhûnap̄ bəḥāzāq zê p̄aṭṭîš-happeleʾ,","translit_ru":"вэхунаф бэхазак зэ фатиш-хапэлэ,","russian":"И вознесён будет с силой сей дивный молот,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"וממך יוציא ניצוצות לרבבות,","hebrew_niqqud":"וּמִמְּךָ יוֹצִיא נִיצוֹצוֹת לִרְבָבוֹת,","translit":"ûmimməḵā yôṣîʾ nîṣôṣôṯ lirḇāḇôṯ,","translit_ru":"умимэха йоци ницоцот лирвавот,","russian":"И из тебя исторгнет искры мириадами,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"וחצב אש לוהט, וחצב להבות","hebrew_niqqud":"וְחָצַב אֵשׁ לוֹהֵט, וְחָצַב לֶהָבוֹת","translit":"wəḥāṣaḇ ʾēš lôhēṭ, wəḥāṣaḇ lehāḇôṯ","translit_ru":"вэхацав еш лохет, вэхацав лэхавот","russian":"И высечет огонь пылающий, и высечет пламя","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"ממך אבן-קרח, חצוב ופוצץ","hebrew_niqqud":"מִמְּךָ אֶבֶן-קֶרַח, חָצוֹב וּפוֹצֵץ","translit":"mimməḵā ʾeḇen-qeraḥ, ḥāṣôḇ ûp̄ôṣēṣ","translit_ru":"мимэха эвэн-кэрах, хацов уфоцец","russian":"Из тебя, камень-лёд, – высекайся и дробись","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"עדי תתפוצץ.","hebrew_niqqud":"עֲדֵי תִתְפּוֹצֵץ.","translit":"ʿăḏê ṯiṯpôṣēṣ.","translit_ru":"аде титпоцец.","russian":"Доколе не взорвёшься.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"ופרץ אז ממך זרם דם,","hebrew_niqqud":"וּפָרַץ אָז מִמְּך זֶרֶם דָּם,","translit":"ûp̄āraṣ ʾāz mimḵ zerem dām,","translit_ru":"уфарац аз мимх зэрэм дам,","russian":"И прорвётся тогда из тебя поток крови,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"דמך הוא החם –","hebrew_niqqud":"דָּמְךָ הוּא הַחַם –","translit":"dāməḵā hûʾ haḥam –","translit_ru":"дамэха ху хахам –","russian":"Кровь твоя, она горяча –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r33","order_index":33,"hebrew_plain":"ויצא אז אחרון ניצוציך,","hebrew_niqqud":"וְיָצָא אָז אַחֲרוֹן נִיצוֹצֶיךָ,","translit":"wəyāṣāʾ ʾāz ʾaḥărôn nîṣôṣêḵā,","translit_ru":"вэйаца аз ахарон ницоцеха,","russian":"И выйдет тогда последняя искра твоя,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r34","order_index":34,"hebrew_plain":"ונפל ורוה מדמך.","hebrew_niqqud":"וְנָפַל וְרָוָה מִדָּמֶךָ.","translit":"wənāp̄al wərāwâ middāmeḵā.","translit_ru":"вэнафал вэрава мидамэха.","russian":"И падёт, и напьётся крови твоей.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r35","order_index":35,"hebrew_plain":"תרס\"ג","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"1903 год","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
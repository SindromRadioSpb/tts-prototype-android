{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-76","text_key":"73c63a66add9d8f6b66fdccf3de1a6eb4ee279c0545a90944977ef63413507b8","title":"אַחֲרֵי מוֹת שַׁדָּ\"ל","level":null,"tags":["poetry","haskalah"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"76","content_hash":"sha256:f60ef5d5aa4b1e4860261be98503fdc9efbb6e459baf68fa4cc5dde763a83bce","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/76","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"76","content_hash":"sha256:f60ef5d5aa4b1e4860261be98503fdc9efbb6e459baf68fa4cc5dde763a83bce","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/76","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"אחרי מות שד\"ל","hebrew_niqqud":"אַחֲרֵי מוֹת שַׁדָּ\"ל","translit":"ʾaḥărê môṯ šaddāl\"","translit_ru":"ахаре мот шадал\"","russian":"После смерти Шадаля,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"דורשיך, בת-ציון, יום יום ימעטו","hebrew_niqqud":"דּוֹרְשַׁיִךְ, בַּת-צִיּוֹן, יוֹם יוֹם יִמְעָטוּ","translit":"dôrəšayiḵ, baṯ-ṣiyyôn, yôm yôm yimʿāṭû","translit_ru":"дорэшайих, бат-цийон, йом йом йимату","russian":"Ищущие тебя, Дочь Сиона, день ото дня будут редеть,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"מפלטת מחנך רבים יחשלו;","hebrew_niqqud":"מִפְּלֵטַת מַחֲנֵךְ רַבִּים יַחָשֵלוּ;","translit":"mippəlēṭaṯ maḥănēḵ rabbîm yaḥāšēlû;","translit_ru":"мипэлетат маханех рабим йахашелу;","russian":"Из остатка твоего стана многие пошатнутся;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"אלה מכאב לב וריש יכשלו,","hebrew_niqqud":"אֵלֶּה מִכְּאֵב לֵב וָרִישׁ יִכָּשֵׁלוּ,","translit":"ʾēllê mikkəʾēḇ lēḇ wārîš yikkāšēlû,","translit_ru":"елэ микэев лев вариш йикашелу,","russian":"Те от сердечной боли и нищеты споткнутся,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"אלה מטוב לב שמנו ויבעטו.","hebrew_niqqud":"אֵלֶּה מִטּוּב לֵב שָׁמְנוּ וַיִּבְעָטוּ.","translit":"ʾēllê miṭṭûḇ lēḇ šāmənû wayyiḇʿāṭû.","translit_ru":"елэ митув лев шамэну вайивату.","russian":"Те от пресыщения разжиреют и лягнут.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"אלה מרשע כסל יתקוטטו,","hebrew_niqqud":"אֵלֶּה מֵרָשַׁע כֶּסֶל יִתְקוֹטָטוּ,","translit":"ʾēllê mērāšaʿ kesel yiṯqôṭāṭû,","translit_ru":"елэ мераша кэсэл йиткотату,","russian":"Те от злой глупости будут ссориться,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"אלה למצוא כבוד והון יחלו,","hebrew_niqqud":"אֵלֶּה לִמְצוֹא כָּבוֹד וָהוֹן יִחַלוּ,","translit":"ʾēllê limṣôʾ kāḇôḏ wāhôn yiḥalû,","translit_ru":"елэ лимцо кавод вахон йихалу,","russian":"Те ради почета и богатства изнемогут,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"אלה חיק נכריות חבק החלו","hebrew_niqqud":"אֵלֶּה חֵיק נָכְרִיּוֹת חַבֵּק הֵחֵלּוּ","translit":"ʾēllê ḥêq nāḵəriyyôṯ ḥabbēq hēḥēllû","translit_ru":"елэ хек нахэрийот хабек хехелу","russian":"Те же к чужеземкам в объятья потянутся,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"ויקהת פניך יבזו כי קמטו.","hebrew_niqqud":"וִיקְהַת פָּנַיִךְ יִבְזוּ כִּי קֻמָּטוּ.","translit":"wîqəhaṯ pānayiḵ yiḇzû kî qūmmāṭû.","translit_ru":"викэхат панайих йивзу ки кумату.","russian":"И блеклый лик твой презирать станут, ибо он увял.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"אחד היה שמואל דוד לוצאטו","hebrew_niqqud":"אֶחָד הָיָה שְׁמוּאֵל דָּוִד לוּצָאטוּ","translit":"ʾeḥāḏ hāyâ šəmûʾēl dāwiḏ lûṣāʾṭû","translit_ru":"эхад хайа шэмуел давид луцату","russian":"Один был Шмуэль Давид Луцатто,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"לא שעה לתלאותיו כי גדלו","hebrew_niqqud":"לֹא שָׁעָה לִתְלָאוֹתָיו כִּי גָדֵלוּ","translit":"lōʾ šāʿâ liṯlāʾôṯāyw kî ḡāḏēlû","translit_ru":"ло шаа литлаотав ки гаделу","russian":"Не внимал своим бедам, хоть и велики были,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"לא חדל עבדך עד ימיו חדלו,","hebrew_niqqud":"לֹא חָדַל עָבְדֵךְ עַד יָמָיו חָדֵלוּ,","translit":"lōʾ ḥāḏal ʿāḇəḏēḵ ʿaḏ yāmāyw ḥāḏēlû,","translit_ru":"ло хадал авэдех ад йамав хаделу,","russian":"Не переставал раб Твой, пока дни его не кончились,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"לא נטה עד צללי ערבו ינטו.","hebrew_niqqud":"לֹא נָטָה עַד צִלְלֵי עַרְבּוֹ יִנָּטוּ.","translit":"lōʾ nāṭâ ʿaḏ ṣillê ʿarbô yinnāṭû.","translit_ru":"ло ната ад цилле арбо йинату.","russian":"Не отступал, пока не склонились тени его вечера.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"עוד שטו העם ומנו לקטו,","hebrew_niqqud":"עוֹד שָׁטוּ הָעָם וּמִנּוּ לָקָטוּ,","translit":"ʿôḏ šāṭû hāʿām ûminnû lāqāṭû,","translit_ru":"од шату хаам умину лакату,","russian":"Ещё народ скитался и ману собирал,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"עוד קוו כי דבשו ירדו יאכלו,","hebrew_niqqud":"עוֹד קִוּוּ כִּי דִבְשׁוֹ יִרְדּוּ יֹאכֵלוּ,","translit":"ʿôḏ qiwwû kî ḏiḇšô yirdû yōʾḵēlû,","translit_ru":"од киву ки дившо йирду йохелу,","russian":"Ещё чаял, что мед его сойдет, и они вкусят,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"פתאם שמעו מותו ויבהלו","hebrew_niqqud":"פִּתְאֹם שָׁמְעוּ מוֹתוֹ וַיִּבָּהֵלוּ","translit":"piṯʾōm šāməʿû môṯô wayyibbāhēlû","translit_ru":"питом шамэу мото вайибахелу","russian":"Вдруг услышали о смерти его и встревожились,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"שדדה אדרתם ושממה יעטו.","hebrew_niqqud":"שֻׁדְּדָה אַדַּרְתָּם וּשְׁמָמָה יָעָטוּ.","translit":"šūddəḏâ ʾaddartām ûšəmāmâ yāʿāṭû.","translit_ru":"шудэда адартам ушэмама йаату.","russian":"Похищена их слава, и в опустошение облекутся.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"אך אם בידי מות חייו נשמטו","hebrew_niqqud":"אַךְ אִם בִּידֵי מָוֶת חַיָּיו נִשְׁמָטוּ","translit":"ʾaḵ ʾim bîḏê māweṯ ḥayyāyw nišmāṭû","translit_ru":"ах им биде мавэт хайав нишмату","russian":"А если жизнь его в объятья смерти ускользнула,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"קרני אל-מות על שד\"ל יהלו –","hebrew_niqqud":"קַרְנֵי אַל-מָוֶת עַל שַׁדָּ\"ל יָהַלּוּ –","translit":"qarnê ʾal-māweṯ ʿal šaddāl\" yāhallû –","translit_ru":"карне ал-мавэт ал шадал\" йахалу –","russian":"Лучи бессмертия над Шадалем засияют –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"ובני דורו שואלים אלו לאלו:","hebrew_niqqud":"וּבְנֵי דוֹרוֹ שׁוֹאֲלִים אֵלּוּ לָאֵלּוּ:","translit":"ûḇənê ḏôrô šôʾălîm ʾēllû lāʾēllû:","translit_ru":"увэне доро шоалим елу лаелу:","russian":"И сыны поколения его спрашивают друг друга:","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"מי זה יקום לנו במקום לוצאטו?","hebrew_niqqud":"מִי זֶה יָקוּם לָנוּ בִּמְקוֹם לוּצָאטוּ?","translit":"mî zê yāqûm lānû bimqôm lûṣāʾṭû?","translit_ru":"ми зэ йакум лану бимком луцату?","russian":"Кто же восстанет за нас на место Луцатто?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
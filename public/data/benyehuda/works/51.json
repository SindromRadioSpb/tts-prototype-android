{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-51","text_key":"5ebb98a828d015aabd0ecc00bddab0ef93940d11c83a7c106cd2ede565fce9ee","title":"שִׁלְהֵי קַיְטָא","level":null,"tags":["poetry","haskalah"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"51","content_hash":"sha256:484e34b746ccd97daaf0c1191181f42d834be387d7bb446197fbceb7136c829f","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/51","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"51","content_hash":"sha256:484e34b746ccd97daaf0c1191181f42d834be387d7bb446197fbceb7136c829f","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/51","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"שלהי קיטא","hebrew_niqqud":"שִׁלְהֵי קַיְטָא","translit":"šilhê qayṭāʾ","translit_ru":"шилхе кайта","russian":"Конец лета,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"(בהאריך הקיץ עד סוף תשרי)","hebrew_niqqud":"(בְּהֶאֱרֵךְ הַקַּיִץ עַד סוֹף תִּשְׁרֵי)","translit":"(bəheʾĕrēḵ haqqayiṣ ʿaḏ sôp̄ tišrê)","translit_ru":"(бэхээрех хакайиц ад соф тишре)","russian":"(если лето продлится до конца Тишрея)","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"עוד חם היום גדול לא יט לרדת,","hebrew_niqqud":"עוֹד חֹם הַיּוֹם גָּדוֹל לֹא יֵט לָרֶדֶת,","translit":"ʿôḏ ḥōm hayyôm gāḏôl lōʾ yēṭ lāreḏeṯ,","translit_ru":"од хом хайом гадол ло йет ларэдэт,","russian":"Всё ещё жарок великий день, не склонен он к закату,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"עוד על ראשינו השמש עומדת","hebrew_niqqud":"עוֹד עַל רֹאשֵׁינוּ הַשֶּׁמֶשׁ עוֹמֶדֶת","translit":"ʿôḏ ʿal rōʾšênû haššemeš ʿômeḏeṯ","translit_ru":"од ал рошену хашэмэш омэдэт","russian":"Всё ещё над нами солнце, не сходя с зенита,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"ותשלח אשה בנו ותמגגנו –","hebrew_niqqud":"וּתְשַׁלַּח אִשּׁהּ בָּנוּ וּתְמֹגְגֵנוּ –","translit":"ûṯəšallaḥ ʾišh bānû ûṯəmōḡəḡēnû –","translit_ru":"утэшалах ишх бану утэмогэгену –","russian":"И посылает огонь в нас, и плавит нас –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"וכבר יצא תשרי ירח חגינו.","hebrew_niqqud":"וּכְבָר יָצָא תִּשְׁרֵי יֶרַח חַגֵּינוּ.","translit":"ûḵəḇār yāṣāʾ tišrê yeraḥ ḥaggênû.","translit_ru":"ухэвар йаца тишре йэрах хагену.","russian":"А уже минул Тишрей, месяц наших торжеств.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"כל שבעת הימים בסכה דרנו,","hebrew_niqqud":"כָּל שִׁבְעַת הַיָּמִים בַּסֻּכָּה דַּרְנוּ,","translit":"kol šiḇʿaṯ hayyāmîm bassūkkâ darnû,","translit_ru":"кол шиват хайамим басука дарну,","russian":"Все семь дней мы обитали в куще,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"מרוחות וגשמים לא נצטערנו","hebrew_niqqud":"מֵרוּחוֹת וּגְשָׁמִים לֹא נִצְטַעַרְנוּ","translit":"mērûḥôṯ ûḡəšāmîm lōʾ niṣṭaʿarnû","translit_ru":"мерухот угэшамим ло ництаарну","russian":"От ветров и дождей не страдали мы,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"ו\"גבורות הגשמים\" הננו מזכירים","hebrew_niqqud":"וּ\"גְבוּרוֹת הַגְּשָׁמִים\" הִנְנוּ מַזְכִּירִים","translit":"ûḡəḇûrôṯ\" haggəšāmîm\" hinnû mazkîrîm","translit_ru":"угэвурот\" хагэшамим\" хинну мазкирим","russian":"И «Гвурот ха-Гешамим» мы поминаем,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"ופני השמים עודם ספירים.","hebrew_niqqud":"וּפְנֵי הַשָּׁמַיִם עוֹדָם סַפִּירִים.","translit":"ûp̄ənê haššāmayim ʿôḏām sappîrîm.","translit_ru":"уфэне хашамайим одам сапирим.","russian":"А небеса по-прежнему лазурны.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"אתה האל עשה זה הפלא!","hebrew_niqqud":"אַתָּה הָאֵל עֹשֵׂה זֶה הַפֶּלֶא!","translit":"ʾattâ hāʾēl ʿōśê zê happeleʾ!","translit_ru":"ата хаел осе зэ хапэлэ!","russian":"Ты, Боже, сотворил сие чудо!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"קיץ וחרף – בידך כל אלה.","hebrew_niqqud":"קַיִץ וָחֹרֶף – בְּיָדְךָ כָּל אֵלֶּה.","translit":"qayiṣ wāḥōrep̄ – bəyāḏəḵā kol ʾēllê.","translit_ru":"кайиц вахорэф – бэйадэха кол елэ.","russian":"Лето и зима – всё это в Твоей руке.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"תקצף ובאלול הסתו יקדמנו.","hebrew_niqqud":"תִּקְצֹף וּבֶאֱלוּל הַסְּתָו יְקַדְּמֵנוּ.","translit":"tiqṣōp̄ ûḇeʾĕlûl hassəṯāw yəqaddəmēnû.","translit_ru":"тикцоф увээлул хасэтав йэкадэмену.","russian":"Разгневаешься – и в Элуле Осень нас опередит.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"תרצה ולמרחשון יאריך קיצנו.","hebrew_niqqud":"תִּרְצֶה וּלְמַרְחֶשְׁוָן יַאֲרִיךְ קֵיצֵנוּ.","translit":"tirṣê ûləmarḥešwān yaʾărîḵ qêṣēnû.","translit_ru":"тирцэ улэмархэшван йаарих кецену.","russian":"Если же благоволишь – до Мархешвана продлится лето наше.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"ברוך אתה, אל, על ארך ארך,","hebrew_niqqud":"בָּרוּךְ אַתָּה, אֵל, עַל אֹרֶךְ אֹרֶךָ,","translit":"bārûḵ ʾattâ, ʾēl, ʿal ʾōreḵ ʾōreḵā,","translit_ru":"барух ата, ел, ал орэх орэха,","russian":"Благословен Ты, Боже, за долготу долгот,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"חדש חיים הוספת ליצוריך;","hebrew_niqqud":"חֹדֶשׁ חַיִּים הוֹסַפְתָּ לִיצוּרֶיךָ;","translit":"ḥōḏeš ḥayyîm hôsap̄tā lîṣûrêḵā;","translit_ru":"ходэш хайим хосафта лицуреха;","russian":"Новую жизнь даровал Ты созданиям Твоим;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"כי מה הקיץ אם לא חיי ארץ,","hebrew_niqqud":"כִּי מָה הַקַּיִץ אִם לֹא חַיֵּי אָרֶץ,","translit":"kî mâ haqqayiṣ ʾim lōʾ ḥayyê ʾāreṣ,","translit_ru":"ки ма хакайиц им ло хайе арэц,","russian":"Ибо что есть лето, как не жизнь земная,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"ומה הסתו אם לא מות וקרץ?","hebrew_niqqud":"וּמָה הַסְּתָו אִם לֹא מָוֶת וָקָרֶץ?","translit":"ûmâ hassəṯāw ʾim lōʾ māweṯ wāqāreṣ?","translit_ru":"ума хасэтав им ло мавэт вакарэц?","russian":"И что есть осень, как не смерть и стужа?","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"הפלה, אל עשי, גם לי נא חסדך,","hebrew_niqqud":"הַפְלֵה, אֵל עֹשָׂי, גַּם לִי נָא חַסְדֶּךָ,","translit":"hap̄lê, ʾēl ʿōśāy, gam lî nāʾ ḥasdeḵā,","translit_ru":"хафле, ел осай, гам ли на хасдэха,","russian":"Сотвори же чудо, Боже, Создатель мой, и мне, молю, яви Свою милость,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"האריכה לי קיצי, העמד שמשך,","hebrew_niqqud":"הַאֲרִיכָה לִי קֵיצִי, הַעֲמֵד שִׁמְשֶׁךָ,","translit":"haʾărîḵâ lî qêṣî, haʿămēḏ šimšeḵā,","translit_ru":"хаариха ли кеци, хаамед шимшэха,","russian":"Продли моё лето, удержи Своё солнце,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"וסתו חיי, עת זקנה, כי יבואני –","hebrew_niqqud":"וּסְתָו חַיַּי, עֵת זִקְנָה, כִּי יְבוּאֵנִי –","translit":"ûsəṯāw ḥayyay, ʿēṯ ziqnâ, kî yəḇûʾēnî –","translit_ru":"усэтав хайай, ет зикна, ки йэвуени –","russian":"И когда осень жизни моей, пора старости, наступит –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"רוח קדשך אל תקח ממני!","hebrew_niqqud":"רוּחַ קָדְשֶׁךָ אַל תִּקַּח מִמֶּנִּי!","translit":"rûaḥ qoḏšeḵā ʾal tiqqaḥ mimmennî!","translit_ru":"руах кодшэха ал тиках мимэни!","russian":"Дух Святой Твой не отними от меня!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"(א\"ח הסכות תרמ\"ג)","hebrew_niqqud":"(א\"ח הַסָּכוֹת תרמ\"ג)","translit":"(ʾḥ\" hassāḵôṯ ṯrmḡ\")","translit_ru":"(х\" хасахот трмг\")","russian":"(Последний день Суккота, 5643 г.)","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-297","text_key":"db4817bb9c5c8c489178d21c5f936396da6fd0d2014db603fbec171087726be1","title":"לְמִרְיָם","level":null,"tags":["poetry","tehiya"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"297","content_hash":"sha256:6dc1c0bbd24786ce26465a8604ff73b3338c0c0417aee5336476dcfc8330c25e","author":"שאול טשרניחובסקי","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q521410","translator":null,"translator_uri":null,"orig_language":"he","era":"tehiya","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/297","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"שירי שאול טשרניחובסקי\", תל אביב: דביר, תשכ\"ח","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"297","content_hash":"sha256:6dc1c0bbd24786ce26465a8604ff73b3338c0c0417aee5336476dcfc8330c25e","author":"שאול טשרניחובסקי","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q521410","translator":null,"translator_uri":null,"orig_language":"he","era":"tehiya","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/297","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"שירי שאול טשרניחובסקי\", תל אביב: דביר, תשכ\"ח","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"למרים","hebrew_niqqud":"לְמִרְיָם","translit":"ləmiryām","translit_ru":"лэмирйам","russian":"К Мириам","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"לו אך ככוכב הנופל בנשפים","hebrew_niqqud":"לוּ אַךְ כַּכּוֹכָב הַנּוֹפֵל בַּנְּשָׁפִים","translit":"lû ʾaḵ kakkôḵāḇ hannôp̄ēl bannəšāp̄îm","translit_ru":"лу ах какохав ханофел банэшафим","russian":"О, если б лишь звездой упавшей в ночь,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"על שמי חייך שמי חלף, גז,","hebrew_niqqud":"עַל שְׁמֵי חַיַּיִךְ שְׁמִי חָלַף, גָּז,","translit":"ʿal šəmê ḥayyayiḵ šəmî ḥālap̄, gāz,","translit_ru":"ал шэме хайайих шэми халаф, газ,","russian":"По небу жизни твоей моё промчалось, сгинуло,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"אם בא בעז ורתוקות-הכשפים,","hebrew_niqqud":"אִם בָּא בָּעֹז וּרְתוּקוֹת-הַכְּשָׁפִים,","translit":"ʾim bāʾ bāʿōz ûrəṯûqôṯ-hakkəšāp̄îm,","translit_ru":"им ба баоз урэтукот-хакэшафим,","russian":"С могучей силой, цепью колдовской,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"ואם תחת עלו לנצח כרעת, -","hebrew_niqqud":"וְאִם תַּחַת עֻלּוֹ לָנֶצַח כָּרַעַתְּ, -","translit":"wəʾim taḥaṯ ʿūllô lāneṣaḥ kāraʿat, -","translit_ru":"вэим тахат уло ланэцах караат, -","russian":"И если под ярмом его ты гнулась, –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"נא אל תקלליני אז,","hebrew_niqqud":"נָא אַל תְּקַלְלִינִי אָז,","translit":"nāʾ ʾal təqallînî ʾāz,","translit_ru":"на ал тэкаллини аз,","russian":"Тогда молю: не проклинай меня,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"נא אל תקלליני את!","hebrew_niqqud":"נָא אַל תְּקַלְלִינִי אַתְּ!","translit":"nāʾ ʾal təqallînî ʾat!","translit_ru":"на ал тэкаллини ат!","russian":"Молю, не проклинай меня ты!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"בכליל פרחיך – זר-העדנים –","hebrew_niqqud":"בִּכְלִיל פְּרָחַיִךְ – זֵר-הָעֲדָנִים –","translit":"biḵlîl pərāḥayiḵ – zēr-hāʿăḏānîm –","translit_ru":"бихлил пэрахайих – зер-хааданим –","russian":"В твоём венце из роз – венок услад –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"אם ידי לך קלעה ורד-ענק,","hebrew_niqqud":"אִם יָדִי לָךְ קָלְעָה וֶרֶד-עֲנָק,","translit":"ʾim yāḏî lāḵ qāləʿâ wereḏ-ʿănāq,","translit_ru":"им йади лах калэа вэрэд-анак,","russian":"Моя рука тебе сплела пышную розу,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"או בכוס תענוגיך מסכתי רוש-פתנים,","hebrew_niqqud":"אוֹ בְּכוֹס תַּעֲנוּגַיִךְ מָסַכְתִּי רוֹשׁ-פְּתָנִים,","translit":"ʾô bəḵôs taʿănûḡayiḵ māsaḵtî rôš-pəṯānîm,","translit_ru":"о бэхос таанугайих масахти рош-пэтаним,","russian":"Иль в чашу нег твоих змеиный яд подлив,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"להרעיל, בה טרם נגעת, -","hebrew_niqqud":"לְהַרְעִיל, בָּהּ טֶרֶם נָגַעַתְּ, -","translit":"ləharʿîl, bāh ṭerem nāḡaʿat, -","translit_ru":"лэхарил, бах тэрэм нагаат, -","russian":"Чтоб отравить, к ней не успев прильнуть, –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"נא אל תקלליני אז,","hebrew_niqqud":"נָא אַל תְּקַלְלִינִי אָז,","translit":"nāʾ ʾal təqallînî ʾāz,","translit_ru":"на ал тэкаллини аз,","russian":"Тогда молю: не проклинай меня,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"נא אל תקלליני את!","hebrew_niqqud":"נָא אַל תְּקַלְלִינִי אַתְּ!","translit":"nāʾ ʾal təqallînî ʾat!","translit_ru":"на ал тэкаллини ат!","russian":"Молю, не проклинай меня ты!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"ויום בו תזכרי לי אהבת נעוריך,","hebrew_niqqud":"וְיוֹם בּוֹ תִּזְכְּרִי לִי אַהֲבַת נְעוּרַיִךְ,","translit":"wəyôm bô tizkərî lî ʾahăḇaṯ nəʿûrayiḵ,","translit_ru":"вэйом бо тизкэри ли ахават нэурайих,","russian":"И в день, когда ты вспомнишь юность лет,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"נשיקותי והגיגי מלאי-אש,","hebrew_niqqud":"נְשִׁיקוֹתַי וַהֲגִיגִי מְלֵאֵי-אֵשׁ,","translit":"nəšîqôṯay wahăḡîḡî məlēʾê-ʾēš,","translit_ru":"нэшикотай вахагиги мэлее-еш,","russian":"Мои лобзанья, пламенные речи,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"או קרות מלי ונהר דמעותיך","hebrew_niqqud":"אוֹ קָרוֹת מִלַּי וּנְהַר דִּמְעוֹתַיִךְ","translit":"ʾô qārôṯ millay ûnəhar dimʿôṯayiḵ","translit_ru":"о карот милай унэхар димотайих","russian":"Иль хладность слов моих и слёз твоих поток,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"בערב נפרדנו לעד, -","hebrew_niqqud":"בָּעֶרֶב נִפְרַדְנוּ לָעַד, -","translit":"bāʿereḇ nip̄raḏnû lāʿaḏ, -","translit_ru":"баэрэв нифрадну лаад, -","russian":"В тот вечер, когда вечно расстались мы, –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"נא אל תקלליני אז,","hebrew_niqqud":"נָא אַל תְּקַלְלִינִי אָז,","translit":"nāʾ ʾal təqallînî ʾāz,","translit_ru":"на ал тэкаллини аз,","russian":"Тогда молю: не проклинай меня,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"נא אל תקלליני את!","hebrew_niqqud":"נָא אַל תְּקַלְלִינִי אַתְּ!","translit":"nāʾ ʾal təqallînî ʾat!","translit_ru":"на ал тэкаллини ат!","russian":"Молю, не проклинай меня ты!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"שלמתי לך!","hebrew_niqqud":"שִׁלַּמְתִּי לָךְ!","translit":"šillamtî lāḵ!","translit_ru":"шиламти лах!","russian":"Я заплатил тебе!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"שלמתי בטל-נעורי,","hebrew_niqqud":"שִׁלַּמְתִּי בְּטַל-נְעוּרַי,","translit":"šillamtî bəṭal-nəʿûray,","translit_ru":"шиламти бэтал-нэурай,","russian":"Росой платил я молодости дней,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"בנשיקת תם, שאת מצית,","hebrew_niqqud":"בִּנְשִׁיקַת תֹּם, שֶׁאַתְּ מָצִית,","translit":"binšîqaṯ tōm, šeʾat māṣîṯ,","translit_ru":"биншикат том, шэат мацит,","russian":"Невинным поцелуем, что зажгла ты,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"וברטט – ראשון הוא ליצורי, –","hebrew_niqqud":"וּבְרֶטֶט – רִאשׁוֹן הוּא לִיצוּרָי, –","translit":"ûḇəreṭeṭ – riʾšôn hûʾ lîṣûrāy, –","translit_ru":"увэрэтэт – ришон ху лицурай, –","russian":"И дрожью, для существа впервые мне, –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"בחלומות רז, את בם הופעת…","hebrew_niqqud":"בַּחֲלוֹמוֹת רָז, אַתְּ בָּם הוֹפַעַתְּ…","translit":"baḥălômôṯ rāz, ʾat bām hôp̄aʿat...","translit_ru":"бахаломот раз, ат бам хофаат...","russian":"В мечтах сокровенных, где явилась ты…","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"נא אל תקלליני אז,","hebrew_niqqud":"נָא אַל תְּקַלְלִינִי אָז,","translit":"nāʾ ʾal təqallînî ʾāz,","translit_ru":"на ал тэкаллини аз,","russian":"Тогда молю: не проклинай меня,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"נא אל תקלליני את!","hebrew_niqqud":"נָא אַל תְּקַלְלִינִי אַתְּ!","translit":"nāʾ ʾal təqallînî ʾat!","translit_ru":"на ал тэкаллини ат!","russian":"Молю, не проклинай меня ты!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"שלמתי לך בדמי לבתי נוגה,","hebrew_niqqud":"שִׁלַּמְתִּי לָךְ בִּדְמֵי לִבָּתִי נוּגָה,","translit":"šillamtî lāḵ biḏmê libbāṯî nûḡâ,","translit_ru":"шиламти лах бидме либати нуга,","russian":"Платил я кровью сердца, полного тоской,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"ביאוש ונחם לאחר זמן,","hebrew_niqqud":"בְּיֵאוּשׁ וְנֹחַם לְאַחַר זְמָן,","translit":"bəyēʾûš wənōḥam ləʾaḥar zəmān,","translit_ru":"бэйеуш вэнохам лэахар зэман,","russian":"Отчаяньем, что после утешеньем,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"בכליון-נפש – נפשי הרת תוגה, -","hebrew_niqqud":"בְּכִלְיוֹן-נֶפֶשׁ – נַפְשִׁי הֲרַת תּוּגָה, -","translit":"bəḵilyôn-nep̄eš – nap̄šî hăraṯ tûḡâ, -","translit_ru":"бэхилйон-нэфэш – нафши харат туга, -","russian":"Истощеньем души, скорбью поглощенной, –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"שלמתי כל אשר נתת.","hebrew_niqqud":"שִׁלַּמְתִּי כָּל אֲשֶׁר נָתַתְּ.","translit":"šillamtî kol ʾăšer nāṯat.","translit_ru":"шиламти кол ашэр натат.","russian":"Я всё вернул, что ты дала.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"נא אל תקלליני אז,","hebrew_niqqud":"נָא אַל תְּקַלְלִינִי אָז,","translit":"nāʾ ʾal təqallînî ʾāz,","translit_ru":"на ал тэкаллини аз,","russian":"Тогда молю: не проклинай меня,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"נא אל תקלליני את!","hebrew_niqqud":"נָא אַל תְּקַלְלִינִי אַתְּ!","translit":"nāʾ ʾal təqallînî ʾat!","translit_ru":"на ал тэкаллини ат!","russian":"Молю, не проклинай меня ты!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"הידלברג","hebrew_niqqud":"הִידְלְבֵּרְג","translit":"hîḏələbērḡ","translit_ru":"хидэлэберг","russian":"Гейдельберг","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
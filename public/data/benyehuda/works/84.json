{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-84","text_key":"a0674bca53c305efc826a4b4fdec6bdab1bcb853b7aea18629a5ca16ca2ae368","title":"הַזְּאֵב לִפְנֵי מוֹתוֹ וְהַשּׁוּעָל","level":null,"tags":["poetry","haskalah"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"84","content_hash":"sha256:bf8270170a983548b42fe35d9b79dd9acd22edb622a3977a2f80d68d75e504c5","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/84","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"84","content_hash":"sha256:bf8270170a983548b42fe35d9b79dd9acd22edb622a3977a2f80d68d75e504c5","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/84","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"הזאב לפני מותו והשועל","hebrew_niqqud":"הַזְּאֵב לִפְנֵי מוֹתוֹ וְהַשּׁוּעָל","translit":"hazzəʾēḇ lip̄nê môṯô wəhaššûʿāl","translit_ru":"хазэев лифне мото вэхашуал","russian":"Волк перед смертью и Лиса","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"לוידאו של הקראת שיר זה בידי","hebrew_niqqud":"לַוִּידֵאוֹ שֶׁל הַקְרָאַת שִׁיר זֶה בְּיָדִי","translit":"lawwîḏēʾô šel haqrāʾaṯ šîr zê bəyāḏî","translit_ru":"лавидео шэл хакраат шир зэ бэйади","russian":"К видеозаписи чтения этого стихотворения","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"ד\"ר יורם מלצר","hebrew_niqqud":"ד\"ר יוֹרָם מֶלְצֶר","translit":"ḏr\" yôrām melṣer","translit_ru":"др\" йорам мэлцэр","russian":"доктора Йорама Мельцера","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"הזאב חלה חליו אשר ימות בו.","hebrew_niqqud":"הַזְּאֵב חָלָה חָלְיוֹ אֲשֶר יָמוּת בּוֹ.","translit":"hazzəʾēḇ ḥālâ ḥāləyô ʾăšer yāmûṯ bô.","translit_ru":"хазэев хала халэйо ашэр йамут бо.","russian":"Волк заболел той болезнью, от которой он умрёт.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"ויהי בראותו כי ימיו קרבו","hebrew_niqqud":"וַיְהִי בִּרְאוֹתוֹ כִּי יָמָיו קָרָבוּ","translit":"wayəhî birʾôṯô kî yāmāyw qārāḇû","translit_ru":"вайэхи бирото ки йамав караву","russian":"И когда увидел он, что дни его сочтены,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"ויחשב דרכו ויאמר אל לבו:","hebrew_niqqud":"וַיְחַשֵּׁב דַּרְכּוֹ וַיֹּאמֶר אֶל לִבּוֹ:","translit":"wayəḥaššēḇ darkô wayyōʾmer ʾel libbô:","translit_ru":"вайэхашев дарко вайомэр эл либо:","russian":"он помыслил о жизни своей и сказал про себя:","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"\"הן אמת כי חטאתי למאד רבו,","hebrew_niqqud":"\"הֵן אֱמֶת כִּי חַטֹּאתַי לִמְאֹד רָבוּ,","translit":"\"hēn ʾĕmeṯ kî ḥaṭṭōʾṯay limʾōḏ rāḇû,","translit_ru":"\"хен эмэт ки хатотай лимод раву,","russian":"«Конечно, правда, что я много грешил,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"כי רעות רבות בימי חיי עשיתי,","hebrew_niqqud":"כִּי רָעוֹת רַבּוֹת בִּימֵי חַיַי עָשִׂיתִי,","translit":"kî rāʿôṯ rabbôṯ bîmê ḥayay ʿāśîṯî,","translit_ru":"ки раот работ биме хайай асити,","russian":"Ибо много зла я совершил в дни свои,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"כסדם הייתי, לעמרה דמיתי,","hebrew_niqqud":"כִּסְדֹם הָיִיתִי, לַעֲמֹרָה דָּמִיתִי,","translit":"kisḏōm hāyîṯî, laʿămōrâ dāmîṯî,","translit_ru":"кисдом хайити, лаамора дамити,","russian":"Подобен я был Содому, и Гоморре я уподобился,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"אך גם מעשות טוב הן לא חדלתי!","hebrew_niqqud":"אַךְ גַּם מֵעֲשׂוֹת טוֹב הֵן לֹא חָדָלְתִּי!","translit":"ʾaḵ gam mēʿăśôṯ ṭôḇ hēn lōʾ ḥāḏālətî!","translit_ru":"ах гам меасот тов хен ло хадалэти!","russian":"Но и от добра я ведь не уклонялся!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"עוד אזכור היום, עודו נגד עיני,","hebrew_niqqud":"עוֹד אֶזְכּוֹר הַיּוֹם, עוֹדוֹ נֶגֶד עֵינִי,","translit":"ʿôḏ ʾezkôr hayyôm, ʿôḏô neḡeḏ ʿênî,","translit_ru":"од эзкор хайом, одо нэгэд ени,","russian":"До сих пор я помню тот день, он и ныне пред глазами моими,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"עת פגע בי שה נבזה ויחרפני,","hebrew_niqqud":"עֵת פָּגַע בִּי שֶׂה נִבְזֶה וַיְחָרְפֵנִי,","translit":"ʿēṯ pāḡaʿ bî śê niḇzê wayəḥārəp̄ēnî,","translit_ru":"ет пага би сэ нивзэ вайэхарэфени,","russian":"Когда встретился мне презренный агнец и оскорбил меня,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"ואני לא המתיו וברוחי משלתי!\"","hebrew_niqqud":"וַאֲנִי לֹא הֲמִתִּיו וּבְרוּחִי מָשָׁלְתִּי!\"","translit":"waʾănî lōʾ hămittîw ûḇərûḥî māšālətî!\"","translit_ru":"ваани ло хамитив увэрухи машалэти!\"","russian":"А я его не убил и духом своим владел!»","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"\"ואני עד!","hebrew_niqqud":"\"וַאֲנִי עֵד!","translit":"\"waʾănî ʿēḏ!","translit_ru":"\"ваани ед!","russian":"«И я тому свидетель!","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"– ענה שועל איש המזמה,","hebrew_niqqud":"– עָנָה שׁוּעָל אִישׁ הַמְּזִמָּה,","translit":"– ʿānâ šûʿāl ʾîš hamməzimmâ,","translit_ru":"– ана шуал иш хамэзима,","russian":"– Ответила лиса, хитрец,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"שבא ויחכה ליציאת הנשמה –","hebrew_niqqud":"שֶׁבָּא וַיְחַכֶּה לִיצִיאַת הַנְּשָׁמָה –","translit":"šebbāʾ wayəḥakkê lîṣîʾaṯ hannəšāmâ –","translit_ru":"шэба вайэхакэ лициат ханэшама –","russian":"Пришедшая пождать исхода души –","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"זאת היתה בעצם","hebrew_niqqud":"זֹאת הָיְתָה בְּעֶצֶם","translit":"zōʾṯ hāyəṯâ bəʿeṣem","translit_ru":"зот хайэта бээцэм","russian":"Это было, собственно,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"יום התקע בגרונך העצם","hebrew_niqqud":"יוֹם הִתָּקַע בִּגְרוֹנְךָ הָעֶצֶם","translit":"yôm hittāqaʿ biḡrônəḵā hāʿeṣem","translit_ru":"йом хитака бигронэха хаэцэм","russian":"В тот день, когда застряла у тебя в глотке кость,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"אשר החסידה הוציאה משמה\".","hebrew_niqqud":"אֲשֶׁר הַחֲסִידָה הוֹצִיאָה מִשָּׁמָּה\".","translit":"ʾăšer haḥăsîḏâ hôṣîʾâ miššāmmâ\".","translit_ru":"ашэр хахасида хоциа мишама\".","russian":"Которую аист вынул оттуда».","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
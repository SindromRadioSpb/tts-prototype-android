"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"ומאז נכון כסאו, ותמיד יבחר.","hebrew_niqqud":"וּמֵאָז נָכוֹן כִּסְאוֹ, וְתָמִיד יְבֻחַר.","translit":"ûmēʾāz nāḵôn kisʾô, wəṯāmîḏ yəḇūḥar.","translit_ru":"умеаз нахон кисо, вэтамид йэвухар.","russian":"И с тех пор его престол утвержден, и он всегда будет почитаем.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
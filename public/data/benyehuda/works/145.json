l,"audio_asset_key":null},{"row_id":"r110","order_index":110,"hebrew_plain":"לא עוד אזי כעבדים,","hebrew_niqqud":"לֹא עוֹד אָזַי כַּעֲבָדִים,","translit":"lōʾ ʿôḏ ʾāzay kaʿăḇāḏîm,","translit_ru":"ло од азай каавадим,","russian":"Не быть тогда уж им рабами,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r111","order_index":111,"hebrew_plain":"לא נדדים נפרדים,","hebrew_niqqud":"לֹא נֹדְדִים נִפְרָדִים,","translit":"lōʾ nōḏəḏîm nip̄rāḏîm,","translit_ru":"ло нодэдим нифрадим,","russian":"Не странниками разрозненными,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r112","order_index":112,"hebrew_plain":"כי חפשים נאחדים","hebrew_niqqud":"כִּי חָפְשִׁים נֶאְחָדִים","translit":"kî ḥop̄šîm neʾḥāḏîm","translit_ru":"ки хофшим нэхадим","russian":"Но свободными, объединенными","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r113","order_index":113,"hebrew_plain":"עמך יהי ונדחיך.","hebrew_niqqud":"עַמֵּךְ יְהִי וּנְדָחָיִךְ.","translit":"ʿammēḵ yəhî ûnəḏāḥāyiḵ.","translit_ru":"амех йэхи унэдахайих.","russian":"С Тобой пребудут и изгнанники Твои.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r114","order_index":114,"hebrew_plain":"או אז יבאך ישע,","hebrew_niqqud":"אוֹ אָז יִבֹאַךְ יֶשַע,","translit":"ʾô ʾāz yiḇōʾaḵ yešaʿ,","translit_ru":"о аз йивоах йэша,","russian":"О, тогда придет к тебе спасенье,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r115","order_index":115,"hebrew_plain":"ימח כענן פשע","hebrew_niqqud":"יִמַּח כְּעָנָן פֶּשַׁע","translit":"yimmaḥ kəʿānān pešaʿ","translit_ru":"йимах кэанан пэша","russian":"Сотрется, как облако, грех,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r116","order_index":116,"hebrew_plain":"וכעב מרי ורשע –","hebrew_niqqud":"וּכְעָב מְרִי וָרֶשַׁע –","translit":"ûḵəʿāḇ mərî wārešaʿ –","translit_ru":"ухэав мэри вар
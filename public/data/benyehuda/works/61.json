{"library":{"schema_version":1,"corpus_meta_version":1,"texts":[{"text_id":"by-61","text_key":"7abc47df86fdd7e1e83691ab1acdde96f7c08c00881b018237a17e2d480c0f37","title":"לְמֵאִיר לֶטֶרִיס","level":null,"tags":["poetry","haskalah"],"source_label":"Project Ben-Yehuda","topic":null,"source_text":"","source_meta":{"origin":"benyehuda-ingest","imported_at":"2026-06-09T19:14:41.249Z","corpus":{"schema":1,"byehuda_id":"61","content_hash":"sha256:86fef0b22684f9500963df5edf0df9f8c4a9a4077cc53ce5e23bb390119a9d9c","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/61","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"}},"corpus":{"schema":1,"byehuda_id":"61","content_hash":"sha256:86fef0b22684f9500963df5edf0df9f8c4a9a4077cc53ce5e23bb390119a9d9c","author":"יהודה ליב גורדון","author_slug":null,"author_uri":"https://wikidata.org/wiki/Q1376036","translator":null,"translator_uri":null,"orig_language":"he","era":"haskalah","genre":"poetry","themes":[],"register":"poetic","track":"accessible","difficulty":null,"series":null,"provenance":{"source":"Project Ben-Yehuda","url":"https://benyehuda.org/read/61","license":"public-domain","reviewer":null,"reviewed_at":null},"attribution":"Текст: Проект Бен-Йехуда. Издание: מתוך \"כתבי יהודה ליב גורדון\", תל אביב: דביר, תשי\"ט 1959","review_status":"machine","audio_status":"none"},"table_model_meta":null,"rows":[{"row_id":"r0","order_index":0,"hebrew_plain":"למאיר לטריס","hebrew_niqqud":"לְמֵאִיר לֶטֶרִיס","translit":"ləmēʾîr leṭerîs","translit_ru":"лэмеир лэтэрис","russian":"Меиру Летарису","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r1","order_index":1,"hebrew_plain":"(ביום קבלי מאתו את תמונת פניו על לוח למנחה)","hebrew_niqqud":"(בְּיוֹם קַבְּלִי מֵאִתּוֹ אֶת תְּמוּנַת פָּנָיו עַל לוּחַ לְמִנְחָה)","translit":"(bəyôm qabbəlî mēʾittô ʾeṯ təmûnaṯ pānāyw ʿal lûaḥ ləminḥâ)","translit_ru":"(бэйом кабэли меито эт тэмунат панав ал луах лэминха)","russian":"(В день, когда я получил от него его портрет на доске в качестве подношения)","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r2","order_index":2,"hebrew_plain":"נפשי אויתיך מקדמת נער,","hebrew_niqqud":"נַפְשִׁי אִוִּיתִיךָ מִקַּדְמַת נֹעַר,","translit":"nap̄šî ʾiwwîṯîḵā miqqaḏmaṯ nōʿar,","translit_ru":"нафши ивитиха микадмат ноар,","russian":"Душой я жаждал тебя с ранней юности,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r3","order_index":3,"hebrew_plain":"ובבקר חיי ובעודני ילד,","hebrew_niqqud":"וּבְבֹקֶר חַיַּי וּבְעוֹדֶנִּי יָלֶד,","translit":"ûḇəḇōqer ḥayyay ûḇəʿôḏennî yāleḏ,","translit_ru":"увэвокэр хайай увэодэни йалэд,","russian":"И на заре моей жизни, еще ребенком,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r4","order_index":4,"hebrew_plain":"עת שחר שחרותי הפיץ הזהר,","hebrew_niqqud":"עַת שַׁחַר שַׁחֲרוּתִי הַפִיץ הַזֹּהַר,","translit":"ʿaṯ šaḥar šaḥărûṯî hap̄îṣ hazzōhar,","translit_ru":"ат шахар шахарути хафиц хазохар,","russian":"Когда заря моей юности разлила сияние,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r5","order_index":5,"hebrew_plain":"עוד בקצות הקדים בשמי החלד","hebrew_niqqud":"עוֹד בִּקְצוֹת הַקָּדִים בִּשְׁמֵי הֶחָלֶד","translit":"ʿôḏ biqṣôṯ haqqāḏîm bišmê heḥāleḏ","translit_ru":"од бикцот хакадим бишме хэхалэд","russian":"Еще на краях востока, в небесах мироздания,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r6","order_index":6,"hebrew_plain":"תבניתך ברוח נכחי עברה","hebrew_niqqud":"תַּבְנִיתְךָ בָּרוּחַ נִכְחִי עָבָרָה","translit":"taḇnîṯəḵā bārûaḥ niḵḥî ʿāḇārâ","translit_ru":"тавнитэха баруах ниххи авара","russian":"Твой образ в духе передо мной прошел,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r7","order_index":7,"hebrew_plain":"ולמופת לי אותך נפשי בחרה.","hebrew_niqqud":"וּלְמוֹפֵת לִי אוֹתְךָ נַפְשִׁי בָּחָרָה.","translit":"ûləmôp̄ēṯ lî ʾôṯəḵā nap̄šî bāḥārâ.","translit_ru":"улэмофет ли отэха нафши бахара.","russian":"И образцом для меня тебя избрала душа моя.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r8","order_index":8,"hebrew_plain":"ושפת קדש ללמד כי התעוררתי","hebrew_niqqud":"וּשְׂפַת קֹדֶש לִלְמֹד כִּי הִתְעוֹרַרְתִּי","translit":"ûśəp̄aṯ qōḏeš lilmōḏ kî hiṯʿôrartî","translit_ru":"усэфат кодэш лилмод ки хиторарти","russian":"И святой язык учить, когда я пробудился,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r9","order_index":9,"hebrew_plain":"אז גם בספריך להגות הרביתי,","hebrew_niqqud":"אָז גַּם בִּסְפָרֶיךָ לַהֲגוֹת הִרְבֵּיתִי,","translit":"ʾāz gam bisp̄ārêḵā lahăḡôṯ hirbêṯî,","translit_ru":"аз гам бисфареха лахагот хирбети,","russian":"Тогда и в твоих книгах я много размышлял,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r10","order_index":10,"hebrew_plain":"כי רוח שיר ציון במו הכרתי","hebrew_niqqud":"כִּי רוּחַ שִׁיר צִיּוֹן בָּמוֹ הִכַּרְתִּי","translit":"kî rûaḥ šîr ṣiyyôn bāmô hikkartî","translit_ru":"ки руах шир цийон бамо хикарти","russian":"Ибо дух песни Сиона в них я распознал,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r11","order_index":11,"hebrew_plain":"ומליץ כמוך היות אויתי;","hebrew_niqqud":"וּמֵלִיץ כָּמוֹךָ הֱיוֹת אִוִּיתִי;","translit":"ûmēlîṣ kāmôḵā hĕyôṯ ʾiwwîṯî;","translit_ru":"умелиц камоха хэйот ивити;","russian":"И быть поэтом, как ты, я возжелал;","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r12","order_index":12,"hebrew_plain":"ובכן מעיר רוחי מאיר היית","hebrew_niqqud":"וּבְכֵן מֵעִיר רוּחִי מֵאִיר הָיִיתָ","translit":"ûḇəḵēn mēʿîr rûḥî mēʾîr hāyîṯā","translit_ru":"увэхен меир рухи меир хайита","russian":"И так, ты был Меиром, что дух мой пробуждал,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r13","order_index":13,"hebrew_plain":"ומבלי דעתך את דעתי נחית.","hebrew_niqqud":"וּמִבְּלִי דַעְתְּךָ אֶת דַּעְתִּי נָחִיתָ.","translit":"ûmibbəlî ḏaʿtəḵā ʾeṯ daʿtî nāḥîṯā.","translit_ru":"умибэли датэха эт дати нахита.","russian":"И без твоего ведома ты вел мои мысли.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r14","order_index":14,"hebrew_plain":"ובסר עץ דעתי עת כי יגמל","hebrew_niqqud":"וּבֹסֶר עֵץ דַּעְתִּי עִת כִּי יִגָּמֶל","translit":"ûḇōser ʿēṣ daʿtî ʿiṯ kî yiggāmel","translit_ru":"увосэр ец дати ит ки йигамэл","russian":"И когда древо познания моего созрело,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r15","order_index":15,"hebrew_plain":"ופרי בכורים אשכלתיו הבשילו,","hebrew_niqqud":"וּפְרִי בִכּוּרִים אַשְׁכְּלֹתָיו הִבְשִׁילוּ,","translit":"ûp̄ərî ḇikkûrîm ʾaškəlōṯāyw hiḇšîlû,","translit_ru":"уфэри викурим ашкэлотав хившилу,","russian":"И плоды его первых гроздьев созрели,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r16","order_index":16,"hebrew_plain":"אז לך, גבר חכם, נס לי וסמל.","hebrew_niqqud":"אָז לָךְ, גֶּבֶר חָכָם, נֵס לִי וָסֵמֶל.","translit":"ʾāz lāḵ, geḇer ḥāḵām, nēs lî wāsēmel.","translit_ru":"аз лах, гэвэр хахам, нес ли васемэл.","russian":"Тогда тебе, мудрый муж, это стало для меня знаменем и символом.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r17","order_index":17,"hebrew_plain":"מפרי בכורי ידי שי הובילו,","hebrew_niqqud":"מִפְּרִי בִכּוּרַי יָדַי שַׁי הוֹבִילוּ,","translit":"mippərî ḇikkûray yāḏay šay hôḇîlû,","translit_ru":"мипэри викурай йадай шай ховилу,","russian":"От первых плодов рук моих они принесли дар,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r18","order_index":18,"hebrew_plain":"וברצון מבין את פניו קדמת","hebrew_niqqud":"וּבִרְצוֹן מֵבִין אֶת פָּנָיו קִדַּמְתָּ","translit":"ûḇirṣôn mēḇîn ʾeṯ pānāyw qiddamtā","translit_ru":"увирцон мевин эт панав кидамта","russian":"И с благосклонным пониманием ты принял его,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r19","order_index":19,"hebrew_plain":"ובחסד עולם גם אותי רחמת.","hebrew_niqqud":"וּבְחֶסֶד עוֹלָם גַּם אוֹתִי רִחַמְתָּ.","translit":"ûḇəḥeseḏ ʿôlām gam ʾôṯî riḥamtā.","translit_ru":"увэхэсэд олам гам оти рихамта.","russian":"И вечной милостью ты также сжалился надо мной.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r20","order_index":20,"hebrew_plain":"ובברית אהבה אתך הבאתני,","hebrew_niqqud":"וּבִבְרִית אַהֲבָה אִתְּךָ הֲבֵאתַנִי,","translit":"ûḇiḇrîṯ ʾahăḇâ ʾittəḵā hăḇēʾṯanî,","translit_ru":"увиврит ахава итэха хаветани,","russian":"И в завет любви ты меня с собою привел,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r21","order_index":21,"hebrew_plain":"כרע כאח עמי התהלכת,","hebrew_niqqud":"כָּרֵעַ כָּאָח עִמִּי הִתְהַלַּכְתָּ,","translit":"kārēaʿ kāʾāḥ ʿimmî hiṯhallaḵtā,","translit_ru":"кареа каах ими хитхалахта,","russian":"Как друг, как брат со мной ты ходил,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r22","order_index":22,"hebrew_plain":"ובלוח צלמך כיום כבדתני,","hebrew_niqqud":"וּבְלוּחַ צַלְמְךָ כַּיּוֹם כִּבַּדְתַּנִי,","translit":"ûḇəlûaḥ ṣalməḵā kayyôm kibbaḏtanî,","translit_ru":"увэлуах цалмэха кайом кибадтани,","russian":"И изображением твоим на доске сегодня ты почтил меня,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r23","order_index":23,"hebrew_plain":"אות אמת הוא כי חסד לי משכת,","hebrew_niqqud":"אוֹת אֶמֶת הוּא כִּי חֶסֶד לִי מָשַׁכְתָּ,","translit":"ʾôṯ ʾemeṯ hûʾ kî ḥeseḏ lî māšaḵtā,","translit_ru":"от эмэт ху ки хэсэд ли машахта,","russian":"Это истинный знак, что ты проявил ко мне милость,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r24","order_index":24,"hebrew_plain":"ולבכורי אות כי תמצא בם טעם,","hebrew_niqqud":"וּלְבִכּוּרֵי אוֹת כִּי תִמְצָא בָם טָעַם,","translit":"ûləḇikkûrê ʾôṯ kî ṯimṣāʾ ḇām ṭāʿam,","translit_ru":"улэвикуре от ки тимца вам таам,","russian":"И знак для моих первенцев, что найдешь в них вкус,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r25","order_index":25,"hebrew_plain":"כי לא כתאנים שערים כלהם.","hebrew_niqqud":"כִּי לֹא כִּתְאֵנִים שֹׁעָרִים כֻּלָּהֵם.","translit":"kî lōʾ kiṯʾēnîm šōʿārîm kūllāhēm.","translit_ru":"ки ло китеним шоарим кулахем.","russian":"Ибо не как незрелые финики все они.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r26","order_index":26,"hebrew_plain":"נפשי אויתיך מקדמת נער,","hebrew_niqqud":"נַפְשִׁי אִוִּיתִיךָ מִקַּדְמַת נֹעַר,","translit":"nap̄šî ʾiwwîṯîḵā miqqaḏmaṯ nōʿar,","translit_ru":"нафши ивитиха микадмат ноар,","russian":"Душой я жаждал тебя с ранней юности,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r27","order_index":27,"hebrew_plain":"בחלום חזון לבי צלמך חזיתי,","hebrew_niqqud":"בַּחֲלוֹם חֲזוֹן לִבִּי צַלְמְךָ חָזִיתִי,","translit":"baḥălôm ḥăzôn libbî ṣalməḵā ḥāzîṯî,","translit_ru":"бахалом хазон либи цалмэха хазити,","russian":"В пророческом сне сердцем я видел твой образ,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r28","order_index":28,"hebrew_plain":"ובהקיץ עתה את נעם התאר","hebrew_niqqud":"וּבְהָקִיץ עַתָּה אֶת נֹעַם הַתֹּאַר","translit":"ûḇəhāqîṣ ʿattâ ʾeṯ nōʿam hattōʾar","translit_ru":"увэхакиц ата эт ноам хатоар","russian":"А ныне, пробудившись, прелесть облика,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r29","order_index":29,"hebrew_plain":"פתוחי חותם, אל עיני ראיתי:","hebrew_niqqud":"פִּתּוּחֵי חוֹתָם, אֶל עֵינַי רָאִיתִי:","translit":"pittûḥê ḥôṯām, ʾel ʿênay rāʾîṯî:","translit_ru":"питухе хотам, эл енай раити:","russian":"Вырезанного печатью, очами я увидел:","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r30","order_index":30,"hebrew_plain":"תבניתך בלוח נכחי תנוח,","hebrew_niqqud":"תַּבְנִיתְךָ בַּלוּחַ נִכְחִי תָנוּחַ,","translit":"taḇnîṯəḵā balûaḥ niḵḥî ṯānûaḥ,","translit_ru":"тавнитэха балуах ниххи тануах,","russian":"Твой образ на доске предо мной пребудет,","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r31","order_index":31,"hebrew_plain":"על כן אזכרך עד יומי יפוח.","hebrew_niqqud":"עַל כֵּן אֶזְכָּרְךָ עַד יוֹמִי יָפוּחַ.","translit":"ʿal kēn ʾezkārəḵā ʿaḏ yômî yāp̄ûaḥ.","translit_ru":"ал кен эзкарэха ад йоми йафуах.","russian":"Поэтому я буду помнить тебя до последнего вздоха моего.","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null},{"row_id":"r32","order_index":32,"hebrew_plain":"(תרי\"ח)","hebrew_niqqud":"","translit":"","translit_ru":"","russian":"(1858 год)","edit_meta":null,"note":"","note_updated_at":null,"audio_asset_key":null}],"text_audio_asset_key":null,"created_at":"2026-06-09T19:14:41.249Z","updated_at":"2026-06-09T19:14:41.249Z","is_archived":false}],"shelves":[],"audio_assets":[]}}
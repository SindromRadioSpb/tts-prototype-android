{
  "permissions": {
    "allow": [
      "Read(**)",
      "Grep(**)",
      "Glob(**)",

      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git diff --name-only)",
      "Bash(git log -n 30 --oneline)",
      "Bash(git branch --show-current)",
      "Bash(git rev-parse --abbrev-ref HEAD)",

      "Bash(node -v)",
      "Bash(npm -v)",
      "Bash(python --version)",

      "Bash(npm ci --no-audit --no-fund)",
      "Bash(npm run db:migrate)",
      "Bash(npm run *)",

      "Bash(node tools/*)",
      "Bash(node db/migrate-cli.js)",

      "Bash(bash scripts/smoke-check.sh)",
      "Bash(powershell -ExecutionPolicy Bypass -File scripts\\smoke-check.ps1)"
    ],
    "ask": [
      "Edit(**)",
      "Write(**)",
      "Bash"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*secret*)",
      "Read(**/*secrets*)",
      "Read(**/*token*)",
      "Read(**/*apikey*)",
      "Read(**/*api_key*)",
      "Read(**/*credentials*)",
      "Read(**/*id_rsa*)",
      "Read(**/*.pem)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os,sys,runpy; p=os.path.join(os.path.expanduser('~'),'.claude','hooks','block_secrets.py'); sys.argv=[p]; runpy.run_path(p, run_name='__main__')\""
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os,sys,runpy; p=os.path.join(os.path.expanduser('~'),'.claude','hooks','block_secrets.py'); sys.argv=[p]; runpy.run_path(p, run_name='__main__')\""
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os,sys,runpy; p=os.path.join(os.path.expanduser('~'),'.claude','hooks','block_secrets.py'); sys.argv=[p]; runpy.run_path(p, run_name='__main__')\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os,sys,runpy; p=os.path.join(os.path.expanduser('~'),'.claude','hooks','validate_bash.py'); sys.argv=[p]; runpy.run_path(p, run_name='__main__')\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os,sys,runpy; p=os.path.join(os.path.expanduser('~'),'.claude','hooks','quality_gate.py'); sys.argv=[p]; runpy.run_path(p, run_name='__main__')\""
          }
        ]
      }
    ]
  }
}
